#!/bin/bash
#
# strada - Compile Strada programs to native executables or shared libraries
#
# Usage: strada [options] input.strada [extra.c ...] [extra.o ...] [extra.a ...]
#
# Options:
#   -c          Keep the generated C file
#   -r, --run   Run the program after compiling
#   -o FILE     Specify output file name
#   -O LEVEL    Optimization level (0, 1, 2, 3, s, fast)
#   -g          Debug with Strada source (#line directives + DWARF)
#   --c-debug   Debug with C source only (DWARF, no #line)
#   --shared      Compile as shared library (.so)
#   --static      Compile as fully static binary (no dynamic linking)
#   --static-lib  Compile as static library (.a)
#   --tcc         Compile with tcc (fast, unoptimized) and link with $CC
#   --object      Compile to object file only (.o)
#   -l LIB        Link with library (e.g., -l ssl -l crypto)
#   -I PATH       Add include path for C headers
#   -v            Verbose output
#   -h, --help    Show this help
#
# Extra Files:
#   You can include additional .c and .o files after the .strada file.
#   These are linked into the final executable, useful for extern "C" libraries.
#
# Examples:
#   strada hello.strada              # Creates ./hello
#   strada hello.strada myapp        # Creates ./myapp
#   strada -r hello.strada           # Compile and run
#   strada -c -g hello.strada        # Keep .c file, debug at Strada level
#   strada -c --c-debug hello.strada # Keep .c file, debug at C level
#   strada --shared mylib.strada     # Creates ./mylib.so
#   strada --static-lib mylib.strada # Creates ./mylib.a (static library)
#   strada --object mylib.strada     # Creates ./mylib.o (object file)
#   strada --static hello.strada     # Creates static binary (no libc dependency)
#
#   # Extern "C" examples:
#   strada app.strada lib/ssl/strada_ssl.c -l ssl -l crypto
#   strada app.strada lib/crypt/strada_crypt.c -l crypt
#   strada app.strada mylib.o -l z
#

set -e
#set -x

# Portable mktemp with suffix (works on Linux and macOS)
mktemp_suffix() {
    local suffix="$1"
    local tmp="$(mktemp)"
    local newfile="${tmp}${suffix}"
    mv "$tmp" "$newfile"
    echo "$newfile"
}

# Find the directory where this script lives
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Platform-specific linker flags.
#   Linux: -ldl for dlopen, -Wl,--gc-sections to strip unused code
#   macOS: dlopen lives in libc (no -ldl), linker uses -Wl,-dead_strip
# Allow $CC override; default to cc (which is clang on macOS, gcc on Linux).
CC="${CC:-cc}"
# Auto-prepend ccache if installed — caches gcc outputs by input+flags
# hash, so repeated builds of the same .c file (a common iteration
# pattern for .pm.so/.pm.o rebuilds) skip gcc entirely. No effect if
# the user already set CC to include ccache, or set CCACHE_DISABLE=1.
if [ -z "${CCACHE_DISABLE:-}" ] && ! echo "$CC" | grep -q ccache && command -v ccache >/dev/null 2>&1; then
    CC="ccache $CC"
fi
UNAME_S="$(uname -s)"
if [ "$UNAME_S" = "Darwin" ]; then
    DLOPEN_LIBS=""
    GC_SECTIONS_FLAG="-Wl,-dead_strip"
    # Shared libs on macOS use a two-level namespace by default and refuse
    # undefined symbols. Strada .so's deliberately leave runtime symbols
    # unresolved so dlopen() can bind them to the host executable (which is
    # linked with -rdynamic). -undefined dynamic_lookup permits that.
    SHARED_UNDEFINED_FLAG="-Wl,-undefined,dynamic_lookup"
else
    DLOPEN_LIBS="-ldl"
    GC_SECTIONS_FLAG="-Wl,--gc-sections"
    SHARED_UNDEFINED_FLAG=""
fi
# Exported for stradac itself (used in Parser.strada to compile temp probe
# programs when extracting metadata from import_object/import_archive targets).
export CC
export STRADA_DLOPEN_LIBS="$DLOPEN_LIBS"

# Source config.sh if it exists (generated by ./configure)
if [ -f "$SCRIPT_DIR/config.sh" ]; then
    . "$SCRIPT_DIR/config.sh"
fi

# When using bundled PCRE2, resolve paths relative to SCRIPT_DIR
# (config.sh stores absolute paths from the build machine, which may differ
# from the installed location)
if [ "${STRADA_PCRE2_BUNDLED:-0}" = "1" ]; then
    STRADA_PCRE2_CFLAGS="-DPCRE2_STATIC -I$SCRIPT_DIR/vendor/pcre2/src"
    STRADA_PCRE2_LIBS="$SCRIPT_DIR/vendor/pcre2/libpcre2-8.a"
fi

# Paths relative to script directory
STRADAC="$SCRIPT_DIR/stradac"
RUNTIME_SRC="$SCRIPT_DIR/runtime/strada_runtime.c"
RUNTIME_OBJ="$SCRIPT_DIR/runtime/strada_runtime.o"
RUNTIME_DIR="$SCRIPT_DIR/runtime"
REPL_DIR="$SCRIPT_DIR/tools"

# Default options
KEEP_C=0
RUN_AFTER=0
VERBOSE=0
OPT_LEVEL="2"
DEBUG_SYMBOLS=0
C_DEBUG_SYMBOLS=0
OUTPUT_FILE=""
SHARED_LIB=0
STATIC_LIB=0
TCC_MODE=0         # --tcc: compile the program with tcc (fast), link with $CC
OBJECT_ONLY=0
OBJECT_FULL=0      # 1 if --object-full was passed (include deps, old behavior)
MODULE_ONLY_MODE=0 # 1 if -M was passed (precompile a module / a tree of modules)
STATIC_LINK=0
SHOW_WARNINGS=0
STRICT_TYPES=0
ENABLE_PROFILING=0
FULL_PROFILE=0
NO_STACK_TRACE=0
NO_LTO=0           # -fno-lto: skip link-time optimization for faster gcc
REPL_MODE=0
SCRIPT_FILE=""
DOC_MODE=0
DOC_TOPIC=""
LIB_PATHS=()
LIB_PATHS_LOW=()
JIT_PASSTHROUGH=()  # --compiler=... collected here, forwarded to strada-jit
EXTRA_C_FILES=()
EXTRA_O_FILES=()
EXTRA_A_FILES=()
IMPLICIT_IMPORT_OBJS=()
IMPLICIT_IMPORT_ARCHS=()
LINK_LIBS=()
INCLUDE_PATHS=()
PP_DEFINES=()
PP_INCLUDE_PATHS=()

# Colors (if terminal supports them)
if [ -t 1 ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[0;33m'
    CYAN='\033[0;36m'
    BOLD='\033[1m'
    NC='\033[0m' # No Color
else
    RED=''
    GREEN=''
    YELLOW=''
    CYAN=''
    BOLD=''
    NC=''
fi

usage() {
    cat << EOF
Usage: strada [options] input.strada [extra.c ...] [extra.o ...]

Compile Strada programs to native executables or shared libraries.

Options:
  -c          Keep the generated C file
  -r, --run   Run the program after compiling
  -o FILE     Specify output file name
  -O LEVEL    Optimization level (0, 1, 2, 3, s, fast) [default: 2]
  -D NAME     Define preprocessor macro NAME as 1
  -D NAME=VAL Define preprocessor macro NAME as VAL
  -L PATH     Add library search path (high priority, searched first)
  -LL PATH    Add library search path (low priority, searched last)
  -l LIB      Link with library (e.g., -l ssl -l crypto)
  -I PATH     Add include path for C headers
  -g          Debug with Strada source (emits #line directives + DWARF symbols)
  -p, --profile  Enable function profiling (timing and call counts)
  --full-profile  Enable line-level profiling (writes strada-prof.out)
  --no-stack-trace  Disable stack traces for better performance
  -fno-lto      Skip link-time optimization (faster gcc, slightly larger
                output). Useful for test/dev builds; production should keep
                LTO on (default at -O2+).
  --c-debug   Debug with C source only (DWARF symbols, no #line directives)
  --shared      Compile as shared library (.so, includes inlined dep code)
  --static      Compile as fully static binary (no dynamic linking)
  --static-lib  Compile as static library (.a)
  --tcc         Compile the program with tcc (much faster than gcc, unoptimized
                output) and link with the C compiler. Full runtime features;
                great for fast edit/run iteration. Requires tcc in PATH.
  --object      Compile to object file only (.o). By default the .o contains
                only the input file's own symbols (deps come from their own .o).
  --object-full Compile to .o that also bundles all transitively-used module code
                (legacy behaviour pre-separate-compilation).
  --use-artifacts  Let `use Foo;` silently link a precompiled sibling Foo.o/
                Foo.so when fresh (faster incremental builds, but runs the
                artifact's native code at compile time). Off by default: `use`
                recompiles from source. Explicit import_object/import_lib/
                import_archive are unaffected.
  -M [TARGET]   Precompile module(s). With a FILE: produce a sibling .o limited
                to that file's own symbols. With a DIR: recursive walk producing
                a sibling .o for each .strada file beneath.
  --repl        Start interactive REPL (via strada-jit; auto-detects tcc/gcc)
  --script FILE Run a script via strada-jit (gcc by default; --compiler=tcc
                to override).
  --doc TOPIC   Show documentation (module POD or guide)
  -w            Show compiler warnings (unused variables, etc.)
  --strict-types  Warn on declared-type mismatches (gradual; untyped code never warns)
  -v          Verbose output
  -h, --help  Show this help

Extra Files:
  You can include additional .c, .o, and .a files after the .strada file.
  Plain C files/objects are linked in (useful for extern "C" libraries).
  Strada module .o/.a files (those compiled with --object/--static-lib) are
  detected automatically and behave like an implicit import_object/import_archive,
  so the main source does not need to declare them.

Examples:
  strada hello.strada              # Creates ./hello
  strada hello.strada myapp        # Creates ./myapp
  strada -r hello.strada           # Compile and run
  strada -DDEBUG hello.strada      # Compile with DEBUG defined
  strada -DDEBUG -DVERSION=2 app.strada  # Multiple defines
  strada -L /opt/strada/lib -r app.strada  # Use custom lib path
  strada -c -g hello.strada        # Keep .c file, debug at Strada level
  strada -c --c-debug hello.strada # Keep .c file, debug at C level
  strada -O0 -g test.strada        # No optimization, debug build
  strada --shared mylib.strada     # Creates ./mylib.so
  strada --shared -o libfoo.so foo.strada  # Custom output name
  strada --static-lib mylib.strada # Creates ./mylib.a (static library)
  strada --object mylib.strada     # Creates ./mylib.o (object file)
  strada --static hello.strada     # Creates portable static binary

  # Implicit import examples (no import_object/import_archive in source):
  strada -o foo foo.strada MyLib.o      # MyLib.o auto-imported
  strada app.strada MyLib.a             # MyLib.a auto-imported

  # Extern "C" examples:
  strada app.strada lib/ssl/strada_ssl.c -l ssl -l crypto
  strada app.strada lib/crypt/strada_crypt.c -l crypt
  strada app.strada lib/compress/strada_compress.c -l z

EOF
    exit 0
}

error() {
    echo -e "${RED}error:${NC} $1" >&2
    exit 1
}

info() {
    if [ "$VERBOSE" -eq 1 ]; then
        echo -e "${GREEN}info:${NC} $1"
    fi
}

warn() {
    echo -e "${YELLOW}warning:${NC} $1" >&2
}

# Run a command, showing it first if verbose
run_cmd() {
    if [ "$VERBOSE" -eq 1 ]; then
        echo -e "${CYAN}\$${NC} $*"
    fi
    "$@"
}

# Show a command without running it (for display purposes)
show_cmd() {
    if [ "$VERBOSE" -eq 1 ]; then
        echo -e "${CYAN}\$${NC} $*"
    fi
}

# Parse command line arguments
POSITIONAL=()
while [[ $# -gt 0 ]]; do
    case $1 in
        -c)
            KEEP_C=1
            shift
            ;;
        -r|--run)
            RUN_AFTER=1
            shift
            ;;
        -o)
            OUTPUT_FILE="$2"
            shift 2
            ;;
        -O)
            OPT_LEVEL="$2"
            shift 2
            ;;
        -O*)
            OPT_LEVEL="${1#-O}"
            shift
            ;;
        -g)
            DEBUG_SYMBOLS=1
            shift
            ;;
        --c-debug)
            C_DEBUG_SYMBOLS=1
            shift
            ;;
        --shared)
            SHARED_LIB=1
            shift
            ;;
        --static)
            STATIC_LINK=1
            shift
            ;;
        --static-lib)
            STATIC_LIB=1
            shift
            ;;
        --tcc)
            TCC_MODE=1
            shift
            ;;
        --object)
            OBJECT_ONLY=1
            shift
            ;;
        --object-full)
            # Old behavior: produce an .o that bundles every `use`d module's
            # compiled code. Useful when you want one stand-alone object.
            OBJECT_ONLY=1
            OBJECT_FULL=1
            shift
            ;;
        -M)
            # Precompile module(s). With a file: produce a sibling .o limited
            # to that file's own symbols. With a directory: walk recursively.
            MODULE_ONLY_MODE=1
            shift
            ;;
        -w|--warnings)
            SHOW_WARNINGS=1
            shift
            ;;
        --strict-types)
            STRICT_TYPES=1
            shift
            ;;
        -p|--profile)
            ENABLE_PROFILING=1
            shift
            ;;
        --full-profile)
            FULL_PROFILE=1
            shift
            ;;
        -fno-lto|--no-lto)
            NO_LTO=1
            shift
            ;;
        --no-stack-trace)
            NO_STACK_TRACE=1
            shift
            ;;
        --use-artifacts)
            # Opt in to `use Foo;` silently linking a precompiled sibling
            # Foo.o/Foo.so (runs the artifact's code at compile time). Off by
            # default for safety; without it `use` recompiles from source.
            export STRADA_USE_ARTIFACTS=1
            shift
            ;;
        -LL)
            LIB_PATHS_LOW+=("$2")
            shift 2
            ;;
        -LL*)
            LIB_PATHS_LOW+=("${1#-LL}")
            shift
            ;;
        -L)
            LIB_PATHS+=("$2")
            shift 2
            ;;
        -L*)
            LIB_PATHS+=("${1#-L}")
            shift
            ;;
        -l)
            LINK_LIBS+=("$2")
            shift 2
            ;;
        -l*)
            LINK_LIBS+=("${1#-l}")
            shift
            ;;
        -I)
            INCLUDE_PATHS+=("$2")
            shift 2
            ;;
        -I*)
            INCLUDE_PATHS+=("${1#-I}")
            shift
            ;;
        -D)
            PP_DEFINES+=("$2")
            shift 2
            ;;
        -D*)
            PP_DEFINES+=("${1#-D}")
            shift
            ;;
        -v|--verbose)
            VERBOSE=1
            shift
            ;;
        -h|--help)
            usage
            ;;
        --repl)
            REPL_MODE=1
            shift
            ;;
        --script)
            SCRIPT_FILE="$2"
            shift 2
            ;;
        --compiler=*|--chunked)
            # Forwarded to strada-jit in --repl/--script modes; the driver
            # itself only swallows them so the unknown-option guard below
            # doesn't reject them.
            JIT_PASSTHROUGH+=("$1")
            shift
            ;;
        --doc)
            DOC_MODE=1
            DOC_TOPIC="$2"
            shift 2
            ;;
        -*)
            error "Unknown option: $1"
            ;;
        *)
            POSITIONAL+=("$1")
            shift
            ;;
    esac
done

# Restore positional parameters
set -- "${POSITIONAL[@]}"

# Locate strada-jit (dev tree vs installed). Used for both --repl and --script.
find_jit_bin() {
    if [ -x "$REPL_DIR/strada-jit" ]; then
        echo "$REPL_DIR/strada-jit"
        return 0
    fi
    if [ -x "$SCRIPT_DIR/strada-jit" ]; then
        echo "$SCRIPT_DIR/strada-jit"
        return 0
    fi
    local installed
    installed="$(dirname "$(dirname "$SCRIPT_DIR")")/bin/strada-jit"
    if [ -x "$installed" ]; then
        echo "$installed"
        return 0
    fi
    return 1
}

# Handle REPL mode — runs via strada-jit with auto-detected backend
# (prefers tcc for snappier per-line latency, falls back to gcc when tcc
# isn't installed). Pass `--compiler=gcc` to force gcc if you need
# try/catch, const, or enum at the REPL (these require gcc per JIT.strada).
if [ "$REPL_MODE" -eq 1 ]; then
    JIT_BIN="$(find_jit_bin)" || error "strada-jit not found. Run 'make tools' to build it."
    exec "$JIT_BIN" "${JIT_PASSTHROUGH[@]}" "$@"
fi

# Handle script mode — runs via strada-jit with gcc forced (the latency hit
# is amortized over the full script, and gcc gives full feature support:
# try/catch, const, enum, etc.). The user can override with --compiler=tcc.
if [ -n "$SCRIPT_FILE" ]; then
    if [ ! -f "$SCRIPT_FILE" ]; then
        error "Script file not found: $SCRIPT_FILE"
    fi
    JIT_BIN="$(find_jit_bin)" || error "strada-jit not found. Run 'make tools' to build it."
    # Force gcc unless the user has explicitly chosen a compiler — other
    # passthrough flags (e.g. --chunked) shouldn't disable the gcc default.
    user_picked_compiler=0
    for f in "${JIT_PASSTHROUGH[@]}"; do
        case "$f" in
            --compiler=*) user_picked_compiler=1 ;;
        esac
    done
    if [ "$user_picked_compiler" -eq 1 ]; then
        exec "$JIT_BIN" "${JIT_PASSTHROUGH[@]}" "$SCRIPT_FILE" "$@"
    else
        exec "$JIT_BIN" --compiler=gcc "${JIT_PASSTHROUGH[@]}" "$SCRIPT_FILE" "$@"
    fi
fi

# Handle doc mode
if [ "$DOC_MODE" -eq 1 ]; then
    # Look for stradadoc in same directory as this script (for installed version)
    # or in tools/ subdirectory (for development version)
    if [ -x "$SCRIPT_DIR/stradadoc" ]; then
        DOC_BIN="$SCRIPT_DIR/stradadoc"
    else
        DOC_BIN="$SCRIPT_DIR/tools/stradadoc"
    fi
    if [ ! -x "$DOC_BIN" ]; then
        error "stradadoc not found.\nRun './strada tools/stradadoc.strada' to build it, or 'make install' to install."
    fi
    exec "$DOC_BIN" "$DOC_TOPIC" "$@"
fi

# Check for input file
if [ $# -lt 1 ]; then
    echo "Usage: strada [options] input.strada [extra.c ...] [extra.o ...]"
    echo "Try 'strada --help' for more information."
    exit 1
fi

INPUT_FILE="$1"
shift

# -M with a directory: walk recursively and produce a sibling .o for each
# .strada file. Each file is precompiled in module-only mode (only that
# file's own symbols end up in its .o).
if [ "$MODULE_ONLY_MODE" -eq 1 ] && [ -d "$INPUT_FILE" ]; then
    SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"
    count=0
    fail_count=0
    while IFS= read -r -d '' f; do
        sibling_o="${f%.strada}.o"
        info "-M: compiling $f -> $sibling_o"
        if "$SCRIPT_PATH" -M --object -o "$sibling_o" "$f"; then
            count=$((count + 1))
        else
            fail_count=$((fail_count + 1))
        fi
    done < <(find "$INPUT_FILE" -type f -name '*.strada' -print0)
    if [ "$VERBOSE" -eq 1 ] || [ "$fail_count" -gt 0 ]; then
        echo "-M: compiled $count file(s), $fail_count failure(s)"
    fi
    if [ "$fail_count" -gt 0 ]; then
        exit 1
    fi
    exit 0
fi

# Check input file exists
if [ ! -f "$INPUT_FILE" ]; then
    error "Input file not found: $INPUT_FILE"
fi

# Check input file has .strada extension
if [[ "$INPUT_FILE" != *.strada ]]; then
    warn "Input file does not have .strada extension"
fi

# -M with a single file: precompile to a SIBLING .o (next to the source).
# Sets OBJECT_ONLY so the rest of the driver picks the .o output path; the
# stradac invocation later in this script adds the -M flag for module-only
# codegen because MODULE_ONLY_MODE is set.
if [ "$MODULE_ONLY_MODE" -eq 1 ] && [ -z "$OUTPUT_FILE" ]; then
    OUTPUT_FILE="${INPUT_FILE%.strada}.o"
    OBJECT_ONLY=1
fi

# Check whether an object file or archive is a Strada module (has the
# __strada_export_info symbol). If it does, we forward it to stradac as an
# implicit import_object/import_archive so the compiler can resolve namespace
# calls into it; otherwise it's a plain extern C blob and we just link it in.
is_strada_module() {
    local file="$1"
    nm "$file" 2>/dev/null | grep -q __strada_export_info
}

# Process remaining positional arguments - could be extra .c/.o/.a files or output name
for arg in "$@"; do
    if [[ "$arg" == *.c ]]; then
        if [ ! -f "$arg" ]; then
            error "C file not found: $arg"
        fi
        EXTRA_C_FILES+=("$arg")
    elif [[ "$arg" == *.o ]]; then
        if [ ! -f "$arg" ]; then
            error "Object file not found: $arg"
        fi
        if is_strada_module "$arg"; then
            # Strada module: stradac will pick up metadata and add it to
            # __STRADA_OBJECT_FILES__ for linking — don't double-link.
            IMPLICIT_IMPORT_OBJS+=("$arg")
        else
            EXTRA_O_FILES+=("$arg")
        fi
    elif [[ "$arg" == *.a ]]; then
        if [ ! -f "$arg" ]; then
            error "Archive file not found: $arg"
        fi
        if is_strada_module "$arg"; then
            # Strada module archive: stradac picks up metadata and adds it to
            # __STRADA_ARCHIVE_FILES__ for linking.
            IMPLICIT_IMPORT_ARCHS+=("$arg")
        else
            EXTRA_A_FILES+=("$arg")
        fi
    elif [ -z "$OUTPUT_FILE" ]; then
        # First non-.c/.o/.a argument becomes output file name
        OUTPUT_FILE="$arg"
    else
        warn "Ignoring extra argument: $arg"
    fi
done

# Determine output file name
if [ -n "$OUTPUT_FILE" ]; then
    OUTPUT="$OUTPUT_FILE"
else
    # Remove .strada extension and path
    OUTPUT="$(basename "$INPUT_FILE" .strada)"
    # Add appropriate extension for libraries
    if [ "$SHARED_LIB" -eq 1 ]; then
        OUTPUT="${OUTPUT}.so"
    elif [ "$STATIC_LIB" -eq 1 ]; then
        OUTPUT="${OUTPUT}.a"
    elif [ "$OBJECT_ONLY" -eq 1 ]; then
        OUTPUT="${OUTPUT}.o"
    fi
fi

# Determine C file name
if [ "$KEEP_C" -eq 1 ]; then
    C_FILE="${OUTPUT}.c"
else
    C_FILE="$(mktemp_suffix .c)"
    trap "rm -f '$C_FILE'" EXIT
fi

# Check for stradac
if [ ! -x "$STRADAC" ]; then
    error "Strada compiler not found at $STRADAC\nRun 'make' in $SCRIPT_DIR to build it."
fi

# Check for runtime
if [ ! -f "$RUNTIME_SRC" ]; then
    error "Runtime not found at $RUNTIME_SRC"
fi

# Build pre-compiled runtime if needed (much faster compilation)
build_runtime() {
    info "Building pre-compiled runtime..."
    local PCRE2_DEF=""
    if [ "${STRADA_HAVE_PCRE2:-0}" = "1" ]; then
        PCRE2_DEF="-DHAVE_PCRE2 $STRADA_PCRE2_CFLAGS"
    fi
    # Memory-management features. Default ON (matching ./configure) when the
    # config var is unset, e.g. building before ./configure has been run.
    local MM_DEF=""
    if [ "${STRADA_HAVE_CYCLE_GC:-1}" = "1" ]; then
        MM_DEF="$MM_DEF -DSTRADA_CYCLE_GC"
    fi
    if [ "${STRADA_HAVE_ARENA:-1}" = "1" ]; then
        MM_DEF="$MM_DEF -DSTRADA_ARENA"
    fi
    if [ "${STRADA_HAVE_LIBFFI:-0}" = "1" ]; then
        MM_DEF="$MM_DEF -DHAVE_LIBFFI $STRADA_FFI_CFLAGS"
    fi
    # -ffat-lto-objects keeps native code in the .o alongside the LTO
    # bitcode, so test/dev builds that pass -fno-lto can link against
    # this same runtime.o without rebuilding it. Production builds at
    # -O2+ still get cross-function LTO benefits.
    if ! run_cmd $CC -O2 -flto=auto -ffat-lto-objects -std=c99 -ffunction-sections -fdata-sections $PCRE2_DEF $MM_DEF -c "$RUNTIME_SRC" -I"$RUNTIME_DIR" -o "$RUNTIME_OBJ"; then
        error "Failed to compile runtime"
    fi
}

if [ ! -f "$RUNTIME_OBJ" ]; then
    build_runtime
elif [ "$RUNTIME_SRC" -nt "$RUNTIME_OBJ" ]; then
    info "Runtime source changed, rebuilding..."
    build_runtime
fi

# Build gcc flags (portable flags only - GCC-specific flags added conditionally)
GCC_FLAGS="-Wall -Wextra -Wno-unused-variable -Wno-unused-function -Wno-return-type -Wno-unused-result -Wno-comment -std=c99 -ffunction-sections -fdata-sections"
# Add GCC-specific flags if not using clang
if ! $CC --version 2>&1 | grep -q clang; then
    GCC_FLAGS="$GCC_FLAGS -Wno-unused-but-set-variable -Wno-clobbered"
fi
# macOS clang emits -Wunused-value noise on generated statement expressions.
if [ "$(uname -s)" = "Darwin" ]; then
    GCC_FLAGS="$GCC_FLAGS -Wno-unused-value"
fi
GCC_FLAGS="$GCC_FLAGS -O$OPT_LEVEL"
# At -O0 (the default for the JIT/REPL and most dev iteration), skip
# work gcc spends on debug info, stack canaries, and variable tracking
# — useless for an -O0 build without -g, and var-tracking dominates
# gcc wall time on large generated .c files. -pipe avoids temp files
# between gcc passes. Skipped automatically when -g/--c-debug is set
# so debugger info stays usable.
if [ "$OPT_LEVEL" = "0" ] && [ "$DEBUG_SYMBOLS" -ne 1 ] && [ "$C_DEBUG_SYMBOLS" -ne 1 ]; then
    GCC_FLAGS="$GCC_FLAGS -pipe -fno-var-tracking -fno-var-tracking-assignments -fno-stack-protector -fno-asynchronous-unwind-tables"
fi
# Enable link-time optimization at -O2 and above for cross-function inlining,
# unless the user explicitly disabled it with -fno-lto.
if [ "$NO_LTO" -eq 1 ]; then
    GCC_FLAGS="$GCC_FLAGS -fno-lto"
elif [ "$OPT_LEVEL" = "2" ] || [ "$OPT_LEVEL" = "3" ] || [ "$OPT_LEVEL" = "fast" ]; then
    GCC_FLAGS="$GCC_FLAGS -flto=auto"
fi
# Enable native CPU tuning at -O3 and -Ofast (not portable)
if [ "$OPT_LEVEL" = "3" ] || [ "$OPT_LEVEL" = "fast" ]; then
    GCC_FLAGS="$GCC_FLAGS -march=native"
fi
if [ "$DEBUG_SYMBOLS" -eq 1 ] || [ "$C_DEBUG_SYMBOLS" -eq 1 ]; then
    GCC_FLAGS="$GCC_FLAGS -g"
fi

# Pass -D defines to C compiler as well (for #ifdef in embedded C code)
for def in "${PP_DEFINES[@]}"; do
    GCC_FLAGS="$GCC_FLAGS -D$def"
done

# Build extra include paths
INCLUDE_FLAGS=""
for path in "${INCLUDE_PATHS[@]}"; do
    INCLUDE_FLAGS="$INCLUDE_FLAGS -I$path"
done

# Build extra link libraries
LINK_FLAGS=""
for lib in "${LINK_LIBS[@]}"; do
    LINK_FLAGS="$LINK_FLAGS -l$lib"
done

# Add PCRE2 libraries if available
if [ "${STRADA_HAVE_PCRE2:-0}" = "1" ]; then
    LINK_FLAGS="$LINK_FLAGS $STRADA_PCRE2_LIBS"
fi

# NOTE: no -lffi here — c::callback dlopens libffi lazily at first use,
# so binaries carry no libffi link dependency.

# Build extra source/object file lists (plain extern C files — Strada module
# .o/.a files are forwarded to stradac via --import-object/--import-archive
# and appear in __STRADA_OBJECT_FILES__/__STRADA_ARCHIVE_FILES__ instead).
EXTRA_FILES=""
for f in "${EXTRA_C_FILES[@]}"; do
    EXTRA_FILES="$EXTRA_FILES $f"
done
for f in "${EXTRA_O_FILES[@]}"; do
    EXTRA_FILES="$EXTRA_FILES $f"
done
for f in "${EXTRA_A_FILES[@]}"; do
    EXTRA_FILES="$EXTRA_FILES $f"
done

# Show info about extra files
if [ ${#EXTRA_C_FILES[@]} -gt 0 ] || [ ${#EXTRA_O_FILES[@]} -gt 0 ] || [ ${#EXTRA_A_FILES[@]} -gt 0 ]; then
    info "Extra files: ${EXTRA_C_FILES[*]} ${EXTRA_O_FILES[*]} ${EXTRA_A_FILES[*]}"
fi
if [ ${#IMPLICIT_IMPORT_OBJS[@]} -gt 0 ] || [ ${#IMPLICIT_IMPORT_ARCHS[@]} -gt 0 ]; then
    info "Implicit imports: ${IMPLICIT_IMPORT_OBJS[*]} ${IMPLICIT_IMPORT_ARCHS[*]}"
fi
if [ ${#LINK_LIBS[@]} -gt 0 ]; then
    info "Extra libraries: ${LINK_LIBS[*]}"
fi

# Step 0: Run preprocessor if -D flags were given
# Look for stradapp in same directory as this script (for installed version)
# or in tools/ subdirectory (for development version)
if [ -x "$SCRIPT_DIR/stradapp" ]; then
    PREPROCESSOR="$SCRIPT_DIR/stradapp"
else
    PREPROCESSOR="$SCRIPT_DIR/tools/stradapp"
fi
ACTUAL_INPUT="$INPUT_FILE"

if [ ${#PP_DEFINES[@]} -gt 0 ]; then
    # Check for preprocessor
    if [ ! -x "$PREPROCESSOR" ]; then
        error "Preprocessor not found.\nRun './strada tools/stradapp.strada' to build it, or 'make install' to install."
    fi

    # Build preprocessor flags
    PP_FLAGS=""
    for def in "${PP_DEFINES[@]}"; do
        PP_FLAGS="$PP_FLAGS -D$def"
    done

    # Create temp file for preprocessed output
    PP_OUTPUT="$(mktemp_suffix .strada)"
    trap "rm -f '$PP_OUTPUT' '$C_FILE'" EXIT

    info "Preprocessing $INPUT_FILE (defines: ${PP_DEFINES[*]})"
    if ! run_cmd "$PREPROCESSOR" $PP_FLAGS "$INPUT_FILE" -o "$PP_OUTPUT"; then
        error "Preprocessing failed"
    fi

    # Use preprocessed file as input
    ACTUAL_INPUT="$PP_OUTPUT"
fi

# Step 1: Compile Strada to C
# Export STRADA_DIR so stradac knows where the runtime is
export STRADA_DIR="$SCRIPT_DIR"
# Build stradac flags
STRADAC_FLAGS=""
if [ "$DEBUG_SYMBOLS" -eq 1 ]; then
    STRADAC_FLAGS="$STRADAC_FLAGS -g"
fi
if [ "$SHOW_WARNINGS" -eq 1 ]; then
    STRADAC_FLAGS="$STRADAC_FLAGS -w"
fi
if [ "$STRICT_TYPES" -eq 1 ]; then
    STRADAC_FLAGS="$STRADAC_FLAGS --strict-types"
fi
if [ "$ENABLE_PROFILING" -eq 1 ]; then
    STRADAC_FLAGS="$STRADAC_FLAGS -p"
fi
if [ "$FULL_PROFILE" -eq 1 ]; then
    STRADAC_FLAGS="$STRADAC_FLAGS --full-profile"
fi
if [ "$NO_STACK_TRACE" -eq 1 ]; then
    STRADAC_FLAGS="$STRADAC_FLAGS --no-stack-trace"
fi
# Add library paths (high priority)
for path in "${LIB_PATHS[@]}"; do
    STRADAC_FLAGS="$STRADAC_FLAGS -L $path"
done
# Add library paths (low priority)
for path in "${LIB_PATHS_LOW[@]}"; do
    STRADAC_FLAGS="$STRADAC_FLAGS -LL $path"
done
# Forward CLI-passed Strada module objects/archives as implicit imports
for f in "${IMPLICIT_IMPORT_OBJS[@]}"; do
    STRADAC_FLAGS="$STRADAC_FLAGS --import-object $f"
done
for f in "${IMPLICIT_IMPORT_ARCHS[@]}"; do
    STRADAC_FLAGS="$STRADAC_FLAGS --import-archive $f"
done

# Module-only mode. Active when:
#   - explicit -M was passed, OR
#   - --object was passed and --object-full was NOT (new default behaviour).
# Disabled for --shared and --static-lib, which keep the old "include
# everything" semantics.
WANT_MODULE_ONLY=0
if [ "$MODULE_ONLY_MODE" -eq 1 ]; then
    WANT_MODULE_ONLY=1
elif [ "$OBJECT_ONLY" -eq 1 ] && [ "$OBJECT_FULL" -ne 1 ]; then
    WANT_MODULE_ONLY=1
fi
if [ "$WANT_MODULE_ONLY" -eq 1 ]; then
    STRADAC_FLAGS="$STRADAC_FLAGS -M"
fi

info "Compiling $ACTUAL_INPUT -> $C_FILE"
if [ "$VERBOSE" -eq 1 ]; then
    STRADAC_FLAGS="$STRADAC_FLAGS -v"
fi
if [ -n "$STRADAC_FLAGS" ]; then
    if ! run_cmd "$STRADAC" $STRADAC_FLAGS "$ACTUAL_INPUT" "$C_FILE"; then
        error "Strada compilation failed"
    fi
else
    if ! run_cmd "$STRADAC" "$ACTUAL_INPUT" "$C_FILE"; then
        error "Strada compilation failed"
    fi
fi

# Extract import_object files from generated C (static linking)
IMPORT_OBJECT_FILES=""
if grep -q '__STRADA_OBJECT_FILES__:' "$C_FILE" 2>/dev/null; then
    # Extract object files from the comment: __STRADA_OBJECT_FILES__: path1.o path2.o ...
    IMPORT_OBJECT_FILES=$(grep '__STRADA_OBJECT_FILES__:' "$C_FILE" | sed 's/.*__STRADA_OBJECT_FILES__: *//' | sed 's/ *\*\///')
    if [ -n "$IMPORT_OBJECT_FILES" ]; then
        info "import_object files: $IMPORT_OBJECT_FILES"
        # Verify each object file exists
        for obj in $IMPORT_OBJECT_FILES; do
            if [ ! -f "$obj" ]; then
                error "import_object: object file not found: $obj"
            fi
        done
        # Add to extra files for linking
        EXTRA_FILES="$EXTRA_FILES $IMPORT_OBJECT_FILES"
    fi
fi

# Extract import_archive files from generated C (static linking)
IMPORT_ARCHIVE_FILES=""
SKIP_RUNTIME=0
if grep -q '__STRADA_ARCHIVE_FILES__:' "$C_FILE" 2>/dev/null; then
    # Extract archive files from the comment: __STRADA_ARCHIVE_FILES__: path1.a path2.a ...
    IMPORT_ARCHIVE_FILES=$(grep '__STRADA_ARCHIVE_FILES__:' "$C_FILE" | sed 's/.*__STRADA_ARCHIVE_FILES__: *//' | sed 's/ *\*\///')
    if [ -n "$IMPORT_ARCHIVE_FILES" ]; then
        info "import_archive files: $IMPORT_ARCHIVE_FILES"
        # Verify each archive file exists
        for arch in $IMPORT_ARCHIVE_FILES; do
            if [ ! -f "$arch" ]; then
                error "import_archive: archive file not found: $arch"
            fi
        done
        # Add to extra files for linking
        EXTRA_FILES="$EXTRA_FILES $IMPORT_ARCHIVE_FILES"
    fi
    # Check if we should skip runtime (archives include it)
    if grep -q '__STRADA_SKIP_RUNTIME__' "$C_FILE" 2>/dev/null; then
        SKIP_RUNTIME=1
        info "Skipping runtime (included in archive)"
    fi
fi

# Pick up extern-C link deps from `link_lib` declarations (in the source or
# inherited from used .o/.so/.a metadata) and add them to LINK_FLAGS.
if grep -q '__STRADA_LINK_LIBS__:' "$C_FILE" 2>/dev/null; then
    IMPORT_LINK_LIBS=$(grep '__STRADA_LINK_LIBS__:' "$C_FILE" | sed 's/.*__STRADA_LINK_LIBS__: *//' | sed 's/ *\*\///')
    if [ -n "$IMPORT_LINK_LIBS" ]; then
        info "link_libs: $IMPORT_LINK_LIBS"
        for lib in $IMPORT_LINK_LIBS; do
            # Availability filter: link_lib declarations come from PARSING a
            # used module's source, where `#ifdef HAVE_X` guards are inert
            # comments — so a multi-driver module like DBI declares ALL its
            # backends (sqlite3, mysqlclient, pq) even when only some are
            # installed. Probe each auto-collected lib and skip+warn when the
            # linker can't find it; a driver that's genuinely needed but
            # missing still fails later with unresolved symbols, now with a
            # warning that names the culprit. User-passed -l flags are NOT
            # filtered (they arrive via LINK_LIBS, added separately).
            if echo 'int main(void){return 0;}' | $CC -x c - -l"$lib" -o /dev/null 2>/dev/null; then
                LINK_FLAGS="$LINK_FLAGS -l$lib"
            else
                echo "Warning: skipping -l$lib (declared via link_lib by a used module, but not installed)" >&2
            fi
        done
    fi
fi

# Step 2: Compile C to executable or library
if [ "$SHARED_LIB" -eq 1 ]; then
    # Shared library: -shared -fPIC, link against runtime source (not object)
    if [ "$STATIC_LINK" -eq 1 ]; then
        error "Cannot use --shared and --static together"
    fi
    if [ "$STATIC_LIB" -eq 1 ]; then
        error "Cannot use --shared and --static-lib together"
    fi
    if [ "$OBJECT_ONLY" -eq 1 ]; then
        error "Cannot use --shared and --object together"
    fi
    info "Compiling $C_FILE -> $OUTPUT (shared library)"
    # Note: We do NOT link the runtime into shared libraries.
    # The runtime symbols are provided by the main program (compiled with -rdynamic).
    # This avoids duplicate globals when the .so is loaded.
    if ! run_cmd $CC -shared -fPIC $GCC_FLAGS $SHARED_UNDEFINED_FLAG -o "$OUTPUT" "$C_FILE" $EXTRA_FILES -I"$RUNTIME_DIR" $INCLUDE_FLAGS $DLOPEN_LIBS -lm -lpthread $LINK_FLAGS; then
        error "C compilation failed"
    fi
elif [ "$OBJECT_ONLY" -eq 1 ]; then
    # Object file only: compile to .o without linking
    if [ "$STATIC_LIB" -eq 1 ]; then
        error "Cannot use --object and --static-lib together"
    fi
    if [ "$STATIC_LINK" -eq 1 ]; then
        error "Cannot use --object and --static together"
    fi
    # -ffat-lto-objects keeps native code alongside the LTO bitcode (when
    # LTO is on), so consumers that link with -fno-lto can still resolve
    # symbols. Adds a bit of .o size but makes test/dev links work.
    OBJECT_EXTRA=""
    if echo "$GCC_FLAGS" | grep -q -- "-flto"; then
        OBJECT_EXTRA="-ffat-lto-objects"
    fi
    info "Compiling $C_FILE -> $OUTPUT (object file)"
    if ! run_cmd $CC -c $GCC_FLAGS $OBJECT_EXTRA -o "$OUTPUT" "$C_FILE" -I"$RUNTIME_DIR" $INCLUDE_FLAGS; then
        error "C compilation failed"
    fi
elif [ "$STATIC_LIB" -eq 1 ]; then
    # Static library: compile to .o then archive with ar
    if [ "$STATIC_LINK" -eq 1 ]; then
        error "Cannot use --static-lib and --static together"
    fi
    OBJ_FILE="${OUTPUT%.a}.o"
    RUNTIME_OBJ_STATIC="${OUTPUT%.a}_runtime.o"
    # Compile extra C files to objects
    EXTRA_OBJ_FILES=()
    for cf in "${EXTRA_C_FILES[@]}"; do
        obj_name="$(basename "$cf" .c).o"
        info "Compiling $cf -> $obj_name"
        if ! run_cmd $CC -c $GCC_FLAGS -o "$obj_name" "$cf" -I"$RUNTIME_DIR" $INCLUDE_FLAGS; then
            error "Compilation of $cf failed"
        fi
        EXTRA_OBJ_FILES+=("$obj_name")
    done
    info "Compiling $C_FILE -> $OBJ_FILE"
    if ! run_cmd $CC -c $GCC_FLAGS -o "$OBJ_FILE" "$C_FILE" -I"$RUNTIME_DIR" $INCLUDE_FLAGS; then
        error "C compilation failed"
    fi
    info "Compiling runtime -> $RUNTIME_OBJ_STATIC"
    if ! run_cmd $CC -c $GCC_FLAGS -o "$RUNTIME_OBJ_STATIC" "$RUNTIME_SRC" -I"$RUNTIME_DIR"; then
        error "Runtime compilation failed"
    fi
    info "Creating archive $OUTPUT"
    if ! run_cmd ar rcs "$OUTPUT" "$OBJ_FILE" "$RUNTIME_OBJ_STATIC" "${EXTRA_OBJ_FILES[@]}" "${EXTRA_O_FILES[@]}"; then
        error "ar failed"
    fi
    # Clean up object files
    rm -f "$OBJ_FILE" "$RUNTIME_OBJ_STATIC" "${EXTRA_OBJ_FILES[@]}"
elif [ "$STATIC_LINK" -eq 1 ]; then
    # Static binary: no dynamic linking, fully portable
    # Note: -ldl removed (no dynamic loading), -lpthread needs special handling
    info "Compiling $C_FILE -> $OUTPUT (static binary)"
    warn "Static binaries cannot use FFI/dynamic library loading (sys::dl_open, import_lib)"
    if ! run_cmd $CC -static $GCC_FLAGS $GC_SECTIONS_FLAG -o "$OUTPUT" "$C_FILE" $EXTRA_FILES "$RUNTIME_SRC" -I"$RUNTIME_DIR" $INCLUDE_FLAGS -lm -lpthread $LINK_FLAGS; then
        error "C compilation failed"
    fi
else
    # Executable linking
    # Only use -rdynamic when the program needs FFI/import_lib (uses dlopen).
    # Without -rdynamic, -Wl,--gc-sections can strip unused runtime functions,
    # producing much smaller binaries.
    RDYNAMIC_FLAG=""
    if grep -qE 'dlopen|strada_dl_open|strada_tie_hash' "$C_FILE" 2>/dev/null; then
        RDYNAMIC_FLAG="-rdynamic"
        info "FFI/import_lib detected, using -rdynamic"
        # A dlopen host must export the ENTIRE runtime: Strada .so modules
        # don't bundle it, and a library built by a NEWER compiler may
        # reference runtime functions this host's own code never calls
        # (e.g. strada_cleanup_push from a host that predates throw-safe
        # codegen patterns). --gc-sections discards those sections BEFORE
        # -rdynamic exports, producing "undefined symbol" at dlopen time —
        # so section GC must be off for dlopen hosts.
        GC_SECTIONS_FLAG=""
        info "dlopen host: disabling --gc-sections (full runtime export)"
    fi
    info "Compiling $C_FILE -> $OUTPUT"
    if [ "$TCC_MODE" -eq 1 ]; then
        # --tcc: compile the generated program with tcc (much faster than gcc),
        # then link with $CC. Two constraints force this split: tcc can't parse
        # the main runtime header's system includes (so swap to the stripped
        # strada_runtime_tcc.h, as the JIT does), and tcc's own linker can't
        # relocate the gcc-built runtime object (GOT relocations) — so $CC links
        # the tcc-produced object against the full runtime. Full runtime features
        # are preserved (the runtime is still the gcc build).
        if ! command -v tcc >/dev/null 2>&1; then
            error "--tcc requires the 'tcc' compiler, which was not found in PATH"
        fi
        info "TCC mode: tcc compiles, $CC links"
        sed 's/strada_runtime\.h/strada_runtime_tcc.h/' "$C_FILE" > "${C_FILE}.tcc" && mv "${C_FILE}.tcc" "$C_FILE"
        TCC_OBJ="$(mktemp_suffix .o)"
        if ! run_cmd tcc -c "$C_FILE" -I"$RUNTIME_DIR" $INCLUDE_FLAGS -o "$TCC_OBJ"; then
            rm -f "$TCC_OBJ"; error "tcc compilation failed"
        fi
        # tcc drops __attribute__((weak)); re-weaken the symbols the source
        # declared weak (e.g. optional import_object __Pkg_oop_init hooks) so
        # they resolve to NULL at link instead of failing as undefined references.
        if command -v objcopy >/dev/null 2>&1; then
            for __ws in $(grep '__attribute__((weak))' "$C_FILE" 2>/dev/null | grep -oE '[A-Za-z_][A-Za-z0-9_]*\(' | tr -d '(' | grep -v '^__attribute__$' | sort -u); do
                objcopy --weaken-symbol="$__ws" "$TCC_OBJ" 2>/dev/null || true
            done
        fi
        TCC_RT="$RUNTIME_OBJ"; [ "$SKIP_RUNTIME" -eq 1 ] && TCC_RT=""
        # -Wl,-z,noexecstack: tcc objects lack the GNU-stack note, which ld warns about.
        if ! run_cmd $CC $RDYNAMIC_FLAG -Wl,-z,noexecstack -o "$OUTPUT" "$TCC_OBJ" $EXTRA_FILES $TCC_RT -I"$RUNTIME_DIR" $INCLUDE_FLAGS $DLOPEN_LIBS -lm -lpthread $LINK_FLAGS; then
            rm -f "$TCC_OBJ"; error "link failed"
        fi
        rm -f "$TCC_OBJ"
    elif [ "$SKIP_RUNTIME" -eq 1 ]; then
        # Skip runtime when import_archive is used (archive includes runtime)
        if ! run_cmd $CC $RDYNAMIC_FLAG $GCC_FLAGS $GC_SECTIONS_FLAG -o "$OUTPUT" "$C_FILE" $EXTRA_FILES -I"$RUNTIME_DIR" $INCLUDE_FLAGS $DLOPEN_LIBS -lm -lpthread $LINK_FLAGS; then
            error "C compilation failed"
        fi
    else
        if ! run_cmd $CC $RDYNAMIC_FLAG $GCC_FLAGS $GC_SECTIONS_FLAG -o "$OUTPUT" "$C_FILE" $EXTRA_FILES "$RUNTIME_OBJ" -I"$RUNTIME_DIR" $INCLUDE_FLAGS $DLOPEN_LIBS -lm -lpthread $LINK_FLAGS; then
            error "C compilation failed"
        fi
    fi
fi

if [ "$VERBOSE" -eq 1 ]; then
    echo -e "${GREEN}Created:${NC} $OUTPUT"
fi

# Step 3: Run if requested
if [ "$RUN_AFTER" -eq 1 ]; then
    if [ "$SHARED_LIB" -eq 1 ]; then
        warn "Cannot run a shared library directly. Use --shared without --run."
    elif [ "$STATIC_LIB" -eq 1 ]; then
        warn "Cannot run a static library directly. Use --static-lib without --run."
    elif [ "$OBJECT_ONLY" -eq 1 ]; then
        warn "Cannot run an object file directly. Use --object without --run."
    else
        echo ""
        show_cmd "./$OUTPUT"
        echo "---"
        exec "./$OUTPUT"
    fi
fi
