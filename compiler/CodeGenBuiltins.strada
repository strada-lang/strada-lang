            emit($cg, "; char *__uc_in = strada_to_str_ss(__uc_tmp); ");
            emit($cg, "char *__uc_out = strada_uc(__uc_in); ");
            emit($cg, "StradaValue *__uc_res = strada_new_str(__uc_out); ");
            emit($cg, "strada_cstr_free(__uc_in); free(__uc_out); ");
            if ($needs_cleanup == 1) {
                emit($cg, "strada_decref(__uc_tmp); ");
            }
            emit($cg, "__uc_res; }))");
            return 1;
        }

        if ($name eq "lc" || $name eq "lower") {
            # lc returns allocated memory, strada_to_str also allocates - both need freeing
            my scalar $args = $expr->{"args"};
            my scalar $arg0 = $args->[0];
            my int $needs_cleanup = needs_temp_cleanup($cg, $arg0);
            emit($cg, "(({ StradaValue *__lc_tmp = ");
            gen_expression($cg, $arg0);
            emit($cg, "; char *__lc_in = strada_to_str_ss(__lc_tmp); ");
            emit($cg, "char *__lc_out = strada_lc(__lc_in); ");
            emit($cg, "StradaValue *__lc_res = strada_new_str(__lc_out); ");
            emit($cg, "strada_cstr_free(__lc_in); free(__lc_out); ");
            if ($needs_cleanup == 1) {
                emit($cg, "strada_decref(__lc_tmp); ");
            }
            emit($cg, "__lc_res; }))");
            return 1;
        }
        
        if ($name eq "index") {
            my scalar $args = $expr->{"args"};
            my int $arg_count = $expr->{"arg_count"};
            my scalar $arg0 = $args->[0];
            my scalar $arg1 = $args->[1];
            my int $arg0_needs_cleanup = needs_temp_cleanup($cg, $arg0);
            my int $arg1_needs_cleanup = needs_temp_cleanup($cg, $arg1);

            if ($arg_count == 3) {
                # 3-argument form: index(string, substring, offset)
                emit($cg, "(({ StradaValue *__idx_str = ");
                gen_expression($cg, $arg0);
                emit($cg, "; StradaValue *__idx_sub = ");
                gen_expression($cg, $arg1);
                # Pass the StradaValues directly to strada_index_sv2 (binary-
                # safe + flag-aware) instead of extracting to char* via
                # strada_to_str_ss, which dropped the UTF-8 flag and made the
                # returned offset char-based even when substr treats the string
                # as bytes — breaking substr($s, index($s,$sub,$off), $n).
                emit($cg, "; StradaValue *__idx_res = strada_new_int(strada_index_sv2(__idx_str, __idx_sub, ");
                emit_int_operand($cg, $args->[2]);
                emit($cg, ")); ");
                if ($arg0_needs_cleanup == 1) {
                    emit($cg, "strada_decref(__idx_str); ");
                }
                if ($arg1_needs_cleanup == 1) {
                    emit($cg, "strada_decref(__idx_sub); ");
                }
                emit($cg, "__idx_res; }))");
            } elsif ($arg1->{"type"} == NODE_STR_LITERAL()) {
                # Fast path: literal needle → strada_index_sv (no string extraction)
                my str $needle_lit = $arg1->{"value"};
                if ($arg0_needs_cleanup == 1) {
                    emit($cg, "(({ StradaValue *__idx_str = ");
                    gen_expression($cg, $arg0);
                    emit($cg, "; StradaValue *__idx_res = strada_new_int(strada_index_sv(__idx_str, ");
                    gen_str_literal_c($cg, $needle_lit);
                    emit($cg, ")); strada_decref(__idx_str); __idx_res; }))");
                } else {
                    emit($cg, "strada_new_int(strada_index_sv(");
                    gen_expression($cg, $arg0);
                    emit($cg, ", ");
                    gen_str_literal_c($cg, $needle_lit);
                    emit($cg, "))");
                }
            } else {
                # General form: pass StradaValues straight to strada_index_sv2
                # (binary-safe + UTF-8-flag-aware) so the returned offset is in
                # the same unit substr expects. Extracting to char* dropped the
                # flag and char-counted non-flagged byte strings.
                emit($cg, "(({ StradaValue *__idx_str = ");
                gen_expression($cg, $arg0);
                emit($cg, "; StradaValue *__idx_sub = ");
                gen_expression($cg, $arg1);
                emit($cg, "; StradaValue *__idx_res = strada_new_int(strada_index_sv2(__idx_str, __idx_sub, 0)); ");
                if ($arg0_needs_cleanup == 1) {
                    emit($cg, "strada_decref(__idx_str); ");
                }
                if ($arg1_needs_cleanup == 1) {
                    emit($cg, "strada_decref(__idx_sub); ");
                }
                emit($cg, "__idx_res; }))");
            }
            return 1;
        }

        if ($name eq "rindex") {
            my scalar $args = $expr->{"args"};
            my scalar $arg0 = $args->[0];
            my scalar $arg1 = $args->[1];
            my int $arg0_needs_cleanup = needs_temp_cleanup($cg, $arg0);
            my int $arg1_needs_cleanup = needs_temp_cleanup($cg, $arg1);

            emit($cg, "(({ StradaValue *__ridx_str = ");
            gen_expression($cg, $arg0);
            emit($cg, "; StradaValue *__ridx_sub = ");
            gen_expression($cg, $arg1);
            emit($cg, "; char *__ridx_s1 = strada_to_str_ss(__ridx_str); ");
            emit($cg, "char *__ridx_s2 = strada_to_str_ss(__ridx_sub); ");
            emit($cg, "StradaValue *__ridx_res = strada_new_int(strada_rindex(__ridx_s1, __ridx_s2)); ");
            emit($cg, "strada_cstr_free(__ridx_s1); strada_cstr_free(__ridx_s2); ");
            if ($arg0_needs_cleanup == 1) {
                emit($cg, "strada_decref(__ridx_str); ");
            }
            if ($arg1_needs_cleanup == 1) {
                emit($cg, "strada_decref(__ridx_sub); ");
            }
            emit($cg, "__ridx_res; }))");
            return 1;
        }

        if ($name eq "sprintf" || $name eq "sys::sprintf") {
            # sprintf needs to capture and cleanup all argument temps.
            # Accept both bare "sprintf" and namespaced "sys::sprintf"
            # (the latter is what core::sprintf normalizes to).
            my scalar $args = $expr->{"args"};
            my int $arg_count = $expr->{"arg_count"};

            emit($cg, "(({ ");

            # Generate temp vars for each argument and push owned-temps
            # to the cleanup stack so a throwing stringify overload
            # (dispatched inside strada_sprintf_sv) doesn't leak the
            # prior args.
            my int $i = 0;
            while ($i < $arg_count) {
                emit($cg, "StradaValue *__sprintf_arg" . $i . " = ");
                gen_expression($cg, $args->[$i]);
                emit($cg, "; ");
                if (needs_temp_cleanup($cg, $args->[$i]) == 1) {
                    emit($cg, "strada_cleanup_push(__sprintf_arg" . $i . "); ");
                }
                $i = $i + 1;
            }

            # Call sprintf_sv with the temp vars
            emit($cg, "StradaValue *__sprintf_res = strada_sprintf_sv(__sprintf_arg0, " . ($arg_count - 1));
            $i = 1;
            while ($i < $arg_count) {
                emit($cg, ", __sprintf_arg" . $i);
                $i = $i + 1;
            }
            emit($cg, "); ");

            # Pop pushed args (reverse order) then decref.
            $i = $arg_count - 1;
            while ($i >= 0) {
                if (needs_temp_cleanup($cg, $args->[$i]) == 1) {
                    emit($cg, "strada_cleanup_pop(); ");
                }
                $i = $i - 1;
            }
            $i = 0;
            while ($i < $arg_count) {
                if (needs_temp_cleanup($cg, $args->[$i]) == 1) {
                    emit($cg, "strada_decref(__sprintf_arg" . $i . "); ");
                }
                $i = $i + 1;
            }

            emit($cg, "__sprintf_res; }))");
            return 1;
        }
        
        if ($name eq "printf") {
            # Route printf through strada_sprintf_sv so each `%d` / `%f`
            # / `%s` actually interprets its arg's StradaValue type
            # (`strada_to_int` / `strada_to_num` / `strada_to_str`).
            # Previously the codegen pre-converted every arg to a C
            # string and called vprintf — so `printf("%d", 42)` passed a
            # `char*` pointer where the format expected `int`, and the
            # output was whatever bits happened to fall under the
            # truncation.
            my scalar $args = $expr->{"args"};
            my int $argc = $expr->{"arg_count"};
            emit($cg, "({ ");
            my int $i = 0;
            while ($i < $argc) {
                emit($cg, "StradaValue *__pf_v" . $i . " = ");
                gen_expression($cg, $args->[$i]);
                emit($cg, "; ");
                $i = $i + 1;
            }
            emit($cg, "StradaValue *__pf_res = strada_sprintf_sv(__pf_v0, " . ($argc - 1));
            $i = 1;
            while ($i < $argc) {
                emit($cg, ", __pf_v" . $i);
                $i = $i + 1;
            }
            emit($cg, "); { char *__pf_buf = strada_to_str(__pf_res); if (__pf_buf) { fputs(__pf_buf, stdout); free(__pf_buf); } fflush(stdout); } strada_decref(__pf_res); ");
            $i = 0;
            while ($i < $argc) {
                if (needs_temp_cleanup($cg, $args->[$i]) == 1) {
                    emit($cg, "strada_decref(__pf_v" . $i . "); ");
                }
                $i = $i + 1;
            }
            emit($cg, "(StradaValue*)NULL; })");
            return 1;
        }
        
        if ($name eq "warn") {
            my scalar $args = $expr->{"args"};
            my int $argc = $expr->{"arg_count"};
            my scalar $arg = $args->[0];
            if ($argc > 1) {
                # Multi-arg warn: concatenate all args before emitting,
                # matching Perl. Previously only args[0] reached the
                # warning output.
                emit($cg, "({ StradaValue *__wn_msg = strada_new_str(\"\"); ");
                my int $wi = 0;
                while ($wi < $argc) {
                    emit($cg, "{ StradaValue *__wn_p = ");
                    gen_expression($cg, $args->[$wi]);
                    emit($cg, "; StradaValue *__wn_new = strada_concat_sv(__wn_msg, __wn_p); strada_decref(__wn_msg); __wn_msg = __wn_new; ");
                    if (needs_temp_cleanup($cg, $args->[$wi]) == 1) {
                        emit($cg, "strada_decref(__wn_p); ");
                    }
                    emit($cg, "} ");
                    $wi = $wi + 1;
                }
                emit($cg, "char *__wn_s = strada_to_str(__wn_msg); strada_warn(\"%s\", __wn_s); free(__wn_s); strada_decref(__wn_msg); (StradaValue*)NULL; })");
            } else {
                emit($cg, "({ StradaValue *__wn_v = ");
                gen_expression($cg, $arg);
                emit($cg, "; char *__wn_s = strada_to_str_ss(__wn_v); strada_warn(\"%s\", __wn_s); strada_cstr_free(__wn_s); ");
                if (needs_temp_cleanup($cg, $arg) == 1) {
                    emit($cg, "strada_decref(__wn_v); ");
                }
                emit($cg, "(StradaValue*)NULL; })");
            }
            return 1;
        }
        
        if ($name eq "sys::slurp" || $name eq "slurp") {
            my scalar $args = $expr->{"args"};
            my scalar $arg = $args->[0];
            emit($cg, "({ StradaValue *__sl_v = ");
            gen_expression($cg, $arg);
            emit($cg, "; char *__sl_s = strada_to_str_ss(__sl_v); StradaValue *__sl_r = strada_slurp(__sl_s); strada_cstr_free(__sl_s); ");
            if (needs_temp_cleanup($cg, $arg) == 1) {
                emit($cg, "strada_decref(__sl_v); ");
            }
            emit($cg, "__sl_r; })");
            return 1;
        }

        if ($name eq "sys::slurp_fh") {
            emit($cg, "strada_slurp_fh(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ")");
            return 1;
        }

        if ($name eq "sys::slurp_fd") {
            emit($cg, "strada_slurp_fd(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ")");
            return 1;
        }

        if ($name eq "sys::spew" || $name eq "spew") {
            my scalar $args = $expr->{"args"};
            my scalar $arg0 = $args->[0];
            my scalar $arg1 = $args->[1];
            # Use binary-safe strada_spew_sv for content to handle embedded NULs
            emit($cg, "({ StradaValue *__sp_v0 = ");
            gen_expression($cg, $arg0);
            emit($cg, "; StradaValue *__sp_v1 = ");
            gen_expression($cg, $arg1);
            emit($cg, "; char *__sp_s0 = strada_to_str_ss(__sp_v0); ");
            emit($cg, "strada_spew_sv(__sp_s0, __sp_v1); strada_cstr_free(__sp_s0); ");
            if (needs_temp_cleanup($cg, $arg0) == 1) {
                emit($cg, "strada_decref(__sp_v0); ");
            }
            if (needs_temp_cleanup($cg, $arg1) == 1) {
                emit($cg, "strada_decref(__sp_v1); ");
            }
            emit($cg, "(StradaValue*)NULL; })");
            return 1;
        }

        if ($name eq "sys::spew_fh") {
            emit($cg, "strada_spew_fh(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ", ");
            gen_expression($cg, $args->[1]);
            emit($cg, ")");
            return 1;
        }

        if ($name eq "sys::spew_fd") {
            emit($cg, "strada_spew_fd(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ", ");
            gen_expression($cg, $args->[1]);
            emit($cg, ")");
            return 1;
        }

        # StringBuilder functions for O(1) amortized append
        if ($name eq "sb_new") {
            my scalar $args = $expr->{"args"};
            my int $arg_count = $expr->{"arg_count"};
            if ($arg_count > 0) {
                gen_call_with_arg_cleanup($cg, "strada_sb_new_cap", $args, 1);
            } else {
                emit($cg, "strada_sb_new()");
            }
            return 1;
        }

        if ($name eq "sb_append") {
            my scalar $args = $expr->{"args"};
            my int $sb0_cleanup = needs_temp_cleanup($cg, $args->[0]);
            my int $sba_cleanup = needs_temp_cleanup($cg, $args->[1]);
            if ($sb0_cleanup == 1 || $sba_cleanup == 1) {
                emit($cg, "({ ");
                if ($sb0_cleanup == 1) {
                    emit($cg, "StradaValue *__sba_sb = ");
                    gen_expression($cg, $args->[0]);
                    emit($cg, "; ");
                }
                if ($sba_cleanup == 1) {
                    emit($cg, "StradaValue *__sba_tmp = ");
                    gen_expression($cg, $args->[1]);
                    emit($cg, "; ");
                }
                emit($cg, "strada_sb_append(");
                if ($sb0_cleanup == 1) {
                    emit($cg, "__sba_sb");
                } else {
                    gen_expression($cg, $args->[0]);
                }
                emit($cg, ", ");
                if ($sba_cleanup == 1) {
                    emit($cg, "__sba_tmp");
                } else {
                    gen_expression($cg, $args->[1]);
                }
                emit($cg, "); ");
                if ($sb0_cleanup == 1) {
                    emit($cg, "strada_decref(__sba_sb); ");
                }
                if ($sba_cleanup == 1) {
                    emit($cg, "strada_decref(__sba_tmp); ");
                }
                emit($cg, "strada_undef_static(); })");
            } else {
                emit($cg, "(strada_sb_append(");
                gen_expression($cg, $args->[0]);
                emit($cg, ", ");
                gen_expression($cg, $args->[1]);
                emit($cg, "), strada_undef_static())");
            }
            return 1;
        }
    return 0;
}

func gen_builtin_g5(scalar $cg, scalar $expr, str $name) int {

        if ($name eq "sb_to_string") {
            my scalar $args = $expr->{"args"};
            if (needs_temp_cleanup($cg, $args->[0]) == 1) {
                emit($cg, "({ StradaValue *__sb_tmp = ");
                gen_expression($cg, $args->[0]);
                emit($cg, "; StradaValue *__sb_res = strada_sb_to_string(__sb_tmp); strada_decref(__sb_tmp); __sb_res; })");
            } else {
                emit($cg, "strada_sb_to_string(");
                gen_expression($cg, $args->[0]);
                emit($cg, ")");
            }
            return 1;
        }

        if ($name eq "sb_length") {
            my scalar $args = $expr->{"args"};
            if (needs_temp_cleanup($cg, $args->[0]) == 1) {
                emit($cg, "({ StradaValue *__sb_tmp = ");
                gen_expression($cg, $args->[0]);
                emit($cg, "; StradaValue *__sb_res = strada_sb_length(__sb_tmp); strada_decref(__sb_tmp); __sb_res; })");
            } else {
                emit($cg, "strada_sb_length(");
                gen_expression($cg, $args->[0]);
                emit($cg, ")");
            }
            return 1;
        }

        if ($name eq "sb_clear") {
            my scalar $args = $expr->{"args"};
            if (needs_temp_cleanup($cg, $args->[0]) == 1) {
                emit($cg, "({ StradaValue *__sb_tmp = ");
                gen_expression($cg, $args->[0]);
                emit($cg, "; strada_sb_clear(__sb_tmp); strada_decref(__sb_tmp); strada_undef_static(); })");
            } else {
                emit($cg, "(strada_sb_clear(");
                gen_expression($cg, $args->[0]);
                emit($cg, "), strada_undef_static())");
            }
            return 1;
        }

        if ($name eq "sb_free") {
            my scalar $args = $expr->{"args"};
            if (needs_temp_cleanup($cg, $args->[0]) == 1) {
                emit($cg, "({ StradaValue *__sb_tmp = ");
                gen_expression($cg, $args->[0]);
                emit($cg, "; strada_sb_free(__sb_tmp); strada_decref(__sb_tmp); strada_undef_static(); })");
            } else {
                emit($cg, "(strada_sb_free(");
                gen_expression($cg, $args->[0]);
                emit($cg, "), strada_undef_static())");
            }
            return 1;
        }

        # open(filename_or_ref, mode) - open file or in-memory handle
        if ($name eq "sys::open") {
            my scalar $args = $expr->{"args"};
            my scalar $arg0 = $args->[0];
            my scalar $arg1 = $args->[1];
            emit($cg, "({ StradaValue *__op_v0 = ");
            gen_expression($cg, $arg0);
            emit($cg, "; StradaValue *__op_v1 = ");
            gen_expression($cg, $arg1);
            emit($cg, "; StradaValue *__op_r = strada_open_sv(__op_v0, __op_v1); ");
            if (needs_temp_cleanup($cg, $arg0) == 1) {
                emit($cg, "strada_decref(__op_v0); ");
            }
            if (needs_temp_cleanup($cg, $arg1) == 1) {
                emit($cg, "strada_decref(__op_v1); ");
            }
            emit($cg, "__op_r; })");
            return 1;
        }

        if ($name eq "sys::open_fd") {
            emit($cg, "strada_open_fd(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ", ");
            gen_expression($cg, $args->[1]);
            emit($cg, ")");
            return 1;
        }

        # open_str(content, mode) - open in-memory file handle
        if ($name eq "sys::open_str") {
            my scalar $args = $expr->{"args"};
            my scalar $arg0 = $args->[0];
            my scalar $arg1 = $args->[1];
            emit($cg, "({ StradaValue *__op_v0 = ");
            gen_expression($cg, $arg0);
            emit($cg, "; StradaValue *__op_v1 = ");
            gen_expression($cg, $arg1);
            emit($cg, "; char *__op_s0 = strada_to_str_ss(__op_v0); char *__op_s1 = strada_to_str_ss(__op_v1); ");
            emit($cg, "StradaValue *__op_r = strada_open_str(__op_s0, __op_s1); strada_cstr_free(__op_s0); strada_cstr_free(__op_s1); ");
            if (needs_temp_cleanup($cg, $arg0) == 1) {
                emit($cg, "strada_decref(__op_v0); ");
            }
            if (needs_temp_cleanup($cg, $arg1) == 1) {
                emit($cg, "strada_decref(__op_v1); ");
            }
            emit($cg, "__op_r; })");
            return 1;
        }

        # str_from_fh(fh) - extract accumulated string from memstream
        if ($name eq "sys::str_from_fh") {
            my scalar $args = $expr->{"args"};
            my scalar $arg0 = $args->[0];
            emit($cg, "({ StradaValue *__op_v0 = ");
            gen_expression($cg, $arg0);
            emit($cg, "; StradaValue *__op_r = strada_str_from_fh(__op_v0); ");
            if (needs_temp_cleanup($cg, $arg0) == 1) {
                emit($cg, "strada_decref(__op_v0); ");
            }
            emit($cg, "__op_r; })");
            return 1;
        }

        # close(fh) - close file handle
        if ($name eq "sys::close") {
            emit($cg, "strada_close(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ")");
            return 1;
        }

        # write_fd(fd, str) - write to file descriptor
        if ($name eq "write_fd" || $name eq "sys::write_fd") {
            emit($cg, "strada_write_fd(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ", ");
            gen_expression($cg, $args->[1]);
            emit($cg, ")");
            return 1;
        }

        # close_fd(fd) - close file descriptor
        if ($name eq "close_fd" || $name eq "sys::close_fd") {
            emit($cg, "strada_close_fd(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ")");
            return 1;
        }

        # getpid() - get process ID
        if ($name eq "getpid" || $name eq "sys::getpid") {
            emit($cg, "strada_new_int(getpid())");
            return 1;
        }

        # unlink(path) - delete file
        if ($name eq "unlink" || $name eq "sys::unlink") {
            emit($cg, "strada_unlink(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ")");
            return 1;
        }

        # fwrite(fh, content) - write to file handle
        if ($name eq "sys::fwrite") {
            my scalar $args = $expr->{"args"};
            my scalar $data_arg = $args->[1];
            emit($cg, "({ StradaValue *__fw_v = ");
            gen_expression($cg, $data_arg);
            emit($cg, "; char *__fw_s = strada_to_str_ss(__fw_v); strada_write_file(");
            gen_expression($cg, $args->[0]);
            emit($cg, ", __fw_s); strada_cstr_free(__fw_s); ");
            if (needs_temp_cleanup($cg, $data_arg) == 1) {
                emit($cg, "strada_decref(__fw_v); ");
            }
            emit($cg, "(StradaValue*)NULL; })");
            return 1;
        }

        # fread(fh) - read entire file from handle
        if ($name eq "sys::fread") {
            emit($cg, "strada_read_file(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ")");
            return 1;
        }

        if ($name eq "die") {
            my scalar $args = $expr->{"args"};
            my int $argc = $expr->{"arg_count"};
            my scalar $arg0 = $args->[0];
            if ($argc > 1) {
                # Multi-arg die: stringify and concat all args (Perl
                # semantics). Previously only args[0] was raised, so
                # `die "error", " in ", "context"` reached the catcher as
                # "error" with the rest dropped.
                emit($cg, "({ StradaValue *__die_msg = strada_new_str(\"\"); ");
                my int $di = 0;
                while ($di < $argc) {
