        }

        if ($name eq "sys::exit_status") {
            emit($cg, "strada_exit_status(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ")");
            return 1;
        }

        # Thread functions
        if ($name eq "thread::create") {
            # The closure is an owned temp and strada_thread_create increfs it
            # (st->closure); without decref'ing the temp here it leaks (refcount
            # stays 1 after thread_join's decref). Wrap with cleanup.
            my scalar $args = $expr->{"args"};
            my scalar $tc_arg = $args->[0];
            if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $tc_arg) == 1) {
                emit($cg, "({ StradaValue *__tc_cl = ");
                gen_expression($cg, $tc_arg);
                emit($cg, "; StradaValue *__tc_r = strada_thread_create(__tc_cl); strada_decref(__tc_cl); __tc_r; })");
            } else {
                emit($cg, "strada_thread_create(");
                gen_expression($cg, $tc_arg);
                emit($cg, ")");
            }
            return 1;
        }

        if ($name eq "thread::join") {
            emit($cg, "strada_thread_join(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ")");
            return 1;
        }

        if ($name eq "thread::detach") {
            emit($cg, "strada_thread_detach(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ")");
            return 1;
        }

        if ($name eq "thread::self") {
            emit($cg, "strada_thread_self()");
            return 1;
        }

        # thread::tls_set($name, $val) — per-thread named value. The store
        # increfs the value (hash_set semantics), so owned temps need the
        # decref wrapper (same discipline as async::send).
        if ($name eq "thread::tls_set") {
            # BOTH args can be owned temps (string-literal names allocate!)
            # — capture and decref each (checklist #1).
            my scalar $tlsargs = $expr->{"args"};
            my int $tls_n_owned = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $tlsargs->[0]) == 1;
            my int $tls_v_owned = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $tlsargs->[1]) == 1;
            emit($cg, "({ StradaValue *__tls_n = ");
            gen_expression($cg, $tlsargs->[0]);
            emit($cg, "; StradaValue *__tls_v = ");
            gen_expression($cg, $tlsargs->[1]);
            emit($cg, "; strada_tls_set(__tls_n, __tls_v); ");
            if ($tls_n_owned == 1) { emit($cg, "strada_decref(__tls_n); "); }
            if ($tls_v_owned == 1) { emit($cg, "strada_decref(__tls_v); "); }
            emit($cg, "strada_undef_static(); })");
            return 1;
        }

        if ($name eq "thread::tls_get" || $name eq "thread::tls_exists"
            || $name eq "thread::tls_delete") {
            my str $tls_fn = "strada_tls_get";
            if ($name eq "thread::tls_exists") { $tls_fn = "strada_tls_exists"; }
            if ($name eq "thread::tls_delete") { $tls_fn = "strada_tls_delete"; }
            my scalar $tlsgargs = $expr->{"args"};
            if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $tlsgargs->[0]) == 1) {
                emit($cg, "({ StradaValue *__tls_n = ");
                gen_expression($cg, $tlsgargs->[0]);
                emit($cg, "; StradaValue *__tls_r = " . $tls_fn . "(__tls_n); strada_decref(__tls_n); __tls_r; })");
            } else {
                emit($cg, $tls_fn . "(");
                gen_expression($cg, $tlsgargs->[0]);
                emit($cg, ")");
            }
            return 1;
        }

        if ($name eq "thread::mutex_new") {
            emit($cg, "strada_mutex_new()");
            return 1;
        }

        if ($name eq "thread::mutex_lock") {
            emit($cg, "strada_mutex_lock(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ")");
            return 1;
        }

        if ($name eq "thread::mutex_trylock") {
            emit($cg, "strada_mutex_trylock(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ")");
            return 1;
        }

        if ($name eq "thread::mutex_unlock") {
            emit($cg, "strada_mutex_unlock(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ")");
            return 1;
        }

        if ($name eq "thread::mutex_destroy") {
            emit($cg, "strada_mutex_destroy(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ")");
            return 1;
        }

        if ($name eq "thread::cond_new") {
            emit($cg, "strada_cond_new()");
            return 1;
        }

        if ($name eq "thread::cond_wait") {
            emit($cg, "strada_cond_wait(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ", ");
            gen_expression($cg, $args->[1]);
            emit($cg, ")");
            return 1;
        }

        if ($name eq "thread::cond_signal") {
            emit($cg, "strada_cond_signal(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ")");
            return 1;
        }

        if ($name eq "thread::cond_broadcast") {
            emit($cg, "strada_cond_broadcast(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ")");
            return 1;
        }

        if ($name eq "thread::cond_destroy") {
            emit($cg, "strada_cond_destroy(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ")");
            return 1;
        }

        # ===== ASYNC/AWAIT NAMESPACE FUNCTIONS =====
        if ($name eq "async::all") {
            # The arrayref of futures `[$f1, $f2, ...]` is an owned
            # temp; without decref it leaks plus its underlying array
            # and embedded future refs every call.
            my scalar $args = $expr->{"args"};
            my int $all_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $args->[0]) == 1;
            if ($all_cleanup == 1) {
                emit($cg, "({ StradaValue *__all_arg = ");
                gen_expression($cg, $args->[0]);
                emit($cg, "; StradaValue *__all_res = strada_future_all(__all_arg); strada_decref(__all_arg); __all_res; })");
            } else {
                emit($cg, "strada_future_all(");
                gen_expression($cg, $args->[0]);
                emit($cg, ")");
            }
            return 1;
        }

        if ($name eq "async::race") {
            my scalar $args = $expr->{"args"};
            my int $race_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $args->[0]) == 1;
            if ($race_cleanup == 1) {
                emit($cg, "({ StradaValue *__race_arg = ");
                gen_expression($cg, $args->[0]);
                emit($cg, "; StradaValue *__race_res = strada_future_race(__race_arg); strada_decref(__race_arg); __race_res; })");
            } else {
                emit($cg, "strada_future_race(");
                gen_expression($cg, $args->[0]);
                emit($cg, ")");
            }
            return 1;
        }

        if ($name eq "async::timeout") {
            emit($cg, "strada_async_timeout(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ", ");
            gen_expression($cg, $args->[1]);
            emit($cg, ")");
            return 1;
        }

        if ($name eq "async::cancel") {
            emit($cg, "(strada_future_cancel(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, "), strada_undef_static())");
            return 1;
        }

        if ($name eq "async::is_done") {
            emit($cg, "strada_new_int(strada_future_is_done(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, "))");
            return 1;
        }

        if ($name eq "async::is_cancelled") {
            emit($cg, "strada_new_int(strada_future_is_cancelled(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, "))");
            return 1;
        }

        if ($name eq "async::pool_init") {
            emit($cg, "(strada_pool_init(strada_to_int(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ")), strada_undef_static())");
            return 1;
        }

        if ($name eq "async::pool_shutdown") {
            emit($cg, "(strada_pool_shutdown(), strada_undef_static())");
            return 1;
        }

        # async::spawn($closure) — run a closure as a pool future.
        # strada_future_new TAKES OWNERSHIP of the closure: owned temps
        # (anon fns) pass straight through; borrowed variables get an
        # incref so the future's teardown doesn't steal the variable's ref.
        # core::exception_trace() — the call stack captured at the most
        # recent throw in this thread (readable inside catch blocks).
        if ($name eq "sys::exception_trace") {
            emit($cg, "strada_exception_trace_get()");
            return 1;
        }

        if ($name eq "async::spawn") {
            my scalar $spargs = $expr->{"args"};
            if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $spargs->[0]) == 1) {
                emit($cg, "strada_future_new(");
                gen_expression($cg, $spargs->[0]);
                emit($cg, ")");
            } else {
                emit($cg, "({ StradaValue *__sp_cl = ");
                gen_expression($cg, $spargs->[0]);
                emit($cg, "; strada_incref(__sp_cl); strada_future_new(__sp_cl); })");
            }
            return 1;
        }

        # async::select(\@channels [, $timeout_ms]) → [index, value]
        if ($name eq "async::select") {
            my scalar $selargs = $expr->{"args"};
            my int $sel_argc = $expr->{"arg_count"};
            my int $sel_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $selargs->[0]) == 1;
            if ($sel_cleanup == 1) {
                emit($cg, "({ StradaValue *__sel_c = ");
                gen_expression($cg, $selargs->[0]);
                emit($cg, "; StradaValue *__sel_r = strada_channel_select(__sel_c, ");
                if ($sel_argc > 1) { gen_expression($cg, $selargs->[1]); } else { emit($cg, "NULL"); }
                emit($cg, "); strada_decref(__sel_c); __sel_r; })");
            } else {
                emit($cg, "strada_channel_select(");
                gen_expression($cg, $selargs->[0]);
                emit($cg, ", ");
                if ($sel_argc > 1) { gen_expression($cg, $selargs->[1]); } else { emit($cg, "NULL"); }
                emit($cg, ")");
            }
            return 1;
        }

        # async::sleep($ms) — cancellation-aware sleep (1 = full sleep,
        # 0 = woken early by async::cancel on this task's future)
        if ($name eq "async::sleep") {
            my scalar $slargs = $expr->{"args"};
            emit($cg, "strada_async_sleep(");
            gen_expression($cg, $slargs->[0]);
            emit($cg, ")");
            return 1;
        }

        # async::cancelled() — was THIS task asked to cancel?
        if ($name eq "async::cancelled") {
            emit($cg, "strada_async_cancelled()");
            return 1;
        }

        # async::map($fn, \@items [, $workers]) — data-parallel map.
        # Can rethrow a worker error: owned args ride the cleanup stack
        # so the catch drain reclaims them on throw.
        if ($name eq "async::map") {
            my scalar $mpargs = $expr->{"args"};
            my int $mp_argc = $expr->{"arg_count"};
            my int $mp_fn_owned = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $mpargs->[0]) == 1;
            my int $mp_it_owned = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $mpargs->[1]) == 1;
            emit($cg, "({ StradaValue *__mp_fn = ");
            gen_expression($cg, $mpargs->[0]);
            emit($cg, "; ");
            if ($mp_fn_owned == 1) { emit($cg, "strada_cleanup_push(__mp_fn); "); }
            emit($cg, "StradaValue *__mp_it = ");
            gen_expression($cg, $mpargs->[1]);
            emit($cg, "; ");
            if ($mp_it_owned == 1) { emit($cg, "strada_cleanup_push(__mp_it); "); }
            emit($cg, "StradaValue *__mp_r = strada_async_map(__mp_fn, __mp_it, ");
            if ($mp_argc > 2) { gen_expression($cg, $mpargs->[2]); } else { emit($cg, "NULL"); }
            emit($cg, "); ");
            if ($mp_it_owned == 1) { emit($cg, "strada_cleanup_pop(); strada_decref(__mp_it); "); }
            if ($mp_fn_owned == 1) { emit($cg, "strada_cleanup_pop(); strada_decref(__mp_fn); "); }
            emit($cg, "__mp_r; })");
            return 1;
        }

        # ===== CHANNEL NAMESPACE FUNCTIONS =====
        if ($name eq "async::channel") {
            my scalar $args = $expr->{"args"};
            my int $arg_count = $expr->{"arg_count"};
            if ($arg_count > 0) {
                emit($cg, "strada_channel_new(strada_to_int(");
                gen_expression($cg, $args->[0]);
                emit($cg, "))");
            } else {
                emit($cg, "strada_channel_new(0)");
            }
            return 1;
        }

        if ($name eq "async::send") {
            # strada_channel_send increfs the value when queuing.
            # Without the matching decref below, an owned-temp value
            # arg (literal, concat result, etc.) leaks one SV per call.
            my scalar $args = $expr->{"args"};
            my int $send_v_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $args->[1]) == 1;
            if ($send_v_cleanup == 1) {
                emit($cg, "({ StradaValue *__send_v = ");
                gen_expression($cg, $args->[1]);
                emit($cg, "; strada_channel_send(");
                gen_expression($cg, $args->[0]);
                emit($cg, ", __send_v); strada_decref(__send_v); strada_undef_static(); })");
            } else {
                emit($cg, "(strada_channel_send(");
                gen_expression($cg, $args->[0]);
                emit($cg, ", ");
                gen_expression($cg, $args->[1]);
                emit($cg, "), strada_undef_static())");
            }
            return 1;
        }

        if ($name eq "async::recv") {
            emit($cg, "strada_channel_recv(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ")");
            return 1;
        }

        if ($name eq "async::try_send") {
            emit($cg, "strada_new_int(strada_channel_try_send(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ", ");
            gen_expression($cg, $args->[1]);
            emit($cg, "))");
            return 1;
        }

        if ($name eq "async::try_recv") {
            emit($cg, "strada_channel_try_recv(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ")");
            return 1;
        }

        if ($name eq "async::close") {
            emit($cg, "(strada_channel_close(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, "), strada_undef_static())");
            return 1;
        }

        if ($name eq "async::is_closed") {
            emit($cg, "strada_new_int(strada_channel_is_closed(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, "))");
            return 1;
        }

        if ($name eq "async::len") {
            emit($cg, "strada_new_int(strada_channel_len(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, "))");
            return 1;
        }

        # ===== MUTEX NAMESPACE FUNCTIONS =====
        # These use the existing sys::mutex_* implementation (CPOINTER-based)
        if ($name eq "async::mutex") {
            emit($cg, "strada_mutex_new()");
            return 1;
        }

        if ($name eq "async::lock") {
            emit($cg, "strada_mutex_lock(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ")");
            return 1;
        }

        if ($name eq "async::unlock") {
            emit($cg, "strada_mutex_unlock(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ")");
            return 1;
        }

        if ($name eq "async::try_lock") {
            emit($cg, "strada_mutex_trylock(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ")");
            return 1;
        }

        if ($name eq "async::mutex_destroy") {
            emit($cg, "strada_mutex_destroy(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ")");
            return 1;
        }

        # ===== ATOMIC NAMESPACE FUNCTIONS =====
        if ($name eq "async::atomic") {
            my scalar $args = $expr->{"args"};
            my int $arg_count = $expr->{"arg_count"};
            if ($arg_count > 0) {
                emit($cg, "strada_atomic_new(strada_to_int(");
                gen_expression($cg, $args->[0]);
                emit($cg, "))");
            } else {
                emit($cg, "strada_atomic_new(0)");
            }
            return 1;
        }

        if ($name eq "async::atomic_load") {
            emit($cg, "strada_new_int(strada_atomic_load(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, "))");
            return 1;
        }

        if ($name eq "async::atomic_store") {
            emit($cg, "(strada_atomic_store(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ", ");
            emit_int_operand($cg, $args->[1]);
            emit($cg, "), strada_undef_static())");
            return 1;
        }

        if ($name eq "async::atomic_add") {
            emit($cg, "strada_new_int(strada_atomic_add(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ", ");
            emit_int_operand($cg, $args->[1]);
            emit($cg, "))");
            return 1;
        }

        if ($name eq "async::atomic_sub") {
            emit($cg, "strada_new_int(strada_atomic_sub(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ", ");
            emit_int_operand($cg, $args->[1]);
            emit($cg, "))");
            return 1;
        }

        if ($name eq "async::atomic_inc") {
            emit($cg, "strada_new_int(strada_atomic_inc(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, "))");
            return 1;
        }

        if ($name eq "async::atomic_dec") {
            emit($cg, "strada_new_int(strada_atomic_dec(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, "))");
            return 1;
        }

        if ($name eq "async::atomic_cas") {
            emit($cg, "strada_new_int(strada_atomic_cas(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ", ");
            emit_int_operand($cg, $args->[1]);
            emit($cg, ", ");
            emit_int_operand($cg, $args->[2]);
            emit($cg, "))");
            return 1;
        }

        # Directory functions
        if ($name eq "sys::readdir") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_readdir", $args, 1);
            return 1;
        }

        if ($name eq "sys::readdir_full") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_readdir_full", $args, 1);
            return 1;
        }

        if ($name eq "sys::is_dir") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_is_dir", $args, 1);
            return 1;
        }

        if ($name eq "sys::is_file") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_is_file", $args, 1);
            return 1;
        }

        if ($name eq "sys::is_readable") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_is_readable", $args, 1);
            return 1;
        }

        if ($name eq "sys::is_writable") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_is_writable", $args, 1);
            return 1;
        }

        if ($name eq "sys::is_executable") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_is_executable", $args, 1);
            return 1;
        }

        if ($name eq "sys::is_zero_size") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_is_zero_size", $args, 1);
            return 1;
        }

        if ($name eq "sys::is_symlink") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_is_symlink", $args, 1);
            return 1;
        }

        if ($name eq "sys::file_exists") {
            my scalar $args = $expr->{"args"};
            my scalar $arg = $args->[0];
            emit($cg, "({ StradaValue *__fe_v = ");
            gen_expression($cg, $arg);
            emit($cg, "; char *__fe_s = strada_to_str_ss(__fe_v); int __fe_i = strada_file_exists(__fe_s); strada_cstr_free(__fe_s); ");
            if (needs_temp_cleanup($cg, $arg) == 1) {
                emit($cg, "strada_decref(__fe_v); ");
            }
            emit($cg, "strada_new_int(__fe_i); })");
            return 1;
        }

        if ($name eq "sys::file_mtime") {
            # core::file_mtime(path) -> int (seconds since epoch, -1 on stat
            # failure). Cheap stat() wrapper used by the parser to decide
            # whether a pre-compiled .o/.so artifact is fresher than its
            # .strada source.
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_file_mtime", $args, 1);
            return 1;
        }
    return 0;
}

func gen_builtin_g4(scalar $cg, scalar $expr, str $name) int {

        if ($name eq "sys::dir_exists") {
            # dir_exists is the same as is_dir
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_is_dir", $args, 1);
            return 1;
        }

        if ($name eq "sys::file_size") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_file_size", $args, 1);
            return 1;
        }

        # Math functions - with argument cleanup
        if ($name eq "math::sin" || $name eq "math::cos" || $name eq "math::tan" ||
            $name eq "math::asin" || $name eq "math::acos" || $name eq "math::atan" ||
            $name eq "math::sqrt" || $name eq "math::log" || $name eq "math::log10" ||
            $name eq "math::exp" || $name eq "math::floor" || $name eq "math::ceil" ||
            $name eq "math::abs" || $name eq "math::round" ||
            $name eq "math::sinh" || $name eq "math::cosh" || $name eq "math::tanh") {
            my scalar $args = $expr->{"args"};
            my scalar $arg0 = $args->[0];
            my int $needs_cleanup = needs_temp_cleanup($cg, $arg0);

            # Determine the C function name
            my str $c_func = "strada_sin";
            if ($name eq "math::cos") { $c_func = "strada_cos"; }
            if ($name eq "math::tan") { $c_func = "strada_tan"; }
