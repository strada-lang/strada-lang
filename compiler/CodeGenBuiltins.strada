func gen_builtin_g1(scalar $cg, scalar $expr, str $name) int {
        if ($name eq "say") {
            my int $argc = $expr->{"arg_count"};
            my scalar $args = $expr->{"args"};
            if ($argc == 2) {
                # say($fh, $text) - say to filehandle
                my scalar $text_arg = $args->[1];
                if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $text_arg) == 1) {
                    emit($cg, "({ StradaValue *__say_tmp = ");
                    gen_expression($cg, $text_arg);
                    emit($cg, "; strada_say_fh(__say_tmp, ");
                    gen_expression($cg, $args->[0]);
                    emit($cg, "); strada_decref(__say_tmp); })");
                } else {
                    emit($cg, "strada_say_fh(");
                    gen_expression($cg, $text_arg);
                    emit($cg, ", ");
                    gen_expression($cg, $args->[0]);
                    emit($cg, ")");
                }
            } elsif ($argc > 2) {
                # Multi-arg say: print each arg in sequence then a newline.
                # Previously only args[0] was emitted, so `say("a","b","c")`
                # silently dropped "b" and "c".
                emit($cg, "({ ");
                my int $say_i = 0;
                while ($say_i < $argc) {
                    my scalar $sa = $args->[$say_i];
                    if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $sa) == 1) {
                        emit($cg, "{ StradaValue *__say_v = ");
                        gen_expression($cg, $sa);
                        emit($cg, "; strada_print(__say_v); strada_decref(__say_v); } ");
                    } else {
                        emit($cg, "strada_print(");
                        gen_expression($cg, $sa);
                        emit($cg, "); ");
                    }
                    $say_i = $say_i + 1;
                }
                emit($cg, "putchar('\\n'); fflush(stdout); })");
            } elsif ($argc > 0) {
                my scalar $arg = $args->[0];
                # If cleanup enabled and arg is a temporary, wrap to decref after
                if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $arg) == 1) {
                    emit($cg, "({ StradaValue *__say_tmp = ");
                    gen_expression($cg, $arg);
                    emit($cg, "; strada_say(__say_tmp); strada_decref(__say_tmp); })");
                } else {
                    emit($cg, "strada_say(");
                    gen_expression($cg, $arg);
                    emit($cg, ")");
                }
            } else {
                emit($cg, "({ StradaValue *__say_tmp = strada_new_str(\"\"); strada_say(__say_tmp); strada_decref(__say_tmp); })");
            }
            return 1;
        }

        if ($name eq "print") {
            my int $argc = $expr->{"arg_count"};
            my scalar $args = $expr->{"args"};
            if ($argc == 2) {
                # print($fh, $text) - print to filehandle
                my scalar $text_arg = $args->[1];
                if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $text_arg) == 1) {
                    emit($cg, "({ StradaValue *__print_tmp = ");
                    gen_expression($cg, $text_arg);
                    emit($cg, "; strada_print_fh(__print_tmp, ");
                    gen_expression($cg, $args->[0]);
                    emit($cg, "); strada_decref(__print_tmp); })");
                } else {
                    emit($cg, "strada_print_fh(");
                    gen_expression($cg, $text_arg);
                    emit($cg, ", ");
                    gen_expression($cg, $args->[0]);
                    emit($cg, ")");
                }
            } elsif ($argc > 2) {
                # Multi-arg print: emit each arg in sequence. Previously
                # only args[0] was emitted, silently dropping later args.
                emit($cg, "({ ");
                my int $print_i = 0;
                while ($print_i < $argc) {
                    my scalar $pa = $args->[$print_i];
                    if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $pa) == 1) {
                        emit($cg, "{ StradaValue *__print_v = ");
                        gen_expression($cg, $pa);
                        emit($cg, "; strada_print(__print_v); strada_decref(__print_v); } ");
                    } else {
                        emit($cg, "strada_print(");
                        gen_expression($cg, $pa);
                        emit($cg, "); ");
                    }
                    $print_i = $print_i + 1;
                }
                emit($cg, "})");
            } elsif ($argc > 0) {
                my scalar $arg = $args->[0];
                # If cleanup enabled and arg is a temporary, wrap to decref after
                if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $arg) == 1) {
                    emit($cg, "({ StradaValue *__print_tmp = ");
                    gen_expression($cg, $arg);
                    emit($cg, "; strada_print(__print_tmp); strada_decref(__print_tmp); })");
                } else {
                    emit($cg, "strada_print(");
                    gen_expression($cg, $arg);
                    emit($cg, ")");
                }
            } else {
                emit($cg, "({ StradaValue *__print_tmp = strada_new_str(\"\"); strada_print(__print_tmp); strada_decref(__print_tmp); })");
            }
            return 1;
        }
        
        if ($name eq "length") {
            # Binary-safe UTF-8 character count — walks the full byte length
            # so embedded NUL bytes are counted as chars rather than ending
            # the string (which strlen-based path did).
            my scalar $args = $expr->{"args"};
            my scalar $arg = $args->[0];
            emit($cg, "({ StradaValue *__len_tmp = ");
            gen_expression($cg, $arg);
            emit($cg, "; int64_t __len_res = strada_length_chars_sv(__len_tmp); ");
            if (needs_temp_cleanup($cg, $arg) == 1) {
                emit($cg, "strada_decref(__len_tmp); ");
            }
            emit($cg, "strada_new_int(__len_res); })");
            return 1;
        }

        if ($name eq "bytes") {
            # Binary-safe byte count using struct_size
            my scalar $args = $expr->{"args"};
            if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $args->[0]) == 1) {
                emit($cg, "({ StradaValue *__bytes_v = ");
                gen_expression($cg, $args->[0]);
                emit($cg, "; StradaValue *__bytes_r = strada_new_int(strada_length_sv(__bytes_v)); strada_decref(__bytes_v); __bytes_r; })");
            } else {
                emit($cg, "strada_new_int(strada_length_sv(");
                gen_expression($cg, $args->[0]);
                emit($cg, "))");
            }
            return 1;
        }

        if ($name eq "char_at") {
            my scalar $args = $expr->{"args"};
            my scalar $ca_arg0 = $args->[0];
            my scalar $ca_arg1 = $args->[1];
            my int $ca_cleanup0 = needs_temp_cleanup($cg, $ca_arg0);
            my int $ca_cleanup1 = needs_temp_cleanup($cg, $ca_arg1);
            if ($ca_cleanup0 == 1 || $ca_cleanup1 == 1) {
                emit($cg, "({ ");
                if ($ca_cleanup0 == 1) {
                    emit($cg, "StradaValue *__ca_a0 = ");
                    gen_expression($cg, $ca_arg0);
                    emit($cg, "; ");
                }
                if ($ca_cleanup1 == 1) {
                    emit($cg, "StradaValue *__ca_a1 = ");
                    gen_expression($cg, $ca_arg1);
                    emit($cg, "; ");
                }
                emit($cg, "StradaValue *__ca_res = strada_char_at(");
                if ($ca_cleanup0 == 1) {
                    emit($cg, "__ca_a0");
                } else {
                    gen_expression($cg, $ca_arg0);
                }
                emit($cg, ", ");
                if ($ca_cleanup1 == 1) {
                    emit($cg, "__ca_a1");
                } else {
                    gen_expression($cg, $ca_arg1);
                }
                emit($cg, "); ");
                if ($ca_cleanup0 == 1) {
                    emit($cg, "strada_decref(__ca_a0); ");
                }
                if ($ca_cleanup1 == 1) {
                    emit($cg, "strada_decref(__ca_a1); ");
                }
                emit($cg, "__ca_res; })");
            } else {
                emit($cg, "strada_char_at(");
                gen_expression($cg, $ca_arg0);
                emit($cg, ", ");
                gen_expression($cg, $ca_arg1);
                emit($cg, ")");
            }
            return 1;
        }

        if ($name eq "byte_at") {
            my scalar $args = $expr->{"args"};
            my scalar $ba_arg0 = $args->[0];
            my scalar $ba_arg1 = $args->[1];
            my int $ba_cleanup0 = needs_temp_cleanup($cg, $ba_arg0);
            my int $ba_cleanup1 = needs_temp_cleanup($cg, $ba_arg1);
            if ($ba_cleanup0 == 1 || $ba_cleanup1 == 1) {
                emit($cg, "({ ");
                if ($ba_cleanup0 == 1) {
                    emit($cg, "StradaValue *__ba_a0 = ");
                    gen_expression($cg, $ba_arg0);
                    emit($cg, "; ");
                }
                if ($ba_cleanup1 == 1) {
                    emit($cg, "StradaValue *__ba_a1 = ");
                    gen_expression($cg, $ba_arg1);
                    emit($cg, "; ");
                }
                emit($cg, "StradaValue *__ba_res = strada_byte_at(");
                if ($ba_cleanup0 == 1) {
                    emit($cg, "__ba_a0");
                } else {
                    gen_expression($cg, $ba_arg0);
                }
                emit($cg, ", ");
                if ($ba_cleanup1 == 1) {
                    emit($cg, "__ba_a1");
                } else {
                    gen_expression($cg, $ba_arg1);
                }
                emit($cg, "); ");
                if ($ba_cleanup0 == 1) {
                    emit($cg, "strada_decref(__ba_a0); ");
                }
                if ($ba_cleanup1 == 1) {
                    emit($cg, "strada_decref(__ba_a1); ");
                }
                emit($cg, "__ba_res; })");
            } else {
                emit($cg, "strada_byte_at(");
                gen_expression($cg, $ba_arg0);
                emit($cg, ", ");
                gen_expression($cg, $ba_arg1);
                emit($cg, ")");
            }
            return 1;
        }

        if ($name eq "substr_bytes") {
            my scalar $args = $expr->{"args"};
            if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $args->[0]) == 1) {
                emit($cg, "({ StradaValue *__subb_v = ");
                gen_expression($cg, $args->[0]);
                emit($cg, "; StradaValue *__subb_r = strada_substr_bytes(__subb_v, ");
                emit_int_operand($cg, $args->[1]);
                emit($cg, ", ");
                if ($expr->{"arg_count"} > 2) {
                    emit_int_operand($cg, $args->[2]);
                } else {
                    emit($cg, "-1");
                }
                emit($cg, "); strada_decref(__subb_v); __subb_r; })");
            } else {
                emit($cg, "strada_substr_bytes(");
                gen_expression($cg, $args->[0]);
                emit($cg, ", ");
                emit_int_operand($cg, $args->[1]);
                emit($cg, ", ");
                if ($expr->{"arg_count"} > 2) {
                    emit_int_operand($cg, $args->[2]);
                } else {
                    emit($cg, "-1");
                }
                emit($cg, ")");
            }
            return 1;
        }

        if ($name eq "substr") {
            my scalar $args = $expr->{"args"};
            my int $argc_sub = $expr->{"arg_count"};
            # 4-arg substr($s, $off, $len, $repl): replace [off, off+len)
            # with $repl in $s and return the removed slice. Routes to
            # strada_substr_replace and writes the new string back to the
            # lvalue ($s scalar var / $arr[N] / $h{k}). Without this branch
            # the 4th arg was silently ignored — substr(\$x, 0, 5, "Y") on
            # "Hello World" was a no-op.
            if ($argc_sub >= 4) {
                my scalar $tgt = $args->[0];
                my int $tt = $tgt->{"type"};
                if ($tt == NODE_VARIABLE()) {
                    my str $vname = escape_c_keyword($tgt->{"name"});
                    emit($cg, "({ StradaValue *__sr_old = NULL; ");
                    emit($cg, "StradaValue *__sr_new = strada_substr_replace(" . $vname . ", ");
                    emit_int_operand($cg, $args->[1]);
                    emit($cg, ", ");
                    emit_int_operand($cg, $args->[2]);
                    emit($cg, ", ");
                    gen_expression($cg, $args->[3]);
                    emit($cg, ", &__sr_old); ");
                    emit($cg, "strada_decref(" . $vname . "); " . $vname . " = __sr_new; ");
                    emit($cg, "strada_incref(" . $vname . "); __sr_old; })");
                    return 1;
                }
                if ($tt == NODE_SUBSCRIPT()) {
                    emit($cg, "({ StradaArray *__sr_av = strada_deref_array(");
                    gen_expression($cg, $tgt->{"array"});
                    emit($cg, "); int __sr_idx = (int)strada_to_int(");
                    gen_expression($cg, $tgt->{"index"});
                    emit($cg, "); if (__sr_idx < 0 && __sr_av) __sr_idx += strada_array_length(__sr_av); ");
                    emit($cg, "StradaValue *__sr_oldv = __sr_av ? strada_array_get(__sr_av, __sr_idx) : NULL; ");
                    emit($cg, "StradaValue *__sr_old = NULL; ");
                    emit($cg, "StradaValue *__sr_new = strada_substr_replace(__sr_oldv, ");
                    emit_int_operand($cg, $args->[1]);
                    emit($cg, ", ");
                    emit_int_operand($cg, $args->[2]);
                    emit($cg, ", ");
                    gen_expression($cg, $args->[3]);
                    emit($cg, ", &__sr_old); ");
                    emit($cg, "if (__sr_av) strada_array_set(__sr_av, __sr_idx, __sr_new); ");
                    emit($cg, "else strada_decref(__sr_new); __sr_old; })");
                    return 1;
                }
                if ($tt == NODE_HASH_ACCESS()) {
                    emit($cg, "({ StradaValue *__sr_h = ");
                    gen_expression($cg, $tgt->{"hash"});
                    emit($cg, "; char *__sr_k = strada_to_str_ss(");
                    gen_expression($cg, $tgt->{"key"});
                    emit($cg, "); StradaValue *__sr_oldv = strada_hv_fetch_owned(__sr_h, __sr_k); ");
                    emit($cg, "StradaValue *__sr_old = NULL; ");
                    emit($cg, "StradaValue *__sr_new = strada_substr_replace(__sr_oldv, ");
                    emit_int_operand($cg, $args->[1]);
                    emit($cg, ", ");
                    emit_int_operand($cg, $args->[2]);
                    emit($cg, ", ");
                    gen_expression($cg, $args->[3]);
                    emit($cg, ", &__sr_old); ");
                    emit($cg, "strada_hv_store(__sr_h, __sr_k, __sr_new); ");
                    emit($cg, "strada_decref(__sr_oldv); strada_cstr_free(__sr_k); __sr_old; })");
                    return 1;
                }
                /* Other lvalue shapes fall through to non-mutating form */
            }
            # 2-arg substr($s, $offset) means "to end of string". Passing
            # -1 here would be re-interpreted by strada_substr() as Perl's
            # negative-length "leave N chars at end" semantics, dropping
            # one char. Use INT64_MAX so the runtime clamps to (slen-offset).
            if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $args->[0]) == 1) {
                emit($cg, "({ StradaValue *__sub_v = ");
                gen_expression($cg, $args->[0]);
                emit($cg, "; StradaValue *__sub_r = strada_substr(__sub_v, ");
                emit_int_operand($cg, $args->[1]);
                emit($cg, ", ");
                if ($argc_sub > 2) {
                    emit_int_operand($cg, $args->[2]);
                } else {
                    emit($cg, "INT64_MAX");
                }
                emit($cg, "); strada_decref(__sub_v); __sub_r; })");
            } else {
                emit($cg, "strada_substr(");
                gen_expression($cg, $args->[0]);
                emit($cg, ", ");
                emit_int_operand($cg, $args->[1]);
                emit($cg, ", ");
                if ($argc_sub > 2) {
                    emit_int_operand($cg, $args->[2]);
                } else {
                    emit($cg, "INT64_MAX");
                }
                emit($cg, ")");
            }
            return 1;
        }
        
        if ($name eq "push") {
            my scalar $args = $expr->{"args"};
            my int $argc = $expr->{"arg_count"};
            my int $arr_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $args->[0]) == 1;
            # Capture array once (avoids re-evaluating side-effectful access
            # expressions) and iterate over all value arguments. Previously
            # only args[1] was emitted, so `push @a, x, y, z` silently
            # dropped y and z.
            emit($cg, "({ ");
            if ($arr_cleanup == 1) {
                emit($cg, "StradaValue *__push_a = ");
                gen_expression($cg, $args->[0]);
                emit($cg, "; StradaArray *__push_av = strada_deref_array(__push_a); ");
            } else {
                emit($cg, "StradaArray *__push_av = strada_deref_array(");
                gen_expression($cg, $args->[0]);
                emit($cg, "); ");
            }
            my int $pi = 1;
            while ($pi < $argc) {
                my scalar $val_arg = $args->[$pi];
                if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $val_arg) == 1) {
                    emit($cg, "{ StradaValue *__push_v = ");
                    gen_expression($cg, $val_arg);
                    emit($cg, "; strada_array_push(__push_av, __push_v); strada_decref(__push_v); } ");
                } else {
                    emit($cg, "strada_array_push(__push_av, ");
                    gen_expression($cg, $val_arg);
                    emit($cg, "); ");
                }
                $pi = $pi + 1;
            }
            if ($arr_cleanup == 1) {
                emit($cg, "strada_decref(__push_a); ");
            }
            emit($cg, "strada_undef_static(); })");
            return 1;
        }

        # reserve - pre-allocate array capacity
        if ($name eq "reserve") {
            my scalar $args = $expr->{"args"};
            if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $args->[0]) == 1) {
                emit($cg, "({ StradaValue *__rsv_v = ");
                gen_expression($cg, $args->[0]);
                emit($cg, "; strada_reserve_sv(__rsv_v, ");
                emit_int_operand($cg, $args->[1]);
                emit($cg, "); strada_decref(__rsv_v); strada_undef_static(); })");
            } else {
                emit($cg, "(strada_reserve_sv(");
                gen_expression($cg, $args->[0]);
                emit($cg, ", ");
                emit_int_operand($cg, $args->[1]);
                emit($cg, "), strada_undef_static())");
            }
            return 1;
        }

        if ($name eq "size") {
            my scalar $args = $expr->{"args"};
            my scalar $arg = $args->[0];
            if (needs_temp_cleanup($cg, $arg) == 1) {
                emit($cg, "({ StradaValue *__sz_v = ");
                gen_expression($cg, $arg);
                emit($cg, "; StradaValue *__sz_r = strada_new_int(strada_size(__sz_v)); strada_decref(__sz_v); __sz_r; })");
            } else {
                emit($cg, "strada_new_int(strada_size(");
                gen_expression($cg, $arg);
                emit($cg, "))");
            }
            return 1;
        }
        
        if ($name eq "pop") {
            my scalar $args = $expr->{"args"};
            my int $arr_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $args->[0]) == 1;
            if ($arr_cleanup == 1) {
                emit($cg, "({ StradaValue *__pop_a = ");
                gen_expression($cg, $args->[0]);
                emit($cg, "; StradaValue *__pop_r = strada_array_pop(strada_deref_array(__pop_a)); strada_decref(__pop_a); __pop_r; })");
            } else {
                emit($cg, "strada_array_pop(strada_deref_array(");
                gen_expression($cg, $args->[0]);
                emit($cg, "))");
            }
            return 1;
        }

        if ($name eq "shift") {
            my scalar $args = $expr->{"args"};
            my int $arr_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $args->[0]) == 1;
            if ($arr_cleanup == 1) {
                emit($cg, "({ StradaValue *__shift_a = ");
                gen_expression($cg, $args->[0]);
                emit($cg, "; StradaValue *__shift_r = strada_array_shift(strada_deref_array(__shift_a)); strada_decref(__shift_a); __shift_r; })");
            } else {
                emit($cg, "strada_array_shift(strada_deref_array(");
                gen_expression($cg, $args->[0]);
                emit($cg, "))");
            }
            return 1;
        }
        
        if ($name eq "unshift") {
            my scalar $args = $expr->{"args"};
            my int $argc = $expr->{"arg_count"};
            my int $arr_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $args->[0]) == 1;
            # Multi-arg unshift: emit unshifts in reverse so that
            # `unshift @a, x, y, z` ends with @a = (x, y, z, ...orig).
            # Each unshift prepends a single element, so the LAST arg
            # must be unshifted first.
            emit($cg, "({ ");
            if ($arr_cleanup == 1) {
                emit($cg, "StradaValue *__unsh_a = ");
                gen_expression($cg, $args->[0]);
                emit($cg, "; StradaArray *__unsh_av = strada_deref_array(__unsh_a); ");
            } else {
                emit($cg, "StradaArray *__unsh_av = strada_deref_array(");
                gen_expression($cg, $args->[0]);
                emit($cg, "); ");
            }
            my int $ui = $argc - 1;
            while ($ui >= 1) {
                my scalar $val_arg = $args->[$ui];
                if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $val_arg) == 1) {
                    emit($cg, "{ StradaValue *__unsh_v = ");
                    gen_expression($cg, $val_arg);
                    emit($cg, "; strada_array_unshift(__unsh_av, __unsh_v); strada_decref(__unsh_v); } ");
                } else {
                    emit($cg, "strada_array_unshift(__unsh_av, ");
                    gen_expression($cg, $val_arg);
                    emit($cg, "); ");
                }
                $ui = $ui - 1;
            }
            if ($arr_cleanup == 1) {
                emit($cg, "strada_decref(__unsh_a); ");
            }
            emit($cg, "strada_undef_static(); })");
            return 1;
        }

        # splice(@arr, offset [, length [, @replacement]])
        if ($name eq "splice") {
            my scalar $args = $expr->{"args"};
            my int $argc = $expr->{"arg_count"};
            my int $sp_arr_cleanup = 0;
            if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $args->[0]) == 1) {
                $sp_arr_cleanup = 1;
            }
            my int $sp_repl_cleanup = 0;
            if ($argc >= 4 && $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $args->[3]) == 1) {
                $sp_repl_cleanup = 1;
            }
            # Multi-arg splice: `splice(@a, OFF, LEN, X, Y, Z)` — pack the
            # replacement values (args[3..]) into a temporary array so the
            # runtime sees the full list, not just args[3]. Previously
            # args[4]+ were silently dropped.
            my int $sp_multi_repl = 0;
            if ($argc > 4) { $sp_multi_repl = 1; }
            emit($cg, "({ ");
            if ($sp_arr_cleanup == 1) {
                emit($cg, "StradaValue *__sp_a = ");
                gen_expression($cg, $args->[0]);
                emit($cg, "; ");
            }
            if ($sp_multi_repl == 1) {
                emit($cg, "StradaValue *__sp_r = strada_new_array(); StradaArray *__sp_rv = strada_deref_array(__sp_r); ");
                my int $spi = 3;
                while ($spi < $argc) {
                    my scalar $rv = $args->[$spi];
                    if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $rv) == 1) {
                        emit($cg, "{ StradaValue *__sp_e = ");
                        gen_expression($cg, $rv);
                        emit($cg, "; strada_array_push(__sp_rv, __sp_e); strada_decref(__sp_e); } ");
                    } else {
                        emit($cg, "strada_array_push(__sp_rv, ");
                        gen_expression($cg, $rv);
                        emit($cg, "); ");
                    }
                    $spi = $spi + 1;
                }
            } elsif ($sp_repl_cleanup == 1) {
                emit($cg, "StradaValue *__sp_r = ");
                gen_expression($cg, $args->[3]);
                emit($cg, "; ");
            }
            emit($cg, "StradaValue *__sp_res = strada_array_splice_sv(");
            if ($sp_arr_cleanup == 1) {
                emit($cg, "__sp_a");
            } else {
                gen_expression($cg, $args->[0]);
            }
            emit($cg, ", ");
            if ($argc >= 2) {
                emit_int_operand($cg, $args->[1]);
            } else {
                emit($cg, "0");
            }
            emit($cg, ", ");
            if ($argc >= 3) {
                emit_int_operand($cg, $args->[2]);
            } else {
                # INT64_MAX is the "length omitted" sentinel — distinct
                # from negative length (Perl's "leave N at end" semantic).
                # `-1` here previously collided with that semantic so
                # `splice(@a, OFFSET)` removed only "size-1-OFFSET"
                # elements instead of all-to-end.
                emit($cg, "INT64_MAX");
            }
            emit($cg, ", ");
            if ($sp_multi_repl == 1 || $sp_repl_cleanup == 1) {
                emit($cg, "__sp_r");
            } elsif ($argc >= 4) {
                gen_expression($cg, $args->[3]);
            } else {
                emit($cg, "NULL");
            }
            emit($cg, "); ");
            if ($sp_arr_cleanup == 1) {
                emit($cg, "strada_decref(__sp_a); ");
            }
            if ($sp_multi_repl == 1 || $sp_repl_cleanup == 1) {
                emit($cg, "strada_decref(__sp_r); ");
            }
            emit($cg, "__sp_res; })");
            return 1;
        }

        # each(%hash) - returns [key, value] pair or empty array
        if ($name eq "each") {
            my scalar $args = $expr->{"args"};
            if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $args->[0]) == 1) {
                emit($cg, "({ StradaValue *__each_h = ");
                gen_expression($cg, $args->[0]);
                emit($cg, "; StradaValue *__each_r = strada_hash_each(strada_deref_hash(__each_h)); strada_decref(__each_h); __each_r; })");
            } else {
                emit($cg, "strada_hash_each(strada_deref_hash(");
                gen_expression($cg, $args->[0]);
                emit($cg, "))");
            }
            return 1;
        }

        # select() - get/set default filehandle
        if ($name eq "select") {
            my scalar $args = $expr->{"args"};
            my int $argc = $expr->{"arg_count"};
            if ($argc == 0) {
                emit($cg, "strada_select_get()");
            } else {
                if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $args->[0]) == 1) {
                    emit($cg, "({ StradaValue *__sel_tmp = ");
                    gen_expression($cg, $args->[0]);
                    emit($cg, "; StradaValue *__sel_r = strada_select(__sel_tmp); strada_decref(__sel_tmp); __sel_r; })");
                } else {
                    emit($cg, "strada_select(");
                    gen_expression($cg, $args->[0]);
                    emit($cg, ")");
                }
            }
            return 1;
        }

        # tie(%hash, "ClassName", @args)
        if ($name eq "tie") {
            my scalar $args = $expr->{"args"};
            my int $argc = $expr->{"arg_count"};
            # tie(%hash, "ClassName", @extra_args...)
            # strada_tie_hash(ref, const char *classname, int argc, ...)
            emit($cg, "strada_tie_hash(");
            gen_expression($cg, $args->[0]);
            emit($cg, ", ");
            # Class name must be a string literal for now. Route through the
            # escaper (NOT raw concat) — a `"`/`\`/newline in the literal would
            # otherwise close the C string and inject arbitrary C (CWE-94).
            if ($argc >= 2 && $args->[1]->{"type"} == NODE_STR_LITERAL()) {
                gen_str_literal_c($cg, $args->[1]->{"value"});
            } elsif ($argc >= 2) {
                emit($cg, "\"HASH\"");
            } else {
                emit($cg, "\"HASH\"");
            }
            # Pass remaining args count and values
            my int $extra = $argc - 2;
            if ($extra < 0) {
                $extra = 0;
            }
            emit($cg, ", " . $extra);
            my int $ai = 2;
            while ($ai < $argc) {
                emit($cg, ", ");
                gen_expression($cg, $args->[$ai]);
                $ai = $ai + 1;
            }
            emit($cg, ")");
            return 1;
        }

        # untie(%hash)
        if ($name eq "untie") {
            my scalar $args = $expr->{"args"};
            emit($cg, "(strada_untie(");
            gen_expression($cg, $args->[0]);
            emit($cg, "), strada_undef_static())");
            return 1;
        }

        # tied(%hash) - returns tied object or undef
        if ($name eq "tied") {
            my scalar $args = $expr->{"args"};
            emit($cg, "strada_tied(");
            gen_expression($cg, $args->[0]);
            emit($cg, ")");
            return 1;
        }

        if ($name eq "sort") {
            my scalar $args = $expr->{"args"};
            if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $args->[0]) == 1) {
                emit($cg, "({ StradaValue *__sort_a = ");
                gen_expression($cg, $args->[0]);
                emit($cg, "; StradaValue *__sort_r = strada_sort(__sort_a); strada_decref(__sort_a); __sort_r; })");
            } else {
                emit($cg, "strada_sort(");
                gen_expression($cg, $args->[0]);
                emit($cg, ")");
            }
            return 1;
        }

        if ($name eq "nsort") {
            my scalar $args = $expr->{"args"};
            if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $args->[0]) == 1) {
                emit($cg, "({ StradaValue *__nsort_a = ");
                gen_expression($cg, $args->[0]);
                emit($cg, "; StradaValue *__nsort_r = strada_nsort(__nsort_a); strada_decref(__nsort_a); __nsort_r; })");
            } else {
                emit($cg, "strada_nsort(");
                gen_expression($cg, $args->[0]);
                emit($cg, ")");
            }
            return 1;
        }

        if ($name eq "split") {
            # split(pattern, string[, limit]) - like Perl
            my scalar $args = $expr->{"args"};
            my scalar $pattern_arg = $args->[0];
            my scalar $string_arg = $args->[1];
            my int $pattern_needs_cleanup = needs_temp_cleanup($cg, $pattern_arg);
            my int $string_needs_cleanup = needs_temp_cleanup($cg, $string_arg);
            my int $argc_sp = 0;
            if (defined($args)) { $argc_sp = size(@{$args}); }
            my int $has_limit = 0;
            my scalar $limit_arg = $args->[0];
            if ($argc_sp >= 3) {
                $has_limit = 1;
                $limit_arg = $args->[2];
            }

            # Fast path: literal pattern with no regex metacharacters uses plain string split
            # (only when no LIMIT — the limit path goes through regex_split_limit).
            my int $is_literal_pat = 0;
            if ($has_limit == 0 && $pattern_arg->{"type"} == NODE_STR_LITERAL()) {
                my str $pat_val = $pattern_arg->{"value"};
                # Check for regex metacharacters — if none, safe for plain string split
                my int $has_meta = 0;
                my int $pi2 = 0;
                my int $plen = length($pat_val);
                while ($pi2 < $plen) {
                    my str $pc = substr($pat_val, $pi2, 1);
                    if ($pc eq "." || $pc eq "*" || $pc eq "?" ||
                        $pc eq "[" || $pc eq "]" || $pc eq "(" || $pc eq ")" ||
                        $pc eq "{" || $pc eq "}" || $pc eq "^" || $pc eq "$" ||
                        $pc eq "|" || $pc eq "\\") {
                        $has_meta = 1;
                    }
                    $pi2 = $pi2 + 1;
                }
                if ($has_meta == 0) {
                    $is_literal_pat = 1;
                }
            }

            emit($cg, "(({ ");
            if ($is_literal_pat == 1) {
                # Plain string split — avoid regex overhead
                emit($cg, "StradaValue *__split_str = ");
                gen_expression($cg, $string_arg);
                emit($cg, "; char *__str_cstr = strada_to_str_ss(__split_str); ");
                emit($cg, "StradaValue *__sv = strada_new_array_from_av(strada_string_split(__str_cstr, ");
                gen_str_literal_c($cg, $pattern_arg->{"value"});
                emit($cg, ")); strada_cstr_free(__str_cstr); ");
            } else {
                # Dynamic pattern — use regex split (with optional LIMIT)
                emit($cg, "StradaValue *__split_pat = ");
                gen_expression($cg, $pattern_arg);
                emit($cg, "; StradaValue *__split_str = ");
                gen_expression($cg, $string_arg);
                emit($cg, "; char *__pat_cstr = strada_to_str_ss(__split_pat); ");
                emit($cg, "char *__str_cstr = strada_to_str_ss(__split_str); ");
                if ($has_limit == 1) {
                    # If the limit arg is an owned temp (e.g. unary
                    # minus produces a heap-allocated num), capture and
                    # decref so it doesn't leak per call.
                    my int $lim_owned = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $limit_arg) == 1;
                    if ($lim_owned == 1) {
                        emit($cg, "StradaValue *__split_lim_sv = ");
                        gen_expression($cg, $limit_arg);
                        emit($cg, "; int __split_lim = (int)strada_to_int(__split_lim_sv); strada_decref(__split_lim_sv); ");
                    } else {
                        emit($cg, "int __split_lim = (int)strada_to_int(");
                        gen_expression($cg, $limit_arg);
                        emit($cg, "); ");
                    }
                    emit($cg, "StradaValue *__sv = strada_new_array_from_av(strada_regex_split_limit(__str_cstr, __pat_cstr, __split_lim)); ");
                } else {
                    emit($cg, "StradaValue *__sv = strada_new_array_from_av(strada_regex_split(__str_cstr, __pat_cstr)); ");
                }
                emit($cg, "strada_cstr_free(__pat_cstr); strada_cstr_free(__str_cstr); ");
                if ($pattern_needs_cleanup == 1) {
                    emit($cg, "strada_decref(__split_pat); ");
                }
            }
            if ($string_needs_cleanup == 1) {
                emit($cg, "strada_decref(__split_str); ");
            }
            emit($cg, "__sv; }))");
            return 1;
        }
        
        if ($name eq "join") {
            # join(separator, LIST). Two shapes: `join(",", @arr)` (the
            # 2-arg array case) and `join("|", "a", "b", "c")` (list of
            # scalars). Previously only the 2-arg case worked because
            # only args[1] was passed to strada_join, so the scalar form
            # produced an empty string.
            my scalar $args = $expr->{"args"};
            my int $argc = $expr->{"arg_count"};
            my scalar $sep_arg = $args->[0];
            my int $sep_needs_cleanup = needs_temp_cleanup($cg, $sep_arg);

            # Call strada_join_sv directly: it borrows plain-STR elements
            # (no per-element copy), builds straight into the result
            # StradaString, and takes the separator as an SV (no
            # stringify/copy of the separator). The old path went through
            # the char* strada_join + strada_new_str, copying the joined
            # result twice and every element once.
            emit($cg, "(({ ");
            emit($cg, "StradaValue *__join_sep = ");
            gen_expression($cg, $sep_arg);
            emit($cg, "; ");
            if ($argc == 2) {
                my int $arr_needs_cleanup = needs_temp_cleanup($cg, $args->[1]);
                if ($arr_needs_cleanup == 1) {
                    emit($cg, "StradaValue *__join_arr = ");
                    gen_expression($cg, $args->[1]);
                    emit($cg, "; StradaValue *__join_res = strada_join_sv(__join_sep, strada_deref_array(__join_arr)); ");
                } else {
                    emit($cg, "StradaValue *__join_res = strada_join_sv(__join_sep, strada_deref_array(");
                    gen_expression($cg, $args->[1]);
                    emit($cg, ")); ");
                }
                if ($sep_needs_cleanup == 1) {
                    emit($cg, "strada_decref(__join_sep); ");
                }
                if ($arr_needs_cleanup == 1) {
                    emit($cg, "strada_decref(__join_arr); ");
                }
            } else {
                # Build a temporary array of all the scalar elements.
                emit($cg, "StradaValue *__join_arr = strada_new_array(); StradaArray *__join_av = strada_deref_array(__join_arr); ");
                my int $ji = 1;
                while ($ji < $argc) {
                    my scalar $je = $args->[$ji];
                    if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $je) == 1) {
                        emit($cg, "{ StradaValue *__je = ");
                        gen_expression($cg, $je);
                        emit($cg, "; strada_array_push(__join_av, __je); strada_decref(__je); } ");
                    } else {
                        emit($cg, "strada_array_push(__join_av, ");
                        gen_expression($cg, $je);
                        emit($cg, "); ");
                    }
                    $ji = $ji + 1;
                }
                emit($cg, "StradaValue *__join_res = strada_join_sv(__join_sep, __join_av); ");
                emit($cg, "strada_decref(__join_arr); ");
                if ($sep_needs_cleanup == 1) {
                    emit($cg, "strada_decref(__join_sep); ");
                }
            }
            emit($cg, "__join_res; }))");
            return 1;
        }
        
        if ($name eq "keys") {
            my scalar $args = $expr->{"args"};
            if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $args->[0]) == 1) {
                emit($cg, "({ StradaValue *__keys_v = ");
                gen_expression($cg, $args->[0]);
                emit($cg, "; StradaValue *__keys_r = strada_new_array_from_av(strada_hash_keys(strada_deref_hash(__keys_v))); strada_decref(__keys_v); __keys_r; })");
            } else {
                emit($cg, "strada_new_array_from_av(strada_hash_keys(strada_deref_hash(");
                gen_expression($cg, $args->[0]);
                emit($cg, ")))");
            }
            return 1;
        }
        
        if ($name eq "values") {
            my scalar $args = $expr->{"args"};
            if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $args->[0]) == 1) {
                emit($cg, "({ StradaValue *__vals_v = ");
                gen_expression($cg, $args->[0]);
                emit($cg, "; StradaValue *__vals_r = strada_new_array_from_av(strada_hash_values(strada_deref_hash(__vals_v))); strada_decref(__vals_v); __vals_r; })");
            } else {
                emit($cg, "strada_new_array_from_av(strada_hash_values(strada_deref_hash(");
                gen_expression($cg, $args->[0]);
                emit($cg, ")))");
            }
            return 1;
        }
        
        if ($name eq "exists") {
            my scalar $args = $expr->{"args"};
            my scalar $arg0 = $args->[0];

            # `exists $arr[N]` — true iff the slot is in bounds AND has not
            # been removed by a prior `delete $arr[N]` (which sets the slot
            # to NULL as a tombstone).
            if ($expr->{"arg_count"} == 1 && $arg0->{"type"} == NODE_SUBSCRIPT()) {
                emit($cg, "({ StradaArray *__ex_av = strada_deref_array(");
                gen_expression($cg, $arg0->{"array"});
                emit($cg, "); int64_t __ex_idx = strada_to_int(");
                gen_expression($cg, $arg0->{"index"});
                emit($cg, "); strada_new_int(strada_array_exists_idx(__ex_av, __ex_idx)); })");
                return 1;
            }

            # Check if single arg is a hash access node
            if ($expr->{"arg_count"} == 1 && $arg0->{"type"} == NODE_HASH_ACCESS()) {
                my scalar $key_expr = $arg0->{"key"};
                my scalar $hash_expr = $arg0->{"hash"};
                my int $key_needs_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $key_expr) == 1;
                my int $hash_needs_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $hash_expr) == 1;
                emit($cg, "({ StradaValue *__ex_key = ");
                gen_expression($cg, $key_expr);
                emit($cg, "; ");
                if ($hash_needs_cleanup == 1) {
                    emit($cg, "StradaValue *__ex_h = ");
                    gen_expression($cg, $hash_expr);
                    emit($cg, "; int __ex_res = strada_hv_exists_sv(__ex_h, __ex_key); strada_decref(__ex_h); ");
                } else {
                    emit($cg, "int __ex_res = strada_hv_exists_sv(");
                    gen_expression($cg, $hash_expr);
                    emit($cg, ", __ex_key); ");
                }
                if ($key_needs_cleanup == 1) {
                    emit($cg, "strada_decref(__ex_key); ");
                }
                emit($cg, "strada_new_int(__ex_res); })");
            } elsif ($expr->{"arg_count"} == 1 && $arg0->{"type"} == NODE_DEREF_HASH()) {
                my scalar $key_expr = $arg0->{"key"};
                my scalar $ref_expr = $arg0->{"ref"};
                my int $key_needs_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $key_expr) == 1;
                my int $ref_needs_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $ref_expr) == 1;
                emit($cg, "({ StradaValue *__ex_key = ");
                gen_expression($cg, $key_expr);
                emit($cg, "; ");
                if ($ref_needs_cleanup == 1) {
                    emit($cg, "StradaValue *__ex_h = ");
                    gen_expression($cg, $ref_expr);
                    emit($cg, "; int __ex_res = strada_hv_exists_sv(__ex_h, __ex_key); strada_decref(__ex_h); ");
                } else {
                    emit($cg, "int __ex_res = strada_hv_exists_sv(");
                    gen_expression($cg, $ref_expr);
                    emit($cg, ", __ex_key); ");
                }
                if ($key_needs_cleanup == 1) {
                    emit($cg, "strada_decref(__ex_key); ");
                }
                emit($cg, "strada_new_int(__ex_res); })");
            } else {
                # Two arg form: exists(hash, key)
                my scalar $key_expr = $args->[1];
                my scalar $hash_expr = $args->[0];
                my int $key_needs_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $key_expr) == 1;
                my int $hash_needs_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $hash_expr) == 1;
                emit($cg, "({ StradaValue *__ex_key = ");
                gen_expression($cg, $key_expr);
                emit($cg, "; ");
                if ($hash_needs_cleanup == 1) {
                    emit($cg, "StradaValue *__ex_h = ");
                    gen_expression($cg, $hash_expr);
                    emit($cg, "; int __ex_res = strada_hv_exists_sv(__ex_h, __ex_key); strada_decref(__ex_h); ");
                } else {
                    emit($cg, "int __ex_res = strada_hv_exists_sv(");
                    gen_expression($cg, $hash_expr);
                    emit($cg, ", __ex_key); ");
                }
                if ($key_needs_cleanup == 1) {
                    emit($cg, "strada_decref(__ex_key); ");
                }
                emit($cg, "strada_new_int(__ex_res); })");
            }
            return 1;
        }
    return 0;
}

func gen_builtin_g2(scalar $cg, scalar $expr, str $name) int {
        
        if ($name eq "delete") {
            my scalar $args = $expr->{"args"};
            my scalar $arg0 = $args->[0];

            # `delete $arr[N]` — return the deleted value (with incref so
            # caller owns it), mark slot as a tombstone, and shrink if the
            # deletion is at the tail. Without this branch, delete on an
            # array element fell through to the hash-delete path and
            # produced invalid C (`__del_key = ;`).
            if ($expr->{"arg_count"} == 1 && $arg0->{"type"} == NODE_SUBSCRIPT()) {
                emit($cg, "({ StradaArray *__del_av = strada_deref_array(");
                gen_expression($cg, $arg0->{"array"});
                emit($cg, "); int64_t __del_idx = strada_to_int(");
                gen_expression($cg, $arg0->{"index"});
                emit($cg, "); strada_array_delete_idx(__del_av, __del_idx); })");
                return 1;
            }

            # Check if single arg is a hash access node
            if ($expr->{"arg_count"} == 1 && $arg0->{"type"} == NODE_HASH_ACCESS()) {
                my scalar $key_expr = $arg0->{"key"};
                if (is_concat_str_literal_left($key_expr) == 1) {
                    # Concat key "prefix" . $expr - zero-alloc stack buffer
                    my scalar $concat_right = $key_expr->{"right"};
                    my int $right_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $concat_right) == 1;
                    my str $prefix_val = $key_expr->{"left"}->{"value"};
                    my int $prefix_len = bytes($prefix_val);
                    if ($right_cleanup == 1) {
                        emit($cg, "({ StradaValue *__ck_r = ");
                        gen_expression($cg, $concat_right);
                        emit($cg, "; strada_hv_delete_concat(");
                        gen_expression($cg, $arg0->{"hash"});
                        emit($cg, ", ");
                        gen_str_literal_c($cg, $prefix_val);
                        emit($cg, ", " . $prefix_len . ", __ck_r); strada_decref(__ck_r); strada_undef_static(); })");
                    } else {
                        emit($cg, "({ strada_hv_delete_concat(");
                        gen_expression($cg, $arg0->{"hash"});
                        emit($cg, ", ");
                        gen_str_literal_c($cg, $prefix_val);
                        emit($cg, ", " . $prefix_len . ", ");
                        gen_expression($cg, $concat_right);
                        emit($cg, "); strada_undef_static(); })");
                    }
                } else {
                    my int $key_needs_cleanup = needs_temp_cleanup($cg, $key_expr);
                    my scalar $hash_expr = $arg0->{"hash"};
                    my int $hash_needs_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $hash_expr) == 1;
                    emit($cg, "({ StradaValue *__del_key = ");
                    gen_expression($cg, $key_expr);
                    emit($cg, "; ");
                    if ($hash_needs_cleanup == 1) {
                        emit($cg, "StradaValue *__del_h = ");
                        gen_expression($cg, $hash_expr);
                        emit($cg, "; StradaValue *__del_v = strada_hv_delete_take_sv(__del_h, __del_key); strada_decref(__del_h); ");
                    } else {
                        emit($cg, "StradaValue *__del_v = strada_hv_delete_take_sv((");
                        gen_expression($cg, $hash_expr);
                        emit($cg, "), __del_key); ");
                    }
                    if ($key_needs_cleanup == 1) {
                        emit($cg, "strada_decref(__del_key); ");
                    }
                    emit($cg, "__del_v; })");
                }
            } elsif ($expr->{"arg_count"} == 1 && $arg0->{"type"} == NODE_DEREF_HASH()) {
                my scalar $key_expr = $arg0->{"key"};
                if (is_concat_str_literal_left($key_expr) == 1) {
                    # Concat key "prefix" . $expr - zero-alloc stack buffer
                    my scalar $concat_right = $key_expr->{"right"};
                    my int $right_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $concat_right) == 1;
                    my str $prefix_val = $key_expr->{"left"}->{"value"};
                    my int $prefix_len = bytes($prefix_val);
                    if ($right_cleanup == 1) {
                        emit($cg, "({ StradaValue *__ck_r = ");
                        gen_expression($cg, $concat_right);
                        emit($cg, "; strada_hv_delete_concat(");
                        gen_expression($cg, $arg0->{"ref"});
                        emit($cg, ", ");
                        gen_str_literal_c($cg, $prefix_val);
                        emit($cg, ", " . $prefix_len . ", __ck_r); strada_decref(__ck_r); strada_undef_static(); })");
                    } else {
                        emit($cg, "({ strada_hv_delete_concat(");
                        gen_expression($cg, $arg0->{"ref"});
                        emit($cg, ", ");
                        gen_str_literal_c($cg, $prefix_val);
                        emit($cg, ", " . $prefix_len . ", ");
                        gen_expression($cg, $concat_right);
                        emit($cg, "); strada_undef_static(); })");
                    }
                } else {
                    my int $key_needs_cleanup = needs_temp_cleanup($cg, $key_expr);
                    my scalar $ref_expr = $arg0->{"ref"};
                    my int $ref_needs_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $ref_expr) == 1;
                    emit($cg, "({ StradaValue *__del_key = ");
                    gen_expression($cg, $key_expr);
                    emit($cg, "; ");
                    if ($ref_needs_cleanup == 1) {
                        emit($cg, "StradaValue *__del_h = ");
                        gen_expression($cg, $ref_expr);
                        emit($cg, "; StradaValue *__del_v = strada_hv_delete_take_sv(__del_h, __del_key); strada_decref(__del_h); ");
                    } else {
                        emit($cg, "StradaValue *__del_v = strada_hv_delete_take_sv((");
                        gen_expression($cg, $ref_expr);
                        emit($cg, "), __del_key); ");
                    }
                    if ($key_needs_cleanup == 1) {
                        emit($cg, "strada_decref(__del_key); ");
                    }
                    emit($cg, "__del_v; })");
                }
            } else {
