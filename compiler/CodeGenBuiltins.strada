        if ($name eq "sys::B2000000") { emit($cg, "strada_new_int(B2000000)"); return 1; }

        # Termios control mode flags (c_cflag)
        if ($name eq "sys::CSIZE") { emit($cg, "strada_new_int(CSIZE)"); return 1; }
        if ($name eq "sys::CS5") { emit($cg, "strada_new_int(CS5)"); return 1; }
        if ($name eq "sys::CS6") { emit($cg, "strada_new_int(CS6)"); return 1; }
        if ($name eq "sys::CS7") { emit($cg, "strada_new_int(CS7)"); return 1; }
        if ($name eq "sys::CS8") { emit($cg, "strada_new_int(CS8)"); return 1; }
        if ($name eq "sys::CSTOPB") { emit($cg, "strada_new_int(CSTOPB)"); return 1; }
        if ($name eq "sys::CREAD") { emit($cg, "strada_new_int(CREAD)"); return 1; }
        if ($name eq "sys::PARENB") { emit($cg, "strada_new_int(PARENB)"); return 1; }
        if ($name eq "sys::PARODD") { emit($cg, "strada_new_int(PARODD)"); return 1; }
        if ($name eq "sys::HUPCL") { emit($cg, "strada_new_int(HUPCL)"); return 1; }
        if ($name eq "sys::CLOCAL") { emit($cg, "strada_new_int(CLOCAL)"); return 1; }
        if ($name eq "sys::CRTSCTS") { emit($cg, "strada_new_int(CRTSCTS)"); return 1; }

        # Termios input mode flags (c_iflag)
        if ($name eq "sys::IGNBRK") { emit($cg, "strada_new_int(IGNBRK)"); return 1; }
        if ($name eq "sys::BRKINT") { emit($cg, "strada_new_int(BRKINT)"); return 1; }
        if ($name eq "sys::IGNPAR") { emit($cg, "strada_new_int(IGNPAR)"); return 1; }
        if ($name eq "sys::PARMRK") { emit($cg, "strada_new_int(PARMRK)"); return 1; }
        if ($name eq "sys::INPCK") { emit($cg, "strada_new_int(INPCK)"); return 1; }
        if ($name eq "sys::ISTRIP") { emit($cg, "strada_new_int(ISTRIP)"); return 1; }
        if ($name eq "sys::INLCR") { emit($cg, "strada_new_int(INLCR)"); return 1; }
        if ($name eq "sys::IGNCR") { emit($cg, "strada_new_int(IGNCR)"); return 1; }
        if ($name eq "sys::ICRNL") { emit($cg, "strada_new_int(ICRNL)"); return 1; }
        if ($name eq "sys::IXON") { emit($cg, "strada_new_int(IXON)"); return 1; }
        if ($name eq "sys::IXOFF") { emit($cg, "strada_new_int(IXOFF)"); return 1; }
        if ($name eq "sys::IXANY") { emit($cg, "strada_new_int(IXANY)"); return 1; }

        # Termios output mode flags (c_oflag)
        if ($name eq "sys::OPOST") { emit($cg, "strada_new_int(OPOST)"); return 1; }
        if ($name eq "sys::ONLCR") { emit($cg, "strada_new_int(ONLCR)"); return 1; }
        if ($name eq "sys::OCRNL") { emit($cg, "strada_new_int(OCRNL)"); return 1; }

        # Termios local mode flags (c_lflag)
        if ($name eq "sys::ISIG") { emit($cg, "strada_new_int(ISIG)"); return 1; }
        if ($name eq "sys::ICANON") { emit($cg, "strada_new_int(ICANON)"); return 1; }
        if ($name eq "sys::ECHO") { emit($cg, "strada_new_int(ECHO)"); return 1; }
        if ($name eq "sys::ECHOE") { emit($cg, "strada_new_int(ECHOE)"); return 1; }
        if ($name eq "sys::ECHOK") { emit($cg, "strada_new_int(ECHOK)"); return 1; }
        if ($name eq "sys::ECHONL") { emit($cg, "strada_new_int(ECHONL)"); return 1; }
        if ($name eq "sys::NOFLSH") { emit($cg, "strada_new_int(NOFLSH)"); return 1; }
        if ($name eq "sys::TOSTOP") { emit($cg, "strada_new_int(TOSTOP)"); return 1; }
        if ($name eq "sys::IEXTEN") { emit($cg, "strada_new_int(IEXTEN)"); return 1; }

        # tcsetattr when values
        if ($name eq "sys::TCSANOW") { emit($cg, "strada_new_int(TCSANOW)"); return 1; }
        if ($name eq "sys::TCSADRAIN") { emit($cg, "strada_new_int(TCSADRAIN)"); return 1; }
        if ($name eq "sys::TCSAFLUSH") { emit($cg, "strada_new_int(TCSAFLUSH)"); return 1; }

        # tcflush queue selectors
        if ($name eq "sys::TCIFLUSH") { emit($cg, "strada_new_int(TCIFLUSH)"); return 1; }
        if ($name eq "sys::TCOFLUSH") { emit($cg, "strada_new_int(TCOFLUSH)"); return 1; }
        if ($name eq "sys::TCIOFLUSH") { emit($cg, "strada_new_int(TCIOFLUSH)"); return 1; }

        # File open flags (for low-level open)
        if ($name eq "sys::O_RDONLY") { emit($cg, "strada_new_int(O_RDONLY)"); return 1; }
        if ($name eq "sys::O_WRONLY") { emit($cg, "strada_new_int(O_WRONLY)"); return 1; }
        if ($name eq "sys::O_RDWR") { emit($cg, "strada_new_int(O_RDWR)"); return 1; }
        if ($name eq "sys::O_CREAT") { emit($cg, "strada_new_int(O_CREAT)"); return 1; }
        if ($name eq "sys::O_EXCL") { emit($cg, "strada_new_int(O_EXCL)"); return 1; }
        if ($name eq "sys::O_NOCTTY") { emit($cg, "strada_new_int(O_NOCTTY)"); return 1; }
        if ($name eq "sys::O_TRUNC") { emit($cg, "strada_new_int(O_TRUNC)"); return 1; }
        if ($name eq "sys::O_APPEND") { emit($cg, "strada_new_int(O_APPEND)"); return 1; }
        if ($name eq "sys::O_NONBLOCK") { emit($cg, "strada_new_int(O_NONBLOCK)"); return 1; }
        if ($name eq "sys::O_SYNC") { emit($cg, "strada_new_int(O_SYNC)"); return 1; }

        # Advanced file operations
        if ($name eq "sys::fcntl") {
            emit($cg, "strada_fcntl(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ", ");
            gen_expression($cg, $args->[1]);
            emit($cg, ", ");
            if ($expr->{"arg_count"} > 2) {
                gen_expression($cg, $args->[2]);
            } else {
                emit($cg, "NULL");
            }
            emit($cg, ")");
            return 1;
        }

        if ($name eq "sys::flock") {
            emit($cg, "strada_flock(");
            my scalar $args = $expr->{"args"};
            gen_expression($cg, $args->[0]);
            emit($cg, ", ");
            gen_expression($cg, $args->[1]);
            emit($cg, ")");
            return 1;
        }

        if ($name eq "sys::quotemeta") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_quotemeta", $args, 1);
            return 1;
        }

        if ($name eq "sys::ioctl") {
            my scalar $args = $expr->{"args"};
            if ($expr->{"arg_count"} > 2) {
                gen_call_with_arg_cleanup($cg, "strada_ioctl", $args, 3);
            } else {
                gen_call_with_arg_cleanup($cg, "strada_ioctl", $args, 2);
            }
            return 1;
        }

        if ($name eq "sys::statvfs") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_statvfs", $args, 1);
            return 1;
        }

        if ($name eq "sys::fstatvfs") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_fstatvfs", $args, 1);
            return 1;
        }

        if ($name eq "sys::dup") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_dup", $args, 1);
            return 1;
        }

        # Additional math functions
        if ($name eq "math::hypot") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_hypot", $args, 2);
            return 1;
        }

        if ($name eq "math::cbrt") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_cbrt", $args, 1);
            return 1;
        }

        if ($name eq "math::isnan") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_isnan", $args, 1);
            return 1;
        }

        if ($name eq "math::isinf") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_isinf", $args, 1);
            return 1;
        }

        if ($name eq "math::isfinite") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_isfinite", $args, 1);
            return 1;
        }

        if ($name eq "math::fmax") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_fmax", $args, 2);
            return 1;
        }

        if ($name eq "math::fmin") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_fmin", $args, 2);
            return 1;
        }

        if ($name eq "math::copysign") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_copysign", $args, 2);
            return 1;
        }

        if ($name eq "math::remainder") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_remainder", $args, 2);
            return 1;
        }

        if ($name eq "math::trunc") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_trunc", $args, 1);
            return 1;
        }

        if ($name eq "math::ldexp") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_ldexp", $args, 2);
            return 1;
        }

        if ($name eq "math::frexp") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_frexp", $args, 1);
            return 1;
        }

        if ($name eq "math::modf") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_modf", $args, 1);
            return 1;
        }

        if ($name eq "math::scalbn") {
            my scalar $args = $expr->{"args"};
            gen_call_with_arg_cleanup($cg, "strada_scalbn", $args, 2);
            return 1;
        }
    return 0;
}

func gen_user_call(scalar $cg, scalar $expr, str $name) void {

        # User-defined function - check for default parameters
        my str $c_name = sanitize_name($name);
        my scalar $func_info = $cg->{"functions"}->{$c_name};
        my scalar $args = $expr->{"args"};
        my int $arg_count = $expr->{"arg_count"};

        # If function not found, try package-prefixed name when in a package
        my int $func_ret_type = $func_info->{"return_type"};
        my int $func_is_extern = $func_info->{"is_extern"};
        my int $func_found = 0;
        if ($func_ret_type > 0) {
            $func_found = 1;
        }
        if ($func_is_extern == 1) {
            $func_found = 1;
        }
        if ($func_found == 0) {
            my str $fn_pkg = $cg->{"current_fn_package"};
            my int $has_colon = index($name, "::");
            if (length($fn_pkg) > 0 && $fn_pkg ne "main" && $has_colon < 0) {
                # Convert :: to _ in package name
                my str $c_pkg = $fn_pkg;
                my int $ci = index($c_pkg, "::");
                while ($ci >= 0) {
                    $c_pkg = substr($c_pkg, 0, $ci) . "_" . substr($c_pkg, $ci + 2, length($c_pkg) - $ci - 2);
                    $ci = index($c_pkg, "::");
                }
                # Try package-prefixed name
                my str $prefixed_name = $c_pkg . "_" . $c_name;
                my scalar $fn_info_pkg = $cg->{"functions"}->{$prefixed_name};
                my int $pkg_ret = $fn_info_pkg->{"return_type"};
                my int $pkg_is_extern = $fn_info_pkg->{"is_extern"};
                if ($pkg_ret > 0 || $pkg_is_extern == 1) {
                    $c_name = $prefixed_name;
                    $func_info = $fn_info_pkg;
                }
            }
        }

        # Separate compilation (module-only / -M): a call to a function neither
        # defined nor declared in this translation unit is a legitimate cross-module
        # or stdlib reference that the final link resolves. Record its mangled name
        # so get_output() emits `extern StradaValue* name();` — otherwise C assumes
        # `int name()` and truncates the returned 64-bit StradaValue* pointer.
        if ($cg->{"module_only_mode"} == 1) {
            # NB: no `//` defined-or here — the frozen bootstrap can't parse it
            # (it appears nowhere else in compiler/*.strada). Default with
            # explicit defined() checks instead.
            my int $is_known = 0;
            if (defined($func_info)) {
                my int $ak_rt = 0;
                if (defined($func_info->{"return_type"})) { $ak_rt = $func_info->{"return_type"}; }
                my int $ak_ext = 0;
                if (defined($func_info->{"is_extern"})) { $ak_ext = $func_info->{"is_extern"}; }
                if ($ak_rt > 0 || $ak_ext == 1) { $is_known = 1; }
            }
            if ($is_known == 0 && length($c_name) > 0) {
                $cg->{"auto_externs"}->{$c_name} = 1;
            }
        }

        # Handle extern function calls - convert between StradaValue* and raw C types
        if ($func_info && $func_info->{"is_extern"} == 1) {
            my int $ret_type = $func_info->{"return_type"};
            my int $param_count = $func_info->{"param_count"};
            my scalar $params = $func_info->{"params"};
            my int $is_c_extern = $func_info->{"is_c_extern"};

            # Generate block for extern call with conversion
            emit($cg, "({ ");

            # Create temps for args and convert from StradaValue* to raw C types
            my int $t = 0;
            while ($t < $arg_count) {
                my int $param_type = TYPE_SCALAR();
                if ($t < $param_count) {
                    $param_type = $params->[$t]->{"param_type"};
                }
                emit($cg, "StradaValue *__sv_arg" . $t . " = ");
                gen_expression($cg, $args->[$t]);
                emit($cg, "; ");
                $t = $t + 1;
            }

            # Pre-convert string arguments to char* (non-c_extern only)
            if ($is_c_extern == 0) {
                my int $s = 0;
                while ($s < $arg_count) {
                    my int $spt = TYPE_SCALAR();
                    if ($s < $param_count) {
                        $spt = $params->[$s]->{"param_type"};
                    }
                    if ($spt == TYPE_STR() || ($spt != TYPE_INT() && $spt != TYPE_BOOL() && $spt != TYPE_INT32() && $spt != TYPE_INT64() && $spt != TYPE_NUM() && $spt != TYPE_FLOAT64() && $spt != TYPE_FLOAT32())) {
                        emit($cg, "char *__str_arg" . $s . " = strada_to_str_ss(__sv_arg" . $s . "); ");
                    }
                    $s = $s + 1;
                }
            }

            # Call the extern function with converted args
            if ($ret_type == TYPE_VOID()) {
                emit($cg, $c_name . "(");
            } elsif ($ret_type == TYPE_STR()) {
                emit($cg, "char *__ext_ret = " . $c_name . "(");
            } elsif ($ret_type == TYPE_INT()) {
                emit($cg, "int __ext_ret = " . $c_name . "(");
            } elsif ($ret_type == TYPE_BOOL()) {
                emit($cg, "bool __ext_ret = " . $c_name . "(");
            } elsif ($ret_type == TYPE_NUM()) {
                emit($cg, "double __ext_ret = " . $c_name . "(");
            } elsif ($ret_type == TYPE_INT32()) {
                emit($cg, "int32_t __ext_ret = " . $c_name . "(");
            } elsif ($ret_type == TYPE_INT64()) {
                emit($cg, "int64_t __ext_ret = " . $c_name . "(");
            } elsif ($ret_type == TYPE_FLOAT32()) {
                emit($cg, "float __ext_ret = " . $c_name . "(");
            } elsif ($ret_type == TYPE_FLOAT64()) {
                emit($cg, "double __ext_ret = " . $c_name . "(");
            } else {
                emit($cg, "void *__ext_ret = " . $c_name . "(");
            }

            # Pass converted arguments
            my int $a = 0;
            while ($a < $arg_count) {
                if ($a > 0) {
                    emit($cg, ", ");
                }
                my int $param_type = TYPE_SCALAR();
                if ($a < $param_count) {
                    $param_type = $params->[$a]->{"param_type"};
                }

                # For c_extern, use direct conversions without allocation
                if ($is_c_extern == 1) {
                    if ($param_type == TYPE_STR()) {
                        # For c_extern, str is already a char* pointer stored as int
                        emit($cg, "(char*)strada_to_int(__sv_arg" . $a . ")");
                    } elsif ($param_type == TYPE_INT() || $param_type == TYPE_BOOL()) {
                        emit($cg, "(int)strada_to_int(__sv_arg" . $a . ")");
                    } elsif ($param_type == TYPE_INT32()) {
                        emit($cg, "(int32_t)strada_to_int(__sv_arg" . $a . ")");
                    } elsif ($param_type == TYPE_INT64()) {
                        emit($cg, "strada_to_int(__sv_arg" . $a . ")");
                    } elsif ($param_type == TYPE_UINT8()) {
                        emit($cg, "(uint8_t)strada_to_int(__sv_arg" . $a . ")");
                    } elsif ($param_type == TYPE_UINT16()) {
                        emit($cg, "(uint16_t)strada_to_int(__sv_arg" . $a . ")");
                    } elsif ($param_type == TYPE_UINT32()) {
                        emit($cg, "(uint32_t)strada_to_int(__sv_arg" . $a . ")");
                    } elsif ($param_type == TYPE_UINT64()) {
                        emit($cg, "(uint64_t)strada_to_int(__sv_arg" . $a . ")");
                    } elsif ($param_type == TYPE_SIZE_T()) {
                        emit($cg, "(size_t)strada_to_int(__sv_arg" . $a . ")");
                    } elsif ($param_type == TYPE_CHAR()) {
                        emit($cg, "(char)strada_to_int(__sv_arg" . $a . ")");
                    } elsif ($param_type == TYPE_NUM() || $param_type == TYPE_FLOAT64()) {
                        emit($cg, "strada_to_num(__sv_arg" . $a . ")");
                    } elsif ($param_type == TYPE_FLOAT32()) {
                        emit($cg, "(float)strada_to_num(__sv_arg" . $a . ")");
                    } elsif ($param_type == TYPE_LONG_DOUBLE()) {
                        emit($cg, "(long double)strada_to_num(__sv_arg" . $a . ")");
                    } else {
                        emit($cg, "(void*)strada_to_int(__sv_arg" . $a . ")");
                    }
                } else {
                    # Traditional extern - uses pre-converted __str_argN
                    if ($param_type == TYPE_STR()) {
                        emit($cg, "__str_arg" . $a);
                    } elsif ($param_type == TYPE_INT() || $param_type == TYPE_BOOL()) {
                        emit($cg, "(int)strada_to_int(__sv_arg" . $a . ")");
                    } elsif ($param_type == TYPE_INT32()) {
                        emit($cg, "(int32_t)strada_to_int(__sv_arg" . $a . ")");
                    } elsif ($param_type == TYPE_INT64()) {
                        emit($cg, "strada_to_int(__sv_arg" . $a . ")");
                    } elsif ($param_type == TYPE_NUM() || $param_type == TYPE_FLOAT64()) {
                        emit($cg, "strada_to_num(__sv_arg" . $a . ")");
                    } elsif ($param_type == TYPE_FLOAT32()) {
                        emit($cg, "(float)strada_to_num(__sv_arg" . $a . ")");
                    } else {
                        emit($cg, "__str_arg" . $a);
                    }
                }
                $a = $a + 1;
            }
            emit($cg, "); ");

            # Free pre-converted string arguments (non-c_extern only)
            if ($is_c_extern == 0) {
                my int $f = 0;
                while ($f < $arg_count) {
                    my int $fpt = TYPE_SCALAR();
                    if ($f < $param_count) {
                        $fpt = $params->[$f]->{"param_type"};
                    }
                    if ($fpt == TYPE_STR() || ($fpt != TYPE_INT() && $fpt != TYPE_BOOL() && $fpt != TYPE_INT32() && $fpt != TYPE_INT64() && $fpt != TYPE_NUM() && $fpt != TYPE_FLOAT64() && $fpt != TYPE_FLOAT32())) {
                        emit($cg, "strada_cstr_free(__str_arg" . $f . "); ");
                    }
                    $f = $f + 1;
                }
            }

            # Decref the temp StradaValue args (skip for c_extern - no allocations)
            if ($is_c_extern == 0) {
                my int $d = 0;
                while ($d < $arg_count) {
                    if (needs_temp_cleanup($cg, $args->[$d]) == 1) {
                        emit($cg, "strada_decref(__sv_arg" . $d . "); ");
                    }
                    $d = $d + 1;
                }
            }

            # Convert return value back to StradaValue*
            if ($ret_type == TYPE_VOID()) {
                emit($cg, "strada_new_undef(); })");
            } elsif ($ret_type == TYPE_STR()) {
                if ($is_c_extern == 1) {
                    # For c_extern, store the char* as an int64
                    emit($cg, "strada_new_int((int64_t)__ext_ret); })");
                } else {
                    emit($cg, "strada_new_str(__ext_ret); })");
                }
            } elsif ($ret_type == TYPE_INT() || $ret_type == TYPE_BOOL() || $ret_type == TYPE_INT32() || $ret_type == TYPE_INT64()) {
                emit($cg, "strada_new_int(__ext_ret); })");
            } elsif ($ret_type == TYPE_UINT8() || $ret_type == TYPE_UINT16() || $ret_type == TYPE_UINT32() || $ret_type == TYPE_UINT64() || $ret_type == TYPE_SIZE_T() || $ret_type == TYPE_CHAR()) {
                emit($cg, "strada_new_int(__ext_ret); })");
            } elsif ($ret_type == TYPE_NUM() || $ret_type == TYPE_FLOAT32() || $ret_type == TYPE_FLOAT64() || $ret_type == TYPE_LONG_DOUBLE()) {
                emit($cg, "strada_new_num(__ext_ret); })");
            } else {
                emit($cg, "strada_new_undef(); })");
            }
            return;
        }

        # Check if this is a variadic function call or if any arg has spread
        my int $is_variadic_call = 0;
        my int $variadic_param_idx = -1;
        my int $has_spread = 0;

        # Check for spread in arguments
        for (my int $sa = 0; $sa < $arg_count; $sa = $sa + 1) {
            if ($args->[$sa]->{"type"} == NODE_SPREAD()) {
                $has_spread = 1;
            }
        }

        # Check if function is variadic
        if ($func_info) {
            if ($func_info->{"is_variadic"} == 1) {
                $is_variadic_call = 1;
                $variadic_param_idx = $func_info->{"variadic_param_idx"};
            }
        }

        # Check if function returns dynamic (context-sensitive)
        my int $is_dynamic_call = 0;
        if ($func_info) {
            if ($func_info->{"return_type"} == TYPE_DYNAMIC()) {
                $is_dynamic_call = 1;
            }
        }
        my int $dyn_ctx = $cg->{"call_context"} + 0;

        # Inline constructor optimization: Pkg::new("key", val, "key", val, ...)
        # When all odd-position args are string literals, emit direct hash construction
        # Skip inline constructor for user-defined constructors:
        # - variadic (no-parens) = always user-defined body
        # - explicit params with named args (not Moose key-value pattern)
        my int $ctor_is_user_defined = 0;
        if ($func_info && $func_info->{"is_variadic"} == 1) {
            $ctor_is_user_defined = 1;
        }
        if ($func_info && $func_info->{"param_count"} > 1) {
            $ctor_is_user_defined = 1;
        }
        # Auto-generated has constructors are variadic but should still be inlined
        # Check if the package has has_attrs — if so, the constructor is auto-generated
        if ($ctor_is_user_defined == 1) {
            my int $cnl2 = length($c_name);
            if ($cnl2 > 4 && substr($c_name, $cnl2 - 4, 4) eq "_new") {
                my str $check_pkg2 = substr($c_name, 0, $cnl2 - 4);
                my scalar $ha2 = $cg->{"has_attrs"};
                my int $hac2 = $cg->{"has_attr_count"};
                my int $hai2 = 0;
                while ($hai2 < $hac2) {
                    my str $ha_pkg = $ha2->[$hai2]->{"package"};
                    my int $hp_col = index($ha_pkg, "::");
                    while ($hp_col >= 0) {
                        $ha_pkg = substr($ha_pkg, 0, $hp_col) . "_" . substr($ha_pkg, $hp_col + 2, length($ha_pkg) - $hp_col - 2);
                        $hp_col = index($ha_pkg, "::");
                    }
                    if ($ha_pkg eq $check_pkg2) {
                        $ctor_is_user_defined = 0;
                    }
                    $hai2 = $hai2 + 1;
                }
            }
        }
        if ($ctor_is_user_defined == 0 && $has_spread == 0 && $arg_count >= 2) {
            # Check if this is a ::new call with alternating literal keys
            my int $cnl = length($c_name);
            my int $is_ctor = 0;
            if ($cnl > 4) {
                my str $cn_suffix = substr($c_name, $cnl - 4, 4);
                if ($cn_suffix eq "_new") { $is_ctor = 1; }
            }
            # Only inline for classes without inheritance (simple case)
            my int $has_parents = 0;
            if ($is_ctor == 1) {
                my str $ctor_pkg = substr($c_name, 0, $cnl - 4);
                my scalar $inh_list = $cg->{"inherits"};
                my int $inh_ct = $cg->{"inherit_count"};
                my int $ii = 0;
                while ($ii < $inh_ct) {
                    my str $child = $inh_list->[$ii]->{"child"};
                    my int $ci2 = index($child, "::");
                    while ($ci2 >= 0) {
                        $child = substr($child, 0, $ci2) . "_" . substr($child, $ci2 + 2, length($child) - $ci2 - 2);
                        $ci2 = index($child, "::");
                    }
                    if ($child eq $ctor_pkg) { $has_parents = 1; }
                    $ii = $ii + 1;
                }
            }
            if ($is_ctor == 1 && $arg_count >= 2) {
                my int $all_lit_keys = 1;
                my int $ki = 0;
                while ($ki < $arg_count) {
                    if ($args->[$ki]->{"type"} != NODE_STR_LITERAL()) {
                        $all_lit_keys = 0;
                    }
                    $ki = $ki + 2;
                }
                if ($all_lit_keys == 1) {
                    # Inline constructor: create hash, set entries directly, bless
                    my str $pkg_name = substr($c_name, 0, $cnl - 4);

                    # Build package chain for inherited defaults
                    my array @pkg_chain = ();
                    push(@pkg_chain, $pkg_name);
                    my int $pc_len = 1;
                    if ($has_parents == 1) {
                        my scalar $inh_list2 = $cg->{"inherits"};
                        my int $inh_ct2 = $cg->{"inherit_count"};
                        my int $pci = 0;
                        while ($pci < $pc_len) {
                            my str $check_pkg = $pkg_chain[$pci];
                            my int $pi = 0;
                            while ($pi < $inh_ct2) {
                                my str $ichild = $inh_list2->[$pi]->{"child"};
                                my int $ci3 = index($ichild, "::");
                                while ($ci3 >= 0) {
                                    $ichild = substr($ichild, 0, $ci3) . "_" . substr($ichild, $ci3 + 2, length($ichild) - $ci3 - 2);
                                    $ci3 = index($ichild, "::");
                                }
                                if ($ichild eq $check_pkg) {
                                    my str $iparent = $inh_list2->[$pi]->{"parent"};
                                    my int $ci4 = index($iparent, "::");
                                    while ($ci4 >= 0) {
                                        $iparent = substr($iparent, 0, $ci4) . "_" . substr($iparent, $ci4 + 2, length($iparent) - $ci4 - 2);
                                        $ci4 = index($iparent, "::");
                                    }
                                    push(@pkg_chain, $iparent);
                                    $pc_len = $pc_len + 1;
                                }
                                $pi = $pi + 1;
                            }
                            $pci = $pci + 1;
                        }
                    }

                    # Fused-ctor fast path: replace the 5-call inline sequence
                    # (new_hash + ref_create + bless + N hash_set) with one
                    # runtime call (strada_new_blessed_Nattr_take). Only fires
                    # when:
                    #   - 2 or 3 explicit attrs
                    #   - all values are int-typed (tagged ints, no refcount
                    #     concerns; eliminates the v_owned branch)
                    #   - all has-attrs in chain are explicitly set (no
                    #     defaults to apply)
                    #   - we're outside any try frame (so no need to
                    #     cleanup_push the partial object)
                    # The fused fn keeps hash buckets in registers across the
                    # 2-3 direct inserts, dropping ~25ns per object on hot
                    # OOP loops vs the 5 separate calls.
                    if (($arg_count == 4 || $arg_count == 6) && cleanup_push_useful($cg) == 0) {
                        my int $all_int_vals = 1;
                        my int $fvi = 1;
                        while ($fvi < $arg_count) {
                            if (expr_is_int_typed($cg, $args->[$fvi]) != 1) {
                                $all_int_vals = 0;
                                last;
                            }
                            $fvi = $fvi + 2;
                        }
                        # Check no defaults need application: every has-attr
                        # in the chain must either have no default OR be set
                        # explicitly in args.
                        my int $no_defaults = 1;
                        my scalar $ha_attrs3 = $cg->{"has_attrs"};
                        my int $ha_count3 = $cg->{"has_attr_count"};
                        my int $da3 = 0;
                        while ($da3 < $ha_count3 && $no_defaults == 1) {
                            my scalar $dattr3 = $ha_attrs3->[$da3];
                            my str $dpkg3 = $dattr3->{"package"};
                            my int $dc3 = index($dpkg3, "::");
                            while ($dc3 >= 0) {
                                $dpkg3 = substr($dpkg3, 0, $dc3) . "_" . substr($dpkg3, $dc3 + 2, length($dpkg3) - $dc3 - 2);
                                $dc3 = index($dpkg3, "::");
                            }
                            my int $in_chain3 = 0;
                            my int $pj3 = 0;
                            while ($pj3 < $pc_len) {
                                if ($dpkg3 eq $pkg_chain[$pj3]) { $in_chain3 = 1; }
                                $pj3 = $pj3 + 1;
                            }
                            if ($in_chain3 == 1 && $dattr3->{"default_node"} != 0) {
                                my str $dn3 = $dattr3->{"name"};
                                my int $set3 = 0;
                                my int $ds3 = 0;
                                while ($ds3 < $arg_count) {
                                    if ($args->[$ds3]->{"value"} eq $dn3) { $set3 = 1; }
                                    $ds3 = $ds3 + 2;
                                }
                                if ($set3 == 0) { $no_defaults = 0; }
                            }
                            $da3 = $da3 + 1;
                        }
                        if ($all_int_vals == 1 && $no_defaults == 1) {
                            # Emit fused call.
                            my int $fbn = $cg->{"tmp_counter"} + 0;
                            $cg->{"tmp_counter"} = $fbn + 1;
                            emit($cg, "({ static char *__fpkg" . $fbn . " = NULL; if (__builtin_expect(!__fpkg" . $fbn . ", 0)) __fpkg" . $fbn . " = strada_intern_pkg_name(\"" . $pkg_name . "\"); ");
                            my int $nattr = $arg_count / 2;
                            my array @fss_ids = ();
                            my int $fai = 0;
                            while ($fai < $arg_count) {
                                my str $fkey = $args->[$fai]->{"value"};
                                my int $fkhash = djb2_hash_32($fkey);
                                my int $fsi = $cg->{"tmp_counter"} + 0;
                                $cg->{"tmp_counter"} = $fsi + 1;
                                push(@fss_ids, $fsi);
                                emit($cg, "static StradaString *__fss" . $fsi . " = NULL; if (__builtin_expect(!__fss" . $fsi . ", 0)) __fss" . $fsi . " = strada_intern_attr_ss(\"" . $fkey . "\", " . $fkhash . "u); ");
                                $fai = $fai + 2;
                            }
                            # Use the _hv_take variant — directly-blessed
                            # HASH (no REF wrapper) — when safe. Method
                            # dispatch via strada_deref_hash handles both
                            # forms; ref() returns the package name for
                            # blessed values regardless of REF vs HASH
                            # wrapper. Saves one SV alloc + one SV decref
                            # per object construct/drop cycle, ~20-25ns
                            # on bench_oop's hot loop.
                            if ($nattr == 2) {
                                emit($cg, "strada_new_blessed_2attr_hv_take(__fpkg" . $fbn . ", __fss" . $fss_ids[0] . ", ");
                                gen_expression($cg, $args->[1]);
                                emit($cg, ", __fss" . $fss_ids[1] . ", ");
                                gen_expression($cg, $args->[3]);
                                emit($cg, "); })");
                            } else {
                                emit($cg, "strada_new_blessed_3attr_hv_take(__fpkg" . $fbn . ", __fss" . $fss_ids[0] . ", ");
                                gen_expression($cg, $args->[1]);
                                emit($cg, ", __fss" . $fss_ids[1] . ", ");
                                gen_expression($cg, $args->[3]);
                                emit($cg, ", __fss" . $fss_ids[2] . ", ");
                                gen_expression($cg, $args->[5]);
                                emit($cg, "); })");
                            }
                            return;
                        }
                    }

                    # Count total attributes (explicit + defaults from chain).
                    # Capacity hint must match the *distinct* number of fields
                    # the constructor will set — double-counting (args + every
                    # has-attr in chain) inflates min_buckets past the small-
                    # bucket fast path and forces an extra malloc per object.
                    my int $total_attrs = $arg_count / 2;
                    my scalar $ha_attrs2 = $cg->{"has_attrs"};
                    my int $ha_count2 = $cg->{"has_attr_count"};
                    my int $dai = 0;
                    while ($dai < $ha_count2) {
                        my scalar $dattr = $ha_attrs2->[$dai];
                        my str $dattr_pkg = $dattr->{"package"};
                        my int $dcol = index($dattr_pkg, "::");
                        while ($dcol >= 0) {
                            $dattr_pkg = substr($dattr_pkg, 0, $dcol) . "_" . substr($dattr_pkg, $dcol + 2, length($dattr_pkg) - $dcol - 2);
                            $dcol = index($dattr_pkg, "::");
                        }
                        my int $in_chain2 = 0;
                        my int $pj2 = 0;
                        while ($pj2 < $pc_len) {
                            if ($dattr_pkg eq $pkg_chain[$pj2]) { $in_chain2 = 1; }
                            $pj2 = $pj2 + 1;
                        }
                        if ($in_chain2 == 1 && $dattr->{"default_node"} != 0) {
                            # Only counts toward capacity if the default will
                            # actually run — i.e. the attr wasn't already in
                            # the explicit args list.
                            my str $da_name = $dattr->{"name"};
                            my int $da_was_set = 0;
                            my int $dasi = 0;
                            while ($dasi < $arg_count) {
                                if ($args->[$dasi]->{"value"} eq $da_name) { $da_was_set = 1; }
                                $dasi = $dasi + 2;
                            }
                            if ($da_was_set == 0) { $total_attrs = $total_attrs + 1; }
                        }
                        $dai = $dai + 1;
                    }
                    emit($cg, "({ StradaValue *__ct_h = strada_new_hash_presized(" . $total_attrs . "); ");
                    emit($cg, "StradaValue *__ct_ref = strada_ref_create_take(__ct_h); ");
                    # Push __ct_ref to the cleanup stack so a later
                    # arg expression that throws (e.g.
                    # `Pkg::new("name", boom())`) lets the surrounding
                    # catch's drain free the partial object. Pop just
                    # before the expression yields __ct_ref at the end.
                    # When in main() outside any try block, no catch can
                    # drain — skip the push/pop pair entirely.
                    my int $ctor_needs_push = cleanup_push_useful($cg);
                    if ($ctor_needs_push == 1) {
                        emit($cg, "strada_cleanup_push(__ct_ref); ");
                    }
                    # Cache the interned package-name pointer at the call site —
                    # skips strada_intern_str's bucket walk and oop_find_package
                    # on every construction.
                    my int $bn_uid = $cg->{"tmp_counter"} + 0;
                    $cg->{"tmp_counter"} = $bn_uid + 1;
                    emit($cg, "{ static char *__pkg_n" . $bn_uid . " = NULL; if (__builtin_expect(!__pkg_n" . $bn_uid . ", 0)) __pkg_n" . $bn_uid . " = strada_intern_pkg_name(\"" . $pkg_name . "\"); strada_bless_cached(__ct_ref, __pkg_n" . $bn_uid . "); } ");
                    my int $ci = 0;
                    while ($ci < $arg_count) {
                        my str $key_val = $args->[$ci]->{"value"};
                        my int $key_hash = djb2_hash_32($key_val);
                        my scalar $vexpr = $args->[$ci + 1];
                        # strada_hash_set_ss_take adopts the value ref without
                        # increfing. If the value is a borrowed reference
                        # (e.g., a plain variable — needs_temp_cleanup == 0),
                        # we must incref so the variable's later scope-decref
                        # doesn't drop the refcount below the hash's view.
                        # If it's a temp (owned), pass through unchanged.
                        my int $v_owned = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $vexpr) == 1;
                        # Use a per-call-site cached interned StradaString singleton
                        # to skip per-construction ss_new/strlen/memcpy overhead.
                        my int $cs_uid = $cg->{"tmp_counter"} + 0;
                        $cg->{"tmp_counter"} = $cs_uid + 1;
                        emit($cg, "({ static StradaString *__attr_ss" . $cs_uid . " = NULL; ");
                        emit($cg, "if (__builtin_expect(!__attr_ss" . $cs_uid . ", 0)) __attr_ss" . $cs_uid . " = strada_intern_attr_ss(\"" . $key_val . "\", " . $key_hash . "u); ");
                        if ($v_owned == 1) {
                            emit($cg, "strada_hash_set_ss_take(__ct_ref->value.rv->value.hv, __attr_ss" . $cs_uid . ", ");
                            gen_expression($cg, $vexpr);
                            emit($cg, "); ");
                        } else {
                            emit($cg, "StradaValue *__ct_v" . $cs_uid . " = ");
                            gen_expression($cg, $vexpr);
                            emit($cg, "; strada_incref(__ct_v" . $cs_uid . "); strada_hash_set_ss_take(__ct_ref->value.rv->value.hv, __attr_ss" . $cs_uid . ", __ct_v" . $cs_uid . "); ");
                        }
                        emit($cg, "}); ");
                        $ci = $ci + 2;
                    }
                    # Apply defaults from has_attrs (own + parent packages)
                    my scalar $ha_attrs = $cg->{"has_attrs"};
                    my int $ha_count = $cg->{"has_attr_count"};
                    my int $di = 0;
                    while ($di < $ha_count) {
                        my scalar $attr = $ha_attrs->[$di];
                        my str $attr_pkg = $attr->{"package"};
                        # Sanitize :: to _ for comparison
                        my int $col_idx = index($attr_pkg, "::");
                        while ($col_idx >= 0) {
                            $attr_pkg = substr($attr_pkg, 0, $col_idx) . "_" . substr($attr_pkg, $col_idx + 2, length($attr_pkg) - $col_idx - 2);
                            $col_idx = index($attr_pkg, "::");
                        }
                        # Check if attr belongs to any package in the chain
                        my int $in_chain = 0;
                        my int $pj = 0;
                        while ($pj < $pc_len) {
                            if ($attr_pkg eq $pkg_chain[$pj]) {
                                $in_chain = 1;
                            }
                            $pj = $pj + 1;
                        }
                        if ($in_chain == 1 && $attr->{"default_node"} != 0) {
                            my str $attr_name = $attr->{"name"};
                            # Check if this attr was explicitly set
                            my int $was_set = 0;
                            my int $si = 0;
                            while ($si < $arg_count) {
                                if ($args->[$si]->{"value"} eq $attr_name) {
                                    $was_set = 1;
                                }
                                $si = $si + 2;
                            }
                            if ($was_set == 0) {
                                # Apply default
                                emit($cg, "if (!strada_hash_exists(__ct_h->value.hv, \"" . $attr_name . "\")) { ");
                                emit($cg, "strada_hash_set_take(__ct_h->value.hv, \"" . $attr_name . "\", ");
                                gen_expression($cg, $attr->{"default_node"});
                                emit($cg, "); } ");
                            }
                        }
                        $di = $di + 1;
                    }
                    if ($ctor_needs_push == 1) {
                        emit($cg, "strada_cleanup_pop(); ");
                    }
                    emit($cg, "__ct_ref; })");
                    return;
                }
            }
        }

        # Variadic call: pack args into array at call site
        if ($is_variadic_call == 1 || $has_spread == 1) {
            # For variadic functions, variadic_param_idx tells us where to start packing
            # For non-variadic functions with spread, pack ALL args and let runtime sort it out
            if ($variadic_param_idx < 0) {
                $variadic_param_idx = 0;  # Pack all args if no variadic info
            }

            # Check if function returns void
            my int $returns_void = 0;
            if ($func_info) {
                my int $ret_type = $func_info->{"return_type"};
                if ($ret_type == TYPE_VOID()) {
                    $returns_void = 1;
                }
            }

            emit($cg, "({ ");
            emit($cg, "StradaValue *__va_arr = strada_new_array(); ");

            # Pack args starting from variadic position
            my int $a = $variadic_param_idx;
            while ($a < $arg_count) {
                my scalar $arg = $args->[$a];
                if ($arg->{"type"} == NODE_SPREAD()) {
                    # Spread: iterate array and push elements
                    # Incref first to keep element alive, then use push_take to transfer ownership to variadic array
                    emit($cg, "{ StradaValue *__spread = ");
                    gen_expression($cg, $arg->{"target"});
                    emit($cg, "; StradaArray *__sa = strada_deref_array(__spread); ");
                    emit($cg, "if (__sa) { for (size_t __si = 0; __si < __sa->size; __si++) { ");
                    emit($cg, "strada_incref(__sa->elements[__si]); ");
                    emit($cg, "strada_array_push_take(strada_deref_array(__va_arr), __sa->elements[__si]); ");
                    emit($cg, "} } } ");
                } elsif ($arg->{"type"} == NODE_VARIABLE() && $arg->{"sigil"} eq "@") {
                    # A bare @array argument to a variadic function flattens its
                    # elements into the call (Perl list semantics), rather than
                    # being pushed as a single array-ref element. Same handling as
                    # an explicit spread.
                    emit($cg, "{ StradaValue *__flat = ");
                    gen_expression($cg, $arg);
                    emit($cg, "; StradaArray *__fa = strada_deref_array(__flat); ");
                    emit($cg, "if (__fa) { for (size_t __fi = 0; __fi < __fa->size; __fi++) { ");
                    emit($cg, "StradaValue *__fe = strada_array_get(__fa, __fi); ");
                    emit($cg, "strada_incref(__fe); ");
                    emit($cg, "strada_array_push_take(strada_deref_array(__va_arr), __fe); ");
                    emit($cg, "} } } ");
                } else {
                    # Regular scalar arg: push (with incref) for variables since
                    # they'll be cleaned up later; push_take for temporaries.
                    my int $arg_is_var = $arg->{"type"} == NODE_VARIABLE();
                    if ($arg_is_var == 1) {
                        emit($cg, "strada_array_push(strada_deref_array(__va_arr), ");
                    } else {
                        emit($cg, "strada_array_push_take(strada_deref_array(__va_arr), ");
                    }
                    gen_expression($cg, $arg);
                    emit($cg, "); ");
                }
                $a = $a + 1;
            }

            # Capture fixed args in temps for cleanup
            for (my int $f = 0; $f < $variadic_param_idx; $f = $f + 1) {
                emit($cg, "StradaValue *__farg" . $f . " = ");
                if ($f < $arg_count) {
                    gen_expression($cg, $args->[$f]);
                } else {
                    # Missing arg - use default or undef
                    if ($func_info) {
                        my scalar $params = $func_info->{"params"};
                        my scalar $param = $params->[$f];
                        if ($param->{"has_default"} == 1) {
                            gen_expression($cg, $param->{"default"});
                        } else {
                            emit($cg, "strada_new_undef()");
                        }
                    } else {
                        emit($cg, "strada_new_undef()");
                    }
                }
                emit($cg, "; ");
            }

            # Emit the function call with fixed args + variadic array
            if ($is_dynamic_call == 1) {
                emit($cg, "strada_set_call_context(" . $dyn_ctx . "); ");
            }
            # Stash this call site's line so the callee's stack_push
            # records it as the new frame's `line` — that's what
            # caller(0) inside the callee reads. Without this, every
            # frame has line=0.
            if ($cg->{"enable_stack_trace"} == 1) {
                my int $__cl_line = $expr->{"line"} + 0;
                if ($__cl_line > 0) {
                    emit($cg, "strada_stack_line_il(" . $__cl_line . "); ");
                }
            }
            if ($returns_void == 0) {
                emit($cg, "StradaValue *__va_result = ");
            }
            emit($cg, $c_name . "(");

            # Emit fixed args (using captured temps)
            for (my int $f = 0; $f < $variadic_param_idx; $f = $f + 1) {
                if ($f > 0) {
                    emit($cg, ", ");
                }
                emit($cg, "__farg" . $f);
            }

            # Emit variadic array as last param
            if ($variadic_param_idx > 0) {
                emit($cg, ", ");
            }
            emit($cg, "__va_arr); ");

            # Decref variadic array and fixed arg temps
            emit($cg, "strada_decref(__va_arr); ");
            for (my int $f = 0; $f < $variadic_param_idx; $f = $f + 1) {
                emit($cg, "strada_decref(__farg" . $f . "); ");
            }

            if ($is_dynamic_call == 1) {
                emit($cg, "strada_set_call_context(0); ");
            }

            # Return result
            if ($returns_void == 0) {
                emit($cg, "__va_result; })");
            } else {
                emit($cg, "})");
            }
            return;
        }

        # Check if any arguments need temp cleanup (anonymous values)
        my int $needs_temps = 0;
        my int $check_i = 0;
        while ($check_i < $arg_count) {
            if (needs_temp_cleanup($cg, $args->[$check_i]) == 1) {
                $needs_temps = 1;
            }
            $check_i = $check_i + 1;
        }

        # Also need temps when default parameter values will be emitted (they allocate and need cleanup)
        if ($needs_temps == 0 && $func_info) {
            if ($arg_count < $func_info->{"param_count"}) {
                $needs_temps = 1;
            }
        }

        if ($needs_temps == 1) {
            # Check if function returns void
            # Default to non-void when we don't have func_info (safer - allows use in expression context)
            my int $returns_void = 0;
            if ($func_info) {
                my int $ret_type = $func_info->{"return_type"};
                if ($ret_type == TYPE_VOID()) {
                    $returns_void = 1;
                }
            }

            # Generate block with temp variables for cleanup
            emit($cg, "({ ");
            # Declare temps for args that need cleanup
            my int $in_try = $cg->{"try_depth"} + 0;
            my int $t = 0;
            while ($t < $arg_count) {
                if (needs_temp_cleanup($cg, $args->[$t]) == 1) {
                    emit($cg, "StradaValue *__arg" . $t . " = ");
                    gen_expression($cg, $args->[$t]);
                    emit($cg, "; ");
                    # If inside a try block, register for cleanup in case the call throws
                    if ($in_try > 0) {
                        emit($cg, "strada_cleanup_push(__arg" . $t . "); ");
                    }
                }
                $t = $t + 1;
            }
            # Declare temps for default parameter values (positions beyond provided args)
            if ($func_info) {
                my int $param_count = $func_info->{"param_count"};
                my scalar $params = $func_info->{"params"};
                my int $dt = $arg_count;
                while ($dt < $param_count) {
                    emit($cg, "StradaValue *__arg" . $dt . " = ");
                    my scalar $dparam = $params->[$dt];
                    if ($dparam->{"has_default"} == 1) {
                        gen_expression($cg, $dparam->{"default"});
                    } else {
                        emit($cg, "strada_new_undef()");
                    }
                    emit($cg, "; ");
                    if ($in_try > 0) {
                        emit($cg, "strada_cleanup_push(__arg" . $dt . "); ");
                    }
                    $dt = $dt + 1;
                }
            }
            # Emit the function call, storing result if not void
            if ($is_dynamic_call == 1) {
                emit($cg, "strada_set_call_context(" . $dyn_ctx . "); ");
            }
            # Stash call-site line for caller() — see comment above.
            if ($cg->{"enable_stack_trace"} == 1) {
                my int $__cl_line2 = $expr->{"line"} + 0;
                if ($__cl_line2 > 0) {
                    emit($cg, "strada_stack_line_il(" . $__cl_line2 . "); ");
                }
            }
            if ($returns_void == 0) {
                emit($cg, "StradaValue *__call_result = ");
            }
            emit($cg, $c_name . "(");
            if ($func_info) {
                my int $param_count = $func_info->{"param_count"};
                my scalar $params = $func_info->{"params"};
                my int $i = 0;
                while ($i < $param_count) {
                    if ($i > 0) {
                        emit($cg, ", ");
                    }
                    if ($i < $arg_count) {
                        if (needs_temp_cleanup($cg, $args->[$i]) == 1) {
                            emit($cg, "__arg" . $i);
                        } else {
                            gen_expression($cg, $args->[$i]);
                        }
                    } else {
                        # Use the pre-captured __argN temp for default values
                        emit($cg, "__arg" . $i);
                    }
                    $i = $i + 1;
                }
            } else {
                my int $i = 0;
                while ($i < $arg_count) {
                    if ($i > 0) {
                        emit($cg, ", ");
                    }
                    if (needs_temp_cleanup($cg, $args->[$i]) == 1) {
                        emit($cg, "__arg" . $i);
                    } else {
                        gen_expression($cg, $args->[$i]);
                    }
                    $i = $i + 1;
                }
            }
            emit($cg, "); ");
            # Decref temps and pop from cleanup stack
            # Skip decref for args that are guaranteed tagged ints (int literals, int binary ops)
            my int $d = 0;
            while ($d < $arg_count) {
                if (needs_temp_cleanup($cg, $args->[$d]) == 1) {
                    # Pop from cleanup stack first (in case decref throws somehow)
                    if ($in_try > 0) {
                        emit($cg, "strada_cleanup_pop(); ");
                    }
                    # Skip decref for int literal args and int binary ops (always tagged ints)
                    my int $ad_type = $args->[$d]->{"type"};
                    my int $skip_decref = 0;
                    if ($ad_type == NODE_INT_LITERAL()) {
                        $skip_decref = 1;
                    } elsif ($ad_type == NODE_BINARY_OP() && expr_is_int_typed($cg, $args->[$d]) == 1) {
                        $skip_decref = 1;
                    }
                    if ($skip_decref == 0) {
                        emit($cg, "strada_decref(__arg" . $d . "); ");
                    }
                }
                $d = $d + 1;
            }
            # Decref default parameter temps
            if ($func_info) {
                my int $param_count = $func_info->{"param_count"};
                my int $dd = $arg_count;
                while ($dd < $param_count) {
                    if ($in_try > 0) {
                        emit($cg, "strada_cleanup_pop(); ");
                    }
                    emit($cg, "strada_decref(__arg" . $dd . "); ");
                    $dd = $dd + 1;
                }
            }
            if ($is_dynamic_call == 1) {
                emit($cg, "strada_set_call_context(0); ");
            }
            # Return result if not void
            if ($returns_void == 0) {
                emit($cg, "__call_result; })");
            } else {
                emit($cg, "})");
            }
        } else {
            # No temps needed, simple call
            if ($is_dynamic_call == 1) {
                emit($cg, "({ strada_set_call_context(" . $dyn_ctx . "); StradaValue *__dyn_r = ");
            }
            # Stash call-site line for caller() — see comment above.
            # Wrap the call in a comma expression so this stays an
            # expression at any nesting level (statement, my-init,
            # sort key, etc.). strada_stack_set_line returns void so
            # use comma operator with sequenced cast to (void).
            if ($cg->{"enable_stack_trace"} == 1) {
                my int $__cl_line3 = $expr->{"line"} + 0;
                if ($__cl_line3 > 0) {
                    emit($cg, "(strada_stack_line_il(" . $__cl_line3 . "), ");
                }
            }
            emit($cg, $c_name . "(");
            if ($func_info) {
                my int $param_count = $func_info->{"param_count"};
                my scalar $params = $func_info->{"params"};
                my int $i = 0;
                while ($i < $param_count) {
                    if ($i > 0) {
                        emit($cg, ", ");
                    }
                    if ($i < $arg_count) {
                        gen_expression($cg, $args->[$i]);
                    } else {
                        my scalar $param = $params->[$i];
                        if ($param->{"has_default"} == 1) {
                            gen_expression($cg, $param->{"default"});
                        } else {
                            emit($cg, "strada_new_undef()");
                        }
                    }
                    $i = $i + 1;
                }
            } else {
                my int $i = 0;
                while ($i < $arg_count) {
                    if ($i > 0) {
                        emit($cg, ", ");
                    }
                    gen_expression($cg, $args->[$i]);
                    $i = $i + 1;
                }
            }
            if ($is_dynamic_call == 1) {
                emit($cg, "); strada_set_call_context(0); __dyn_r; })");
            } else {
                emit($cg, ")");
            }
            # Close the comma-expression wrapper from the call-line set.
            if ($cg->{"enable_stack_trace"} == 1) {
                my int $__cl_line3c = $expr->{"line"} + 0;
                if ($__cl_line3c > 0) {
                    emit($cg, ")");
                }
            }
        }
        return;
}

