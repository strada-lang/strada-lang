# ===== Multi-part concat flattening =====
# String interpolation desugars (in the parser) to left-deep `.` chains:
# "a $x b $y" => ((("a " . $x) . " b ") . $y). The pairwise emitter costs
# one concat call per part plus growth reallocs on the accumulator. For
# chains of >= 3 leaf parts, flatten the tree and emit ONE
# strada_concat_multi(...) call: the runtime sizes every part, allocates
# the result StradaString exactly once, and memcpys the parts in.

# Count the leaf parts of a `.` chain.
func concat_chain_count(scalar $node) int {
    if ($node->{"type"} == NODE_BINARY_OP() && $node->{"op"} eq ".") {
        return concat_chain_count($node->{"left"}) + concat_chain_count($node->{"right"});
    }
    return 1;
}

# Collect leaf parts left-to-right into $st->{"nodes"} / $st->{"n"}.
func concat_chain_collect(scalar $node, scalar $st) void {
    if ($node->{"type"} == NODE_BINARY_OP() && $node->{"op"} eq ".") {
        concat_chain_collect($node->{"left"}, $st);
        concat_chain_collect($node->{"right"}, $st);
        return;
    }
    my int $n = $st->{"n"};
    $st->{"nodes"}->[$n] = $node;
    $st->{"n"} = $n + 1;
}

# Emit a flattened multi-part concat. Returns 1 if emitted, 0 to fall back
# to the pairwise paths (overload concern or oversized chain).
#
# Owned parts (calls, hash accesses, nested temps) are captured into temps
# IN PART ORDER with cleanup_push between captures, so a later part's
# throwing evaluation can't leak an earlier one — same discipline as the
# pairwise emitter. Borrowed parts (plain variables, array subscripts) are
# passed inline in the varargs call; their relative C evaluation order is
# unspecified, which is only observable for tied containers with
# order-dependent FETCH side effects (accepted, matches the risk profile
# of the rest of the codegen's inline-arg emission).
func gen_concat_multi(scalar $cg, scalar $expr) int {
    my hash %st = ();
    $st{"n"} = 0;
    my array @nodes = ();
    $st{"nodes"} = \@nodes;
    concat_chain_collect($expr, \%st);
    my int $n = $st{"n"};
    if ($n < 3 || $n > 64) {
        return 0;
    }

    # Mirror the pairwise emitter's overload gate: when a `.` or '""'
    # overload is registered anywhere, any possibly-blessed part must take
    # the overload-dispatching pairwise path.
    if ($cg->{"has_overloads"} == 1) {
        my scalar $ol_ops = $cg->{"overloaded_ops"};
        my int $ol_concern = 0;
        if (length("" . $ol_ops->{"."}) > 0) { $ol_concern = 1; }
        if (length("" . $ol_ops->{"\"\""}) > 0) { $ol_concern = 1; }
        if ($ol_concern == 1) {
            my int $oi = 0;
            while ($oi < $n) {
                my scalar $opart = $nodes[$oi];
                if ($opart->{"type"} != NODE_STR_LITERAL() && could_be_blessed($opart) == 1) {
                    return 0;
                }
                $oi = $oi + 1;
            }
        }
    }

    my int $cm_id = $cg->{"tmp_counter"};
    $cg->{"tmp_counter"} = $cm_id + 1;
    my int $cleanup_on = $cg->{"cleanup_enabled"};

    emit($cg, "(({ ");
    # Capture owned parts into temps, push each for throw safety.
    my int $i = 0;
    my int $owned_count = 0;
    while ($i < $n) {
        my scalar $part = $nodes[$i];
        if ($part->{"type"} != NODE_STR_LITERAL()
            && $cleanup_on == 1 && needs_temp_cleanup($cg, $part) == 1) {
            $st{"owned_" . $i} = 1;
            emit($cg, "StradaValue *__cm" . $cm_id . "_" . $i . " = ");
            gen_expression($cg, $part);
            emit($cg, "; strada_cleanup_push(__cm" . $cm_id . "_" . $i . "); ");
            $owned_count = $owned_count + 1;
        }
        $i = $i + 1;
    }
    $i = 0;
    while ($i < $owned_count) {
        emit($cg, "strada_cleanup_pop(); ");
        $i = $i + 1;
    }
    emit($cg, "StradaValue *__cmr" . $cm_id . " = strada_concat_multi(" . $n);
    $i = 0;
    while ($i < $n) {
        my scalar $part = $nodes[$i];
        if ($part->{"type"} == NODE_STR_LITERAL()) {
            my str $lit = $part->{"value"};
            my int $litlen = bytes($lit);
            # ASCII-ness known at compile time: kind 0 = ASCII, 2 = non-ASCII.
            my int $kind = 0;
            my int $bi = 0;
            while ($bi < $litlen) {
                if (ord(substr_bytes($lit, $bi, 1)) >= 128) { $kind = 2; last; }
                $bi = $bi + 1;
            }
            emit($cg, ", " . $kind . ", ");
            gen_str_literal_c($cg, $lit);
            emit($cg, ", (size_t)" . $litlen);
        } elsif (length("" . $st{"owned_" . $i}) > 0) {
            emit($cg, ", 1, __cm" . $cm_id . "_" . $i);
        } else {
            emit($cg, ", 1, ");
            gen_expression($cg, $part);
        }
        $i = $i + 1;
    }
    emit($cg, "); ");
    $i = 0;
    while ($i < $n) {
        if (length("" . $st{"owned_" . $i}) > 0) {
            emit($cg, "strada_decref(__cm" . $cm_id . "_" . $i . "); ");
        }
        $i = $i + 1;
    }
    emit($cg, "__cmr" . $cm_id . "; }))");
    return 1;
}

# True when an assignment-target sub-expression is itself an element access
# (hash or array, direct or deref) — i.e. an intermediate chain link that
# must be autovivified rather than rvalue-fetched. Callers set
# $cg->{"autoviv"} (1 = viv as hash, 2 = viv as array) immediately before
# generating that sub-expression, never earlier, so accesses inside key,
# index, or value expressions can't consume the flag by mistake.
func autoviv_link_type(scalar $node) int {
    my int $t = $node->{"type"};
    if ($t == NODE_HASH_ACCESS() || $t == NODE_DEREF_HASH()
        || $t == NODE_SUBSCRIPT() || $t == NODE_DEREF_ARRAY()) {
        return 1;
    }
    return 0;
}

# Generate the container sub-expression of an assignment target,
# autovivifying intermediate access links. $want: 1 = this level must
# hold a hash, 2 = an array. The flag is set immediately before the
# generation (the access-node consumers in gen_expression clear it).
func gen_assign_container(scalar $cg, scalar $node, int $want) void {
    if (autoviv_link_type($node) == 1) {
        $cg->{"autoviv"} = $want;
    }
    gen_expression($cg, $node);
}

func gen_assign_hash_access(scalar $cg, scalar $expr, scalar $target) void {
    my int $type = $expr->{"type"};
    my int $in_extern = $cg->{"in_extern"};
    my int $target_type = $target->{"type"};
                my scalar $val = $expr->{"value"};
                my int $val_type = $val->{"type"};
                # Whether the value is an owned temp whose extra ref must be
                # released after the store (strada_hv_store* increfs/shares).
                # Unified with needs_temp_cleanup — the canonical owned-value
                # predicate — so this can't drift from it. The old hand-kept
                # node-type list repeatedly omitted owned cases ($1 captures,
                # our-variables, owned subscripts), leaking the store's extra ref.
                my int $is_anonymous = needs_temp_cleanup($cg, $val);
                my scalar $key_expr = $target->{"key"};
                my int $key_is_literal = $key_expr->{"type"} == NODE_STR_LITERAL();
                my int $key_is_concat = is_concat_str_literal_left($key_expr);
                if ($is_anonymous == 1) {
                    # Anonymous value: store in temp, hash_set takes shared ownership, then release our copy
                    emit($cg, "({ StradaValue *__hset_v = ");
                    # Handle empty () which parser returns as anon_hash
                    if ($val_type == NODE_ANON_HASH() && $val->{"pair_count"} == 0) {
                        emit($cg, "strada_new_hash()");
                    } else {
                        gen_expression($cg, $val);
                    }
                    emit($cg, "; ");
                    if ($key_is_literal == 1) {
                        # Literal key - use directly without allocation
                        # (intermediate autoviv handled by gen_assign_container)
                        emit($cg, "strada_hv_store(");
                        gen_assign_container($cg, $target->{"hash"}, 1);
                        emit($cg, ", ");
                        gen_str_literal_c($cg, $key_expr->{"value"});
                        emit($cg, ", __hset_v); strada_decref(__hset_v); })");
                    } elsif ($key_is_concat == 1) {
                        # Concat key "prefix" . $expr - zero-alloc stack buffer
                        my scalar $concat_right = $key_expr->{"right"};
                        my int $right_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $concat_right) == 1;
                        my str $prefix_val = $key_expr->{"left"}->{"value"};
                        my int $prefix_len = bytes($prefix_val);
                        if ($right_cleanup == 1) {
                            emit($cg, "StradaValue *__ck_r = ");
                            gen_expression($cg, $concat_right);
                            emit($cg, "; strada_hv_store_concat(");
                            gen_assign_container($cg, $target->{"hash"}, 1);
                            emit($cg, ", ");
                            gen_str_literal_c($cg, $prefix_val);
                            emit($cg, ", " . $prefix_len . ", __ck_r, __hset_v); strada_decref(__ck_r); ");
                        } else {
                            emit($cg, "strada_hv_store_concat(");
                            gen_assign_container($cg, $target->{"hash"}, 1);
                            emit($cg, ", ");
                            gen_str_literal_c($cg, $prefix_val);
                            emit($cg, ", " . $prefix_len . ", ");
                            gen_expression($cg, $concat_right);
                            emit($cg, ", __hset_v); ");
                        }
                        emit($cg, "strada_decref(__hset_v); })");
                    } else {
                        # Expression key - use _sv variant (no strada_to_str needed)
                        my int $key_needs_cleanup = needs_temp_cleanup($cg, $key_expr);
                        emit($cg, "StradaValue *__hset_k = ");
                        gen_expression($cg, $key_expr);
                        emit($cg, "; strada_hv_store_sv(");
                        gen_assign_container($cg, $target->{"hash"}, 1);
                        emit($cg, ", __hset_k, __hset_v); ");
                        if ($key_needs_cleanup == 1) {
                            emit($cg, "strada_decref(__hset_k); ");
                        }
                        emit($cg, "strada_decref(__hset_v); })");
                    }
                } else {
                    # Borrowed value: just pass to hash_set which handles incref
                    if ($key_is_literal == 1) {
                        # Literal key - use directly without allocation
                        # (intermediate autoviv handled by gen_assign_container)
                        emit($cg, "strada_hv_store(");
                        gen_assign_container($cg, $target->{"hash"}, 1);
                        emit($cg, ", ");
                        gen_str_literal_c($cg, $key_expr->{"value"});
                        emit($cg, ", ");
                        gen_expression($cg, $val);
                        emit($cg, ")");
                    } elsif ($key_is_concat == 1) {
                        # Concat key "prefix" . $expr - zero-alloc stack buffer
                        my scalar $concat_right = $key_expr->{"right"};
                        my int $right_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $concat_right) == 1;
                        my str $prefix_val = $key_expr->{"left"}->{"value"};
                        my int $prefix_len = bytes($prefix_val);
                        if ($right_cleanup == 1) {
                            emit($cg, "({ StradaValue *__ck_r = ");
                            gen_expression($cg, $concat_right);
                            emit($cg, "; strada_hv_store_concat(");
                            gen_assign_container($cg, $target->{"hash"}, 1);
                            emit($cg, ", ");
                            gen_str_literal_c($cg, $prefix_val);
                            emit($cg, ", " . $prefix_len . ", __ck_r, ");
                            gen_expression($cg, $val);
                            emit($cg, "); strada_decref(__ck_r); })");
                        } else {
                            emit($cg, "strada_hv_store_concat(");
                            gen_assign_container($cg, $target->{"hash"}, 1);
                            emit($cg, ", ");
                            gen_str_literal_c($cg, $prefix_val);
                            emit($cg, ", " . $prefix_len . ", ");
                            gen_expression($cg, $concat_right);
                            emit($cg, ", ");
                            gen_expression($cg, $val);
                            emit($cg, ")");
                        }
                    } else {
                        # Expression key - use _sv variant (no strada_to_str needed)
                        my int $key_needs_cleanup = needs_temp_cleanup($cg, $key_expr);
                        emit($cg, "({ StradaValue *__hset_k = ");
                        gen_expression($cg, $key_expr);
                        emit($cg, "; strada_hv_store_sv(");
                        gen_assign_container($cg, $target->{"hash"}, 1);
                        emit($cg, ", __hset_k, ");
                        gen_expression($cg, $val);
                        emit($cg, "); ");
                        if ($key_needs_cleanup == 1) {
                            emit($cg, "strada_decref(__hset_k); ");
                        }
                        emit($cg, "})");
                    }
                }
                return;
}

func gen_assign_deref_hash(scalar $cg, scalar $expr, scalar $target) void {
    my int $type = $expr->{"type"};
    my int $in_extern = $cg->{"in_extern"};
    my int $target_type = $target->{"type"};
                my scalar $val = $expr->{"value"};
                my int $val_type = $val->{"type"};
                # Whether the value is an owned temp whose extra ref must be
                # released after the store (strada_hv_store* increfs/shares).
                # Unified with needs_temp_cleanup — the canonical owned-value
                # predicate — so this can't drift from it. The old hand-kept
                # node-type list repeatedly omitted owned cases ($1 captures,
                # our-variables, owned subscripts), leaking the store's extra ref.
                my int $is_anonymous = needs_temp_cleanup($cg, $val);
                my scalar $key_expr = $target->{"key"};
                my int $key_is_literal = $key_expr->{"type"} == NODE_STR_LITERAL();
                my int $key_is_concat = is_concat_str_literal_left($key_expr);
                my int $hst_ref_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $target->{"ref"}) == 1;
                # An autovivified intermediate is BORROWED (owned by its
                # parent container) — must not be decref'd as an owned temp.
                if (autoviv_link_type($target->{"ref"}) == 1) {
                    $hst_ref_cleanup = 0;
                }
                if ($is_anonymous == 1) {
                    # Anonymous value: store in temp, hash_set takes shared ownership, then release our copy
                    emit($cg, "({ StradaValue *__hset_v = ");
                    gen_expression($cg, $val);
                    emit($cg, "; ");
                    if ($hst_ref_cleanup == 1) {
                        emit($cg, "StradaValue *__hst_ref = ");
                        gen_assign_container($cg, $target->{"ref"}, 1);
                        emit($cg, "; ");
                    }
                    if ($key_is_literal == 1) {
                        # Literal key - use directly without allocation
                        emit($cg, "strada_hv_store(");
                        if ($hst_ref_cleanup == 1) {
                            emit($cg, "__hst_ref");
                        } else {
                            gen_assign_container($cg, $target->{"ref"}, 1);
                        }
                        emit($cg, ", ");
                        gen_str_literal_c($cg, $key_expr->{"value"});
                        emit($cg, ", __hset_v); ");
                        if ($hst_ref_cleanup == 1) {
                            emit($cg, "strada_decref(__hst_ref); ");
                        }
                        emit($cg, "strada_decref(__hset_v); })");
                    } elsif ($key_is_concat == 1) {
                        # Concat key "prefix" . $expr - zero-alloc stack buffer
                        my scalar $concat_right = $key_expr->{"right"};
                        my int $right_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $concat_right) == 1;
                        my str $prefix_val = $key_expr->{"left"}->{"value"};
                        my int $prefix_len = bytes($prefix_val);
                        if ($right_cleanup == 1) {
                            emit($cg, "StradaValue *__ck_r = ");
                            gen_expression($cg, $concat_right);
                            emit($cg, "; ");
                        }
                        emit($cg, "strada_hv_store_concat(");
                        if ($hst_ref_cleanup == 1) {
                            emit($cg, "__hst_ref");
                        } else {
                            gen_assign_container($cg, $target->{"ref"}, 1);
                        }
                        emit($cg, ", ");
                        gen_str_literal_c($cg, $prefix_val);
                        emit($cg, ", " . $prefix_len . ", ");
                        if ($right_cleanup == 1) {
                            emit($cg, "__ck_r");
                        } else {
                            gen_expression($cg, $concat_right);
                        }
                        emit($cg, ", __hset_v); ");
                        if ($right_cleanup == 1) {
                            emit($cg, "strada_decref(__ck_r); ");
                        }
                        if ($hst_ref_cleanup == 1) {
                            emit($cg, "strada_decref(__hst_ref); ");
                        }
                        emit($cg, "strada_decref(__hset_v); })");
                    } else {
                        # Expression key - use _sv variant (no strada_to_str needed)
                        my int $key_needs_cleanup = needs_temp_cleanup($cg, $key_expr);
                        emit($cg, "StradaValue *__hset_k = ");
                        gen_expression($cg, $key_expr);
                        emit($cg, "; strada_hv_store_sv(");
                        if ($hst_ref_cleanup == 1) {
                            emit($cg, "__hst_ref");
                        } else {
                            gen_assign_container($cg, $target->{"ref"}, 1);
                        }
                        emit($cg, ", __hset_k, __hset_v); ");
                        if ($key_needs_cleanup == 1) {
                            emit($cg, "strada_decref(__hset_k); ");
                        }
                        if ($hst_ref_cleanup == 1) {
                            emit($cg, "strada_decref(__hst_ref); ");
                        }
                        emit($cg, "strada_decref(__hset_v); })");
                    }
                } else {
                    # Borrowed value: just pass to hash_set which handles incref
                    if ($key_is_literal == 1) {
                        # Literal key - use directly without allocation
                        if ($hst_ref_cleanup == 1) {
                            emit($cg, "({ StradaValue *__hst_ref = ");
                            gen_assign_container($cg, $target->{"ref"}, 1);
                            emit($cg, "; strada_hv_store(__hst_ref, ");
                            gen_str_literal_c($cg, $key_expr->{"value"});
                            emit($cg, ", ");
                            gen_expression($cg, $val);
                            emit($cg, "); strada_decref(__hst_ref); })");
                        } else {
                            emit($cg, "strada_hv_store(");
                            gen_assign_container($cg, $target->{"ref"}, 1);
                            emit($cg, ", ");
                            gen_str_literal_c($cg, $key_expr->{"value"});
                            emit($cg, ", ");
                            gen_expression($cg, $val);
                            emit($cg, ")");
                        }
                    } elsif ($key_is_concat == 1) {
                        # Concat key "prefix" . $expr - zero-alloc stack buffer
                        my scalar $concat_right = $key_expr->{"right"};
                        my int $right_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $concat_right) == 1;
                        my str $prefix_val = $key_expr->{"left"}->{"value"};
                        my int $prefix_len = bytes($prefix_val);
                        emit($cg, "({ ");
                        if ($hst_ref_cleanup == 1) {
                            emit($cg, "StradaValue *__hst_ref = ");
                            gen_assign_container($cg, $target->{"ref"}, 1);
                            emit($cg, "; ");
                        }
                        if ($right_cleanup == 1) {
                            emit($cg, "StradaValue *__ck_r = ");
                            gen_expression($cg, $concat_right);
                            emit($cg, "; ");
                        }
                        emit($cg, "strada_hv_store_concat(");
                        if ($hst_ref_cleanup == 1) {
                            emit($cg, "__hst_ref");
                        } else {
                            gen_assign_container($cg, $target->{"ref"}, 1);
                        }
                        emit($cg, ", ");
                        gen_str_literal_c($cg, $prefix_val);
                        emit($cg, ", " . $prefix_len . ", ");
                        if ($right_cleanup == 1) {
                            emit($cg, "__ck_r");
                        } else {
                            gen_expression($cg, $concat_right);
                        }
                        emit($cg, ", ");
                        gen_expression($cg, $val);
                        emit($cg, "); ");
                        if ($right_cleanup == 1) {
                            emit($cg, "strada_decref(__ck_r); ");
                        }
                        if ($hst_ref_cleanup == 1) {
                            emit($cg, "strada_decref(__hst_ref); ");
                        }
                        emit($cg, "})");
                    } else {
                        # Expression key - use _sv variant (no strada_to_str needed)
                        my int $key_needs_cleanup = needs_temp_cleanup($cg, $key_expr);
                        emit($cg, "({ ");
                        if ($hst_ref_cleanup == 1) {
                            emit($cg, "StradaValue *__hst_ref = ");
                            gen_assign_container($cg, $target->{"ref"}, 1);
                            emit($cg, "; ");
                        }
                        emit($cg, "StradaValue *__hset_k = ");
                        gen_expression($cg, $key_expr);
                        emit($cg, "; strada_hv_store_sv(");
                        if ($hst_ref_cleanup == 1) {
                            emit($cg, "__hst_ref");
                        } else {
                            gen_assign_container($cg, $target->{"ref"}, 1);
                        }
                        emit($cg, ", __hset_k, ");
                        gen_expression($cg, $val);
                        emit($cg, "); ");
                        if ($key_needs_cleanup == 1) {
                            emit($cg, "strada_decref(__hset_k); ");
                        }
                        if ($hst_ref_cleanup == 1) {
                            emit($cg, "strada_decref(__hst_ref); ");
                        }
                        emit($cg, "})");
                    }
                }
                return;
}

func gen_assign_subscript(scalar $cg, scalar $expr, scalar $target) void {
    my int $type = $expr->{"type"};
    my int $in_extern = $cg->{"in_extern"};
    my int $target_type = $target->{"type"};
                my scalar $idx_expr = $target->{"index"};
                my scalar $val_expr = $expr->{"value"};
                my int $idx_needs_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $idx_expr) == 1;
                my int $val_needs_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $val_expr) == 1;

                if ($idx_needs_cleanup == 1 || $val_needs_cleanup == 1) {
                    emit($cg, "({ ");
                    if ($idx_needs_cleanup == 1) {
                        emit($cg, "StradaValue *__idx_tmp = ");
                        gen_expression($cg, $idx_expr);
                        emit($cg, "; ");
                    }
                    if ($val_needs_cleanup == 1) {
                        emit($cg, "StradaValue *__val_tmp = ");
                        gen_expression($cg, $val_expr);
                        emit($cg, "; ");
                    }
                    emit($cg, "strada_array_set(strada_deref_array(");
                    gen_assign_container($cg, $target->{"array"}, 2);
                    emit($cg, "), strada_to_int(");
                    if ($idx_needs_cleanup == 1) {
                        emit($cg, "__idx_tmp");
                    } else {
                        gen_expression($cg, $idx_expr);
                    }
                    emit($cg, "), ");
                    if ($val_needs_cleanup == 1) {
                        emit($cg, "__val_tmp");
                    } else {
                        gen_expression($cg, $val_expr);
                    }
                    emit($cg, "); ");
                    if ($idx_needs_cleanup == 1) {
                        emit($cg, "strada_decref(__idx_tmp); ");
                    }
                    if ($val_needs_cleanup == 1) {
                        emit($cg, "strada_decref(__val_tmp); ");
                    }
                    emit($cg, "})");
                } else {
                    emit($cg, "strada_array_set(strada_deref_array(");
                    gen_assign_container($cg, $target->{"array"}, 2);
                    emit($cg, "), strada_to_int(");
                    gen_expression($cg, $idx_expr);
                    emit($cg, "), ");
                    gen_expression($cg, $val_expr);
                    emit($cg, ")");
                }
                return;
}

func gen_assign_deref_array(scalar $cg, scalar $expr, scalar $target) void {
    my int $type = $expr->{"type"};
    my int $in_extern = $cg->{"in_extern"};
    my int $target_type = $target->{"type"};
                my scalar $idx_expr = $target->{"index"};
                my scalar $val_expr = $expr->{"value"};
                my scalar $ref_expr = $target->{"ref"};
                my int $idx_needs_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $idx_expr) == 1;
                my int $val_needs_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $val_expr) == 1;
                # Bug fix: when the ref sub-expression is owned (e.g.
                # get_ref()->[i] = v, $$r->[i] = v, $h{k}->[i] = v,
                # $obj->arr()->[i] = v), we previously left it uncaptured
                # inside strada_deref_array(...), leaking the wrapper SV
                # on every assignment. Sister NODE_DEREF_HASH branch
                # handles this correctly.
                my int $ref_needs_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $ref_expr) == 1;
                # An autovivified intermediate is BORROWED (owned by its
                # parent container) — must not be decref'd as an owned temp.
                if (autoviv_link_type($ref_expr) == 1) {
                    $ref_needs_cleanup = 0;
                }

                if ($idx_needs_cleanup == 1 || $val_needs_cleanup == 1 || $ref_needs_cleanup == 1) {
                    emit($cg, "({ ");
                    if ($ref_needs_cleanup == 1) {
                        emit($cg, "StradaValue *__ast_ref = ");
                        gen_assign_container($cg, $ref_expr, 2);
                        emit($cg, "; ");
                    }
                    if ($idx_needs_cleanup == 1) {
                        emit($cg, "StradaValue *__idx_tmp = ");
                        gen_expression($cg, $idx_expr);
                        emit($cg, "; ");
                    }
                    if ($val_needs_cleanup == 1) {
                        emit($cg, "StradaValue *__val_tmp = ");
                        gen_expression($cg, $val_expr);
                        emit($cg, "; ");
                    }
                    emit($cg, "strada_array_set(strada_deref_array(");
                    if ($ref_needs_cleanup == 1) {
                        emit($cg, "__ast_ref");
                    } else {
                        gen_assign_container($cg, $ref_expr, 2);
                    }
                    emit($cg, "), strada_to_int(");
                    if ($idx_needs_cleanup == 1) {
                        emit($cg, "__idx_tmp");
                    } else {
                        gen_expression($cg, $idx_expr);
                    }
                    emit($cg, "), ");
                    if ($val_needs_cleanup == 1) {
                        emit($cg, "__val_tmp");
                    } else {
                        gen_expression($cg, $val_expr);
                    }
                    emit($cg, "); ");
                    if ($idx_needs_cleanup == 1) {
                        emit($cg, "strada_decref(__idx_tmp); ");
                    }
                    if ($val_needs_cleanup == 1) {
                        emit($cg, "strada_decref(__val_tmp); ");
                    }
                    if ($ref_needs_cleanup == 1) {
                        emit($cg, "strada_decref(__ast_ref); ");
                    }
                    emit($cg, "})");
                } else {
                    emit($cg, "strada_array_set(strada_deref_array(");
                    gen_assign_container($cg, $ref_expr, 2);
                    emit($cg, "), strada_to_int(");
                    gen_expression($cg, $idx_expr);
                    emit($cg, "), ");
                    gen_expression($cg, $val_expr);
                    emit($cg, ")");
                }
                return;
}

func gen_assign_array_slice(scalar $cg, scalar $expr, scalar $target) void {
    my int $type = $expr->{"type"};
    my int $in_extern = $cg->{"in_extern"};
    my int $target_type = $target->{"type"};
                my scalar $sl_src = $target->{"source"};
                my scalar $sl_items = $target->{"items"};
                my int $sl_ic = $target->{"item_count"};
                my scalar $sl_val = $expr->{"value"};
                # Peel one DEREF_SCALAR so @{$ref}[...] resolves to $ref.
                my scalar $sl_se = $sl_src;
                if ($sl_src->{"type"} == NODE_DEREF_SCALAR()) {
                    $sl_se = $sl_src->{"ref"};
                }
                my int $sl_src_cl = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $sl_se) == 1;
                my int $sl_rhs_cl = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $sl_val) == 1;
                emit($cg, "({ StradaValue *__sas_rhs = ");
                gen_expression($cg, $sl_val);
                emit($cg, "; StradaArray *__sas_rav = strada_deref_array(__sas_rhs); ");
                # A scalar RHS (e.g. `@a[0,1] = $x`, or `(99)` which strada
                # parses as a plain scalar) is a 1-element list in Perl — wrap
                # it so element 0 lands and the rest fill with undef.
                emit($cg, "StradaValue *__sas_rhs1 = NULL; if (!__sas_rav && __sas_rhs) { __sas_rhs1 = strada_new_array(); StradaArray *__sas_one = strada_deref_array(__sas_rhs1); strada_incref(__sas_rhs); strada_array_push_take(__sas_one, __sas_rhs); __sas_rav = __sas_one; } ");
                if ($sl_src_cl == 1) {
                    emit($cg, "StradaValue *__sas_src = ");
                    gen_expression($cg, $sl_se);
                    emit($cg, "; StradaArray *__sas_tav = strada_deref_array(__sas_src); ");
                } else {
                    emit($cg, "StradaArray *__sas_tav = strada_deref_array(");
                    gen_expression($cg, $sl_se);
                    emit($cg, "); ");
                }
                emit($cg, "int64_t __sas_j = 0; ");
                for (my int $si = 0; $si < $sl_ic; $si = $si + 1) {
                    my scalar $sl_item = $sl_items->[$si];
                    if ($sl_item->{"type"} == NODE_RANGE()) {
                        emit($cg, "for (int64_t __sl_i = ");
                        emit_int_operand($cg, $sl_item->{"start"});
                        emit($cg, "; __sl_i <= ");
                        emit_int_operand($cg, $sl_item->{"end"});
                        emit($cg, "; __sl_i++) { strada_array_set(__sas_tav, __sl_i, (__sas_rav && __sas_j < (int64_t)__sas_rav->size) ? strada_array_get(__sas_rav, __sas_j) : strada_undef_static()); __sas_j++; } ");
                    } else {
                        emit($cg, "strada_array_set(__sas_tav, ");
                        emit_int_operand($cg, $sl_item);
                        emit($cg, ", (__sas_rav && __sas_j < (int64_t)__sas_rav->size) ? strada_array_get(__sas_rav, __sas_j) : strada_undef_static()); __sas_j++; ");
                    }
                }
                if ($sl_src_cl == 1) {
                    emit($cg, "strada_decref(__sas_src); ");
                }
                emit($cg, "if (__sas_rhs1) strada_decref(__sas_rhs1); ");
                if ($sl_rhs_cl == 1) {
                    emit($cg, "strada_decref(__sas_rhs); ");
                }
                emit($cg, "(StradaValue*)NULL; })");
                return;
}

func gen_assign_hash_slice(scalar $cg, scalar $expr, scalar $target) void {
    my int $type = $expr->{"type"};
    my int $in_extern = $cg->{"in_extern"};
    my int $target_type = $target->{"type"};
                my scalar $hl_src = $target->{"source"};
                my scalar $hl_items = $target->{"items"};
                my int $hl_ic = $target->{"item_count"};
                my scalar $hl_val = $expr->{"value"};
                my scalar $hl_se = $hl_src;
                if ($hl_src->{"type"} == NODE_DEREF_SCALAR()) {
                    $hl_se = $hl_src->{"ref"};
                }
                my int $hl_src_cl = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $hl_se) == 1;
                my int $hl_rhs_cl = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $hl_val) == 1;
                emit($cg, "({ StradaValue *__shs_rhs = ");
                gen_expression($cg, $hl_val);
                emit($cg, "; StradaArray *__shs_rav = strada_deref_array(__shs_rhs); ");
                emit($cg, "StradaValue *__shs_rhs1 = NULL; if (!__shs_rav && __shs_rhs) { __shs_rhs1 = strada_new_array(); StradaArray *__shs_one = strada_deref_array(__shs_rhs1); strada_incref(__shs_rhs); strada_array_push_take(__shs_one, __shs_rhs); __shs_rav = __shs_one; } ");
                emit($cg, "StradaValue *__shs_src = ");
                gen_expression($cg, $hl_se);
                emit($cg, "; int64_t __shs_j = 0; ");
                for (my int $hi = 0; $hi < $hl_ic; $hi = $hi + 1) {
                    my scalar $hl_item = $hl_items->[$hi];
                    if ($hl_item->{"type"} == NODE_STR_LITERAL()) {
                        emit($cg, "strada_hv_store(__shs_src, ");
                        gen_str_literal_c($cg, $hl_item->{"value"});
                        emit($cg, ", (__shs_rav && __shs_j < (int64_t)__shs_rav->size) ? strada_array_get(__shs_rav, __shs_j) : strada_undef_static()); __shs_j++; ");
                    } else {
                        my int $hl_k_cl = needs_temp_cleanup($cg, $hl_item);
                        emit($cg, "{ StradaValue *__shs_k = ");
                        gen_expression($cg, $hl_item);
                        emit($cg, "; char *__shs_ks = strada_to_str_ss(__shs_k); strada_hv_store(__shs_src, __shs_ks, (__shs_rav && __shs_j < (int64_t)__shs_rav->size) ? strada_array_get(__shs_rav, __shs_j) : strada_undef_static()); __shs_j++; strada_cstr_free(__shs_ks); ");
                        if ($hl_k_cl == 1) {
                            emit($cg, "strada_decref(__shs_k); ");
                        }
                        emit($cg, "} ");
                    }
                }
                if ($hl_src_cl == 1) {
                    emit($cg, "strada_decref(__shs_src); ");
                }
                emit($cg, "if (__shs_rhs1) strada_decref(__shs_rhs1); ");
                if ($hl_rhs_cl == 1) {
                    emit($cg, "strada_decref(__shs_rhs); ");
                }
                emit($cg, "(StradaValue*)NULL; })");
                return;
}

func gen_assign_deref_scalar(scalar $cg, scalar $expr, scalar $target) void {
    my int $type = $expr->{"type"};
    my int $in_extern = $cg->{"in_extern"};
    my int $target_type = $target->{"type"};
                my int $ref_needs_cleanup = 0;
                my int $val_needs_cleanup = 0;
                if ($cg->{"cleanup_enabled"} == 1) {
                    $ref_needs_cleanup = needs_temp_cleanup($cg, $target->{"ref"});
                    $val_needs_cleanup = needs_temp_cleanup($cg, $expr->{"value"});
                }
                if ($ref_needs_cleanup == 1 || $val_needs_cleanup == 1) {
                    emit($cg, "({ ");
                    if ($ref_needs_cleanup == 1) {
                        emit($cg, "StradaValue *__ds_ref = ");
                        gen_expression($cg, $target->{"ref"});
                        emit($cg, "; ");
                    }
                    if ($val_needs_cleanup == 1) {
                        emit($cg, "StradaValue *__ds_val = ");
                        gen_expression($cg, $expr->{"value"});
                        emit($cg, "; ");
                    }
                    emit($cg, "strada_deref_set(");
                    if ($ref_needs_cleanup == 1) {
                        emit($cg, "__ds_ref");
                    } else {
                        gen_expression($cg, $target->{"ref"});
                    }
                    emit($cg, ", ");
                    if ($val_needs_cleanup == 1) {
                        emit($cg, "__ds_val");
                    } else {
                        gen_expression($cg, $expr->{"value"});
                    }
                    emit($cg, "); ");
                    if ($ref_needs_cleanup == 1) {
                        emit($cg, "strada_decref(__ds_ref); ");
                    }
                    if ($val_needs_cleanup == 1) {
                        emit($cg, "strada_decref(__ds_val); ");
                    }
                    emit($cg, "})");
                } else {
                    emit($cg, "strada_deref_set(");
                    gen_expression($cg, $target->{"ref"});
                    emit($cg, ", ");
                    gen_expression($cg, $expr->{"value"});
                    emit($cg, ")");
                }
                return;
}

func gen_assign_node(scalar $cg, scalar $expr) void {
    my int $type = $expr->{"type"};
    my int $in_extern = $cg->{"in_extern"};
        my str $op = $expr->{"op"};
        my scalar $target = $expr->{"target"};
        my int $target_type = $target->{"type"};
        
        if ($op eq "=") {
            # Special case: substr($s, offset, len) = value — in-place string modification
            if ($target_type == NODE_CALL()) {
                my str $call_name = "" . $target->{"name"};
                if ($call_name eq "substr") {
                    my int $sargc = $target->{"arg_count"} + 0;
                    my scalar $sargs = $target->{"args"};
                    if ($sargc >= 2) {
                        emit($cg, "({ StradaValue *__sa_sv = ");
                        gen_expression($cg, $expr->{"value"});
                        emit($cg, "; char *__sa_r = strada_to_str(__sa_sv); strada_substr_assign(&");
                        gen_expression($cg, $sargs->[0]);
                        emit($cg, ", (int64_t)strada_to_int(");
                        gen_expression($cg, $sargs->[1]);
                        emit($cg, "), ");
                        if ($sargc >= 3) {
                            emit($cg, "(int64_t)strada_to_int(");
                            gen_expression($cg, $sargs->[2]);
                            emit($cg, ")");
                        } else {
                            emit($cg, "(int64_t)999999");
                        }
                        emit($cg, ", __sa_r); free(__sa_r); strada_decref(__sa_sv); (StradaValue*)NULL; })");
                        return;
                    }
                }
            }
            # Special case: hash assignment %hash{key} = value
            # strada_hash_set handles incref internally for shared ownership
            # For anonymous values, we need to decref after hash_set takes ownership
            if ($target_type == NODE_HASH_ACCESS()) { gen_assign_hash_access($cg, $expr, $target); return; }
            # Special case: hash deref assignment $ref->{key} = value
            # strada_hash_set handles incref internally for shared ownership
            # For anonymous values, we need to decref after hash_set takes ownership
            if ($target_type == NODE_DEREF_HASH()) { gen_assign_deref_hash($cg, $expr, $target); return; }
            # Special case: array subscript assignment $arr[idx] = value
            if ($target_type == NODE_SUBSCRIPT()) { gen_assign_subscript($cg, $expr, $target); return; }
            # Special case: array deref assignment $ref->[idx] = value
            if ($target_type == NODE_DEREF_ARRAY()) { gen_assign_deref_array($cg, $expr, $target); return; }
            # Special case: array slice assignment  @a[i,j] = LIST  and
            # @{$ref}[i,j] = LIST. A slice node otherwise compiles as a READ
            # (it builds a fresh __slice_res array), which is not an lvalue —
            # so `(read-slice) = (rhs)` was a hard C error ("lvalue required").
            # Emit per-index strada_array_set writes into the target array,
            # pulling values positionally from the RHS list (undef past its
            # end). strada_array_set increfs the value, so we hand it borrowed
            # RHS elements and decref the RHS container once at the end.
            if ($target_type == NODE_ARRAY_SLICE()) { gen_assign_array_slice($cg, $expr, $target); return; }
            # Special case: hash slice assignment  @h{a,b} = LIST  and
            # @{$ref}{a,b} = LIST. Same lvalue problem as array slices.
            if ($target_type == NODE_HASH_SLICE()) { gen_assign_hash_slice($cg, $expr, $target); return; }
            # Special case: scalar deref assignment $$ref = value
            if ($target_type == NODE_DEREF_SCALAR()) { gen_assign_deref_scalar($cg, $expr, $target); return; }
            # Special case: assigning scalar to array variable @arr = ($x)
            if ($target_type == NODE_VARIABLE() && $target->{"sigil"} eq "@") {
                # Check if it's an 'our' array — use global_set
                my str $arr_our_name = escape_c_keyword($target->{"name"});
                my scalar $arr_our_vars = $cg->{"our_vars"};
                my str $arr_our_key = "" . $arr_our_vars->{$arr_our_name};
                if (length($arr_our_key) > 0) {
                    my int $rhs_needs_cleanup = needs_temp_cleanup($cg, $expr->{"value"});
                    emit($cg, "({ StradaValue *__oa_val = ");
                    gen_expression($cg, $expr->{"value"});
                    if ($rhs_needs_cleanup == 0) {
                        emit($cg, "; strada_incref(__oa_val)");
                    }
                    emit($cg, "; strada_global_set_cstr(\"" . $arr_our_key . "\", __oa_val); (StradaValue*)NULL; })");
                    return;
                }
                my scalar $val = $expr->{"value"};
                my int $val_type = $val->{"type"};
                if ($val_type == NODE_READLINE()) {
                    # Diamond operator in array context - read all lines
                    my str $varname = $val->{"varname"};
                    if ($cg->{"cleanup_enabled"} == 1) {
                        emit($cg, "({ StradaValue *__old = ");
                        gen_expression($cg, $target);
                        emit($cg, "; ");
                    }
                    gen_expression($cg, $target);
                    emit($cg, " = strada_read_all_lines(" . escape_c_keyword($varname) . ")");
                    if ($cg->{"cleanup_enabled"} == 1) {
                        emit($cg, "; strada_decref(__old); ");
                        gen_expression($cg, $target);
                        emit($cg, "; })");
                    }
                } elsif ($val_type == NODE_ANON_HASH() && $val->{"pair_count"} == 0) {
                    # Empty () - clear and reset array
                    if ($cg->{"cleanup_enabled"} == 1) {
                        emit($cg, "({ StradaValue *__old = ");
                        gen_expression($cg, $target);
                        emit($cg, "; ");
                    }
                    gen_expression($cg, $target);
                    emit($cg, " = strada_new_array()");
                    if ($cg->{"cleanup_enabled"} == 1) {
                        emit($cg, "; strada_decref(__old); ");
                        gen_expression($cg, $target);
                        emit($cg, "; })");
                    }
                } elsif ($val_type == NODE_ANON_ARRAY()) {
                    # Array literal [1, 2, 3] - assign directly
                    if ($cg->{"cleanup_enabled"} == 1) {
                        emit($cg, "({ StradaValue *__old = ");
                        gen_expression($cg, $target);
                        emit($cg, "; ");
                    }
                    gen_expression($cg, $target);
                    emit($cg, " = ");
                    gen_expression($cg, $val);
                    if ($cg->{"cleanup_enabled"} == 1) {
                        emit($cg, "; strada_decref(__old); ");
                        gen_expression($cg, $target);
                        emit($cg, "; })");
                    }
                } elsif (is_scalar_expr($val)) {
                    # Single scalar - wrap in array
                    if ($cg->{"cleanup_enabled"} == 1) {
                        emit($cg, "({ StradaValue *__old = ");
                        gen_expression($cg, $target);
                        emit($cg, "; ");
                    }
                    gen_expression($cg, $target);
                    emit($cg, " = strada_new_array(); strada_array_push(");
                    gen_expression($cg, $target);
                    emit($cg, "->value.av, ");
                    gen_expression($cg, $val);
                    emit($cg, ")");
                    if ($cg->{"cleanup_enabled"} == 1) {
                        emit($cg, "; strada_decref(__old); ");
                        gen_expression($cg, $target);
                        emit($cg, "; })");
                    }
                } else {
                    # Value returns an array - copy if from variable/deref to avoid aliasing
                    my int $val_type2 = $val->{"type"};
                    if ($val_type2 == NODE_VARIABLE() && $val->{"sigil"} eq "%") {
                        # Hash-to-array flattening: @arr = %hash
                        emit($cg, "strada_decref(");
                        gen_expression($cg, $target);
                        emit($cg, "); ");
                        gen_expression($cg, $target);
                        emit($cg, " = strada_hash_to_flat_array(");
                        gen_expression($cg, $val);
                        emit($cg, ")");
                    } elsif ($val_type2 == NODE_VARIABLE() || ($val_type2 == NODE_DEREF_SCALAR() && $val->{"sigil"} eq "@")) {
                        # Decref old array, assign copy
                        emit($cg, "strada_decref(");
                        gen_expression($cg, $target);
                        emit($cg, "); ");
                        gen_expression($cg, $target);
                        emit($cg, " = strada_array_copy(");
                        gen_expression($cg, $val);
                        emit($cg, ")");
                    } else {
                        if ($cg->{"cleanup_enabled"} == 1) {
                            emit($cg, "({ StradaValue *__old = ");
                            gen_expression($cg, $target);
                            emit($cg, "; ");
                        }
                        gen_expression($cg, $target);
                        emit($cg, " = ");
                        gen_expression($cg, $val);
                        if ($cg->{"cleanup_enabled"} == 1) {
                            emit($cg, "; strada_decref(__old); ");
                            gen_expression($cg, $target);
                            emit($cg, "; })");
                        }
                    }
                }
                return;
            }
            # Special case: assigning to hash variable %h = (...)
            if ($target_type == NODE_VARIABLE() && $target->{"sigil"} eq "%") {
                my scalar $val = $expr->{"value"};
                my int $val_type = $val->{"type"};
                if ($val_type == NODE_ANON_HASH() && $val->{"pair_count"} == 0) {
                    # Empty () - clear hash: %h = ()
                    if ($cg->{"cleanup_enabled"} == 1) {
                        emit($cg, "({ StradaValue *__old = ");
                        gen_expression($cg, $target);
                        emit($cg, "; ");
                    }
                    gen_expression($cg, $target);
                    emit($cg, " = strada_new_hash()");
                    if ($cg->{"cleanup_enabled"} == 1) {
                        emit($cg, "; strada_decref(__old); ");
                        gen_expression($cg, $target);
                        emit($cg, "; })");
                    }
                } elsif ($val_type == NODE_ANON_ARRAY() || $val_type == NODE_MAP()) {
                    # List init: %h = ("a" => 1, "b" => 2) or %h = map { ... } @arr
                    if ($cg->{"cleanup_enabled"} == 1) {
                        emit($cg, "({ StradaValue *__old = ");
                        gen_expression($cg, $target);
                        emit($cg, "; ");
                    }
                    gen_expression($cg, $target);
                    emit($cg, " = strada_hash_from_flat_array(");
                    gen_expression($cg, $val);
                    emit($cg, ")");
                    if ($cg->{"cleanup_enabled"} == 1) {
                        emit($cg, "; strada_decref(__old); ");
                        gen_expression($cg, $target);
                        emit($cg, "; })");
                    }
                } elsif ($val_type == NODE_VARIABLE() && $val->{"sigil"} eq "@") {
                    # Hash from flat array: %h = @pairs
                    if ($cg->{"cleanup_enabled"} == 1) {
                        emit($cg, "({ StradaValue *__old = ");
                        gen_expression($cg, $target);
                        emit($cg, "; ");
                    }
                    gen_expression($cg, $target);
                    emit($cg, " = strada_hash_from_flat_array(");
                    gen_expression($cg, $val);
                    emit($cg, ")");
                    if ($cg->{"cleanup_enabled"} == 1) {
                        emit($cg, "; strada_decref(__old); ");
                        gen_expression($cg, $target);
                        emit($cg, "; })");
                    }
                } elsif ($val_type == NODE_VARIABLE() && $val->{"sigil"} eq "%") {
                    # Hash copy: %h = %other
                    emit($cg, "strada_decref(");
                    gen_expression($cg, $target);
                    emit($cg, "); ");
                    gen_expression($cg, $target);
                    emit($cg, " = strada_hash_from_ref(");
                    gen_expression($cg, $val);
                    emit($cg, ")");
                } else {
                    # Generic assignment
                    if ($cg->{"cleanup_enabled"} == 1) {
                        emit($cg, "({ StradaValue *__old = ");
                        gen_expression($cg, $target);
                        emit($cg, "; ");
                    }
                    gen_expression($cg, $target);
                    emit($cg, " = ");
                    if ($val_type == NODE_CALL()) {
                        $cg->{"call_context"} = 2;
                    }
                    gen_expression($cg, $val);
                    if ($val_type == NODE_CALL()) {
                        $cg->{"call_context"} = 0;
                    }
                    if ($cg->{"cleanup_enabled"} == 1) {
                        emit($cg, "; strada_decref(__old); ");
                        gen_expression($cg, $target);
                        emit($cg, "; })");
                    }
                }
                return;
            }
            # Check for 'our' variable assignment - use strada_global_set() instead of local assign
            if ($target_type == NODE_VARIABLE()) {
                my str $our_target_name = escape_c_keyword($target->{"name"});
                my scalar $our_vars2 = $cg->{"our_vars"};
                my str $our_key2 = "" . $our_vars2->{$our_target_name};
                if (length($our_key2) > 0) {
                    my scalar $our_rhs = $expr->{"value"};
                    if (needs_temp_cleanup($cg, $our_rhs) == 0) {
                        # RHS is a borrowed/shared ref (local var, array subscript, param).
                        # strada_global_set() consumes the caller's ref, so we need an
                        # extra incref to keep the local/param alive.
                        emit($cg, "({ StradaValue *__gs_v = ");
                        gen_expression($cg, $our_rhs);
                        emit($cg, "; strada_incref(__gs_v); strada_global_set_cstr(\"" . $our_key2 . "\", __gs_v); __gs_v; })");
                    } else {
                        emit($cg, "strada_global_set_cstr(\"" . $our_key2 . "\", ");
                        gen_expression($cg, $our_rhs);
                        emit($cg, ")");
                    }
                    return;
                }
            }
            # $0 assignment: also call setprocname
            if ($target_type == NODE_VARIABLE() && $target->{"name"} eq "__program_name") {
                my scalar $pn_rhs = $expr->{"value"};
                emit($cg, "({ StradaValue *__pn_v = ");
                gen_expression($cg, $pn_rhs);
                emit($cg, "; strada_decref(__program_name); __program_name = __pn_v; strada_incref(__program_name); ");
                emit($cg, "strada_setprocname(__pn_v); __pn_v; })");
                return;
            }

            # Perl-style scalar context: $n = @arr gives array count
            my scalar $sc_rhs = $expr->{"value"};
            if ($target_type == NODE_VARIABLE() && $target->{"sigil"} ne "@" && $target->{"sigil"} ne "%" &&
                $sc_rhs->{"type"} == NODE_VARIABLE() && $sc_rhs->{"sigil"} eq "@") {
                if ($cg->{"cleanup_enabled"} == 1) {
                    emit($cg, "({ StradaValue *__old = ");
                    gen_expression($cg, $target);
                    emit($cg, "; ");
                }
                gen_expression($cg, $target);
                emit($cg, " = STRADA_MAKE_TAGGED_INT((int64_t)strada_size(");
                gen_expression($cg, $sc_rhs);
                emit($cg, "))");
                if ($cg->{"cleanup_enabled"} == 1) {
                    emit($cg, "; strada_decref(__old); ");
                    gen_expression($cg, $target);
                    emit($cg, "; })");
                }
                return;
            }

            # Normal assignment with reference counting
            # Runtime returns owned references, so we just decref the old value
            # For variable-to-variable copy and borrowed references (hash/array access),
            # we need to incref since we're sharing the reference
            my scalar $rhs = $expr->{"value"};
            my int $rhs_type = $rhs->{"type"};
            # Optimize $s = $s . expr → strada_concat_inplace(s, expr)
            if ($target_type == NODE_VARIABLE() && $rhs_type == NODE_BINARY_OP() &&
                $rhs->{"op"} eq ".") {
                my scalar $concat_left = $rhs->{"left"};
                if ($concat_left->{"type"} == NODE_VARIABLE() &&
                    $concat_left->{"name"} eq $target->{"name"}) {
                    my scalar $concat_right = $rhs->{"right"};
                    if ($concat_right->{"type"} == NODE_STR_LITERAL()) {
                        my str $cl = $concat_right->{"value"};
                        gen_expression($cg, $target);
                        emit($cg, " = strada_concat_inplace_cstr(");
                        gen_expression($cg, $target);
                        emit($cg, ", ");
                        gen_str_literal_c($cg, $cl);
                        emit($cg, ", " . length($cl) . ")");
                        return;
                    }
                    if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $concat_right) == 1) {
                        emit($cg, "({ StradaValue *__rhs_tmp = ");
                        gen_expression($cg, $concat_right);
                        emit($cg, "; ");
                        gen_expression($cg, $target);
                        emit($cg, " = strada_concat_inplace(");
                        gen_expression($cg, $target);
                        emit($cg, ", __rhs_tmp); strada_decref(__rhs_tmp); ");
                        gen_expression($cg, $target);
                        emit($cg, "; })");
                    } else {
                        gen_expression($cg, $target);
                        emit($cg, " = strada_concat_inplace(");
                        gen_expression($cg, $target);
                        emit($cg, ", ");
                        gen_expression($cg, $concat_right);
                        emit($cg, ")");
                    }
                    return;
                }
            }
            my int $needs_incref = 0;
            # Variable assignment shares reference
            if ($rhs_type == NODE_VARIABLE()) {
                $needs_incref = 1;
            }
            # Array access returns borrowed reference — must incref to own
            # it — UNLESS the source was owned and codegen used the
            # _owned variant (needs_temp_cleanup detects this).
            if ($rhs_type == NODE_SUBSCRIPT() || $rhs_type == NODE_DEREF_ARRAY()) {
                if (needs_temp_cleanup($cg, $rhs) == 0) {
                    $needs_incref = 1;
                }
            }
            # Ternary and other complex expressions - use return_needs_incref() for proper analysis
            if ($rhs_type == NODE_TERNARY()) {
                $needs_incref = return_needs_incref($cg, $rhs);
            }
            # num-declared targets coerce non-numeric RHS values (mirrors
            # the int coercion below; numeric = tagged int / heap INT / NUM)
            my int $tgt_is_num = 0;
            if ($target_type == NODE_VARIABLE()) {
                my str $tgt_vname = escape_c_keyword($target->{"name"});
                if (length("" . $cg->{"num_vars"}->{$tgt_vname}) > 0) {
                    $tgt_is_num = 1;
                }
            }
            # In-place num accumulate: $numvar = <numeric expr> writes the
            # double into the existing heap NUM when solely owned, skipping
            # the per-iteration box/unbox pair (float accumulators measured
            # ~26x slower than int before this).
            if ($tgt_is_num == 1 && $cg->{"cleanup_enabled"} == 1
                && $cg->{"has_overloads"} == 0
                && expr_is_numeric($cg, $rhs) == 1) {
                emit($cg, "(");
                gen_expression($cg, $target);
                emit($cg, " = strada_num_set_inplace(");
                gen_expression($cg, $target);
                emit($cg, ", ");
                emit_num_operand($cg, $rhs);
                emit($cg, "))");
            } elsif ($tgt_is_num == 1 && $cg->{"cleanup_enabled"} == 1
                && expr_is_numeric($cg, $rhs) == 0) {
                emit($cg, "({ StradaValue *__old = ");
                gen_expression($cg, $target);
                emit($cg, "; StradaValue *__ncv = ");
                gen_expression($cg, $rhs);
                emit($cg, "; ");
                gen_expression($cg, $target);
                emit($cg, " = strada_new_num(strada_to_num(__ncv)); ");
                if (needs_temp_cleanup($cg, $rhs) == 1) {
                    emit($cg, "strada_decref(__ncv); ");
                }
                emit($cg, "strada_decref(__old); ");
                gen_expression($cg, $target);
                emit($cg, "; })");
            # Int-declared targets coerce non-int RHS values to canonical
            # ints — previously `$intvar = $str_scalar` stored the shared
            # string pointer into the "int" variable (type confusion: the
            # variable then printed as the string, and int fast paths read
            # garbage from it).
            } elsif ($target_type == NODE_VARIABLE() && $cg->{"cleanup_enabled"} == 1
                && expr_is_int_typed($cg, $target) == 1 && expr_is_int_typed($cg, $rhs) == 0) {
                emit($cg, "({ StradaValue *__old = ");
                gen_expression($cg, $target);
                emit($cg, "; StradaValue *__icv = ");
                gen_expression($cg, $rhs);
                emit($cg, "; ");
                gen_expression($cg, $target);
                emit($cg, " = strada_new_int(strada_to_int(__icv)); ");
                if (needs_temp_cleanup($cg, $rhs) == 1) {
                    emit($cg, "strada_decref(__icv); ");
                }
                emit($cg, "strada_decref(__old); ");
                gen_expression($cg, $target);
                emit($cg, "; })");
            } elsif ($target_type == NODE_VARIABLE() && $cg->{"cleanup_enabled"} == 1) {
                emit($cg, "({ StradaValue *__old = ");
                gen_expression($cg, $target);
                emit($cg, "; ");
                gen_expression($cg, $target);
                emit($cg, " = ");
                gen_expression($cg, $rhs);
                emit($cg, "; ");
                # Incref for shared references (variables, hash/array access)
                if ($needs_incref == 1) {
                    emit($cg, "strada_incref(");
                    gen_expression($cg, $target);
                    emit($cg, "); ");
                }
                emit($cg, "strada_decref(__old); ");
                gen_expression($cg, $target);
                emit($cg, "; })");
            } else {
                gen_expression($cg, $target);
                emit($cg, " = ");
                gen_expression($cg, $rhs);
            }
        } elsif ($op eq "+=" || $op eq "-=" || $op eq ".=" || $op eq "*=" || $op eq "/=") {
            # Check for 'our' variable compound assignment
            if ($target_type == NODE_VARIABLE()) {
                my str $our_ca_name = escape_c_keyword($target->{"name"});
                my scalar $our_ca_vars = $cg->{"our_vars"};
                my str $our_ca_key = "" . $our_ca_vars->{$our_ca_name};
                if (length($our_ca_key) > 0) {
                    # Read current value, compute new value, set it
                    # Capture RHS in temp to avoid leaking it
                    emit($cg, "({ StradaValue *__our_old = strada_global_get(strada_new_str(\"" . $our_ca_key . "\")); ");
                    emit($cg, "StradaValue *__our_rhs = ");
                    gen_expression($cg, $expr->{"value"});
                    emit($cg, "; ");
                    if ($op eq ".=") {
                        emit($cg, "StradaValue *__our_new = strada_concat_inplace(__our_old, __our_rhs); ");
                        emit($cg, "strada_decref(__our_rhs); ");
                    } elsif ($op eq "+=") {
                        emit($cg, "StradaValue *__our_new = strada_new_num(strada_to_num(__our_old) + strada_to_num(__our_rhs)); ");
                        emit($cg, "strada_decref(__our_rhs); strada_decref(__our_old); ");
                    } elsif ($op eq "*=") {
                        emit($cg, "StradaValue *__our_new = strada_new_num(strada_to_num(__our_old) * strada_to_num(__our_rhs)); ");
                        emit($cg, "strada_decref(__our_rhs); strada_decref(__our_old); ");
                    } elsif ($op eq "/=") {
                        emit($cg, "StradaValue *__our_new = strada_new_num(strada_to_num(__our_old) / strada_to_num(__our_rhs)); ");
                        emit($cg, "strada_decref(__our_rhs); strada_decref(__our_old); ");
                    } else {
                        emit($cg, "StradaValue *__our_new = strada_new_num(strada_to_num(__our_old) - strada_to_num(__our_rhs)); ");
                        emit($cg, "strada_decref(__our_rhs); strada_decref(__our_old); ");
                    }
                    emit($cg, "strada_global_set_cstr(\"" . $our_ca_key . "\", __our_new); })");
                    return;
                }
            }
            # Compound assignment on hash element: $h{"k"} += expr
            if ($target_type == NODE_HASH_ACCESS() || $target_type == NODE_DEREF_HASH()) {
                gen_hash_compound_assign($cg, $target, $expr->{"value"}, $op);
                return;
            }
            # Compound assignment on array element: $a[$i] += expr,
            # OR on deref-array target: $ref->[i] += expr,
            # $h{k}->[i] += expr, etc. gen_array_compound_assign handles
            # both target shapes (NODE_SUBSCRIPT and NODE_DEREF_ARRAY).
            # Without the second branch here, deref-array compound assign
            # fell through to the generic path that emitted the LHS as
            # a statement-expression (not a valid C lvalue).
            if ($target_type == NODE_SUBSCRIPT() || $target_type == NODE_DEREF_ARRAY()) {
                gen_array_compound_assign($cg, $target, $expr->{"value"}, $op);
                return;
            }
            # Check for overloaded compound assignment (Perl: $a += $b uses + overload)
            if ($cg->{"has_overloads"} == 1 && $target_type == NODE_VARIABLE() && could_be_blessed($target) == 1) {
                my str $base_op = "+";
                if ($op eq "-=") {
                    $base_op = "-";
                } elsif ($op eq ".=") {
                    $base_op = ".";
                } elsif ($op eq "*=") {
                    $base_op = "*";
                } elsif ($op eq "/=") {
                    $base_op = "/";
                }
                my scalar $ol_ops = $cg->{"overloaded_ops"};
                my int $base_op_overloaded = 0;
                if (length("" . $ol_ops->{$base_op}) > 0) {
                    $base_op_overloaded = 1;
                }
                if ($op eq ".=") {
                    my str $sq = chr(34) . chr(34);
                    if (length("" . $ol_ops->{$sq}) > 0) {
                        $base_op_overloaded = 1;
                    }
                }
                if ($base_op_overloaded == 1) {
                    my scalar $rhs = $expr->{"value"};
                    my int $rhs_tmp = 0;
                    if ($cg->{"cleanup_enabled"} == 1) {
                        $rhs_tmp = needs_temp_cleanup($cg, $rhs);
                    }
                    emit($cg, "({ StradaValue *__ca_old = ");
                    gen_expression($cg, $target);
                    emit($cg, "; StradaValue *__ca_rhs = ");
                    gen_expression($cg, $rhs);
                    emit($cg, "; StradaValue *__ca_res = ");
                    if ($op eq ".=") {
                        # For .= try both . overload and "" stringify
                        emit($cg, "strada_overload_binary(__ca_old, __ca_rhs, \".\"); ");
                        emit($cg, "if (!__ca_res) { ");
                        emit($cg, "StradaValue *__ca_sl = strada_overload_stringify(__ca_old); ");
                        emit($cg, "StradaValue *__ca_sr = strada_overload_stringify(__ca_rhs); ");
                        # Use strada_concat_sv (borrows BOTH operands, returns a new
                        # value), NOT strada_concat_inplace (which consumes/reuses its
                        # first arg). With concat_inplace the first arg was both
                        # consumed there AND decref'd below (and the trailing
                        # decref(__ca_old) freed the very value assigned to the
                        # target) — a double-decref / use-after-free. concat_sv keeps
                        # all the explicit decrefs balanced.
                        emit($cg, "__ca_res = strada_concat_sv(__ca_sl ? __ca_sl : __ca_old, __ca_sr ? __ca_sr : __ca_rhs); ");
                        emit($cg, "if (__ca_sl) strada_decref(__ca_sl); ");
                        emit($cg, "if (__ca_sr) strada_decref(__ca_sr); } ");
                    } else {
                        emit($cg, "strada_overload_binary(__ca_old, __ca_rhs, \"" . $base_op . "\"); ");
                        if ($op eq "+=") {
                            emit($cg, "if (!__ca_res) __ca_res = strada_new_num(strada_to_num(__ca_old) + strada_to_num(__ca_rhs)); ");
                        } elsif ($op eq "*=") {
                            emit($cg, "if (!__ca_res) __ca_res = strada_new_num(strada_to_num(__ca_old) * strada_to_num(__ca_rhs)); ");
                        } elsif ($op eq "/=") {
                            emit($cg, "if (!__ca_res) __ca_res = strada_new_num(strada_to_num(__ca_old) / strada_to_num(__ca_rhs)); ");
                        } else {
                            emit($cg, "if (!__ca_res) __ca_res = strada_new_num(strada_to_num(__ca_old) - strada_to_num(__ca_rhs)); ");
                        }
                    }
                    if ($rhs_tmp == 1) {
                        emit($cg, "strada_decref(__ca_rhs); ");
                    }
                    gen_expression($cg, $target);
                    emit($cg, " = __ca_res; strada_decref(__ca_old); ");
                    gen_expression($cg, $target);
                    emit($cg, "; })");
                    return;
                }
            }
            if ($op eq "+=") {
            # Check for int arithmetic path (zero-alloc tagged ints)
            my int $use_int = 0;
            if ($cg->{"has_overloads"} == 0 && $target_type == NODE_VARIABLE()) {
                if (expr_is_int_typed($cg, $target) == 1) {
                    $use_int = 1;
                }
            }
            if ($use_int == 1 && $cg->{"cleanup_enabled"} == 1) {
                emit($cg, "({ StradaValue *__old = ");
                gen_expression($cg, $target);
                emit($cg, "; ");
                gen_expression($cg, $target);
                emit($cg, " = STRADA_MAKE_TAGGED_INT(strada_to_int(__old) + ");
                emit_int_operand($cg, $expr->{"value"});
                emit($cg, "); strada_decref(__old); ");
                gen_expression($cg, $target);
                emit($cg, "; })");
            } elsif ($target_type == NODE_VARIABLE() && $cg->{"cleanup_enabled"} == 1
                && $cg->{"has_overloads"} == 0
                && length("" . $cg->{"num_vars"}->{escape_c_keyword($target->{"name"})}) > 0) {
                # num-declared target: in-place store (see strada_num_set_inplace)
                emit($cg, "(");
                gen_expression($cg, $target);
                emit($cg, " = strada_num_set_inplace(");
                gen_expression($cg, $target);
                emit($cg, ", strada_to_num(");
                gen_expression($cg, $target);
                emit($cg, ") + ");
                emit_num_operand($cg, $expr->{"value"});
                emit($cg, "))");
            } elsif ($target_type == NODE_VARIABLE() && $cg->{"cleanup_enabled"} == 1) {
                emit($cg, "({ StradaValue *__old = ");
                gen_expression($cg, $target);
                emit($cg, "; ");
                gen_expression($cg, $target);
                emit($cg, " = strada_new_num(strada_to_num(__old) + ");
                emit_num_operand($cg, $expr->{"value"});
                emit($cg, "); strada_decref(__old); ");
                gen_expression($cg, $target);
                emit($cg, "; })");
            } else {
                gen_expression($cg, $target);
                emit($cg, " = strada_new_num(strada_to_num(");
                gen_expression($cg, $target);
                emit($cg, ") + ");
                emit_num_operand($cg, $expr->{"value"});
                emit($cg, ")");
            }
            } elsif ($op eq "-=") {
            my int $use_int2 = 0;
            if ($cg->{"has_overloads"} == 0 && $target_type == NODE_VARIABLE()) {
                if (expr_is_int_typed($cg, $target) == 1) {
                    $use_int2 = 1;
                }
            }
            if ($use_int2 == 1 && $cg->{"cleanup_enabled"} == 1) {
                emit($cg, "({ StradaValue *__old = ");
                gen_expression($cg, $target);
                emit($cg, "; ");
                gen_expression($cg, $target);
                emit($cg, " = STRADA_MAKE_TAGGED_INT(strada_to_int(__old) - ");
                emit_int_operand($cg, $expr->{"value"});
                emit($cg, "); strada_decref(__old); ");
                gen_expression($cg, $target);
                emit($cg, "; })");
            } elsif ($target_type == NODE_VARIABLE() && $cg->{"cleanup_enabled"} == 1
                && $cg->{"has_overloads"} == 0
                && length("" . $cg->{"num_vars"}->{escape_c_keyword($target->{"name"})}) > 0) {
                # num-declared target: in-place store (see strada_num_set_inplace)
                emit($cg, "(");
                gen_expression($cg, $target);
                emit($cg, " = strada_num_set_inplace(");
                gen_expression($cg, $target);
                emit($cg, ", strada_to_num(");
                gen_expression($cg, $target);
                emit($cg, ") - ");
                emit_num_operand($cg, $expr->{"value"});
                emit($cg, "))");
            } elsif ($target_type == NODE_VARIABLE() && $cg->{"cleanup_enabled"} == 1) {
                emit($cg, "({ StradaValue *__old = ");
                gen_expression($cg, $target);
                emit($cg, "; ");
                gen_expression($cg, $target);
                emit($cg, " = strada_new_num(strada_to_num(__old) - ");
                emit_num_operand($cg, $expr->{"value"});
                emit($cg, "); strada_decref(__old); ");
                gen_expression($cg, $target);
                emit($cg, "; })");
            } else {
                gen_expression($cg, $target);
                emit($cg, " = strada_new_num(strada_to_num(");
                gen_expression($cg, $target);
                emit($cg, ") - ");
                emit_num_operand($cg, $expr->{"value"});
                emit($cg, ")");
            }
            } elsif ($op eq "*=") {
            # Mirrors -=: int fast path keeps tagged ints, else boxed num
            my int $use_int3 = 0;
            if ($cg->{"has_overloads"} == 0 && $target_type == NODE_VARIABLE()) {
                if (expr_is_int_typed($cg, $target) == 1) {
                    $use_int3 = 1;
                }
            }
            if ($use_int3 == 1 && $cg->{"cleanup_enabled"} == 1) {
                emit($cg, "({ StradaValue *__old = ");
                gen_expression($cg, $target);
                emit($cg, "; ");
                gen_expression($cg, $target);
                emit($cg, " = STRADA_MAKE_TAGGED_INT(strada_to_int(__old) * ");
                emit_int_operand($cg, $expr->{"value"});
                emit($cg, "); strada_decref(__old); ");
                gen_expression($cg, $target);
                emit($cg, "; })");
            } elsif ($target_type == NODE_VARIABLE() && $cg->{"cleanup_enabled"} == 1
                && $cg->{"has_overloads"} == 0
                && length("" . $cg->{"num_vars"}->{escape_c_keyword($target->{"name"})}) > 0) {
                # num-declared target: in-place store (see strada_num_set_inplace)
                emit($cg, "(");
                gen_expression($cg, $target);
                emit($cg, " = strada_num_set_inplace(");
                gen_expression($cg, $target);
                emit($cg, ", strada_to_num(");
                gen_expression($cg, $target);
                emit($cg, ") * ");
                emit_num_operand($cg, $expr->{"value"});
                emit($cg, "))");
            } elsif ($target_type == NODE_VARIABLE() && $cg->{"cleanup_enabled"} == 1) {
                emit($cg, "({ StradaValue *__old = ");
                gen_expression($cg, $target);
                emit($cg, "; ");
                gen_expression($cg, $target);
                emit($cg, " = strada_new_num(strada_to_num(__old) * ");
                emit_num_operand($cg, $expr->{"value"});
                emit($cg, "); strada_decref(__old); ");
                gen_expression($cg, $target);
                emit($cg, "; })");
            } else {
                gen_expression($cg, $target);
                emit($cg, " = strada_new_num(strada_to_num(");
                gen_expression($cg, $target);
                emit($cg, ") * ");
                emit_num_operand($cg, $expr->{"value"});
                emit($cg, ")");
            }
            } elsif ($op eq "/=") {
            # Always the num path — int/int division isn't int (Perl semantics)
            if ($target_type == NODE_VARIABLE() && $cg->{"cleanup_enabled"} == 1
                && $cg->{"has_overloads"} == 0
                && length("" . $cg->{"num_vars"}->{escape_c_keyword($target->{"name"})}) > 0) {
                # num-declared target: in-place store (see strada_num_set_inplace)
                emit($cg, "(");
                gen_expression($cg, $target);
                emit($cg, " = strada_num_set_inplace(");
                gen_expression($cg, $target);
                emit($cg, ", strada_to_num(");
                gen_expression($cg, $target);
                emit($cg, ") / ");
                emit_num_operand($cg, $expr->{"value"});
                emit($cg, "))");
            } elsif ($target_type == NODE_VARIABLE() && $cg->{"cleanup_enabled"} == 1) {
                emit($cg, "({ StradaValue *__old = ");
                gen_expression($cg, $target);
                emit($cg, "; ");
                gen_expression($cg, $target);
                emit($cg, " = strada_new_num(strada_to_num(__old) / ");
                emit_num_operand($cg, $expr->{"value"});
                emit($cg, "); strada_decref(__old); ");
                gen_expression($cg, $target);
                emit($cg, "; })");
            } else {
                gen_expression($cg, $target);
                emit($cg, " = strada_new_num(strada_to_num(");
                gen_expression($cg, $target);
                emit($cg, ") / ");
                emit_num_operand($cg, $expr->{"value"});
                emit($cg, ")");
            }
            } elsif ($op eq ".=") {
            my scalar $rhs_val = $expr->{"value"};
            # Fast path: .= "string literal" — direct C string append, no StradaValue
            if ($rhs_val->{"type"} == NODE_STR_LITERAL()) {
                my str $lit_val = $rhs_val->{"value"};
                my int $lit_len = length($lit_val);
                gen_expression($cg, $target);
                emit($cg, " = strada_concat_inplace_cstr(");
                gen_expression($cg, $target);
                emit($cg, ", ");
                gen_str_literal_c($cg, $lit_val);
                emit($cg, ", " . $lit_len . ")");
            } elsif ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $rhs_val) == 1) {
                emit($cg, "({ StradaValue *__rhs_tmp = ");
                gen_expression($cg, $rhs_val);
                emit($cg, "; ");
                gen_expression($cg, $target);
                emit($cg, " = strada_concat_inplace(");
                gen_expression($cg, $target);
                emit($cg, ", __rhs_tmp); strada_decref(__rhs_tmp); ");
                gen_expression($cg, $target);
                emit($cg, "; })");
            } else {
                gen_expression($cg, $target);
                emit($cg, " = strada_concat_inplace(");
                gen_expression($cg, $target);
                emit($cg, ", ");
                gen_expression($cg, $rhs_val);
                emit($cg, ")");
            }
            }
        }
        return;
}

func gen_binop_node(scalar $cg, scalar $expr) void {
    my int $type = $expr->{"type"};
    my int $in_extern = $cg->{"in_extern"};
        my str $op = $expr->{"op"};

        # For extern functions, generate raw C arithmetic
        if ($in_extern) {
            if ($op eq "+" || $op eq "-" || $op eq "*" || $op eq "/" || $op eq "%") {
                emit($cg, "(");
                gen_expression($cg, $expr->{"left"});
                emit($cg, " " . $op . " ");
                gen_expression($cg, $expr->{"right"});
                emit($cg, ")");
            } elsif ($op eq "**") {
                # Exponentiation in extern - use pow()
                emit($cg, "pow(");
                gen_expression($cg, $expr->{"left"});
                emit($cg, ", ");
                gen_expression($cg, $expr->{"right"});
                emit($cg, ")");
            } elsif ($op eq "==" || $op eq "!=" || $op eq "<" || $op eq ">" || $op eq "<=" || $op eq ">=") {
                emit($cg, "(");
                gen_expression($cg, $expr->{"left"});
                emit($cg, " " . $op . " ");
                gen_expression($cg, $expr->{"right"});
                emit($cg, ")");
            } elsif ($op eq "&&" || $op eq "||" || $op eq "&" || $op eq "|" || $op eq "^" || $op eq "<<" || $op eq ">>") {
                emit($cg, "(");
                gen_expression($cg, $expr->{"left"});
                emit($cg, " " . $op . " ");
                gen_expression($cg, $expr->{"right"});
                emit($cg, ")");
            } elsif ($op eq ".") {
                # String concatenation in extern mode - use strada_cstr_concat helper
                # Need to convert non-string types to strings
                emit($cg, "strada_cstr_concat(");
                emit_extern_str_operand($cg, $expr->{"left"});
                emit($cg, ", ");
                emit_extern_str_operand($cg, $expr->{"right"});
                emit($cg, ")");
            } else {
                # Fallback for other ops
                emit($cg, "(");
                gen_expression($cg, $expr->{"left"});
                emit($cg, " " . $op . " ");
                gen_expression($cg, $expr->{"right"});
                emit($cg, ")");
            }
            return;
        }

        # Operator overloading dispatch for binary operators
        if ($op eq "+" || $op eq "-" || $op eq "*" || $op eq "/" || $op eq "%" || $op eq "**") {
            my scalar $left = $expr->{"left"};
            my scalar $right = $expr->{"right"};
            if (check_overload_binary($cg, $left, $right, $op) == 1) {
                gen_overloaded_binary($cg, $left, $right, $op);
                return;
            }
        }
        if ($op eq "==" || $op eq "!=" || $op eq "<" || $op eq ">" || $op eq "<=" || $op eq ">=" || $op eq "<=>") {
            my scalar $left = $expr->{"left"};
            my scalar $right = $expr->{"right"};
            if (check_overload_binary($cg, $left, $right, $op) == 1) {
                gen_overloaded_binary($cg, $left, $right, $op);
                return;
            }
        }
        if ($op eq "eq" || $op eq "ne" || $op eq "lt" || $op eq "gt" || $op eq "le" || $op eq "ge" || $op eq "cmp") {
            my scalar $left = $expr->{"left"};
            my scalar $right = $expr->{"right"};
            if (check_overload_binary($cg, $left, $right, $op) == 1) {
                gen_overloaded_binary($cg, $left, $right, $op);
                return;
            }
        }

        if ($op eq "+") {
            if ($cg->{"has_overloads"} == 0 && expr_is_int_typed($cg, $expr->{"left"}) == 1 && expr_is_int_typed($cg, $expr->{"right"}) == 1) {
                if (is_inline_int_accessor_call($cg, $expr->{"left"}) == 1 && accessor_call_eq($expr->{"left"}, $expr->{"right"}) == 1) {
                    my int $cseid = $cg->{"tmp_counter"} + 0;
                    $cg->{"tmp_counter"} = $cseid + 1;
                    emit($cg, "STRADA_MAKE_TAGGED_INT(({ int64_t __cse" . $cseid . " = ");
                    emit_int_operand($cg, $expr->{"left"});
                    emit($cg, "; __cse" . $cseid . " + __cse" . $cseid . "; }))");
                } else {
                    emit($cg, "STRADA_MAKE_TAGGED_INT(");
                    emit_int_operand($cg, $expr->{"left"});
                    emit($cg, " + ");
                    emit_int_operand($cg, $expr->{"right"});
                    emit($cg, ")");
                }
            } else {
                # Runtime tagged int fast-path for scalar + scalar
                my int $uid = $cg->{"tmp_counter"} + 0;
                $cg->{"tmp_counter"} = $uid + 1;
                my str $tl = "__ti_l" . $uid;
                my str $tr = "__ti_r" . $uid;
                my int $cl = needs_temp_cleanup($cg, $expr->{"left"});
                my int $cr = needs_temp_cleanup($cg, $expr->{"right"});
                emit($cg, "({ StradaValue *" . $tl . " = ");
                gen_expression($cg, $expr->{"left"});
                emit($cg, "; StradaValue *" . $tr . " = ");
                gen_expression($cg, $expr->{"right"});
                emit($cg, "; StradaValue *__ti_res" . $uid . " = STRADA_IS_TAGGED_INT(" . $tl . ") && STRADA_IS_TAGGED_INT(" . $tr . ") ? STRADA_MAKE_TAGGED_INT(STRADA_TAGGED_INT_VAL(" . $tl . ") + STRADA_TAGGED_INT_VAL(" . $tr . ")) : strada_new_num(strada_to_num(" . $tl . ") + strada_to_num(" . $tr . ")); ");
                if ($cl == 1) { emit($cg, "if (!STRADA_IS_TAGGED_INT(" . $tl . ")) strada_decref(" . $tl . "); "); }
                if ($cr == 1) { emit($cg, "if (!STRADA_IS_TAGGED_INT(" . $tr . ")) strada_decref(" . $tr . "); "); }
                emit($cg, "__ti_res" . $uid . "; })");
            }
        } elsif ($op eq "-") {
            if ($cg->{"has_overloads"} == 0 && expr_is_int_typed($cg, $expr->{"left"}) == 1 && expr_is_int_typed($cg, $expr->{"right"}) == 1) {
                if (is_inline_int_accessor_call($cg, $expr->{"left"}) == 1 && accessor_call_eq($expr->{"left"}, $expr->{"right"}) == 1) {
                    # x - x = 0 (still emit, in case user wants typed result)
                    my int $cseid = $cg->{"tmp_counter"} + 0;
                    $cg->{"tmp_counter"} = $cseid + 1;
                    emit($cg, "STRADA_MAKE_TAGGED_INT(({ int64_t __cse" . $cseid . " = ");
                    emit_int_operand($cg, $expr->{"left"});
                    emit($cg, "; __cse" . $cseid . " - __cse" . $cseid . "; }))");
                } else {
                    emit($cg, "STRADA_MAKE_TAGGED_INT(");
                    emit_int_operand($cg, $expr->{"left"});
                    emit($cg, " - ");
                    emit_int_operand($cg, $expr->{"right"});
                    emit($cg, ")");
                }
            } else {
                my int $uid = $cg->{"tmp_counter"} + 0;
                $cg->{"tmp_counter"} = $uid + 1;
                my str $tl = "__ti_l" . $uid;
                my str $tr = "__ti_r" . $uid;
                my int $cl = needs_temp_cleanup($cg, $expr->{"left"});
                my int $cr = needs_temp_cleanup($cg, $expr->{"right"});
                emit($cg, "({ StradaValue *" . $tl . " = ");
                gen_expression($cg, $expr->{"left"});
                emit($cg, "; StradaValue *" . $tr . " = ");
                gen_expression($cg, $expr->{"right"});
                emit($cg, "; StradaValue *__ti_res" . $uid . " = STRADA_IS_TAGGED_INT(" . $tl . ") && STRADA_IS_TAGGED_INT(" . $tr . ") ? STRADA_MAKE_TAGGED_INT(STRADA_TAGGED_INT_VAL(" . $tl . ") - STRADA_TAGGED_INT_VAL(" . $tr . ")) : strada_new_num(strada_to_num(" . $tl . ") - strada_to_num(" . $tr . ")); ");
                if ($cl == 1) { emit($cg, "if (!STRADA_IS_TAGGED_INT(" . $tl . ")) strada_decref(" . $tl . "); "); }
                if ($cr == 1) { emit($cg, "if (!STRADA_IS_TAGGED_INT(" . $tr . ")) strada_decref(" . $tr . "); "); }
                emit($cg, "__ti_res" . $uid . "; })");
            }
        } elsif ($op eq "*") {
            if ($cg->{"has_overloads"} == 0 && expr_is_int_typed($cg, $expr->{"left"}) == 1 && expr_is_int_typed($cg, $expr->{"right"}) == 1) {
                if (is_inline_int_accessor_call($cg, $expr->{"left"}) == 1 && accessor_call_eq($expr->{"left"}, $expr->{"right"}) == 1) {
                    my int $cseid = $cg->{"tmp_counter"} + 0;
                    $cg->{"tmp_counter"} = $cseid + 1;
                    emit($cg, "STRADA_MAKE_TAGGED_INT(({ int64_t __cse" . $cseid . " = ");
                    emit_int_operand($cg, $expr->{"left"});
                    emit($cg, "; __cse" . $cseid . " * __cse" . $cseid . "; }))");
                } else {
                    emit($cg, "STRADA_MAKE_TAGGED_INT(");
                    emit_int_operand($cg, $expr->{"left"});
                    emit($cg, " * ");
                    emit_int_operand($cg, $expr->{"right"});
                    emit($cg, ")");
                }
            } else {
                my int $uid = $cg->{"tmp_counter"} + 0;
                $cg->{"tmp_counter"} = $uid + 1;
                my str $tl = "__ti_l" . $uid;
                my str $tr = "__ti_r" . $uid;
                my int $cl = needs_temp_cleanup($cg, $expr->{"left"});
                my int $cr = needs_temp_cleanup($cg, $expr->{"right"});
                emit($cg, "({ StradaValue *" . $tl . " = ");
                gen_expression($cg, $expr->{"left"});
                emit($cg, "; StradaValue *" . $tr . " = ");
                gen_expression($cg, $expr->{"right"});
                emit($cg, "; StradaValue *__ti_res" . $uid . " = STRADA_IS_TAGGED_INT(" . $tl . ") && STRADA_IS_TAGGED_INT(" . $tr . ") ? STRADA_MAKE_TAGGED_INT(STRADA_TAGGED_INT_VAL(" . $tl . ") * STRADA_TAGGED_INT_VAL(" . $tr . ")) : strada_new_num(strada_to_num(" . $tl . ") * strada_to_num(" . $tr . ")); ");
                if ($cl == 1) { emit($cg, "if (!STRADA_IS_TAGGED_INT(" . $tl . ")) strada_decref(" . $tl . "); "); }
                if ($cr == 1) { emit($cg, "if (!STRADA_IS_TAGGED_INT(" . $tr . ")) strada_decref(" . $tr . "); "); }
                emit($cg, "__ti_res" . $uid . "; })");
            }
        } elsif ($op eq "/") {
            # Safe division - returns undef if divisor is zero
            emit($cg, "strada_safe_div(");
            emit_num_operand($cg, $expr->{"left"});
            emit($cg, ", ");
            emit_num_operand($cg, $expr->{"right"});
            emit($cg, ")");
        } elsif ($op eq "**") {
            # Exponentiation - use pow() from math.h
            emit($cg, "strada_new_num(pow(");
            emit_num_operand($cg, $expr->{"left"});
            emit($cg, ", ");
            emit_num_operand($cg, $expr->{"right"});
            emit($cg, "))");
        } elsif ($op eq "%") {
            if ($cg->{"has_overloads"} == 0 && expr_is_int_typed($cg, $expr->{"left"}) == 1 && expr_is_int_typed($cg, $expr->{"right"}) == 1) {
                # Inline tagged int modulo (with zero guard)
                emit($cg, "({ int64_t __ml = ");
                emit_int_operand($cg, $expr->{"left"});
                emit($cg, "; int64_t __mr = ");
                emit_int_operand($cg, $expr->{"right"});
                # Perl floored modulo (sign of the right operand) via the shared
                # header helper — also sidesteps the frozen bootstrap string
                # handler's corruption of a literal "% __" substring.
                emit($cg, "; __mr != 0 ? STRADA_MAKE_TAGGED_INT(strada_floored_mod(__ml, __mr)) : strada_new_undef(); })");
            } else {
                # Runtime fast-path for tagged int modulo.
                # Decref each operand if it was an owned temp — the
                # original code never decref'd __al / __ar, leaking
                # one SV per heap-allocated operand (e.g. `$bignum %
                # 17.0` allocated a num for 17.0 and never freed it).
                my int $mod_l_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $expr->{"left"}) == 1;
                my int $mod_r_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $expr->{"right"}) == 1;
                emit($cg, "({ StradaValue *__al = ");
                gen_expression($cg, $expr->{"left"});
                emit($cg, "; StradaValue *__ar = ");
                gen_expression($cg, $expr->{"right"});
                emit($cg, "; StradaValue *__am_res = (STRADA_IS_TAGGED_INT(__al) && STRADA_IS_TAGGED_INT(__ar) && STRADA_TAGGED_INT_VAL(__ar) != 0) ? STRADA_MAKE_TAGGED_INT(strada_floored_mod(STRADA_TAGGED_INT_VAL(__al), STRADA_TAGGED_INT_VAL(__ar))) : strada_safe_mod(strada_to_int(__al), strada_to_int(__ar)); ");
                if ($mod_l_cleanup == 1) { emit($cg, "strada_decref(__al); "); }
                if ($mod_r_cleanup == 1) { emit($cg, "strada_decref(__ar); "); }
                emit($cg, "__am_res; })");
            }
        } elsif ($op eq "x") {
            # String repetition: "ab" x 3
            my int $left_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $expr->{"left"}) == 1;
            if ($left_cleanup == 1) {
                emit($cg, "({ StradaValue *__rep_s = ");
                gen_expression($cg, $expr->{"left"});
                # Push so a throwing RHS doesn't leak the LHS string.
                emit($cg, "; strada_cleanup_push(__rep_s); StradaValue *__rep_r = strada_string_repeat(__rep_s, (int64_t)");
                emit_int_operand($cg, $expr->{"right"});
                emit($cg, "); strada_cleanup_pop(); strada_decref(__rep_s); __rep_r; })");
            } else {
                emit($cg, "strada_string_repeat(");
                gen_expression($cg, $expr->{"left"});
                emit($cg, ", (int64_t)");
                emit_int_operand($cg, $expr->{"right"});
                emit($cg, ")");
            }
        } elsif ($op eq ".") {
            # Check for stringify ("") or concat (.) overloading
            my scalar $left = $expr->{"left"};
            my scalar $right = $expr->{"right"};

            if ($cg->{"has_overloads"} == 1) {
                my int $has_dot = 0;
                my int $has_stringify = 0;
                my scalar $ol_ops2 = $cg->{"overloaded_ops"};
                my str $dot_check = "" . $ol_ops2->{"."};
                if (length($dot_check) > 0) { $has_dot = 1; }
                my str $str_check = "" . $ol_ops2->{"\"\""};
                if (length($str_check) > 0) { $has_stringify = 1; }
                if (($has_dot == 1 || $has_stringify == 1) &&
                    (could_be_blessed($left) == 1 || could_be_blessed($right) == 1)) {
                    if ($has_dot == 1) {
                        # Full concat overload (checks . operator first, then falls back)
                        gen_overloaded_binary($cg, $left, $right, ".");
                    } else {
                        # Only stringify overload - stringify both sides then concat
                        gen_overloaded_concat($cg, $left, $right);
                    }
                    return;
                }
            }

            # Multi-part chains (string interpolation desugars to these):
            # flatten to one strada_concat_multi call — single exactly-sized
            # allocation instead of a concat call per part.
            if (concat_chain_count($expr) >= 3) {
                if (gen_concat_multi($cg, $expr) == 1) {
                    return;
                }
            }

            # Optimize: "literal" . $expr → strada_concat_cstr_sv(lit, len, expr)
            # Only when the right side doesn't need temp cleanup (hash access returns owned refs)
            if ($left->{"type"} == NODE_STR_LITERAL() && ($cg->{"cleanup_enabled"} == 0 || needs_temp_cleanup($cg, $right) == 0)) {
                my str $lit = $left->{"value"};
                my int $litlen = length($lit);
                emit($cg, "strada_concat_cstr_sv(\"");
                emit_escaped_string($cg, $lit);
                emit($cg, "\", " . $litlen . ", ");
                gen_expression($cg, $right);
                emit($cg, ")");
                return;
            }

            # Fast concat directly on StradaValues - no intermediate copies
            # When cleanup enabled, properly handle temporary arguments
            my int $left_is_temp = 0;
            my int $right_is_temp = 0;
            if ($cg->{"cleanup_enabled"} == 1) {
                if (needs_temp_cleanup($cg, $left) == 1) {
                    $left_is_temp = 1;
                }
                if (needs_temp_cleanup($cg, $right) == 1) {
                    $right_is_temp = 1;
                }
            }

            # Inplace chain: left is a concat result (". " op) → append in-place
            my int $chain_inplace = 0;
            if ($left_is_temp == 1 && $left->{"type"} == NODE_BINARY_OP() && $left->{"op"} eq ".") {
                $chain_inplace = 1;
            }
            if ($chain_inplace == 1 && $right->{"type"} == NODE_STR_LITERAL()) {
                my str $rl = $right->{"value"};
                emit($cg, "({ StradaValue *__concat_l = ");
                gen_expression($cg, $left);
                emit($cg, "; strada_concat_inplace_cstr(__concat_l, ");
                gen_str_literal_c($cg, $rl);
                emit($cg, ", " . length($rl) . "); })");
            } elsif ($chain_inplace == 1) {
                emit($cg, "({ StradaValue *__concat_l = ");
                gen_expression($cg, $left);
                # Push so the throw-on-right path can have the catch
                # decref __concat_l. concat_inplace consumes its first
                # arg, so we pop right before calling it (regardless of
                # whether concat_inplace then frees or reuses __concat_l).
                emit($cg, "; strada_cleanup_push(__concat_l); ");
                if ($right_is_temp == 1) {
                    emit($cg, "StradaValue *__concat_r = ");
                    gen_expression($cg, $right);
                    emit($cg, "; strada_cleanup_pop(); StradaValue *__cr = strada_concat_inplace(__concat_l, __concat_r); strada_decref(__concat_r); __cr; })");
                } else {
                    emit($cg, "strada_cleanup_pop(); strada_concat_inplace(__concat_l, ");
                    gen_expression($cg, $right);
                    emit($cg, "); })");
                }
            } elsif ($left_is_temp == 1 || $right_is_temp == 1) {
                emit($cg, "({ ");
                if ($left_is_temp == 1) {
                    emit($cg, "StradaValue *__concat_l = ");
                    gen_expression($cg, $left);
                    # Push so right-throw doesn't leak the left temp.
                    emit($cg, "; strada_cleanup_push(__concat_l); ");
                }
                if ($right_is_temp == 1) {
                    emit($cg, "StradaValue *__concat_r = ");
                    gen_expression($cg, $right);
                    # Right is now captured; pop left's push so the
                    # normal-path decref below balances cleanly.
                    emit($cg, "; ");
                    if ($left_is_temp == 1) {
                        emit($cg, "strada_cleanup_pop(); ");
                    }
                } elsif ($left_is_temp == 1) {
                    emit($cg, "strada_cleanup_pop(); ");
                }
                emit($cg, "StradaValue *__concat_res = strada_concat_sv(");
                if ($left_is_temp == 1) { emit($cg, "__concat_l"); } else { gen_expression($cg, $left); }
                emit($cg, ", ");
                if ($right_is_temp == 1) { emit($cg, "__concat_r"); } else { gen_expression($cg, $right); }
                emit($cg, "); ");
                if ($left_is_temp == 1) { emit($cg, "strada_decref(__concat_l); "); }
                if ($right_is_temp == 1) { emit($cg, "strada_decref(__concat_r); "); }
                emit($cg, "__concat_res; })");
            } else {
                emit($cg, "strada_concat_sv(");
                gen_expression($cg, $left);
                emit($cg, ", ");
                gen_expression($cg, $right);
                emit($cg, ")");
            }
        } elsif ($op eq "==" || $op eq "!=" || $op eq "<" || $op eq ">" || $op eq "<=" || $op eq ">=") {
            # Numeric comparison in value context. When both sides are int-typed
            # (and no overloads) compare as int64 so integers above 2^53 compare
            # exactly instead of being rounded through double. Mirrors the int
            # branch in emit_condition. The C operator is identical to $op.
            # Use the int64 path only for operands that are NOT function/method
            # calls. A call may return a heap int/num (e.g. a body `return -1;`),
            # which emit_int_operand's tagged-int fast path would misread; route
            # those through emit_num_operand (double) instead — correct, and the
            # values involved are small. Variables/literals/arithmetic keep the
            # exact int64 comparison (the large-int >2^53 precision fix).
            my int $cmp_int = 0;
            if ($cg->{"has_overloads"} == 0
                && expr_is_int_typed($cg, $expr->{"left"}) == 1 && expr_is_int_typed($cg, $expr->{"right"}) == 1
                && $expr->{"left"}->{"type"} != NODE_CALL() && $expr->{"left"}->{"type"} != NODE_METHOD_CALL()
                && $expr->{"right"}->{"type"} != NODE_CALL() && $expr->{"right"}->{"type"} != NODE_METHOD_CALL()) {
                $cmp_int = 1;
            }
            emit($cg, "strada_new_int(");
            if ($cmp_int == 1) { emit_int_operand($cg, $expr->{"left"}); } else { emit_num_operand($cg, $expr->{"left"}); }
            emit($cg, " " . $op . " ");
            if ($cmp_int == 1) { emit_int_operand($cg, $expr->{"right"}); } else { emit_num_operand($cg, $expr->{"right"}); }
            emit($cg, ")");
        } elsif ($op eq "&&") {
            emit($cg, "strada_new_int(");
            emit_bool_operand($cg, $expr->{"left"});
            emit($cg, " && ");
            emit_bool_operand($cg, $expr->{"right"});
            emit($cg, ")");
        } elsif ($op eq "||") {
            # Perl-style || - return left if truthy, otherwise return right
            my scalar $left = $expr->{"left"};
            my scalar $right = $expr->{"right"};
            my int $left_needs_cleanup = needs_temp_cleanup($cg, $left);
            my int $left_needs_incref = return_needs_incref($cg, $left);
            my int $right_needs_incref = return_needs_incref($cg, $right);

            if ($cg->{"cleanup_enabled"} == 1) {
                emit($cg, "({ StradaValue *__or_l = ");
                gen_expression($cg, $left);
                emit($cg, "; StradaValue *__or_r; if (strada_to_bool(__or_l)) { __or_r = __or_l; ");
                if ($left_needs_incref == 1) {
                    emit($cg, "strada_incref(__or_r); ");
                }
                emit($cg, "} else { ");
                if ($left_needs_cleanup == 1) {
                    emit($cg, "strada_decref(__or_l); ");
                }
                emit($cg, "__or_r = ");
                gen_expression($cg, $right);
                emit($cg, "; ");
                if ($right_needs_incref == 1) {
                    emit($cg, "strada_incref(__or_r); ");
                }
                emit($cg, "} __or_r; })");
            } else {
                # No cleanup - simpler form (avoids double-evaluation)
                emit($cg, "({ StradaValue *__or_l = ");
                gen_expression($cg, $left);
                emit($cg, "; strada_to_bool(__or_l) ? __or_l : ");
                gen_expression($cg, $right);
                emit($cg, "; })");
            }
        } elsif ($op eq "//") {
            # Defined-or - return left if defined, otherwise return right
            my scalar $left = $expr->{"left"};
            my scalar $right = $expr->{"right"};
            my int $left_needs_cleanup = needs_temp_cleanup($cg, $left);
            my int $left_needs_incref = return_needs_incref($cg, $left);
            my int $right_needs_incref = return_needs_incref($cg, $right);

            if ($cg->{"cleanup_enabled"} == 1) {
                emit($cg, "({ StradaValue *__dor_l = ");
                gen_expression($cg, $left);
                emit($cg, "; StradaValue *__dor_r; if (strada_defined_bool(__dor_l)) { __dor_r = __dor_l; ");
                if ($left_needs_incref == 1) {
                    emit($cg, "strada_incref(__dor_r); ");
                }
                emit($cg, "} else { ");
                if ($left_needs_cleanup == 1) {
                    emit($cg, "strada_decref(__dor_l); ");
                }
                emit($cg, "__dor_r = ");
                gen_expression($cg, $right);
                emit($cg, "; ");
                if ($right_needs_incref == 1) {
                    emit($cg, "strada_incref(__dor_r); ");
                }
                emit($cg, "} __dor_r; })");
            } else {
                # No cleanup - simpler form
                emit($cg, "({ StradaValue *__dor_l = ");
                gen_expression($cg, $left);
                emit($cg, "; strada_defined_bool(__dor_l) ? __dor_l : ");
                gen_expression($cg, $right);
                emit($cg, "; })");
            }
        } elsif ($op eq "&") {
            emit($cg, "strada_new_int(");
            emit_int_operand($cg, $expr->{"left"});
            emit($cg, " & ");
            emit_int_operand($cg, $expr->{"right"});
            emit($cg, ")");
        } elsif ($op eq "|") {
            emit($cg, "strada_new_int(");
            emit_int_operand($cg, $expr->{"left"});
            emit($cg, " | ");
            emit_int_operand($cg, $expr->{"right"});
            emit($cg, ")");
        } elsif ($op eq "^") {
            emit($cg, "strada_new_int(");
            emit_int_operand($cg, $expr->{"left"});
            emit($cg, " ^ ");
            emit_int_operand($cg, $expr->{"right"});
            emit($cg, ")");
        } elsif ($op eq "<<") {
            emit($cg, "strada_new_int(");
            emit_int_operand($cg, $expr->{"left"});
            emit($cg, " << ");
            emit_int_operand($cg, $expr->{"right"});
            emit($cg, ")");
        } elsif ($op eq ">>") {
            emit($cg, "strada_new_int(");
            emit_int_operand($cg, $expr->{"left"});
            emit($cg, " >> ");
            emit_int_operand($cg, $expr->{"right"});
            emit($cg, ")");
        } elsif ($op eq "eq") {
            gen_str_cmp($cg, $expr, "eq");
        } elsif ($op eq "ne") {
            gen_str_cmp($cg, $expr, "ne");
        } elsif ($op eq "lt") {
            gen_str_cmp($cg, $expr, "lt");
        } elsif ($op eq "gt") {
            gen_str_cmp($cg, $expr, "gt");
        } elsif ($op eq "le") {
            gen_str_cmp($cg, $expr, "le");
        } elsif ($op eq "ge") {
            gen_str_cmp($cg, $expr, "ge");
        } elsif ($op eq "<=>") {
            # Spaceship operator: returns -1, 0, or 1
            # Must cleanup StradaValue temporaries from operands
            my scalar $left = $expr->{"left"};
            my scalar $right = $expr->{"right"};
            my int $left_needs_cleanup = needs_temp_cleanup($cg, $left);
            my int $right_needs_cleanup = needs_temp_cleanup($cg, $right);

            if ($cg->{"has_overloads"} == 0
                && expr_is_int_typed($cg, $left) == 1 && expr_is_int_typed($cg, $right) == 1
                && $left->{"type"} != NODE_CALL() && $left->{"type"} != NODE_METHOD_CALL()
                && $right->{"type"} != NODE_CALL() && $right->{"type"} != NODE_METHOD_CALL()) {
                # Int64 spaceship for non-call operands — avoids double precision
                # loss above 2^53; calls fall through to the double path (correct
                # for heap-int/num returns).
                emit($cg, "STRADA_MAKE_TAGGED_INT(({ int64_t __l = ");
                emit_int_operand($cg, $left);
                emit($cg, "; int64_t __r = ");
                emit_int_operand($cg, $right);
                emit($cg, "; (__l < __r) ? -1 : ((__l > __r) ? 1 : 0); }))");
            } elsif ($cg->{"cleanup_enabled"} == 1 && ($left_needs_cleanup == 1 || $right_needs_cleanup == 1)) {
                emit($cg, "({ StradaValue *__sp_lv = ");
                gen_expression($cg, $left);
                emit($cg, "; StradaValue *__sp_rv = ");
                gen_expression($cg, $right);
                emit($cg, "; double __l = strada_to_num(__sp_lv); double __r = strada_to_num(__sp_rv); ");
                if ($left_needs_cleanup == 1) {
                    emit($cg, "strada_decref(__sp_lv); ");
                }
                if ($right_needs_cleanup == 1) {
                    emit($cg, "strada_decref(__sp_rv); ");
                }
                emit($cg, "strada_new_int((__l < __r) ? -1 : ((__l > __r) ? 1 : 0)); })");
            } else {
                emit($cg, "strada_new_int(({ double __l = strada_to_num(");
                gen_expression($cg, $left);
                emit($cg, "); double __r = strada_to_num(");
                gen_expression($cg, $right);
                emit($cg, "); (__l < __r) ? -1 : ((__l > __r) ? 1 : 0); }))");
            }
        } elsif ($op eq "cmp") {
            # String comparison operator: returns -1, 0, or 1
            # Must free strada_to_str results AND cleanup StradaValue temporaries
            my scalar $left = $expr->{"left"};
            my scalar $right = $expr->{"right"};
            my int $left_needs_cleanup = needs_temp_cleanup($cg, $left);
            my int $right_needs_cleanup = needs_temp_cleanup($cg, $right);

            if ($cg->{"cleanup_enabled"} == 1 && ($left_needs_cleanup == 1 || $right_needs_cleanup == 1)) {
                emit($cg, "({ StradaValue *__cmp_lv = ");
                gen_expression($cg, $left);
                emit($cg, "; StradaValue *__cmp_rv = ");
                gen_expression($cg, $right);
                emit($cg, "; char *__sl = strada_to_str_ss(__cmp_lv); char *__sr = strada_to_str_ss(__cmp_rv); ");
                emit($cg, "int __cmp_res = strcmp(__sl, __sr); strada_cstr_free(__sl); strada_cstr_free(__sr); ");
                if ($left_needs_cleanup == 1) {
                    emit($cg, "strada_decref(__cmp_lv); ");
                }
                if ($right_needs_cleanup == 1) {
                    emit($cg, "strada_decref(__cmp_rv); ");
                }
                emit($cg, "strada_new_int((__cmp_res < 0) ? -1 : ((__cmp_res > 0) ? 1 : 0)); })");
            } else {
                emit($cg, "strada_new_int(({ char *__sl = strada_to_str_ss(");
                gen_expression($cg, $left);
                emit($cg, "); char *__sr = strada_to_str_ss(");
                gen_expression($cg, $right);
                emit($cg, "); int __cmp_res = strcmp(__sl, __sr); strada_cstr_free(__sl); strada_cstr_free(__sr); (__cmp_res < 0) ? -1 : ((__cmp_res > 0) ? 1 : 0); }))");
            }
        } elsif ($op eq "=~") {
            # Regex match with string pattern (no flags)
            my scalar $re_left = $expr->{"left"};
            my scalar $re_right = $expr->{"right"};
            my int $re_left_cleanup = needs_temp_cleanup($cg, $re_left);
            my int $re_right_cleanup = needs_temp_cleanup($cg, $re_right);
            emit($cg, "({ StradaValue *__re_lv = ");
            gen_expression($cg, $re_left);
            emit($cg, "; StradaValue *__re_rv = ");
            gen_expression($cg, $re_right);
            emit($cg, "; char *__re_l = strada_to_str_ss(__re_lv); char *__re_r = strada_to_str_ss(__re_rv); ");
            emit($cg, "int __re_m = strada_regex_match_with_capture(__re_l, __re_r, NULL); ");
            emit($cg, "strada_cstr_free(__re_l); strada_cstr_free(__re_r); ");
            if ($re_left_cleanup == 1) {
                emit($cg, "strada_decref(__re_lv); ");
            }
            if ($re_right_cleanup == 1) {
                emit($cg, "strada_decref(__re_rv); ");
            }
            emit($cg, "strada_new_int(__re_m); })");
        } elsif ($op eq "!~") {
            # Negated regex match with string pattern (no flags)
            my scalar $re_left = $expr->{"left"};
            my scalar $re_right = $expr->{"right"};
            my int $re_left_cleanup = needs_temp_cleanup($cg, $re_left);
            my int $re_right_cleanup = needs_temp_cleanup($cg, $re_right);
            emit($cg, "({ StradaValue *__re_lv = ");
            gen_expression($cg, $re_left);
            emit($cg, "; StradaValue *__re_rv = ");
            gen_expression($cg, $re_right);
            emit($cg, "; char *__re_l = strada_to_str_ss(__re_lv); char *__re_r = strada_to_str_ss(__re_rv); ");
            emit($cg, "int __re_m = !strada_regex_match_with_capture(__re_l, __re_r, NULL); ");
            emit($cg, "strada_cstr_free(__re_l); strada_cstr_free(__re_r); ");
            if ($re_left_cleanup == 1) {
                emit($cg, "strada_decref(__re_lv); ");
            }
            if ($re_right_cleanup == 1) {
                emit($cg, "strada_decref(__re_rv); ");
            }
            emit($cg, "strada_new_int(__re_m); })");
        }
        return;
}

func gen_method_call_node(scalar $cg, scalar $expr) void {
    my int $type = $expr->{"type"};
    my int $in_extern = $cg->{"in_extern"};
        my int $arg_count = $expr->{"arg_count"};
        my str $method = $expr->{"method"};
        my scalar $obj = $expr->{"object"};

        # Compile-time isa() folding: when receiver's class is statically known
        # (via known_types) and the target package is a string literal, walk the
        # inheritance chain at codegen time and emit a constant.
        if ($method eq "isa" && $arg_count == 1) {
            my scalar $isa_args = $expr->{"args"};
            my scalar $isa_target_arg = $isa_args->[0];
            if ($isa_target_arg && $isa_target_arg->{"type"} == NODE_STR_LITERAL()) {
                my scalar $isa_recv = $expr->{"base_object"};
                if (!$isa_recv) { $isa_recv = $obj; }
                if ($isa_recv && $isa_recv->{"type"} == NODE_VARIABLE()) {
                    my str $isa_recv_name = escape_c_keyword($isa_recv->{"name"});
                    my scalar $isa_kt = $cg->{"known_types"};
                    if ($isa_kt) {
                        my str $isa_known_pkg = "" . $isa_kt->{$isa_recv_name};
                        if (length($isa_known_pkg) > 0) {
                            my str $isa_target_pkg = $isa_target_arg->{"value"};
                            my int $isa_result = is_subclass_compile_time($cg, $isa_known_pkg, $isa_target_pkg, 0);
                            emit($cg, "strada_new_int(" . $isa_result . ")");
                            return;
                        }
                    }
                }
            }
        }

        # Inline accessor optimization: for zero-arg calls to has-attribute getters,
        # emit direct hash access instead of going through strada_method_call.
        # SAFETY: Only inline when inside a same-package method calling $self->accessor()
        if ($arg_count == 0) {
            my scalar $acc_lookup = $cg->{"accessor_lookup"};
            # Check all known packages for this accessor
            my scalar $inh = $cg->{"inherits"};
            my int $inh_count = $cg->{"inherit_count"};
            my scalar $ha_attrs = $cg->{"has_attrs"};
            my int $ha_count = $cg->{"has_attr_count"};

            # STRICT safety checks for inline accessor:
            # 1. Must be inside a package method (not in main)
            # 2. Receiver must be the first function parameter ($self)
            # 3. Attribute must belong to the current package (or its parents)
            my int $is_accessor = 0;
            my str $cur_pkg = $cg->{"current_fn_package"};

            # Only inline inside package methods (not main)
            if (length($cur_pkg) > 0 && $cur_pkg ne "main") {
                # Check if receiver is the first function parameter
                my scalar $meth_target = $expr->{"base_object"};
                if (!$meth_target) {
                    $meth_target = $obj;
                }
                my int $receiver_is_self = 0;
                if ($meth_target->{"type"} == NODE_VARIABLE()) {
                    my str $recv_name = $meth_target->{"name"};
                    # Check if it's the first param of the current function
                    my int $fpc = $cg->{"func_param_count"} + 0;
                    if ($fpc > 0) {
                        my scalar $fpn = $cg->{"func_param_names"};
                        my str $first_param = $fpn->[0];
                        my str $recv_escaped = escape_c_keyword($recv_name);
                        if ($recv_escaped eq $first_param) {
                            $receiver_is_self = 1;
                        }
                    }
                }

                if ($receiver_is_self == 1) {
                    # Check if method matches a has-attr of this package or parents
                    my int $hai = 0;
                    while ($hai < $ha_count) {
                        my str $attr_name = $ha_attrs->[$hai]->{"name"};
                        my str $attr_pkg = $ha_attrs->[$hai]->{"package"};
                        if ($attr_name eq $method && ($attr_pkg eq $cur_pkg || exists($acc_lookup, $attr_pkg . "\t" . $method))) {
                            $is_accessor = 1;
                        }
                        $hai = $hai + 1;
                    }
                }
            }

            if ($is_accessor == 1) {
                my scalar $meth_target = $expr->{"base_object"};
                if (!$meth_target) {
                    $meth_target = $obj;
                }
                my int $obj_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $meth_target) == 1;
                # Compile-time djb2 hash so accessors skip per-call string hashing,
                # matching the constructor's strada_hash_set_take_ph scheme.
                my int $self_acc_hash = djb2_hash_32($method);
                if ($obj_cleanup == 1) {
                    emit($cg, "({ StradaValue *__iao = ");
                    gen_expression($cg, $meth_target);
                    emit($cg, "; StradaValue *__iar = strada_hv_fetch_owned_ph(__iao, \"" . $method . "\", " . $self_acc_hash . "u); strada_decref(__iao); __iar; })");
                } else {
                    emit($cg, "strada_hv_fetch_owned_ph(");
                    gen_expression($cg, $meth_target);
                    emit($cg, ", \"" . $method . "\", " . $self_acc_hash . "u)");
                }
                return;
            }
        }

        # Inline setter optimization: for 1-arg calls to set_X where X is has rw,
        # emit direct hash store instead of going through strada_method_call.
        if ($arg_count == 1) {
            my str $setter_attr = is_inline_setter($cg, $method);
            if (length($setter_attr) > 0) {
                my scalar $meth_target = $expr->{"base_object"};
                if (!$meth_target) {
                    $meth_target = $obj;
                }
                # Safety: receiver must be $self (first param) — same check as getter
                my int $setter_receiver_ok = 0;
                my str $cur_pkg2 = $cg->{"current_fn_package"};
                if (length($cur_pkg2) > 0 && $cur_pkg2 ne "main") {
                    if ($meth_target->{"type"} == NODE_VARIABLE()) {
                        my str $recv_name2 = $meth_target->{"name"};
                        my int $fpc2 = $cg->{"func_param_count"} + 0;
                        if ($fpc2 > 0) {
                            my str $recv_esc2 = escape_c_keyword($recv_name2);
                            if ($recv_esc2 eq $cg->{"func_param_names"}->[0]) {
                                $setter_receiver_ok = 1;
                            }
                        }
                        # Also allow known-type variables
                        if ($setter_receiver_ok == 0) {
                            my scalar $kt_s = $cg->{"known_types"};
                            if ($kt_s) {
                                my str $recv_esc3 = escape_c_keyword($recv_name2);
                                my str $kt_val_s = "" . $kt_s->{$recv_esc3};
                                if (length($kt_val_s) > 0) {
                                    $setter_receiver_ok = 1;
                                }
                            }
                        }
                    }
                }

                if ($setter_receiver_ok == 1) {
                    my scalar $set_arg = $expr->{"args"}->[0];
                    my int $obj_cleanup2 = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $meth_target) == 1;
                    my int $arg_cleanup2 = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $set_arg) == 1;

                    # Setter returns void — emit as statement expression returning NULL
                    emit($cg, "({ ");
                    if ($obj_cleanup2 == 1) {
                        emit($cg, "StradaValue *__isv_obj = ");
                        gen_expression($cg, $meth_target);
                        emit($cg, "; ");
                    }
                    if ($arg_cleanup2 == 1) {
                        emit($cg, "StradaValue *__isv_val = ");
                        gen_expression($cg, $set_arg);
                        emit($cg, "; ");
                    }
                    emit($cg, "strada_hv_store(");
                    if ($obj_cleanup2 == 1) {
                        emit($cg, "__isv_obj");
                    } else {
                        gen_expression($cg, $meth_target);
                    }
                    emit($cg, ", \"" . $setter_attr . "\", ");
                    if ($arg_cleanup2 == 1) {
                        emit($cg, "__isv_val");
                    } else {
                        gen_expression($cg, $set_arg);
                    }
                    emit($cg, "); ");
                    if ($obj_cleanup2 == 1) {
                        emit($cg, "strada_decref(__isv_obj); ");
                    }
                    if ($arg_cleanup2 == 1) {
                        emit($cg, "strada_decref(__isv_val); ");
                    }
                    emit($cg, "(StradaValue*)NULL; })");
                    return;
                }
            }
        }

        {
            # OOP method call - use base_object (the original object, not field access)
            # Generate: strada_method_call(obj, "method", strada_pack_args(count, arg1, arg2, ...))

            my scalar $args = $expr->{"args"};

            # Determine effective object expression and whether it needs cleanup
            my scalar $meth_target = $expr->{"base_object"};
            if (!$meth_target) {
                $meth_target = $obj;
            }
            my int $meth_obj_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $meth_target) == 1;

            # Precompute the method-name hash for the dispatch inline cache so
            # strada_method_call_ph skips the per-call strlen + djb2 loop.
            # Only printable-ASCII names hash identically at compile time
            # (same gating as the pre-hashed literal hash keys); anything
            # else falls back to runtime hashing via strada_method_call.
            #
            # On top of that, ordinary method names get a per-call-site
            # monomorphic cache: $mc_decl declares a function-scope static
            # StradaCallSite that strada_method_call_cs fills on first
            # dispatch and then hits with two compares + an indirect call.
            # "isa"/"can" are excluded — they're UNIVERSAL methods that
            # method_call_impl intercepts before lookup, so a site cache
            # would never be filled for them.
            my str $mc_fn = "strada_method_call(";
            my str $mc_extra = "";
            my str $mc_decl = "";
            if (key_is_hashable_ascii($method) == 1) {
                if ($method ne "isa" && $method ne "can") {
                    my int $mc_cs_id = $cg->{"tmp_counter"} + 0;
                    $cg->{"tmp_counter"} = $mc_cs_id + 1;
                    $mc_decl = "static StradaCallSite __mcs_" . $mc_cs_id . "; ";
                    $mc_fn = "strada_method_call_cs(";
                    $mc_extra = ", " . djb2_hash_32($method) . "u, &__mcs_" . $mc_cs_id;
                } else {
                    $mc_fn = "strada_method_call_ph(";
                    $mc_extra = ", " . djb2_hash_32($method) . "u";
                }
            }

            # Check if any argument has spread operator
            my int $has_spread = 0;
            for (my int $sa = 0; $sa < $arg_count; $sa = $sa + 1) {
                if ($args->[$sa]->{"type"} == NODE_SPREAD()) {
                    $has_spread = 1;
                }
            }

            # Devirtualization: if we know the object's blessed type from its constructor,
            # emit a direct C function call instead of strada_method_call()
            if ($has_spread == 0) {
                my str $known_pkg = "";
                if ($meth_target->{"type"} == NODE_VARIABLE()) {
                    my str $kt_name = escape_c_keyword($meth_target->{"name"});
                    my scalar $kt = $cg->{"known_types"};
                    if ($kt) {
                        my str $kt_val = "" . $kt->{$kt_name};
                        if (length($kt_val) > 0) {
                            $known_pkg = $kt_val;
                        }
                    }
                }
                if (length($known_pkg) > 0) {
                    # Look up the method: check this class and parents via MRO
                    my str $resolved_fn = "";
                    my int $resolved_ret_type = 0;
                    my str $direct_name = $known_pkg . "_" . $method;
                    # Sanitize :: to _
                    my int $dci = index($direct_name, "::");
                    while ($dci >= 0) {
                        $direct_name = substr($direct_name, 0, $dci) . "_" . substr($direct_name, $dci + 2, length($direct_name) - $dci - 2);
                        $dci = index($direct_name, "::");
                    }
                    my scalar $all_funcs = $cg->{"all_func_names"};
                    if ($all_funcs) {
                        my str $af_check = "" . $all_funcs->{$direct_name};
                        if (length($af_check) > 0) {
                            my int $af_ret = $all_funcs->{$direct_name} + 0;
                            if ($af_ret >= 0) {
                                $resolved_fn = $direct_name;
                                $resolved_ret_type = $af_ret;
                            }
                        }
                    }
                    # If not found in this class, check parent classes
                    if (length($resolved_fn) == 0) {
                        my scalar $inh_list3 = $cg->{"inherits"};
                        my int $inh_ct3 = $cg->{"inherit_count"};
                        my array @check_pkgs = ();
                        push(@check_pkgs, $known_pkg);
                        my int $cp_len = 1;
                        my int $cpi = 0;
                        while ($cpi < $cp_len) {
                            my str $cpkg = $check_pkgs[$cpi];
                            my int $pi3 = 0;
                            while ($pi3 < $inh_ct3) {
                                my str $ichild3 = $inh_list3->[$pi3]->{"child"};
                                if ($ichild3 eq $cpkg) {
                                    my str $ipar3 = $inh_list3->[$pi3]->{"parent"};
                                    push(@check_pkgs, $ipar3);
                                    $cp_len = $cp_len + 1;
                                    my str $parent_fn = $ipar3 . "_" . $method;
                                    my int $pci = index($parent_fn, "::");
                                    while ($pci >= 0) {
                                        $parent_fn = substr($parent_fn, 0, $pci) . "_" . substr($parent_fn, $pci + 2, length($parent_fn) - $pci - 2);
                                        $pci = index($parent_fn, "::");
                                    }
                                    if ($all_funcs && length($resolved_fn) == 0) {
                                        my str $pf_check = "" . $all_funcs->{$parent_fn};
                                        if (length($pf_check) > 0) {
                                            my int $pf_ret = $all_funcs->{$parent_fn} + 0;
                                            if ($pf_ret >= 0) {
                                                $resolved_fn = $parent_fn;
                                                $resolved_ret_type = $pf_ret;
                                            }
                                        }
                                    }
                                }
                                $pi3 = $pi3 + 1;
                            }
                            $cpi = $cpi + 1;
                        }
                    }

                    # Skip devirtualization for methods with before/after/around hooks
                    if (length($resolved_fn) > 0 && has_method_modifier($cg, $method) == 1) {
                        $resolved_fn = "";
                    }
                    if (length($resolved_fn) > 0) {
                        my int $is_void = $resolved_ret_type == TYPE_VOID();
                        # Pad explicit args up to the resolved method's param count
                        # (minus self), emitting each missing trailing param's
                        # default expression. Without this, devirtualizing a method
                        # that has default parameters passed too few C args and gcc
                        # errored. We gen_expression the default directly here (the
                        # dynamic-dispatch wrapper can't, being emitted as C text).
                        my int $eff = $arg_count;
                        my scalar $rf_params = 0;
                        my scalar $rf_i = $cg->{"functions"}->{$resolved_fn};
                        if ($rf_i) {
                            my int $rf_pc = $rf_i->{"param_count"};
                            if ($rf_pc - 1 > $eff) {
                                $eff = $rf_pc - 1;
                                $rf_params = $rf_i->{"params"};
                            }
                        }
                        # AST node for each explicit position: the provided arg, or
                        # the param's default (0 when absent → strada_new_undef()).
                        my array @dv_nodes = ();
                        my int $kk = 0;
                        while ($kk < $eff) {
                            my scalar $nd = 0;
                            if ($kk < $arg_count) {
                                $nd = $args->[$kk];
                            } elsif ($rf_params) {
                                my scalar $dp = $rf_params->[$kk + 1];
                                if ($dp) {
                                    if ($dp->{"has_default"} == 1) { $nd = $dp->{"default"}; }
                                }
                            }
                            push(@dv_nodes, $nd);
                            $kk = $kk + 1;
                        }
                        if ($eff == 0) {
                            if ($is_void == 1) {
                                if ($meth_obj_cleanup == 1) {
                                    emit($cg, "({ StradaValue *__dv_obj = ");
                                    gen_expression($cg, $meth_target);
                                    emit($cg, "; " . $resolved_fn . "(__dv_obj); strada_decref(__dv_obj); (StradaValue*)NULL; })");
                                } else {
                                    emit($cg, "({ " . $resolved_fn . "(");
                                    gen_expression($cg, $meth_target);
                                    emit($cg, "); (StradaValue*)NULL; })");
                                }
                            } elsif ($meth_obj_cleanup == 1) {
                                emit($cg, "({ StradaValue *__dv_obj = ");
                                gen_expression($cg, $meth_target);
                                emit($cg, "; StradaValue *__dv_res = " . $resolved_fn . "(__dv_obj); strada_decref(__dv_obj); __dv_res; })");
                            } else {
                                emit($cg, $resolved_fn . "(");
                                gen_expression($cg, $meth_target);
                                emit($cg, ")");
                            }
                            return;
                        } else {
                            emit($cg, "({ ");
                            if ($meth_obj_cleanup == 1) {
                                emit($cg, "StradaValue *__dv_obj = ");
                                gen_expression($cg, $meth_target);
                                emit($cg, "; ");
                            }
                            my int $da = 0;
                            while ($da < $eff) {
                                my scalar $an = $dv_nodes[$da];
                                emit($cg, "StradaValue *__dv_a" . $da . " = ");
                                if ($an) { gen_expression($cg, $an); } else { emit($cg, "strada_new_undef()"); }
                                emit($cg, "; ");
                                if ($cg->{"cleanup_enabled"} == 1 && $an && needs_temp_cleanup($cg, $an) == 1) {
                                    emit($cg, "strada_cleanup_push(__dv_a" . $da . "); ");
                                }
                                $da = $da + 1;
                            }
                            if ($is_void == 1) {
                                emit($cg, $resolved_fn . "(");
                            } else {
                                emit($cg, "StradaValue *__dv_res = " . $resolved_fn . "(");
                            }
                            if ($meth_obj_cleanup == 1) {
                                emit($cg, "__dv_obj");
                            } else {
                                gen_expression($cg, $meth_target);
                            }
                            my int $da2 = 0;
                            while ($da2 < $eff) {
                                emit($cg, ", __dv_a" . $da2);
                                $da2 = $da2 + 1;
                            }
                            emit($cg, "); ");
                            my int $da_pop = $eff - 1;
                            while ($da_pop >= 0) {
                                my scalar $anp = $dv_nodes[$da_pop];
                                if ($cg->{"cleanup_enabled"} == 1 && $anp && needs_temp_cleanup($cg, $anp) == 1) {
                                    emit($cg, "strada_cleanup_pop(); ");
                                }
                                $da_pop = $da_pop - 1;
                            }
                            if ($meth_obj_cleanup == 1) {
                                emit($cg, "strada_decref(__dv_obj); ");
                            }
                            my int $da3 = 0;
                            while ($da3 < $eff) {
                                my scalar $an3 = $dv_nodes[$da3];
                                if ($cg->{"cleanup_enabled"} == 1 && $an3 && needs_temp_cleanup($cg, $an3) == 1) {
                                    emit($cg, "strada_decref(__dv_a" . $da3 . "); ");
                                }
                                $da3 = $da3 + 1;
                            }
                            if ($is_void == 1) {
                                emit($cg, "(StradaValue*)NULL; })");
                            } else {
                                emit($cg, "__dv_res; })");
                            }
                            return;
                        }
                    }
                }
            }

            if ($has_spread == 1) {
                # Build args array dynamically with spread support
                emit($cg, "({ ");
                if ($meth_obj_cleanup == 1) {
                    emit($cg, "StradaValue *__meth_obj = ");
                    gen_expression($cg, $meth_target);
                    emit($cg, "; strada_cleanup_push(__meth_obj); ");
                }
                emit($cg, "StradaValue *__method_args = strada_new_array(); ");

                my int $a = 0;
                while ($a < $arg_count) {
                    my scalar $arg = $args->[$a];
                    if ($arg->{"type"} == NODE_SPREAD()) {
                        # Spread: iterate array and push elements. Use
                        # incref + push_take (matches the function-call
                        # spread pattern at ~line 12217). Previously this
                        # path emitted push (which increfs) AND an
                        # explicit incref — double-incref leaked one ref
                        # per spread element.
                        emit($cg, "{ StradaValue *__spread = ");
                        gen_expression($cg, $arg->{"target"});
                        emit($cg, "; StradaArray *__sa = strada_deref_array(__spread); ");
                        emit($cg, "if (__sa) { for (size_t __si = 0; __si < __sa->size; __si++) { ");
                        emit($cg, "strada_incref(__sa->elements[__si]); ");
                        emit($cg, "strada_array_push_take(strada_deref_array(__method_args), __sa->elements[__si]); } } } ");
                    } else {
                        # Regular arg: push_take for owned temps (new
                        # allocs), push for borrowed refs (variables).
                        # Previously this used push unconditionally —
                        # owned-temp args mixed with spread leaked
                        # (the non-spread fast path correctly handles
                        # this; only this spread-mixed branch was wrong).
                        my int $arg_is_var = $arg->{"type"} == NODE_VARIABLE();
                        if ($arg_is_var == 1) {
                            emit($cg, "strada_array_push(strada_deref_array(__method_args), ");
                        } else {
                            emit($cg, "strada_array_push_take(strada_deref_array(__method_args), ");
                        }
                        gen_expression($cg, $arg);
                        emit($cg, "); ");
                    }
                    $a = $a + 1;
                }

                emit($cg, $mc_decl . "StradaValue *__meth_res = " . $mc_fn);
                if ($meth_obj_cleanup == 1) {
                    emit($cg, "__meth_obj");
                } else {
                    gen_expression($cg, $meth_target);
                }
                emit($cg, ", \"" . $method . "\", __method_args" . $mc_extra . "); ");
                if ($meth_obj_cleanup == 1) {
                    emit($cg, "strada_cleanup_pop(); strada_decref(__meth_obj); ");
                }
                emit($cg, "__meth_res; })");
            } else {
                # No spread - use regular strada_pack_args
                # Check if any args need temp cleanup
                my int $needs_arg_cleanup = 0;
                if ($cg->{"cleanup_enabled"} == 1) {
                    my int $c = 0;
                    while ($c < $arg_count) {
                        if (needs_temp_cleanup($cg, $args->[$c]) == 1) {
                            $needs_arg_cleanup = 1;
                        }
                        $c = $c + 1;
                    }
                }

                if ($needs_arg_cleanup == 1) {
                    # Capture temp args, call method, decref temps and pack_args
                    emit($cg, "({ ");
                    if ($meth_obj_cleanup == 1) {
                        emit($cg, "StradaValue *__meth_obj = ");
                        gen_expression($cg, $meth_target);
                        # Push to cleanup stack so that if the method
                        # body throws, the catch's drain decrefs the
                        # owned-ref receiver. Without this, longjmp
                        # would skip the matching strada_decref(__meth_obj)
                        # below and leak the receiver per throw.
                        emit($cg, "; strada_cleanup_push(__meth_obj); ");
                    }
                    my int $a = 0;
                    while ($a < $arg_count) {
                        if (needs_temp_cleanup($cg, $args->[$a]) == 1) {
                            emit($cg, "StradaValue *__meth_arg_" . $a . " = ");
                            gen_expression($cg, $args->[$a]);
                            emit($cg, "; ");
                        }
                        $a = $a + 1;
                    }
                    emit($cg, "StradaValue *__meth_pa = strada_pack_args(" . $arg_count);
                    my int $i = 0;
                    while ($i < $arg_count) {
                        emit($cg, ", ");
                        if (needs_temp_cleanup($cg, $args->[$i]) == 1) {
                            emit($cg, "__meth_arg_" . $i);
                        } else {
                            gen_expression($cg, $args->[$i]);
                        }
                        $i = $i + 1;
                    }
                    emit($cg, "); ");
                    emit($cg, $mc_decl . "StradaValue *__meth_res = " . $mc_fn);
                    if ($meth_obj_cleanup == 1) {
                        emit($cg, "__meth_obj");
                    } else {
                        gen_expression($cg, $meth_target);
                    }
                    emit($cg, ", \"" . $method . "\", __meth_pa" . $mc_extra . "); ");
                    if ($meth_obj_cleanup == 1) {
                        emit($cg, "strada_cleanup_pop(); strada_decref(__meth_obj); ");
                    }
                    my int $d = 0;
                    while ($d < $arg_count) {
                        if (needs_temp_cleanup($cg, $args->[$d]) == 1) {
                            emit($cg, "strada_decref(__meth_arg_" . $d . "); ");
                        }
                        $d = $d + 1;
                    }
                    emit($cg, "__meth_res; })");
                } elsif ($arg_count == 0) {
                    # Check for inline accessor optimization
                    my str $inline_attr = is_inline_accessor($cg, $method);
                    if (length($inline_attr) > 0) {
                        # Emit strada_hv_fetch_owned_ph with compile-time djb2 hash —
                        # same scheme used by inline constructors, so OOP accessor
                        # calls skip per-call string hashing.
                        my int $acc_hash = djb2_hash_32($inline_attr);
                        if ($meth_obj_cleanup == 1) {
                            emit($cg, "({ StradaValue *__acc_obj = ");
                            gen_expression($cg, $meth_target);
                            emit($cg, "; StradaValue *__acc_res = strada_hv_fetch_owned_ph(__acc_obj, \"");
                            emit($cg, $inline_attr . "\", " . $acc_hash . "u); strada_decref(__acc_obj); __acc_res; })");
                        } else {
                            emit($cg, "strada_hv_fetch_owned_ph(");
                            gen_expression($cg, $meth_target);
                            emit($cg, ", \"" . $inline_attr . "\", " . $acc_hash . "u)");
                        }
                    } else {
                        # Zero args - pass NULL instead of allocating empty pack_args
                        if ($meth_obj_cleanup == 1) {
                            emit($cg, "({ StradaValue *__meth_obj = ");
                            gen_expression($cg, $meth_target);
                            emit($cg, "; strada_cleanup_push(__meth_obj); " . $mc_decl . "StradaValue *__meth_res = " . $mc_fn . "__meth_obj, \"" . $method . "\", NULL" . $mc_extra . "); ");
                            emit($cg, "strada_cleanup_pop(); strada_decref(__meth_obj); __meth_res; })");
                        } elsif (length($mc_decl) > 0) {
                            # The call-site static needs a block to live in —
                            # wrap the bare call in a statement expression.
                            emit($cg, "({ " . $mc_decl . $mc_fn);
                            gen_expression($cg, $meth_target);
                            emit($cg, ", \"" . $method . "\", NULL" . $mc_extra . "); })");
                        } else {
                            emit($cg, $mc_fn);
                            gen_expression($cg, $meth_target);
                            emit($cg, ", \"" . $method . "\", NULL" . $mc_extra . ")");
                        }
                    }
                } else {
                    # Has args but no temp cleanup needed - use pack_args
                    emit($cg, "({ ");
                    if ($meth_obj_cleanup == 1) {
                        emit($cg, "StradaValue *__meth_obj = ");
                        gen_expression($cg, $meth_target);
                        # Push to cleanup stack so that if the method
                        # body throws, the catch's drain decrefs the
                        # owned-ref receiver. Without this, longjmp
                        # would skip the matching strada_decref(__meth_obj)
                        # below and leak the receiver per throw.
                        emit($cg, "; strada_cleanup_push(__meth_obj); ");
                    }
                    emit($cg, "StradaValue *__meth_pa = strada_pack_args(" . $arg_count);
                    my int $i = 0;
                    while ($i < $arg_count) {
                        emit($cg, ", ");
                        gen_expression($cg, $args->[$i]);
                        $i = $i + 1;
                    }
                    emit($cg, "); " . $mc_decl . "StradaValue *__meth_res = " . $mc_fn);
                    if ($meth_obj_cleanup == 1) {
                        emit($cg, "__meth_obj");
                    } else {
                        gen_expression($cg, $meth_target);
                    }
                    emit($cg, ", \"" . $method . "\", __meth_pa" . $mc_extra . "); ");
                    if ($meth_obj_cleanup == 1) {
                        emit($cg, "strada_cleanup_pop(); strada_decref(__meth_obj); ");
                    }
                    emit($cg, "__meth_res; })");
                }
            }
        }
        return;
}

func gen_expression(scalar $cg, scalar $expr) void {
    my int $type = $expr->{"type"};
    my int $in_extern = $cg->{"in_extern"};

    # Integer literal
    if ($type == NODE_INT_LITERAL()) {
        if ($in_extern) {
            emit($cg, $expr->{"value"});
        } else {
            emit($cg, "strada_new_int(" . $expr->{"value"} . ")");
        }
        return;
    }

    # Number literal
    if ($type == NODE_NUM_LITERAL()) {
        if ($in_extern) {
            emit($cg, $expr->{"value"});
        } else {
            emit($cg, "strada_new_num(" . $expr->{"value"} . ")");
        }
        return;
    }
    
    # String literal - use byte-level operations for proper UTF-8 handling
    if ($type == NODE_STR_LITERAL()) {
        # In extern mode, emit raw C string literal; otherwise wrap in
        # STRADA_NEW_STR_LIT so embedded NUL bytes survive the constructor
        # (strada_new_str's strlen would truncate at the first NUL).
        if ($in_extern) {
            emit($cg, "\"");
        } else {
            emit($cg, "STRADA_NEW_STR_LIT(\"");
        }
        my str $val = $expr->{"value"};
        my int $i = 0;
        my int $len = bytes($val);
        while ($i < $len) {
            my int $code = char_at($val, $i);
            if ($code == 10) {
                emit($cg, "\\n");
            } elsif ($code == 9) {
                emit($cg, "\\t");
            } elsif ($code == 13) {
                emit($cg, "\\r");
            } elsif ($code == 0) {
                # 3-digit octal so a following digit isn't merged into the escape
                emit($cg, "\\000");
            } elsif ($code == 7) {
                emit($cg, "\\a");
            } elsif ($code == 8) {
                emit($cg, "\\b");
            } elsif ($code == 12) {
                emit($cg, "\\f");
            } elsif ($code == 11) {
                emit($cg, "\\v");
            } elsif ($code == 27) {
                emit($cg, "\\033");
            } elsif ($code == 34) {
                emit($cg, "\\\"");
            } elsif ($code == 92) {
                emit($cg, "\\\\");
            } elsif ($code >= 32 && $code <= 126) {
                # Printable ASCII - output as-is
                emit($cg, chr($code));
            } else {
                # Non-printable/high bytes - output raw byte directly
                # The C source file is UTF-8, so raw UTF-8 bytes are valid
                emit($cg, substr_bytes($val, $i, 1));
            }
            $i = $i + 1;
        }
        if ($in_extern) {
            emit($cg, "\"");
        } else {
            emit($cg, "\")");
        }
        return;
    }

    # Undef literal
    if ($type == NODE_UNDEF()) {
        emit($cg, "strada_new_undef()");
        return;
    }

    # Value-producing do { } block: GNU statement expression. The last
    # EXPRESSION statement's value is the result (owned: incref'd when
    # borrowed, before the block's scope cleanup runs); a block ending in
    # a non-expression yields undef. Control-flow exits (return/next/
    # last) inside a value-do are unsupported (gcc forbids jumping out
    # of statement expressions) — documented.
    if ($type == NODE_DO_EXPR()) {
        my int $do_id = $cg->{"tmp_counter"};
        $cg->{"tmp_counter"} = $do_id + 1;
        my scalar $do_block = $expr->{"block"};
        my scalar $do_stmts = $do_block->{"statements"};
        my int $do_n = $do_block->{"statement_count"};
        emit($cg, "({ StradaValue *__do_res_" . $do_id . " = NULL; {\n");
        indent($cg);
        scope_push($cg);
        my int $di = 0;
        while ($di < $do_n) {
            my scalar $dstmt = $do_stmts->[$di];
            if ($di == $do_n - 1 && $dstmt->{"type"} == NODE_EXPR_STMT()) {
                # Last expression statement: capture as the result.
                my scalar $dval = $dstmt->{"expr"};
                emit_indent($cg);
                emit($cg, "__do_res_" . $do_id . " = ");
                if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $dval) == 0) {
                    emit($cg, "({ StradaValue *__do_b = ");
                    gen_expression($cg, $dval);
                    emit($cg, "; strada_incref(__do_b); __do_b; })");
                } else {
                    gen_expression($cg, $dval);
                }
                emit($cg, ";\n");
            } else {
                gen_statement($cg, $dstmt);
            }
            $di = $di + 1;
        }
        # Scope cleanup (local decrefs) BEFORE yielding — the result is
        # already owned/incref'd so it survives.
        scope_pop($cg);
        dedent($cg);
        emit_indent($cg);
        emit($cg, "} __do_res_" . $do_id . " ? __do_res_" . $do_id . " : strada_new_undef(); })");
        return;
    }

    # Variable
    if ($type == NODE_VARIABLE()) {
        my str $var_name = $expr->{"name"};
        # $0 (__program_name) — always read fresh from getprocname
        if ($var_name eq "__program_name") {
            emit($cg, "strada_getprocname()");
            return;
        }
        # Escape C keywords in variable names
        my str $c_var_name = escape_c_keyword($var_name);
        # Check if this is an 'our' variable - emit strada_global_get() instead
        my scalar $our_vars = $cg->{"our_vars"};
        my str $our_key = "" . $our_vars->{$c_var_name};
        if (length($our_key) > 0) {
            emit($cg, "strada_global_get(strada_new_str(\"");
            emit($cg, $our_key);
            emit($cg, "\"))");
            return;
        }
        # Handle magic variables for map/sort/grep blocks (only when in those contexts)
        if ($var_name eq "_" && ($cg->{"in_map_block"} || $cg->{"in_grep_block"})) {
            emit($cg, "__elem_");
        } elsif ($var_name eq "a" && $cg->{"in_sort_block"}) {
            emit($cg, "__sort_a_");
        } elsif ($var_name eq "b" && $cg->{"in_sort_block"}) {
            emit($cg, "__sort_b_");
        } elsif ($cg->{"in_anon_func"}) {
            # Inside anonymous function - check if it's a param, local, or capture
            my str $param_str = $cg->{"anon_param_str"};
            my str $local_str = $cg->{"anon_local_str"};
            my str $capture_str = $cg->{"anon_capture_str"};
            if (str_contains_name($param_str, $var_name)) {
                # It's a parameter - use directly (escaped for C)
                emit($cg, $c_var_name);
            } elsif (str_contains_name($local_str, $var_name)) {
                # It's a local variable - use directly (escaped for C)
                emit($cg, $c_var_name);
            } else {
                # It's a capture - get or add index
                my int $idx = get_capture_index($capture_str, $var_name);
                if ($idx < 0) {
                    # New capture - add it
                    if ($capture_str eq "") {
                        $cg->{"anon_capture_str"} = $var_name;
                    } else {
                        $cg->{"anon_capture_str"} = $capture_str . "," . $var_name;
                    }
                    $idx = $cg->{"anon_capture_count"};
                    $cg->{"anon_capture_count"} = $idx + 1;
                }
                # Use double pointer dereference for capture-by-reference
                emit($cg, "(*__captures[" . $idx . "])");
            }
        } else {
            emit($cg, $c_var_name);
        }
        return;
    }
    
    # Binary operation
    if ($type == NODE_BINARY_OP()) { gen_binop_node($cg, $expr); return; }

    # Regex match: $str =~ /pattern/flags or $str !~ /pattern/flags
    if ($type == NODE_REGEX_MATCH()) {
        my str $op = $expr->{"op"};
        my str $pattern = $expr->{"pattern"};
        my str $flags = $expr->{"flags"};

        # Check if pattern contains variable interpolation ($varname)
        # Only consider it interpolation if $ is followed by a word character
        # (not $ at end of pattern which is regex end-of-line anchor)
        my int $has_interp = 0;
        my int $check_i = 0;
        my int $pat_len = length($pattern);
        while ($check_i < $pat_len) {
            my str $ch = substr($pattern, $check_i, 1);
            if ($ch eq "$" && $check_i + 1 < $pat_len) {
                my str $next_ch = substr($pattern, $check_i + 1, 1);
                # Check if next char is start of variable name (letter or underscore)
                if ($next_ch eq "_" || ($next_ch ge "a" && $next_ch le "z") || ($next_ch ge "A" && $next_ch le "Z")) {
                    $has_interp = 1;
                    last;
                }
            }
            $check_i = $check_i + 1;
        }

        # Wrap in statement expression to free strada_to_str_ss() temp
        # Also cleanup target if it's a temp (e.g., string literal in "abc" =~ /pattern/)
        my int $tgt_needs_cleanup = 0;
        if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $expr->{"target"}) == 1) {
            $tgt_needs_cleanup = 1;
        }
        if ($tgt_needs_cleanup == 1) {
            emit($cg, "({ StradaValue *__re_tgt = ");
            gen_expression($cg, $expr->{"target"});
            emit($cg, "; char *__re_str = strada_to_str_ss(__re_tgt); ");
        } else {
            emit($cg, "({ char *__re_str = strada_to_str_ss(");
            gen_expression($cg, $expr->{"target"});
            emit($cg, "); ");
        }

        # Also free interpolated pattern temp if needed
        if ($has_interp == 1) {
            emit($cg, "char *__re_pat = strada_to_str_ss(");
            gen_regex_interpolated_pattern($cg, $pattern);
            emit($cg, "); ");
        }

        if ($op eq "=~") {
            emit($cg, "int __re_res = strada_regex_match_with_capture(__re_str, ");
        } else {
            emit($cg, "int __re_res = !strada_regex_match_with_capture(__re_str, ");
        }

        if ($has_interp == 1) {
            emit($cg, "__re_pat");
        } else {
            # Static pattern - emit as literal string
            emit($cg, "\"");
            my int $i = 0;
            my int $len = length($pattern);
            while ($i < $len) {
                my str $ch = substr($pattern, $i, 1);
                if ($ch eq "\\") {
                    emit($cg, "\\\\");
                } elsif ($ch eq "\"") {
                    emit($cg, "\\\"");
                } elsif ($ch eq "\n") {
                    emit($cg, "\\n");
                } elsif ($ch eq "\t") {
                    emit($cg, "\\t");
                } else {
                    emit($cg, $ch);
                }
                $i = $i + 1;
            }
            emit($cg, "\"");
        }
        emit($cg, ", ");
        # Pass flags (or NULL if empty)
        if (length($flags) > 0) {
            emit($cg, "\"" . $flags . "\"");
        } else {
            emit($cg, "NULL");
        }
        emit($cg, "); strada_cstr_free(__re_str); ");
        if ($has_interp == 1) {
            emit($cg, "strada_cstr_free(__re_pat); ");
        }
        if ($tgt_needs_cleanup == 1) {
            emit($cg, "strada_decref(__re_tgt); ");
        }
        emit($cg, "strada_new_int(__re_res); })");
        return;
    }

    # Regex substitution: $str =~ s/pattern/replacement/flags
    if ($type == NODE_REGEX_SUBST()) {
        my str $pattern = $expr->{"pattern"};
        my str $replacement = $expr->{"replacement"};
        my str $flags = $expr->{"flags"};

        # Check for flags
        my int $global = 0;
        if (index($flags, "g") >= 0) {
            $global = 1;
        }
        my int $eval_mode = 0;
        if (index($flags, "e") >= 0) {
            $eval_mode = 1;
        }

        if ($eval_mode == 1) {
            # /e modifier: evaluate replacement as expression for each match
            emit($cg, "{\n");
            emit_indent($cg);
            emit($cg, "char *__re_src = strada_to_str_ss(");
            gen_expression($cg, $expr->{"target"});
            emit($cg, ");\n");
            emit_indent($cg);
            emit($cg, "StradaValue *__re_matches = strada_regex_find_all(__re_src, \"");
            # Escape pattern for C string
            my int $i = 0;
            my int $len = length($pattern);
            while ($i < $len) {
                my str $ch = substr($pattern, $i, 1);
                if ($ch eq "\\") {
                    emit($cg, "\\\\");
                } elsif ($ch eq "\"") {
                    emit($cg, "\\\"");
                } elsif ($ch eq "\n") {
                    emit($cg, "\\n");
                } elsif ($ch eq "\t") {
                    emit($cg, "\\t");
                } elsif ($ch eq "\r") {
                    emit($cg, "\\r");
                } else {
                    emit($cg, $ch);
                }
                $i = $i + 1;
            }
            emit($cg, "\", ");
            if (length($flags) > 0) {
                emit($cg, "\"" . $flags . "\"");
            } else {
                emit($cg, "NULL");
            }
            emit($cg, ", " . $global . ");\n");
            emit_indent($cg);
            emit($cg, "StradaValue *__re_repls = strada_new_array();\n");
            emit_indent($cg);
            emit($cg, "for (size_t __re_i = 0; __re_i < __re_matches->value.av->size; __re_i++) {\n");
            emit_indent($cg);
            emit($cg, "    strada_set_captures_sv(__re_matches->value.av->elements[__re_i]);\n");
            emit_indent($cg);
            emit($cg, "    StradaValue *__re_repl = ");
            my scalar $eval_expr = $expr->{"eval_expr"};
            gen_expression($cg, $eval_expr);
            emit($cg, ";\n");
            emit_indent($cg);
            emit($cg, "    strada_array_push(__re_repls->value.av, __re_repl);\n");
            emit_indent($cg);
            emit($cg, "    strada_decref(__re_repl);\n");
            emit_indent($cg);
            emit($cg, "}\n");
            emit_indent($cg);
            emit($cg, "strada_decref(");
            gen_expression($cg, $expr->{"target"});
            emit($cg, ");\n");
            emit_indent($cg);
            gen_expression($cg, $expr->{"target"});
            emit($cg, " = strada_regex_build_result(__re_src, __re_matches, __re_repls);\n");
            emit_indent($cg);
            emit($cg, "strada_decref(__re_matches);\n");
            emit_indent($cg);
            emit($cg, "strada_decref(__re_repls);\n");
            emit_indent($cg);
            emit($cg, "strada_cstr_free(__re_src);\n");
            emit($cg, "}\n");
            return;
        }

        # Check if pattern is a plain literal (no regex metacharacters)
        # and replacement has no backreferences, and no regex-specific flags
        my int $is_literal = 1;
        # Check flags: only "g" is compatible with literal mode
        my int $fi = 0;
        my int $flen = length($flags);
        while ($fi < $flen) {
            my str $fc = substr($flags, $fi, 1);
            if ($fc ne "g") {
                $is_literal = 0;
            }
            $fi = $fi + 1;
        }
        # Check pattern for regex metacharacters: . ^ $ * + ? { } [ ] \ | ( )
        if ($is_literal == 1) {
            my int $pi = 0;
            my int $plen = length($pattern);
            while ($pi < $plen) {
                my str $pc = substr($pattern, $pi, 1);
                if ($pc eq "." || $pc eq "^" || $pc eq "*" || $pc eq "+" || $pc eq "$" || $pc eq "?" || $pc eq "[" || $pc eq "]" || $pc eq "(" || $pc eq ")" || $pc eq "{" || $pc eq "}" || $pc eq "|" || $pc eq "\\") {
                    $is_literal = 0;
                }
                $pi = $pi + 1;
            }
        }
        # Check replacement for backreferences ($0-$9, \0-\9)
        if ($is_literal == 1) {
            my int $ri = 0;
            my int $rlen = length($replacement);
            while ($ri < $rlen) {
                my str $rc = substr($replacement, $ri, 1);
                if ($ri + 1 < $rlen) {
                    my str $rnext = substr($replacement, $ri + 1, 1);
                    if ($rc eq "\\") {
                        if ($rnext eq "0" || $rnext eq "1" || $rnext eq "2" || $rnext eq "3" || $rnext eq "4" || $rnext eq "5" || $rnext eq "6" || $rnext eq "7" || $rnext eq "8" || $rnext eq "9") {
                            $is_literal = 0;
                        }
                    }
                }
                $ri = $ri + 1;
            }
        }

        if ($is_literal == 1) {
            # Fast path: literal string substitution via strada_subst_sv
            # Cast to (StradaValue**) to avoid volatile qualifier warning in try blocks
            emit($cg, "strada_subst_sv((StradaValue**)&");
            gen_expression($cg, $expr->{"target"});
            emit($cg, ", \"");
            # Escape pattern for C string
            my int $i = 0;
            my int $len = length($pattern);
            while ($i < $len) {
                my str $ch = substr($pattern, $i, 1);
                if ($ch eq "\"") {
                    emit($cg, "\\\"");
                } elsif ($ch eq "\n") {
                    emit($cg, "\\n");
                } elsif ($ch eq "\t") {
                    emit($cg, "\\t");
                } elsif ($ch eq "\r") {
                    emit($cg, "\\r");
                } else {
                    emit($cg, $ch);
                }
                $i = $i + 1;
            }
            emit($cg, "\", \"");
            # Escape replacement for C string
            $i = 0;
            $len = length($replacement);
            while ($i < $len) {
                my str $ch = substr($replacement, $i, 1);
                if ($ch eq "\\") {
                    emit($cg, "\\\\");
                } elsif ($ch eq "\"") {
                    emit($cg, "\\\"");
                } elsif ($ch eq "\n") {
                    emit($cg, "\\n");
                } elsif ($ch eq "\t") {
                    emit($cg, "\\t");
                } elsif ($ch eq "\r") {
                    emit($cg, "\\r");
                } else {
                    emit($cg, $ch);
                }
                $i = $i + 1;
            }
            emit($cg, "\", " . $global . ")");
            return;
        }

        # Regex path: { char *__subst_src = strada_to_str_ss(target); char *__subst_res = strada_regex_replace[_all](__subst_src, pattern, replacement, flags); strada_decref(target); target = strada_new_str(__subst_res); strada_cstr_free(__subst_res); strada_cstr_free(__subst_src); }
        emit($cg, "{ char *__subst_src = strada_to_str_ss(");
        gen_expression($cg, $expr->{"target"});
        emit($cg, "); char *__subst_res = ");
        if ($global == 1) {
            emit($cg, "strada_regex_replace_all(");
        } else {
            emit($cg, "strada_regex_replace(");
        }
        emit($cg, "__subst_src, \"");
        # Escape pattern
        my int $i = 0;
        my int $len = length($pattern);
        while ($i < $len) {
            my str $ch = substr($pattern, $i, 1);
            if ($ch eq "\\") {
                emit($cg, "\\\\");
            } elsif ($ch eq "\"") {
                emit($cg, "\\\"");
            } elsif ($ch eq "\n") {
                emit($cg, "\\n");
            } elsif ($ch eq "\t") {
                emit($cg, "\\t");
            } elsif ($ch eq "\r") {
                emit($cg, "\\r");
            } else {
                emit($cg, $ch);
            }
            $i = $i + 1;
        }
        emit($cg, "\", \"");
        # Escape replacement
        $i = 0;
        $len = length($replacement);
        while ($i < $len) {
            my str $ch = substr($replacement, $i, 1);
            if ($ch eq "\\") {
                emit($cg, "\\\\");
            } elsif ($ch eq "\"") {
                emit($cg, "\\\"");
            } elsif ($ch eq "\n") {
                emit($cg, "\\n");
            } elsif ($ch eq "\t") {
                emit($cg, "\\t");
            } elsif ($ch eq "\r") {
                emit($cg, "\\r");
            } else {
                emit($cg, $ch);
            }
            $i = $i + 1;
        }
        emit($cg, "\", ");
        # Pass flags (or NULL if empty)
        if (length($flags) > 0) {
            emit($cg, "\"" . $flags . "\"");
        } else {
            emit($cg, "NULL");
        }
        emit($cg, "); strada_decref(");
        gen_expression($cg, $expr->{"target"});
        emit($cg, "); ");
        gen_expression($cg, $expr->{"target"});
        emit($cg, " = strada_new_str(__subst_res); free(__subst_res); strada_cstr_free(__subst_src); }");
        return;
    }

    # Transliteration: $str =~ tr/search/replace/flags
    if ($type == NODE_TR()) {
        my str $search = $expr->{"search"};
        my str $replace_str = $expr->{"replace"};
        my str $flags = $expr->{"flags"};

        # Generate: ({ StradaValue *__tr_r = strada_tr(target, ...); strada_decref(__tr_r); })
        # strada_tr modifies the string in-place and returns the count
        emit($cg, "({ StradaValue *__tr_r = strada_tr(");
        gen_expression($cg, $expr->{"target"});
        emit($cg, ", \"");
        # Escape search string
        my int $i = 0;
        my int $len = length($search);
        while ($i < $len) {
            my str $ch = substr($search, $i, 1);
            if ($ch eq "\\") {
                emit($cg, "\\\\");
            } elsif ($ch eq "\"") {
                emit($cg, "\\\"");
            } else {
                emit($cg, $ch);
            }
            $i = $i + 1;
        }
        emit($cg, "\", \"");
        # Escape replace string
        $i = 0;
        $len = length($replace_str);
        while ($i < $len) {
            my str $ch = substr($replace_str, $i, 1);
            if ($ch eq "\\") {
                emit($cg, "\\\\");
            } elsif ($ch eq "\"") {
                emit($cg, "\\\"");
            } else {
                emit($cg, $ch);
            }
            $i = $i + 1;
        }
        emit($cg, "\", ");
        if (length($flags) > 0) {
            emit($cg, "\"" . $flags . "\"");
        } else {
            emit($cg, "\"\"");
        }
        # Yield the count SV as the expression value. Previously this
        # path decref'd __tr_r and ended with `})` — making the entire
        # statement expression void, which broke value-context uses like
        # `my $n = ($s =~ tr/a-z/A-Z/);` (gcc: "void value not ignored
        # as it ought to be"). NODE_TR is registered in
        # needs_temp_cleanup so consumers will decref properly.
        emit($cg, "); __tr_r; })");
        return;
    }

    # Unary operation
    if ($type == NODE_UNARY_OP()) {
        my str $op = $expr->{"op"};
        my scalar $operand = $expr->{"operand"};
        my int $needs_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $operand) == 1;

        # Check for overloaded unary operators
        if ($cg->{"has_overloads"} == 1 && could_be_blessed($operand) == 1) {
            my str $ol_op = $op;
            if ($op eq "-") { $ol_op = "neg"; }
            my scalar $ol_ops3 = $cg->{"overloaded_ops"};
            my str $uop_check = "" . $ol_ops3->{$ol_op};
            if (length($uop_check) > 0) {
                gen_overloaded_unary($cg, $operand, $ol_op);
                return;
            }
        }

        if ($op eq "-") {
            # Int-typed operand: negate as an int. strada_new_int keeps the
            # result canonical (tagged, heap-boxed only beyond 2^62);
            # previously -$int boxed a heap NUM, so an int function with
            # `return -1;` returned a heap double.
            if (expr_is_int_typed($cg, $operand) == 1) {
                if ($needs_cleanup == 1) {
                    emit($cg, "({ StradaValue *__unary_tmp = ");
                    gen_expression($cg, $operand);
                    emit($cg, "; StradaValue *__unary_res = strada_new_int(-strada_to_int(__unary_tmp)); strada_decref(__unary_tmp); __unary_res; })");
                } else {
                    emit($cg, "strada_new_int(-strada_to_int(");
                    gen_expression($cg, $operand);
                    emit($cg, "))");
                }
            } elsif ($needs_cleanup == 1) {
                emit($cg, "({ StradaValue *__unary_tmp = ");
                gen_expression($cg, $operand);
                emit($cg, "; StradaValue *__unary_res = strada_new_num(-strada_to_num(__unary_tmp)); strada_decref(__unary_tmp); __unary_res; })");
            } else {
                emit($cg, "strada_new_num(-strada_to_num(");
                gen_expression($cg, $operand);
                emit($cg, "))");
            }
        } elsif ($op eq "!") {
            if ($needs_cleanup == 1) {
                emit($cg, "({ StradaValue *__unary_tmp = ");
                gen_expression($cg, $operand);
                emit($cg, "; StradaValue *__unary_res = strada_new_int(!strada_to_bool(__unary_tmp)); strada_decref(__unary_tmp); __unary_res; })");
            } else {
                emit($cg, "strada_new_int(!strada_to_bool(");
                gen_expression($cg, $operand);
                emit($cg, "))");
            }
        } elsif ($op eq "~") {
            if ($needs_cleanup == 1) {
                emit($cg, "({ StradaValue *__unary_tmp = ");
                gen_expression($cg, $operand);
                emit($cg, "; StradaValue *__unary_res = strada_new_int(~strada_to_int(__unary_tmp)); strada_decref(__unary_tmp); __unary_res; })");
            } else {
                emit($cg, "strada_new_int(~strada_to_int(");
                gen_expression($cg, $operand);
                emit($cg, "))");
            }
        }
        return;
    }

    # Increment/decrement (++ and --)
    if ($type == NODE_INCREMENT()) {
        my str $op = $expr->{"op"};
        my int $is_prefix = $expr->{"is_prefix"};
        my scalar $operand = $expr->{"operand"};
        my int $operand_type = $operand->{"type"};

        # Check for our variable (global) — can't take address of global_get
        if ($operand_type == NODE_VARIABLE()) {
            my str $incr_vname = escape_c_keyword($operand->{"name"});
            my scalar $incr_our = $cg->{"our_vars"};
            my str $incr_our_key = "" . $incr_our->{$incr_vname};
            if (length($incr_our_key) > 0) {
                # our variable: global_get (returns owned ref), increment, global_set (consumes ref)
                my str $delta = "1";
                if ($op eq "--") { $delta = "-1"; }
                emit($cg, "({ StradaValue *__incr_old = strada_global_get(strada_new_str(\"" . $incr_our_key . "\")); ");
                emit($cg, "StradaValue *__incr_new = strada_new_num(strada_to_num(__incr_old) + " . $delta . ".0); ");
                emit($cg, "strada_incref(__incr_new); ");
                emit($cg, "strada_global_set_cstr(\"" . $incr_our_key . "\", __incr_new); ");
                if ($is_prefix == 1) {
                    emit($cg, "strada_decref(__incr_old); __incr_new; })");
                } else {
                    emit($cg, "strada_decref(__incr_new); __incr_old; })");
                }
                return;
            }
        }
        # For simple local variables, use address-of
        if ($operand_type == NODE_VARIABLE()) {
            # Fast path: int-typed local — emit direct tagged-int arith,
            # skipping the strada_postincr function call entirely. Both
            # operand and result fit in tagged ints; refcounting is a no-op.
            my str $iv_name = escape_c_keyword($operand->{"name"});
            my scalar $iv_set = $cg->{"int_vars"};
            my int $is_int_var = 0;
            if ($iv_set) {
                my str $iv_check = "" . $iv_set->{$iv_name};
                if (length($iv_check) > 0) { $is_int_var = 1; }
            }
            if ($is_int_var == 1) {
                my str $delta = "1";
                if ($op eq "--") { $delta = "-1"; }
                if ($is_prefix == 1) {
                    # ++$i: assign new, yield new (tagged int → no refcounting)
                    emit($cg, "(" . $iv_name . " = STRADA_MAKE_TAGGED_INT(strada_to_int(" . $iv_name . ") + " . $delta . "))");
                } else {
                    # $i++: capture old, assign new, yield old. Old is
                    # tagged int — caller's strada_decref is a no-op so
                    # no leak even though we don't strada_incref it.
                    emit($cg, "({ StradaValue *__pi_old = " . $iv_name . "; " . $iv_name . " = STRADA_MAKE_TAGGED_INT(strada_to_int(__pi_old) + " . $delta . "); __pi_old; })");
                }
                return;
            }
            if ($is_prefix == 1) {
                if ($op eq "++") {
                    emit($cg, "strada_preincr(&");
                } else {
                    emit($cg, "strada_predecr(&");
                }
            } else {
                if ($op eq "++") {
                    emit($cg, "strada_postincr(&");
                } else {
                    emit($cg, "strada_postdecr(&");
                }
            }
            gen_expression($cg, $operand);
            emit($cg, ")");
        } elsif ($operand_type == NODE_SUBSCRIPT() || $operand_type == NODE_DEREF_ARRAY()) {
            # $arr[N]++ / $arr[N]-- / ++$arr[N] / --$arr[N], OR the
            # arrow form $ref->[N]++ etc. NODE_DEREF_ARRAY stores the
            # array sub-expression in `ref`; NODE_SUBSCRIPT uses
            # `array`. Without the DEREF_ARRAY branch, $h{k}->[i]++ fell
            # through to the generic `(strada_array_get(...) = ...)`
            # fallback which is not a valid C lvalue.
            my scalar $inc_arr_expr;
            if ($operand_type == NODE_DEREF_ARRAY()) {
                $inc_arr_expr = $operand->{"ref"};
            } else {
                $inc_arr_expr = $operand->{"array"};
            }
            # If the array sub-expression is owned (e.g. strada_hv_fetch_owned
            # from $h{k}->[i]), capture it so we can decref after. Previously
            # the wrapper SV leaked once per increment call.
            my int $inc_arr_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $inc_arr_expr) == 1;
            my str $delta = "1";
            if ($op eq "--") { $delta = "-1"; }
            emit($cg, "({ ");
            if ($inc_arr_cleanup == 1) {
                emit($cg, "StradaValue *__ii_src = ");
                gen_expression($cg, $inc_arr_expr);
                emit($cg, "; StradaArray *__ii_av = strada_deref_array(__ii_src); ");
            } else {
                emit($cg, "StradaArray *__ii_av = strada_deref_array(");
                gen_expression($cg, $inc_arr_expr);
                emit($cg, "); ");
            }
            emit($cg, "int __ii_idx = (int)strada_to_int(");
            gen_expression($cg, $operand->{"index"});
            emit($cg, "); if (__ii_idx < 0 && __ii_av) __ii_idx += strada_array_length(__ii_av); ");
            emit($cg, "StradaValue *__ii_old = __ii_av ? strada_array_get(__ii_av, __ii_idx) : NULL; ");
            emit($cg, "double __ii_v = strada_to_num(__ii_old); ");
            emit($cg, "StradaValue *__ii_new = strada_new_num(__ii_v + (" . $delta . ".0)); ");
            emit($cg, "if (__ii_old) strada_incref(__ii_old); ");
            emit($cg, "if (__ii_av) { strada_array_set(__ii_av, __ii_idx, __ii_new); strada_decref(__ii_new); } ");
            # array_set increfs the new value (refcount 1 → 2) and decrefs
            # the previous slot. Without the explicit decref(__ii_new)
            # here, the new value was left at refcount 2 — only the array
            # owns it after we exit this expression, so we drop our hold.
            # (The old `else strada_decref(__ii_new);` branch handles the
            # NULL-av error path.)
            emit($cg, "else strada_decref(__ii_new); ");
            if ($inc_arr_cleanup == 1) {
                emit($cg, "strada_decref(__ii_src); ");
                # Source decref is safe here: the array_set already
                # transferred ownership of __ii_new into the array, and
                # the existing incref(__ii_old) above ensures __ii_old
                # survives a potential array-free when the source is the
                # last holder.
            }
            if ($is_prefix == 1) {
                emit($cg, "if (__ii_old) strada_decref(__ii_old); __ii_new; })");
            } else {
                emit($cg, "__ii_old ? __ii_old : strada_new_undef(); })");
            }
        } elsif ($operand_type == NODE_HASH_ACCESS()) {
            # $h{k}++ / $h{k}-- / ++$h{k} / --$h{k}
            my scalar $key_expr_inc = $operand->{"key"};
            my int $key_needs_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $key_expr_inc) == 1;
            my str $delta = "1";
            if ($op eq "--") { $delta = "-1"; }
            emit($cg, "({ StradaValue *__ih_h = ");
            gen_expression($cg, $operand->{"hash"});
            # Capture key as a StradaValue so we can decref any owned
            # temp (e.g. STRADA_NEW_STR_LIT("c") from a string literal
            # key, or strada_hv_fetch_owned from a chained access).
            # Previously the SV was passed inline to strada_to_str_ss
            # and never freed — leaking one SV per increment.
            emit($cg, "; StradaValue *__ih_kv = ");
            gen_expression($cg, $key_expr_inc);
            # Single-probe lvalue read-modify-write: one hash probe instead of
            # fetch_owned + store (two probes), no key strdup (the _sv_key
            # variant reuses the key SV's pv), and a type-preserving increment
            # that stays a tagged int for int counters (no per-++ heap NUM).
            # NULL slot (tied/non-hash) falls back to the fetch/store path so
            # tie FETCH/STORE magic still fires.
            emit($cg, "; StradaValue **__ih_slot = strada_hv_fetch_lvalue_sv_key(__ih_h, __ih_kv, 1); StradaValue *__ih_old; StradaValue *__ih_new; ");
            emit($cg, "if (__ih_slot) { __ih_old = *__ih_slot; __ih_new = strada_inc_value(__ih_old, " . $delta . "); *__ih_slot = __ih_new; } ");
            emit($cg, "else { char *__ih_k = strada_to_str_ss(__ih_kv); __ih_old = strada_hv_fetch_owned(__ih_h, __ih_k); __ih_new = strada_inc_value(__ih_old, " . $delta . "); strada_hv_store(__ih_h, __ih_k, __ih_new); strada_decref(__ih_new); strada_cstr_free(__ih_k); } ");
            if ($key_needs_cleanup == 1) {
                emit($cg, "strada_decref(__ih_kv); ");
            }
            if ($is_prefix == 1) {
                # Prefix returns the NEW value (owned: incref over the slot's
                # ref); release the old value the slot no longer holds.
                emit($cg, "strada_decref(__ih_old); strada_incref(__ih_new); __ih_new; })");
            } else {
                # Postfix returns the OLD value; the slot's ownership of it
                # transferred to the result when we overwrote the slot.
                emit($cg, "__ih_old; })");
            }
        } elsif ($operand_type == NODE_DEREF_HASH()) {
            # $ref->{k}++ / $h{a}->{b}++ — same shape as NODE_HASH_ACCESS
            # but the hash sub-expression lives in `ref`, not `hash`.
            # Without this branch the operation fell through to the
            # generic "lvalue = ..." fallback that emitted a statement
            # expression as the lvalue (gcc rejected it).
            my scalar $dhi_key_expr = $operand->{"key"};
            my int $dhi_key_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $dhi_key_expr) == 1;
            my scalar $dhi_ref_expr = $operand->{"ref"};
            my int $dhi_ref_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $dhi_ref_expr) == 1;
            my str $delta = "1";
            if ($op eq "--") { $delta = "-1"; }
            emit($cg, "({ StradaValue *__ih_h = ");
            gen_expression($cg, $dhi_ref_expr);
            emit($cg, "; StradaValue *__ih_kv = ");
            gen_expression($cg, $dhi_key_expr);
            # Single-probe lvalue RMW (see NODE_HASH_ACCESS above for the
            # rationale); NULL slot (tied/non-hash) falls back to fetch/store.
            emit($cg, "; StradaValue **__ih_slot = strada_hv_fetch_lvalue_sv_key(__ih_h, __ih_kv, 1); StradaValue *__ih_old; StradaValue *__ih_new; ");
            emit($cg, "if (__ih_slot) { __ih_old = *__ih_slot; __ih_new = strada_inc_value(__ih_old, " . $delta . "); *__ih_slot = __ih_new; } ");
            emit($cg, "else { char *__ih_k = strada_to_str_ss(__ih_kv); __ih_old = strada_hv_fetch_owned(__ih_h, __ih_k); __ih_new = strada_inc_value(__ih_old, " . $delta . "); strada_hv_store(__ih_h, __ih_k, __ih_new); strada_decref(__ih_new); strada_cstr_free(__ih_k); } ");
            if ($dhi_key_cleanup == 1) { emit($cg, "strada_decref(__ih_kv); "); }
            if ($dhi_ref_cleanup == 1) { emit($cg, "strada_decref(__ih_h); "); }
            if ($is_prefix == 1) {
                emit($cg, "strada_decref(__ih_old); strada_incref(__ih_new); __ih_new; })");
            } else {
                emit($cg, "__ih_old; })");
            }
        } else {
            # For complex expressions, fall back to inline increment
            # This works for statement context but returns wrong value for postfix
            emit($cg, "(");
            gen_expression($cg, $operand);
            emit($cg, " = strada_new_num(strada_to_num(");
            gen_expression($cg, $operand);
            if ($op eq "++") {
                emit($cg, ") + 1))");
            } else {
                emit($cg, ") - 1))");
            }
        }
        return;
    }

    # Function call
    if ($type == NODE_CALL()) {
        my str $name = $expr->{"name"};

        # Warn if user wrote sys:: directly (deprecated, use core:: instead)
        if (length($name) > 5 && substr($name, 0, 5) eq "sys::") {
            my str $core_name = "core::" . substr($name, 5, length($name) - 5);
            warn("Warning: sys:: is deprecated, use " . $core_name . " instead\n");
        }

        # Normalize core:: to sys:: (core:: is a preferred alias)
        if (length($name) > 6 && substr($name, 0, 6) eq "core::") {
            $name = "sys::" . substr($name, 6, length($name) - 6);
            $expr->{"name"} = $name;
        }

        # Handle constant references (e.g., enum values like Color::RED)
        if ($expr->{"is_constant"} == 1) {
            emit($cg, "strada_new_int(" . sanitize_name($name) . ")");
            return;
        }

        # Built-in functions
        if (gen_builtin_g1($cg, $expr, $name) == 1) { return; }
        if (gen_builtin_g2($cg, $expr, $name) == 1) { return; }
        if (gen_builtin_g3($cg, $expr, $name) == 1) { return; }
        if (gen_builtin_g4($cg, $expr, $name) == 1) { return; }
        if (gen_builtin_g5($cg, $expr, $name) == 1) { return; }
        if (gen_builtin_g6($cg, $expr, $name) == 1) { return; }
        if (gen_builtin_g7($cg, $expr, $name) == 1) { return; }
        if (gen_builtin_g8($cg, $expr, $name) == 1) { return; }
        gen_user_call($cg, $expr, $name);
        return;
    }

    # Assignment
    if ($type == NODE_ASSIGN()) { gen_assign_node($cg, $expr); return; }

    # Array subscript - use strada_deref_array to handle both direct arrays and refs
    if ($type == NODE_SUBSCRIPT()) {
        my scalar $arr_expr = $expr->{"array"};

        # Autovivification: intermediate subscript in an assignment-target
        # chain ($aoa[0][1] = v, $a[0]{"k"} = v). Flag values: 1 = the
        # parent accessor needs a HASH in this element, 2 = an ARRAY.
        # strada_autoviv_elem_* return a BORROWED ref (owned by the array).
        if ($cg->{"autoviv"} >= 1) {
            my int $sub_av = $cg->{"autoviv"};
            $cg->{"autoviv"} = 0;
            my str $sub_av_fn = "strada_autoviv_elem_hash";
            if ($sub_av == 2) {
                $sub_av_fn = "strada_autoviv_elem_array";
            }
            emit($cg, $sub_av_fn . "(");
            # The array sub-expression itself needs autoviv (as an ARRAY,
            # since this node indexes it) if it's another access node
            if ($arr_expr->{"type"} == NODE_HASH_ACCESS() || $arr_expr->{"type"} == NODE_DEREF_HASH()
                || $arr_expr->{"type"} == NODE_SUBSCRIPT() || $arr_expr->{"type"} == NODE_DEREF_ARRAY()) {
                $cg->{"autoviv"} = 2;
            }
            gen_expression($cg, $arr_expr);
            emit($cg, ", ");
            emit_int_operand($cg, $expr->{"index"});
            emit($cg, ")");
            return;
        }

        my int $arr_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $arr_expr) == 1;
        if ($arr_cleanup == 1) {
            # Owned-ref source (e.g. $h{$k}[i]): capture the source,
            # fetch the element with an extra incref via the _owned
            # variant, then decref the source. The element now owns
            # one reference independent of the array, so the caller
            # can safely consume it after the source goes away. The
            # NODE_SUBSCRIPT case in needs_temp_cleanup mirrors this
            # — callers will decref the result.
            emit($cg, "({ StradaValue *__sub_arr = ");
            gen_expression($cg, $arr_expr);
            emit($cg, "; StradaValue *__sub_el = strada_array_get_owned(strada_deref_array(__sub_arr), ");
            emit_int_operand($cg, $expr->{"index"});
            emit($cg, "); strada_decref(__sub_arr); __sub_el; })");
        } else {
            emit($cg, "strada_array_get(strada_deref_array(");
            gen_expression($cg, $arr_expr);
            emit($cg, "), ");
            emit_int_operand($cg, $expr->{"index"});
            emit($cg, ")");
        }
        return;
    }
    
    # Hash access - use strada_hv_fetch_owned to return owned ref (fixes tied hash leak)
    if ($type == NODE_HASH_ACCESS()) {
        # CSE: this fetch was hoisted into a condition-level temp — emit
        # the temp name instead of re-probing (see emit_condition_cse).
        my str $cse_tmp = "" . $expr->{"cse_temp"};
        if (length($cse_tmp) > 0) {
            emit($cg, $cse_tmp);
            return;
        }

        my scalar $key_expr = $expr->{"key"};
        my int $key_is_literal = $key_expr->{"type"} == NODE_STR_LITERAL();

        # Autovivification: when this hash access is an intermediate in an
        # assignment target chain ($h{"a"}{"b"} = val), use autoviv to
        # auto-create missing intermediate containers. Flag values:
        # 1 = the parent accessor needs a HASH here, 2 = needs an ARRAY
        # ($h{"a"}[0] = val). Both runtime fns return a BORROWED ref.
        my int $autoviv = $cg->{"autoviv"};
        if ($autoviv >= 1) {
            $cg->{"autoviv"} = 0;
            my str $av_fn = "strada_autoviv_hash";
            if ($autoviv == 2) {
                $av_fn = "strada_autoviv_array";
            }
            # The hash sub-expression also needs autoviv (as a HASH, since
            # this node subscripts it with a key) if it's another access
            # node. Set the flag immediately before generating the hash
            # sub-expression — NOT earlier — so a hash access inside the
            # key expression can't consume it by mistake.
            my scalar $hash_sub = $expr->{"hash"};
            my int $av_propagate = 0;
            if ($hash_sub->{"type"} == NODE_HASH_ACCESS() || $hash_sub->{"type"} == NODE_DEREF_HASH()
                || $hash_sub->{"type"} == NODE_SUBSCRIPT() || $hash_sub->{"type"} == NODE_DEREF_ARRAY()) {
                $av_propagate = 1;
            }
            if ($key_is_literal == 1) {
                emit($cg, $av_fn . "(");
                if ($av_propagate == 1) { $cg->{"autoviv"} = 1; }
                gen_expression($cg, $expr->{"hash"});
                emit($cg, ", ");
                gen_str_literal_c($cg, $key_expr->{"value"});
                emit($cg, ")");
            } else {
                emit($cg, "({ StradaValue *__av_k = ");
                gen_expression($cg, $key_expr);
                emit($cg, "; char *__av_ks = strada_to_str_ss(__av_k); StradaValue *__av_r = " . $av_fn . "(");
                if ($av_propagate == 1) { $cg->{"autoviv"} = 1; }
                gen_expression($cg, $expr->{"hash"});
                emit($cg, ", __av_ks); strada_cstr_free(__av_ks); ");
                if (needs_temp_cleanup($cg, $key_expr) == 1) {
                    emit($cg, "strada_decref(__av_k); ");
                }
                emit($cg, "__av_r; })");
            }
            return;
        }

        # Check if hash sub-expression returns an owned ref (needs cleanup)
        my scalar $hash_expr = $expr->{"hash"};
        my int $hash_needs_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $hash_expr) == 1;

        if ($key_is_literal == 1) {
            # Literal key: pre-hashed fetch (compile-time djb2, ASCII keys) so the
            # constant key isn't re-hashed on every access.
            emit_hash_fetch_literal($cg, $hash_expr, $key_expr->{"value"}, $hash_needs_cleanup);
        } elsif (is_concat_str_literal_left($key_expr) == 1) {
            # Concat key "prefix" . $expr - use stack-buffer concat (zero allocs)
            my scalar $concat_right = $key_expr->{"right"};
            my int $right_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $concat_right) == 1;
            my str $prefix_val = $key_expr->{"left"}->{"value"};
            my int $prefix_len = bytes($prefix_val);
            if ($right_cleanup == 1 || $hash_needs_cleanup == 1) {
                emit($cg, "({ ");
                if ($hash_needs_cleanup == 1) {
                    emit($cg, "StradaValue *__ck_h = ");
                    gen_expression($cg, $expr->{"hash"});
                    emit($cg, "; ");
                }
                if ($right_cleanup == 1) {
                    emit($cg, "StradaValue *__ck_r = ");
                    gen_expression($cg, $concat_right);
                    emit($cg, "; ");
                }
                emit($cg, "StradaValue *__ck_res = strada_hv_fetch_owned_concat(");
                if ($hash_needs_cleanup == 1) {
                    emit($cg, "__ck_h");
                } else {
                    gen_expression($cg, $expr->{"hash"});
                }
                emit($cg, ", ");
                gen_str_literal_c($cg, $prefix_val);
                emit($cg, ", " . $prefix_len . ", ");
                if ($right_cleanup == 1) {
                    emit($cg, "__ck_r");
                } else {
                    gen_expression($cg, $concat_right);
                }
                emit($cg, "); ");
                if ($right_cleanup == 1) { emit($cg, "strada_decref(__ck_r); "); }
                if ($hash_needs_cleanup == 1) { emit($cg, "strada_decref(__ck_h); "); }
                emit($cg, "__ck_res; })");
            } else {
                emit($cg, "strada_hv_fetch_owned_concat(");
                gen_expression($cg, $expr->{"hash"});
                emit($cg, ", ");
                gen_str_literal_c($cg, $prefix_val);
                emit($cg, ", " . $prefix_len . ", ");
                gen_expression($cg, $concat_right);
                emit($cg, ")");
            }
        } else {
            # Expression key - use _sv variant (no strada_to_str needed)
            my int $key_needs_cleanup = needs_temp_cleanup($cg, $key_expr);
            emit($cg, "({ StradaValue *__hget_k = ");
            gen_expression($cg, $key_expr);
            emit($cg, "; ");
            if ($hash_needs_cleanup == 1) {
                emit($cg, "StradaValue *__hget_h = ");
                gen_expression($cg, $expr->{"hash"});
                emit($cg, "; StradaValue *__hget_r = strada_hv_fetch_owned_sv(__hget_h, __hget_k); strada_decref(__hget_h); ");
            } else {
                emit($cg, "StradaValue *__hget_r = strada_hv_fetch_owned_sv(");
                gen_expression($cg, $expr->{"hash"});
                emit($cg, ", __hget_k); ");
            }
            if ($key_needs_cleanup == 1) {
                emit($cg, "strada_decref(__hget_k); ");
            }
            emit($cg, "__hget_r; })");
        }
        return;
    }

    # Array slice: @arr[0, 2, 4] or @{$ref}[0, 1]
    if ($type == NODE_ARRAY_SLICE()) {
        my scalar $source = $expr->{"source"};
        my scalar $items = $expr->{"items"};
        my int $item_count = $expr->{"item_count"};

        # Determine the actual source SV expression (peel one DEREF_SCALAR)
        # and whether it returns an owned ref that needs decref after we
        # finish reading slice elements out of its array.
        my scalar $src_expr = $source;
        if ($source->{"type"} == NODE_DEREF_SCALAR()) {
            $src_expr = $source->{"ref"};
        }
        my int $src_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $src_expr) == 1;

        emit($cg, "({ StradaValue *__slice_res = strada_new_array(); ");
        if ($src_cleanup == 1) {
            emit($cg, "StradaValue *__slice_src_sv = ");
            gen_expression($cg, $src_expr);
            emit($cg, "; StradaArray *__slice_src = strada_deref_array(__slice_src_sv); ");
        } else {
            emit($cg, "StradaArray *__slice_src = strada_deref_array(");
            gen_expression($cg, $src_expr);
            emit($cg, "); ");
        }

        for (my int $i = 0; $i < $item_count; $i = $i + 1) {
            my scalar $item = $items->[$i];
            if ($item->{"type"} == NODE_RANGE()) {
                emit($cg, "for (int64_t __sl_i = ");
                emit_int_operand($cg, $item->{"start"});
                emit($cg, "; __sl_i <= ");
                emit_int_operand($cg, $item->{"end"});
                emit($cg, "; __sl_i++) { ");
                emit($cg, "strada_array_push(__slice_res->value.av, strada_array_get(__slice_src, __sl_i)); ");
                emit($cg, "} ");
            } else {
                emit($cg, "strada_array_push(__slice_res->value.av, strada_array_get(__slice_src, ");
                emit_int_operand($cg, $item);
                emit($cg, ")); ");
            }
        }

        if ($src_cleanup == 1) {
            emit($cg, "strada_decref(__slice_src_sv); ");
        }
        emit($cg, "__slice_res; })");
        return;
    }

    # Hash slice: @hash{"a", "b"} or @{$ref}{"a", "b"}
    if ($type == NODE_HASH_SLICE()) {
        my scalar $source = $expr->{"source"};
        my scalar $items = $expr->{"items"};
        my int $item_count = $expr->{"item_count"};

        my scalar $hsrc_expr = $source;
        if ($source->{"type"} == NODE_DEREF_SCALAR()) {
            $hsrc_expr = $source->{"ref"};
        }
        my int $hsrc_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $hsrc_expr) == 1;

        emit($cg, "({ StradaValue *__slice_res = strada_new_array(); ");
        if ($hsrc_cleanup == 1) {
            emit($cg, "StradaValue *__slice_src_sv = ");
            gen_expression($cg, $hsrc_expr);
            emit($cg, "; StradaHash *__slice_src = strada_deref_hash(__slice_src_sv); ");
        } else {
            emit($cg, "StradaHash *__slice_src = strada_deref_hash(");
            gen_expression($cg, $hsrc_expr);
            emit($cg, "); ");
        }

        for (my int $i = 0; $i < $item_count; $i = $i + 1) {
            my scalar $item = $items->[$i];
            my int $key_is_literal = $item->{"type"} == NODE_STR_LITERAL();
            if ($key_is_literal == 1) {
                emit($cg, "strada_array_push(__slice_res->value.av, strada_hash_get(__slice_src, ");
                gen_str_literal_c($cg, $item->{"value"});
                emit($cg, ")); ");
            } else {
                my int $key_needs_cleanup = needs_temp_cleanup($cg, $item);
                emit($cg, "{ StradaValue *__sl_k = ");
                gen_expression($cg, $item);
                emit($cg, "; char *__sl_ks = strada_to_str_ss(__sl_k); ");
                emit($cg, "strada_array_push(__slice_res->value.av, strada_hash_get(__slice_src, __sl_ks)); ");
                emit($cg, "strada_cstr_free(__sl_ks); ");
                if ($key_needs_cleanup == 1) {
                    emit($cg, "strada_decref(__sl_k); ");
                }
                emit($cg, "} ");
            }
        }

        if ($hsrc_cleanup == 1) {
            emit($cg, "strada_decref(__slice_src_sv); ");
        }
        emit($cg, "__slice_res; })");
        return;
    }

    # Reference
    if ($type == NODE_REF()) {
        my str $ref_type = $expr->{"ref_type"};
        if ($ref_type eq "&") {
            # Function reference - use strada_cpointer_new
            emit($cg, "strada_cpointer_new((void*)");
            gen_expression($cg, $expr->{"target"});
            emit($cg, ")");
        } elsif ($ref_type eq "$" && $expr->{"target"}->{"type"} == NODE_VARIABLE() && $expr->{"target"}->{"sigil"} eq "$") {
            # Scalar variable reference \$var — use slot ref for true aliasing
            # This allows $$ref = val to update the original variable
            emit($cg, "strada_slot_ref_create(&");
            gen_expression($cg, $expr->{"target"});
            emit($cg, ")");
        } else {
            emit($cg, "strada_new_ref(");
            gen_expression($cg, $expr->{"target"});
            emit($cg, ", '");
            emit($cg, $ref_type);
            emit($cg, "')");
        }
        return;
    }
    
    # Hash dereference - use strada_hv_fetch_owned for owned ref (fixes tied hash leak)
    if ($type == NODE_DEREF_HASH()) {
        my scalar $key_expr = $expr->{"key"};
        my int $key_is_literal = $key_expr->{"type"} == NODE_STR_LITERAL();

        # Autovivification: when this deref access is an intermediate in an
        # assignment-target chain ($r->{"a"}{"b"} = v, $r->{"a"}{"b"} += v),
        # create the missing intermediate hash instead of fetching undef.
        # Mirrors the NODE_HASH_ACCESS consumer above; strada_autoviv_hash
        # derefs REF/HASH parents itself and returns a BORROWED ref (owned
        # by the parent hash), so no cleanup of the result. Previously this
        # branch ignored the flag, so ref-rooted nested assignment targets
        # silently fetched undef and the store was lost.
        if ($cg->{"autoviv"} >= 1) {
            my int $dh_av = $cg->{"autoviv"};
            $cg->{"autoviv"} = 0;
            my str $dh_av_fn = "strada_autoviv_hash";
            if ($dh_av == 2) {
                $dh_av_fn = "strada_autoviv_array";
            }
            # Propagate (as HASH) right before generating the ref
            # sub-expression so key-expression accesses can't consume it
            my scalar $ref_sub = $expr->{"ref"};
            my int $dh_propagate = 0;
            if ($ref_sub->{"type"} == NODE_HASH_ACCESS() || $ref_sub->{"type"} == NODE_DEREF_HASH()
                || $ref_sub->{"type"} == NODE_SUBSCRIPT() || $ref_sub->{"type"} == NODE_DEREF_ARRAY()) {
                $dh_propagate = 1;
            }
            if ($key_is_literal == 1) {
                emit($cg, $dh_av_fn . "(");
                if ($dh_propagate == 1) { $cg->{"autoviv"} = 1; }
                gen_expression($cg, $expr->{"ref"});
                emit($cg, ", ");
                gen_str_literal_c($cg, $key_expr->{"value"});
                emit($cg, ")");
            } else {
                emit($cg, "({ StradaValue *__av_k = ");
                gen_expression($cg, $key_expr);
                emit($cg, "; char *__av_ks = strada_to_str_ss(__av_k); StradaValue *__av_r = " . $dh_av_fn . "(");
                if ($dh_propagate == 1) { $cg->{"autoviv"} = 1; }
                gen_expression($cg, $expr->{"ref"});
                emit($cg, ", __av_ks); strada_cstr_free(__av_ks); ");
                if (needs_temp_cleanup($cg, $key_expr) == 1) {
                    emit($cg, "strada_decref(__av_k); ");
                }
                emit($cg, "__av_r; })");
            }
            return;
        }

        my int $key_is_concat = is_concat_str_literal_left($key_expr);
        my int $ref_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $expr->{"ref"}) == 1;
        if ($key_is_literal == 1) {
            # Literal key: pre-hashed fetch (compile-time djb2, ASCII keys) so the
            # constant key isn't re-hashed on every access.
            emit_hash_fetch_literal($cg, $expr->{"ref"}, $key_expr->{"value"}, $ref_cleanup);
        } elsif ($key_is_concat == 1) {
            # Concat key "prefix" . $expr - zero-alloc stack buffer
            my scalar $concat_right = $key_expr->{"right"};
            my int $right_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $concat_right) == 1;
            my str $prefix_val = $key_expr->{"left"}->{"value"};
            my int $prefix_len = bytes($prefix_val);
            emit($cg, "({ ");
            if ($ref_cleanup == 1) {
                emit($cg, "StradaValue *__hd_ref = ");
                gen_expression($cg, $expr->{"ref"});
                emit($cg, "; ");
            }
            if ($right_cleanup == 1) {
                emit($cg, "StradaValue *__ck_r = ");
                gen_expression($cg, $concat_right);
                emit($cg, "; ");
            }
            emit($cg, "StradaValue *__ck_res = strada_hv_fetch_owned_concat(");
            if ($ref_cleanup == 1) {
                emit($cg, "__hd_ref");
            } else {
                gen_expression($cg, $expr->{"ref"});
            }
            emit($cg, ", ");
            gen_str_literal_c($cg, $prefix_val);
            emit($cg, ", " . $prefix_len . ", ");
            if ($right_cleanup == 1) {
                emit($cg, "__ck_r); strada_decref(__ck_r); ");
            } else {
                gen_expression($cg, $concat_right);
                emit($cg, "); ");
            }
            if ($ref_cleanup == 1) {
                emit($cg, "strada_decref(__hd_ref); ");
            }
            emit($cg, "__ck_res; })");
        } else {
            # Expression key - use _sv variant (no strada_to_str needed)
            my int $key_needs_cleanup = needs_temp_cleanup($cg, $key_expr);
            emit($cg, "({ ");
            if ($ref_cleanup == 1) {
                emit($cg, "StradaValue *__hd_ref = ");
                gen_expression($cg, $expr->{"ref"});
                emit($cg, "; ");
            }
            emit($cg, "StradaValue *__hget_k = ");
            gen_expression($cg, $key_expr);
            emit($cg, "; StradaValue *__hget_r = strada_hv_fetch_owned_sv(");
            if ($ref_cleanup == 1) {
                emit($cg, "__hd_ref");
            } else {
                gen_expression($cg, $expr->{"ref"});
            }
            emit($cg, ", __hget_k); ");
            if ($key_needs_cleanup == 1) {
                emit($cg, "strada_decref(__hget_k); ");
            }
            if ($ref_cleanup == 1) {
                emit($cg, "strada_decref(__hd_ref); ");
            }
            emit($cg, "__hget_r; })");
        }
        return;
    }

    # Array dereference
    if ($type == NODE_DEREF_ARRAY()) {
        my scalar $ref_expr = $expr->{"ref"};

        # Autovivification: intermediate deref-subscript in an assignment-
        # target chain ($r->[0]{"k"} = v). Mirrors NODE_SUBSCRIPT above.
        if ($cg->{"autoviv"} >= 1) {
            my int $da_av = $cg->{"autoviv"};
            $cg->{"autoviv"} = 0;
            my str $da_av_fn = "strada_autoviv_elem_hash";
            if ($da_av == 2) {
                $da_av_fn = "strada_autoviv_elem_array";
            }
            emit($cg, $da_av_fn . "(");
            if ($ref_expr->{"type"} == NODE_HASH_ACCESS() || $ref_expr->{"type"} == NODE_DEREF_HASH()
                || $ref_expr->{"type"} == NODE_SUBSCRIPT() || $ref_expr->{"type"} == NODE_DEREF_ARRAY()) {
                $cg->{"autoviv"} = 2;
            }
            gen_expression($cg, $ref_expr);
            emit($cg, ", ");
            emit_int_operand($cg, $expr->{"index"});
            emit($cg, ")");
            return;
        }

        my int $ref_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $ref_expr) == 1;
        if ($ref_cleanup == 1) {
            # Owned-ref source (e.g. $h{$k}->[i]) — see NODE_SUBSCRIPT
            # above for the rationale.
            emit($cg, "({ StradaValue *__da_r = ");
            gen_expression($cg, $ref_expr);
            emit($cg, "; StradaValue *__da_el = strada_array_get_owned(strada_deref_array(__da_r), ");
            emit_int_operand($cg, $expr->{"index"});
            emit($cg, "); strada_decref(__da_r); __da_el; })");
            return;
        }
        emit($cg, "strada_array_get(strada_deref_array(");
        gen_expression($cg, $ref_expr);
        emit($cg, "), ");
        emit_int_operand($cg, $expr->{"index"});
        emit($cg, ")");
        return;
    }
    
    # Scalar/Array/Hash dereference (@{}, %{}, $$)
    if ($type == NODE_DEREF_SCALAR()) {
        my str $sigil = $expr->{"sigil"};
        my int $inner_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $expr->{"ref"}) == 1;
        if ($inner_cleanup == 1) {
            # Inner expression returns owned ref - capture and decref after deref
            emit($cg, "({ StradaValue *__dtmp = ");
            gen_expression($cg, $expr->{"ref"});
            if ($sigil eq "@") {
                emit($cg, "; StradaValue *__dres = strada_deref_array_value(__dtmp); ");
            } elsif ($sigil eq "%") {
                emit($cg, "; StradaValue *__dres = strada_deref_hash_value(__dtmp); ");
            } else {
                emit($cg, "; StradaValue *__dres = strada_deref(__dtmp); ");
            }
            emit($cg, "strada_decref(__dtmp); __dres; })");
        } else {
            if ($sigil eq "@") {
                emit($cg, "strada_deref_array_value(");
            } elsif ($sigil eq "%") {
                emit($cg, "strada_deref_hash_value(");
            } else {
                emit($cg, "strada_deref(");
            }
            gen_expression($cg, $expr->{"ref"});
            emit($cg, ")");
        }
        return;
    }
    
    # Field access (obj->field)
    if ($type == NODE_FIELD_ACCESS()) {
        gen_expression($cg, $expr->{"object"});
        emit($cg, "->" . $expr->{"field"});
        return;
    }
    
    # Function reference (&func_name)
    if ($type == NODE_FUNC_REF()) {
        emit($cg, "&" . $expr->{"name"});
        return;
    }
    
    # Method call ($obj->method(args)) - Perl-style blessed reference method dispatch
    if ($type == NODE_METHOD_CALL()) { gen_method_call_node($cg, $expr); return; }

    # Dynamic method call: $obj->$method(args)
    if ($type == NODE_DYN_METHOD_CALL()) {
        my int $dm_arg_count = $expr->{"arg_count"};
        my scalar $dm_base = $expr->{"base_object"};
        my scalar $dm_meth_expr = $expr->{"method_expr"};
        my scalar $dm_args = $expr->{"args"};

        # Does the receiver expression produce an owned ref that must be
        # decref'd after the call? (E.g. $h{"obj"}->$method() — the hash
        # access returns an owned ref.)
        my int $dm_base_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $dm_base) == 1;

        # Check if any argument has spread operator
        my int $dm_has_spread = 0;
        for (my int $dm_sa = 0; $dm_sa < $dm_arg_count; $dm_sa = $dm_sa + 1) {
            if ($dm_args->[$dm_sa]->{"type"} == NODE_SPREAD()) {
                $dm_has_spread = 1;
            }
        }

        if ($dm_has_spread == 1) {
            # Build args array dynamically with spread support
            emit($cg, "({ StradaValue *__dm_mval = ");
            gen_expression($cg, $dm_meth_expr);
            emit($cg, "; char *__dm_mname = strada_to_str_ss(__dm_mval); ");
            emit($cg, "StradaValue *__dm_pa = strada_new_array(); ");

            my int $dm_a = 0;
            while ($dm_a < $dm_arg_count) {
                my scalar $dm_arg = $dm_args->[$dm_a];
                if ($dm_arg->{"type"} == NODE_SPREAD()) {
                    # Same fix as NODE_METHOD_CALL spread path: incref +
                    # push_take instead of push + incref (which
                    # double-counted).
                    emit($cg, "{ StradaValue *__dm_spread = ");
                    gen_expression($cg, $dm_arg->{"target"});
                    emit($cg, "; StradaArray *__dm_sa = strada_deref_array(__dm_spread); ");
                    emit($cg, "if (__dm_sa) { for (size_t __dm_si = 0; __dm_si < __dm_sa->size; __dm_si++) { ");
                    emit($cg, "strada_incref(__dm_sa->elements[__dm_si]); ");
                    emit($cg, "strada_array_push_take(strada_deref_array(__dm_pa), __dm_sa->elements[__dm_si]); } } } ");
                } else {
                    # Owned temps need push_take; variables stay with push.
                    my int $dm_arg_is_var = $dm_arg->{"type"} == NODE_VARIABLE();
                    if ($dm_arg_is_var == 1) {
                        emit($cg, "strada_array_push(strada_deref_array(__dm_pa), ");
                    } else {
                        emit($cg, "strada_array_push_take(strada_deref_array(__dm_pa), ");
                    }
                    gen_expression($cg, $dm_arg);
                    emit($cg, "); ");
                }
                $dm_a = $dm_a + 1;
            }

            emit($cg, "StradaValue *__dm_obj = ");
            gen_expression($cg, $dm_base);
            emit($cg, "; ");
            if ($dm_base_cleanup == 1) { emit($cg, "strada_cleanup_push(__dm_obj); "); }
            emit($cg, "StradaValue *__dm_res = strada_method_call(__dm_obj, __dm_mname, __dm_pa); strada_cstr_free(__dm_mname); ");
            if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $dm_meth_expr) == 1) {
                emit($cg, "strada_decref(__dm_mval); ");
            }
            if ($dm_base_cleanup == 1) { emit($cg, "strada_cleanup_pop(); strada_decref(__dm_obj); "); }
            emit($cg, "__dm_res; })");
        } else {
            # No spread - use regular strada_pack_args
            # Check if any args need temp cleanup
            my int $dm_needs_arg_cleanup = 0;
            if ($cg->{"cleanup_enabled"} == 1) {
                my int $dm_c = 0;
                while ($dm_c < $dm_arg_count) {
                    if (needs_temp_cleanup($cg, $dm_args->[$dm_c]) == 1) {
                        $dm_needs_arg_cleanup = 1;
                    }
                    $dm_c = $dm_c + 1;
                }
            }

            emit($cg, "({ StradaValue *__dm_mval = ");
            gen_expression($cg, $dm_meth_expr);
            emit($cg, "; char *__dm_mname = strada_to_str_ss(__dm_mval); ");

            if ($dm_needs_arg_cleanup == 1) {
                # Capture temp args
                my int $dm_a2 = 0;
                while ($dm_a2 < $dm_arg_count) {
                    if (needs_temp_cleanup($cg, $dm_args->[$dm_a2]) == 1) {
                        emit($cg, "StradaValue *__dm_arg_" . $dm_a2 . " = ");
                        gen_expression($cg, $dm_args->[$dm_a2]);
                        emit($cg, "; ");
                    }
                    $dm_a2 = $dm_a2 + 1;
                }
                emit($cg, "StradaValue *__dm_pa = strada_pack_args(" . $dm_arg_count);
                my int $dm_i = 0;
                while ($dm_i < $dm_arg_count) {
                    emit($cg, ", ");
                    if (needs_temp_cleanup($cg, $dm_args->[$dm_i]) == 1) {
                        emit($cg, "__dm_arg_" . $dm_i);
                    } else {
                        gen_expression($cg, $dm_args->[$dm_i]);
                    }
                    $dm_i = $dm_i + 1;
                }
                emit($cg, "); ");
                emit($cg, "StradaValue *__dm_obj = ");
                gen_expression($cg, $dm_base);
                emit($cg, "; ");
                if ($dm_base_cleanup == 1) { emit($cg, "strada_cleanup_push(__dm_obj); "); }
                emit($cg, "StradaValue *__dm_res = strada_method_call(__dm_obj, __dm_mname, __dm_pa); ");
                my int $dm_d = 0;
                while ($dm_d < $dm_arg_count) {
                    if (needs_temp_cleanup($cg, $dm_args->[$dm_d]) == 1) {
                        emit($cg, "strada_decref(__dm_arg_" . $dm_d . "); ");
                    }
                    $dm_d = $dm_d + 1;
                }
                emit($cg, "strada_cstr_free(__dm_mname); ");
                if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $dm_meth_expr) == 1) {
                    emit($cg, "strada_decref(__dm_mval); ");
                }
                if ($dm_base_cleanup == 1) { emit($cg, "strada_cleanup_pop(); strada_decref(__dm_obj); "); }
                emit($cg, "__dm_res; })");
            } else {
                # No temp args
                emit($cg, "StradaValue *__dm_pa = strada_pack_args(" . $dm_arg_count);
                my int $dm_i2 = 0;
                while ($dm_i2 < $dm_arg_count) {
                    emit($cg, ", ");
                    gen_expression($cg, $dm_args->[$dm_i2]);
                    $dm_i2 = $dm_i2 + 1;
                }
                emit($cg, "); StradaValue *__dm_obj = ");
                gen_expression($cg, $dm_base);
                emit($cg, "; ");
                if ($dm_base_cleanup == 1) { emit($cg, "strada_cleanup_push(__dm_obj); "); }
                emit($cg, "StradaValue *__dm_res = strada_method_call(__dm_obj, __dm_mname, __dm_pa); strada_cstr_free(__dm_mname); ");
                if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $dm_meth_expr) == 1) {
                    emit($cg, "strada_decref(__dm_mval); ");
                }
                if ($dm_base_cleanup == 1) { emit($cg, "strada_cleanup_pop(); strada_decref(__dm_obj); "); }
                emit($cg, "__dm_res; })");
            }
        }
        return;
    }

    # SUPER::method($self, args...) - calls parent method
    if ($type == NODE_SUPER_CALL()) {
        my int $arg_count = $expr->{"arg_count"};
        my str $method = $expr->{"method"};
        my scalar $args = $expr->{"args"};

        # SUPER::method requires at least one argument (the object/self)
        if ($arg_count < 1) {
            emit($cg, "strada_new_undef() /* SUPER call requires self argument */");
            return;
        }

        # Generate: ({ StradaValue *__pa = strada_pack_args(remaining...); StradaValue *__r = strada_super_call(self, pkg, method, __pa); strada_decref(__pa); __r; })
        my int $remaining = $arg_count - 1;
        emit($cg, "({ StradaValue *__super_pa = strada_pack_args(");
        emit($cg, "" . $remaining);
        my int $i = 1;
        while ($i < $arg_count) {
            emit($cg, ", ");
            gen_expression($cg, $args->[$i]);
            $i = $i + 1;
        }
        emit($cg, "); StradaValue *__super_res = strada_super_call(");
        gen_expression($cg, $args->[0]);
        my str $fn_pkg = $cg->{"current_fn_package"};
        emit($cg, ", \"" . $fn_pkg . "\", \"" . $method . "\", __super_pa); __super_res; })");
        return;
    }

    # $1-$9 capture variables
    if ($type == NODE_CAPTURE_VAR()) {
        emit($cg, "strada_capture_var(");
        emit($cg, "" . $expr->{"number"});
        emit($cg, ")");
        return;
    }

    # __PACKAGE__ - returns current package name
    if ($type == NODE_DUNDER_PACKAGE()) {
        emit($cg, "strada_new_str(strada_current_package() ? strada_current_package() : \"\")");
        return;
    }

    # __FILE__ - returns current file name
    if ($type == NODE_DUNDER_FILE()) {
        my str $filename = $cg->{"filename"};
        emit($cg, "strada_new_str(\"" . $filename . "\")");
        return;
    }

    # __LINE__ - returns current line number
    if ($type == NODE_DUNDER_LINE()) {
        my int $line = $expr->{"line_value"};
        emit($cg, "strada_new_int(" . $line . ")");
        return;
    }

    # Anonymous hash
    if ($type == NODE_ANON_HASH()) {
        my scalar $keys = $expr->{"keys"};
        my scalar $values = $expr->{"values"};
        my scalar $key_exprs = $expr->{"key_exprs"};
        my int $pair_count = $expr->{"pair_count"};

        # Check if any keys are expressions (dynamic keys)
        my int $has_expr_keys = 0;
        my int $check_k = 0;
        while ($check_k < $pair_count) {
            if ($key_exprs && $key_exprs->[$check_k]) {
                $has_expr_keys = 1;
            }
            $check_k = $check_k + 1;
        }

        # Check if any values need temp cleanup (newly created values)
        my int $needs_val_cleanup = 0;
        my int $check_i = 0;
        while ($check_i < $pair_count) {
            if (needs_temp_cleanup($cg, $values->[$check_i]) == 1) {
                $needs_val_cleanup = 1;
            }
            $check_i = $check_i + 1;
        }

        if ($has_expr_keys == 1) {
            # Has expression keys - build hash manually
            emit($cg, "({ StradaValue *__ah_hash = strada_new_hash(); ");
            my int $e = 0;
            while ($e < $pair_count) {
                if ($key_exprs && $key_exprs->[$e]) {
                    # Expression key - use strada_to_str
                    emit($cg, "{ char *__ah_k" . $e . " = strada_to_str_ss(");
                    gen_expression($cg, $key_exprs->[$e]);
                    emit($cg, "); strada_hash_set_take(__ah_hash->value.hv, __ah_k" . $e . ", ");
                    gen_expression($cg, $values->[$e]);
                    emit($cg, "); strada_cstr_free(__ah_k" . $e . "); } ");
                } else {
                    # String key (escape into the C string literal — keys can
                    # contain " etc. from single-quoted source, which would
                    # otherwise break out of the literal and inject C)
                    emit($cg, "strada_hash_set_take(__ah_hash->value.hv, \"");
                    emit_escaped_string($cg, $keys->[$e]);
                    emit($cg, "\", ");
                    gen_expression($cg, $values->[$e]);
                    emit($cg, "); ");
                }
                $e = $e + 1;
            }
            emit($cg, "__ah_hash; })");
        } elsif ($needs_val_cleanup == 1 && $cg->{"cleanup_enabled"} == 1) {
            # Generate block with temps for values that need cleanup
            emit($cg, "({ ");

            # Create temps for values that need cleanup
            # For anonymous arrays/hashes, use explicit new + new_ref pattern to avoid heap corruption
            my int $t = 0;
            while ($t < $pair_count) {
                if (needs_temp_cleanup($cg, $values->[$t]) == 1) {
                    my scalar $val = $values->[$t];
                    if ($val->{"type"} == NODE_ANON_ARRAY()) {
                        # Anonymous array: create explicit array + ref pattern
                        # This avoids the strada_ref_create_take issue that can cause heap corruption
                        my scalar $elems = $val->{"elements"};
                        my int $elem_count = $val->{"element_count"};
                        emit($cg, "StradaValue *__ah_arr" . $t . " = strada_new_array(); ");
                        # Add elements with proper refcount management
                        my int $e = 0;
                        while ($e < $elem_count) {
                            emit($cg, "StradaValue *__ah_ael" . $t . "_" . $e . " = ");
                            gen_expression($cg, $elems->[$e]);
                            emit($cg, "; strada_array_push(__ah_arr" . $t . "->value.av, __ah_ael" . $t . "_" . $e . "); ");
                            emit($cg, "strada_decref(__ah_ael" . $t . "_" . $e . "); ");
                            $e = $e + 1;
                        }
                        emit($cg, "StradaValue *__ah_val" . $t . " = strada_new_ref(__ah_arr" . $t . ", '@'); ");
                    } elsif ($val->{"type"} == NODE_ANON_HASH()) {
                        # Anonymous hash: create explicit hash + ref pattern
                        # This avoids the strada_ref_create_take issue that can cause heap corruption
                        my scalar $inner_keys = $val->{"keys"};
                        my scalar $inner_values = $val->{"values"};
                        my int $inner_pair_count = $val->{"pair_count"};
                        emit($cg, "StradaValue *__ah_hsh" . $t . " = strada_new_hash(); ");
                        # Add key-value pairs with proper refcount management
                        my int $p = 0;
                        while ($p < $inner_pair_count) {
                            emit($cg, "StradaValue *__ah_hel" . $t . "_" . $p . " = ");
                            gen_expression($cg, $inner_values->[$p]);
                            emit($cg, "; strada_hash_set(__ah_hsh" . $t . "->value.hv, \"");
                            emit_escaped_string($cg, $inner_keys->[$p]);
                            emit($cg, "\", __ah_hel" . $t . "_" . $p . "); ");
                            emit($cg, "strada_decref(__ah_hel" . $t . "_" . $p . "); ");
                            $p = $p + 1;
                        }
                        emit($cg, "StradaValue *__ah_val" . $t . " = strada_new_ref(__ah_hsh" . $t . ", '%'); ");
                    } else {
                        emit($cg, "StradaValue *__ah_val" . $t . " = ");
                        gen_expression($cg, $val);
                        emit($cg, "; ");
                    }
                    # Push the just-allocated value so a later throwing
                    # value doesn't leak earlier ones.
                    emit($cg, "strada_cleanup_push(__ah_val" . $t . "); ");
                }
                $t = $t + 1;
            }

            # Create the hash
            emit($cg, "StradaValue *__ah_hash = strada_anon_hash(" . $pair_count);
            my int $a = 0;
            while ($a < $pair_count) {
                emit($cg, ", \"");
                emit_escaped_string($cg, $keys->[$a]);
                emit($cg, "\", ");
                if (needs_temp_cleanup($cg, $values->[$a]) == 1) {
                    emit($cg, "__ah_val" . $a);
                } else {
                    gen_expression($cg, $values->[$a]);
                }
                $a = $a + 1;
            }
            emit($cg, "); ");

            # Pop cleanup-stack entries (reverse order) for each pushed value.
            my int $d = $pair_count - 1;
            while ($d >= 0) {
                if (needs_temp_cleanup($cg, $values->[$d]) == 1) {
                    emit($cg, "strada_cleanup_pop(); ");
                }
                $d = $d - 1;
            }
            # Decref temps to balance the incref from strada_hash_set
            # For anonymous arrays/hashes, also decref the underlying container
            $d = 0;
            while ($d < $pair_count) {
                if (needs_temp_cleanup($cg, $values->[$d]) == 1) {
                    my scalar $val = $values->[$d];
                    if ($val->{"type"} == NODE_ANON_ARRAY()) {
                        # Decref both the ref and the underlying array
                        emit($cg, "strada_decref(__ah_arr" . $d . "); ");
                    } elsif ($val->{"type"} == NODE_ANON_HASH()) {
                        # Decref both the ref and the underlying hash
                        emit($cg, "strada_decref(__ah_hsh" . $d . "); ");
                    }
                    emit($cg, "strada_decref(__ah_val" . $d . "); ");
                }
                $d = $d + 1;
            }

            # Return the hash
            emit($cg, "__ah_hash; })");
        } else {
            # Simple generation - no cleanup needed
            emit($cg, "strada_anon_hash(" . $pair_count);
            my int $i = 0;
            while ($i < $pair_count) {
                emit($cg, ", \"");
                emit_escaped_string($cg, $keys->[$i]);
                emit($cg, "\", ");
                gen_expression($cg, $values->[$i]);
                $i = $i + 1;
            }
            emit($cg, ")");
        }
        return;
    }
    
    # Anonymous array
    if ($type == NODE_ANON_ARRAY()) {
        my scalar $elems = $expr->{"elements"};
        my int $elem_count = $expr->{"element_count"};

        # Check if any elements need temp cleanup (newly created values)
        my int $needs_elem_cleanup = 0;
        my int $has_array_flatten = 0;
        my int $check_i = 0;
        while ($check_i < $elem_count) {
            if (needs_temp_cleanup($cg, $elems->[$check_i]) == 1) {
                $needs_elem_cleanup = 1;
            }
            # Perl-style list flattening: check for @array variables in list context
            my scalar $check_elem = $elems->[$check_i];
            if ($check_elem->{"type"} == NODE_VARIABLE() && $check_elem->{"sigil"} eq "@") {
                $has_array_flatten = 1;
            }
            $check_i = $check_i + 1;
        }

        # If any element is an @array, use dynamic building with flattening
        if ($has_array_flatten == 1) {
            emit($cg, "({ StradaValue *__fl_arr = strada_new_array(); ");
            my int $fi = 0;
            while ($fi < $elem_count) {
                my scalar $fl_elem = $elems->[$fi];
                if ($fl_elem->{"type"} == NODE_VARIABLE() && $fl_elem->{"sigil"} eq "@") {
                    # Flatten @array: iterate elements and push each one
                    emit($cg, "{ StradaArray *__fl_sa = strada_deref_array(");
                    gen_expression($cg, $fl_elem);
                    emit($cg, "); if (__fl_sa) { for (size_t __fl_i = 0; __fl_i < __fl_sa->size; __fl_i++) { ");
                    emit($cg, "strada_array_push(__fl_arr->value.av, __fl_sa->elements[__fl_sa->head + __fl_i]); } } } ");
                } else {
                    # Regular element: push directly
                    if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $fl_elem) == 1) {
                        emit($cg, "{ StradaValue *__fl_tmp = ");
                        gen_expression($cg, $fl_elem);
                        emit($cg, "; strada_array_push(__fl_arr->value.av, __fl_tmp); strada_decref(__fl_tmp); } ");
                    } else {
                        emit($cg, "strada_array_push(__fl_arr->value.av, ");
                        gen_expression($cg, $fl_elem);
                        emit($cg, "); ");
                    }
                }
                $fi = $fi + 1;
            }
            emit($cg, "__fl_arr; })");
            return;
        }

        if ($needs_elem_cleanup == 1 && $cg->{"cleanup_enabled"} == 1) {
            # Generate block with temps for elements that need cleanup
            # This ensures newly created values are decreffed after array creation
            # since strada_array_push increfs them (to handle existing variables)
            emit($cg, "({ ");

            # Create temps for elements that need cleanup
            # For anonymous arrays/hashes, use explicit new + new_ref pattern to avoid heap corruption
            my int $t = 0;
            while ($t < $elem_count) {
                if (needs_temp_cleanup($cg, $elems->[$t]) == 1) {
                    my scalar $elem = $elems->[$t];
                    if ($elem->{"type"} == NODE_ANON_ARRAY()) {
                        # Anonymous array: create explicit array + ref pattern
                        my scalar $inner_elems = $elem->{"elements"};
                        my int $inner_elem_count = $elem->{"element_count"};
                        emit($cg, "StradaValue *__aa_arr" . $t . " = strada_new_array(); ");
                        # Push inner array so a throwing inner element
                        # doesn't leak it (e.g. hash list-init pair
                        # like ("a" => boom())).
                        emit($cg, "strada_cleanup_push(__aa_arr" . $t . "); ");
                        # Create temps for inner elements, push, then decref
                        my int $e = 0;
                        while ($e < $inner_elem_count) {
                            emit($cg, "StradaValue *__aa_inner" . $t . "_" . $e . " = ");
                            gen_expression($cg, $inner_elems->[$e]);
                            emit($cg, "; strada_array_push(__aa_arr" . $t . "->value.av, __aa_inner" . $t . "_" . $e . "); ");
                            emit($cg, "strada_decref(__aa_inner" . $t . "_" . $e . "); ");
                            $e = $e + 1;
                        }
                        # _take transfers __aa_arr<t>'s sole owned ref
                        # to the new ref wrapper (no incref). The arr
                        # stays at refcount 1 (now owned by the ref),
                        # so on throw the catch's drain on __aa_el<t>
                        # cascades a free of the arr. The cleanup_pop
                        # below pops the arr's stack entry without
                        # decref (its ownership is in the ref now).
                        emit($cg, "strada_cleanup_pop(); ");
                        emit($cg, "StradaValue *__aa_el" . $t . " = strada_new_ref_take(__aa_arr" . $t . ", '@'); ");
                    } elsif ($elem->{"type"} == NODE_ANON_HASH()) {
                        # Anonymous hash: create explicit hash + ref pattern
                        my scalar $inner_keys = $elem->{"keys"};
                        my scalar $inner_values = $elem->{"values"};
                        my int $inner_pair_count = $elem->{"pair_count"};
                        emit($cg, "StradaValue *__aa_hsh" . $t . " = strada_new_hash(); ");
                        emit($cg, "strada_cleanup_push(__aa_hsh" . $t . "); ");
                        # Create temps for inner values, set, then decref
                        my int $p = 0;
                        while ($p < $inner_pair_count) {
                            emit($cg, "StradaValue *__aa_hval" . $t . "_" . $p . " = ");
                            gen_expression($cg, $inner_values->[$p]);
                            emit($cg, "; strada_hash_set(__aa_hsh" . $t . "->value.hv, \"");
                            emit_escaped_string($cg, $inner_keys->[$p]);
                            emit($cg, "\", __aa_hval" . $t . "_" . $p . "); ");
                            emit($cg, "strada_decref(__aa_hval" . $t . "_" . $p . "); ");
                            $p = $p + 1;
                        }
                        emit($cg, "strada_cleanup_pop(); ");
                        emit($cg, "StradaValue *__aa_el" . $t . " = strada_new_ref_take(__aa_hsh" . $t . ", '%'); ");
                    } else {
                        emit($cg, "StradaValue *__aa_el" . $t . " = ");
                        gen_expression($cg, $elem);
                        emit($cg, "; ");
                    }
                    # Push the just-allocated element so a throw from a
                    # later element doesn't leak the prior ones. Popped
                    # in reverse order before the result is yielded.
                    emit($cg, "strada_cleanup_push(__aa_el" . $t . "); ");
                }
                $t = $t + 1;
            }

            # Create the array
            emit($cg, "StradaValue *__aa_arr = strada_anon_array(" . $elem_count);
            my int $a = 0;
            while ($a < $elem_count) {
                emit($cg, ", ");
                if (needs_temp_cleanup($cg, $elems->[$a]) == 1) {
                    emit($cg, "__aa_el" . $a);
                } else {
                    gen_expression($cg, $elems->[$a]);
                }
                $a = $a + 1;
            }
            emit($cg, "); ");

            # Pop cleanup-stack entries (reverse) and decref temps.
            my int $d = $elem_count - 1;
            while ($d >= 0) {
                if (needs_temp_cleanup($cg, $elems->[$d]) == 1) {
                    emit($cg, "strada_cleanup_pop(); ");
                }
                $d = $d - 1;
            }
            $d = 0;
            while ($d < $elem_count) {
                if (needs_temp_cleanup($cg, $elems->[$d]) == 1) {
                    # __aa_el<d> owns __aa_arr<d>/__aa_hsh<d> via
                    # strada_new_ref_take, so we no longer separately
                    # decref the inner container — that would double-
                    # decref and free it underneath the ref.
                    emit($cg, "strada_decref(__aa_el" . $d . "); ");
                }
                $d = $d + 1;
            }

            # Return the array
            emit($cg, "__aa_arr; })");
        } else {
            # Simple generation - no cleanup needed
            emit($cg, "strada_anon_array(" . $elem_count);
            my int $i = 0;
            while ($i < $elem_count) {
                emit($cg, ", ");
                gen_expression($cg, $elems->[$i]);
                $i = $i + 1;
            }
            emit($cg, ")");
        }
        return;
    }

    # Map expression: map { block } @array
    if ($type == NODE_MAP()) {
        my scalar $block = $expr->{"block"};
        my scalar $array_expr = $expr->{"array"};
        my int $map_id = $cg->{"map_counter"};
        $cg->{"map_counter"} = $map_id + 1;

        my int $map_arr_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $array_expr) == 1;
        # Lazy-range fast path: map over an int-typed range iterates a
        # native C loop — no strada_range array materialization (mirrors
        # the foreach range path; `map {...} (1..1e6)` no longer builds a
        # million-element input). $_ is a tagged int per iteration.
        my int $map_is_range = 0;
        if ($array_expr->{"type"} == NODE_RANGE()
            && expr_is_int_typed($cg, $array_expr->{"start"}) == 1
            && expr_is_int_typed($cg, $array_expr->{"end"}) == 1) {
            $map_is_range = 1;
            $map_arr_cleanup = 0;
        }
        emit($cg, "({ ");
        if ($map_is_range == 1) {
            emit($cg, "int64_t __map_rs_" . $map_id . " = ");
            emit_int_operand($cg, $array_expr->{"start"});
            emit($cg, "; int64_t __map_re_" . $map_id . " = ");
            emit_int_operand($cg, $array_expr->{"end"});
            emit($cg, "; ");
        } elsif ($map_arr_cleanup == 1) {
            emit($cg, "StradaValue *__map_sv_" . $map_id . " = ");
            gen_expression($cg, $array_expr);
            # Push so a throwing block body lets the catch's drain
            # decref the source on the longjmp path.
            emit($cg, "; strada_cleanup_push(__map_sv_" . $map_id . "); StradaArray *__map_input_" . $map_id . " = strada_deref_array(__map_sv_" . $map_id . "); ");
        } else {
            emit($cg, "StradaArray *__map_input_" . $map_id . " = strada_deref_array(");
            gen_expression($cg, $array_expr);
            emit($cg, "); ");
        }
        emit($cg, "StradaValue *__map_result_" . $map_id . " = strada_new_array(); strada_cleanup_push(__map_result_" . $map_id . "); ");
        if ($map_is_range == 1) {
            emit($cg, "for (int64_t __map_i_" . $map_id . " = __map_rs_" . $map_id . "; __map_i_" . $map_id . " <= __map_re_" . $map_id . "; __map_i_" . $map_id . "++) { ");
            # Tagged for the practical range -> immortal, safe to treat as
            # borrowed exactly like the array path's array_get result.
            emit($cg, "StradaValue *__elem_ = strada_new_int(__map_i_" . $map_id . "); ");
        } else {
            emit($cg, "int __map_len_" . $map_id . " = strada_array_length(__map_input_" . $map_id . "); ");
            emit($cg, "for (int __map_i_" . $map_id . " = 0; __map_i_" . $map_id . " < __map_len_" . $map_id . "; __map_i_" . $map_id . "++) { ");
            emit($cg, "StradaValue *__elem_ = strada_array_get(__map_input_" . $map_id . ", __map_i_" . $map_id . "); ");
        }

        # Set flag to enable $_ magic variable
        $cg->{"in_map_block"} = 1;

        # Generate block - the last statement's expression is the result
        my scalar $stmts = $block->{"statements"};
        my int $stmt_count = $block->{"statement_count"};
        if ($stmt_count > 0) {
            # Handle all but last statement normally
            my int $i = 0;
            while ($i < $stmt_count - 1) {
                gen_statement($cg, $stmts->[$i]);
                $i = $i + 1;
            }
            # Last statement - extract its expression for the result
            # Flatten arrays for map { $_ => 1 } idiom
            my scalar $last_stmt = $stmts->[$stmt_count - 1];
            if ($last_stmt->{"type"} == NODE_EXPR_STMT()) {
                emit($cg, "{ StradaValue *__map_elem_" . $map_id . " = ");
                gen_expression($cg, $last_stmt->{"expr"});
                emit($cg, "; ");
                # Handle both STRADA_ARRAY and STRADA_REF to array (from strada_anon_array)
                emit($cg, "StradaValue *__flat_val_" . $map_id . " = __map_elem_" . $map_id . "; ");
                emit($cg, "if (__flat_val_" . $map_id . " && !STRADA_IS_TAGGED_INT(__flat_val_" . $map_id . ") && __flat_val_" . $map_id . "->type == STRADA_REF) { ");
                emit($cg, "__flat_val_" . $map_id . " = __flat_val_" . $map_id . "->value.rv; } ");
                emit($cg, "if (__flat_val_" . $map_id . " && !STRADA_IS_TAGGED_INT(__flat_val_" . $map_id . ") && __flat_val_" . $map_id . "->type == STRADA_ARRAY) { ");
                emit($cg, "StradaArray *__flat_arr_" . $map_id . " = __flat_val_" . $map_id . "->value.av; ");
                emit($cg, "for (size_t __flat_j_" . $map_id . " = 0; __flat_j_" . $map_id . " < __flat_arr_" . $map_id . "->size; __flat_j_" . $map_id . "++) { ");
                emit($cg, "strada_array_push(__map_result_" . $map_id . "->value.av, __flat_arr_" . $map_id . "->elements[__flat_j_" . $map_id . "]); } ");
                emit($cg, "strada_decref(__map_elem_" . $map_id . "); ");
                emit($cg, "} else { ");
                emit($cg, "strada_array_push(__map_result_" . $map_id . "->value.av, __map_elem_" . $map_id . "); strada_decref(__map_elem_" . $map_id . "); } } ");
            }
        }

        # Reset flag
        $cg->{"in_map_block"} = 0;

        emit($cg, "} ");
        # Pop the cleanup-stack entries we pushed (result, then optionally source).
        emit($cg, "strada_cleanup_pop(); ");
        if ($map_arr_cleanup == 1) {
            emit($cg, "strada_cleanup_pop(); strada_decref(__map_sv_" . $map_id . "); ");
        }
        emit($cg, "__map_result_" . $map_id . "; })");
        return;
    }

    # Sort expression: sort { $a <=> $b } @array
    if ($type == NODE_SORT()) {
        my scalar $block = $expr->{"block"};
        my scalar $array_expr = $expr->{"array"};

        # Default sort (no block)
        if (!$block) {
            if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $array_expr) == 1) {
                emit($cg, "({ StradaValue *__sort_a = ");
                gen_expression($cg, $array_expr);
                emit($cg, "; StradaValue *__sort_r = strada_sort(__sort_a); strada_decref(__sort_a); __sort_r; })");
            } else {
                emit($cg, "strada_sort(");
                gen_expression($cg, $array_expr);
                emit($cg, ")");
            }
            return;
        }

        # Custom sort with comparator block
        my int $sort_id = $cg->{"sort_counter"};
        $cg->{"sort_counter"} = $sort_id + 1;

        my int $sort_blk_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $array_expr) == 1;
        emit($cg, "({ ");
        if ($sort_blk_cleanup == 1) {
            emit($cg, "StradaValue *__sort_sv_" . $sort_id . " = ");
            gen_expression($cg, $array_expr);
            emit($cg, "; strada_cleanup_push(__sort_sv_" . $sort_id . "); StradaArray *__sort_input_" . $sort_id . " = strada_deref_array(__sort_sv_" . $sort_id . "); ");
        } else {
            emit($cg, "StradaArray *__sort_input_" . $sort_id . " = strada_deref_array(");
            gen_expression($cg, $array_expr);
            emit($cg, "); ");
        }
        emit($cg, "int __sort_len_" . $sort_id . " = strada_array_length(__sort_input_" . $sort_id . "); ");
        emit($cg, "StradaValue *__sort_result_" . $sort_id . " = strada_new_array(); strada_cleanup_push(__sort_result_" . $sort_id . "); ");
        # Copy elements to result
        emit($cg, "for (int __si_" . $sort_id . " = 0; __si_" . $sort_id . " < __sort_len_" . $sort_id . "; __si_" . $sort_id . "++) { ");
        emit($cg, "strada_array_push(strada_deref_array(__sort_result_" . $sort_id . "), strada_array_get(__sort_input_" . $sort_id . ", __si_" . $sort_id . ")); } ");
        # Bottom-up merge sort with the inlined comparator — O(n log n), stable.
        # Permutes the result array's element pointers in place via a scratch
        # buffer (pure pointer moves: refcount-neutral, no incref/decref of the
        # elements). The single comparison site below evaluates the user block
        # with $a/$b bound to __sort_a_/__sort_b_. (Replaced the original
        # O(n^2) bubble sort.)
        emit($cg, "StradaArray *__res_" . $sort_id . " = strada_deref_array(__sort_result_" . $sort_id . "); ");
        emit($cg, "StradaValue **__src_" . $sort_id . " = __res_" . $sort_id . "->elements + __res_" . $sort_id . "->head; ");
        # The merge scratch buffer is wrapped in a cleanup-tracked CSTRUCT value
        # so a comparator that throws (longjmp past the free below) still has it
        # reclaimed by the catch handler's cleanup-stack drain. See
        # strada_sortbuf_new() in the runtime.
        emit($cg, "StradaValue *__bufsv_" . $sort_id . " = strada_sortbuf_new(__sort_len_" . $sort_id . "); strada_cleanup_push(__bufsv_" . $sort_id . "); ");
        emit($cg, "StradaValue **__buf_" . $sort_id . " = (StradaValue**)__bufsv_" . $sort_id . "->value.ptr; ");
        emit($cg, "for (int __w_" . $sort_id . " = 1; __w_" . $sort_id . " < __sort_len_" . $sort_id . "; __w_" . $sort_id . " *= 2) { ");
        emit($cg, "for (int __lo_" . $sort_id . " = 0; __lo_" . $sort_id . " < __sort_len_" . $sort_id . "; __lo_" . $sort_id . " += __w_" . $sort_id . " + __w_" . $sort_id . ") { ");
        emit($cg, "int __mid_" . $sort_id . " = __lo_" . $sort_id . " + __w_" . $sort_id . "; if (__mid_" . $sort_id . " > __sort_len_" . $sort_id . ") __mid_" . $sort_id . " = __sort_len_" . $sort_id . "; ");
        emit($cg, "int __hi_" . $sort_id . " = __lo_" . $sort_id . " + __w_" . $sort_id . " + __w_" . $sort_id . "; if (__hi_" . $sort_id . " > __sort_len_" . $sort_id . ") __hi_" . $sort_id . " = __sort_len_" . $sort_id . "; ");
        emit($cg, "int __i_" . $sort_id . " = __lo_" . $sort_id . "; int __j_" . $sort_id . " = __mid_" . $sort_id . "; int __k_" . $sort_id . " = __lo_" . $sort_id . "; ");
        emit($cg, "while (__i_" . $sort_id . " < __mid_" . $sort_id . " && __j_" . $sort_id . " < __hi_" . $sort_id . ") { ");
        emit($cg, "StradaValue *__sort_a_ = __src_" . $sort_id . "[__i_" . $sort_id . "]; ");
        emit($cg, "StradaValue *__sort_b_ = __src_" . $sort_id . "[__j_" . $sort_id . "]; ");
        emit($cg, "StradaValue *__cmp_sv_" . $sort_id . " = ");

        # Set flag to enable $a/$b magic variables
        $cg->{"in_sort_block"} = 1;

        # Generate comparator block - extract the comparison expression
        my scalar $stmts = $block->{"statements"};
        my int $stmt_count = $block->{"statement_count"};
        if ($stmt_count > 0) {
            my scalar $last_stmt = $stmts->[$stmt_count - 1];
            if ($last_stmt->{"type"} == NODE_EXPR_STMT()) {
                gen_expression($cg, $last_stmt->{"expr"});
            }
        }

        # Reset flag
        $cg->{"in_sort_block"} = 0;

        emit($cg, "; int __cmp_" . $sort_id . " = strada_to_int(__cmp_sv_" . $sort_id . "); strada_decref(__cmp_sv_" . $sort_id . "); ");
        # __cmp <= 0 keeps the left run's element first → stable sort.
        emit($cg, "if (__cmp_" . $sort_id . " <= 0) { __buf_" . $sort_id . "[__k_" . $sort_id . "++] = __src_" . $sort_id . "[__i_" . $sort_id . "++]; } ");
        emit($cg, "else { __buf_" . $sort_id . "[__k_" . $sort_id . "++] = __src_" . $sort_id . "[__j_" . $sort_id . "++]; } } ");
        emit($cg, "while (__i_" . $sort_id . " < __mid_" . $sort_id . ") { __buf_" . $sort_id . "[__k_" . $sort_id . "++] = __src_" . $sort_id . "[__i_" . $sort_id . "++]; } ");
        emit($cg, "while (__j_" . $sort_id . " < __hi_" . $sort_id . ") { __buf_" . $sort_id . "[__k_" . $sort_id . "++] = __src_" . $sort_id . "[__j_" . $sort_id . "++]; } ");
        emit($cg, "for (int __m_" . $sort_id . " = __lo_" . $sort_id . "; __m_" . $sort_id . " < __hi_" . $sort_id . "; __m_" . $sort_id . "++) { __src_" . $sort_id . "[__m_" . $sort_id . "] = __buf_" . $sort_id . "[__m_" . $sort_id . "]; } ");
        emit($cg, "} } ");
        emit($cg, "strada_cleanup_pop(); strada_decref(__bufsv_" . $sort_id . "); ");
        emit($cg, "strada_cleanup_pop(); ");
        if ($sort_blk_cleanup == 1) {
            emit($cg, "strada_cleanup_pop(); strada_decref(__sort_sv_" . $sort_id . "); ");
        }
        emit($cg, "__sort_result_" . $sort_id . "; })");
        return;
    }

    # Grep expression: grep { block } @array
    if ($type == NODE_GREP()) {
        my scalar $block = $expr->{"block"};
        my scalar $array_expr = $expr->{"array"};
        my int $grep_id = $cg->{"grep_counter"};
        $cg->{"grep_counter"} = $grep_id + 1;

        my int $grep_arr_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $array_expr) == 1;
        # Lazy-range fast path (mirrors map): grep over an int-typed range
        # iterates natively — no input array materialization.
        my int $grep_is_range = 0;
        if ($array_expr->{"type"} == NODE_RANGE()
            && expr_is_int_typed($cg, $array_expr->{"start"}) == 1
            && expr_is_int_typed($cg, $array_expr->{"end"}) == 1) {
            $grep_is_range = 1;
            $grep_arr_cleanup = 0;
        }
        emit($cg, "({ ");
        if ($grep_is_range == 1) {
            emit($cg, "int64_t __grep_rs_" . $grep_id . " = ");
            emit_int_operand($cg, $array_expr->{"start"});
            emit($cg, "; int64_t __grep_re_" . $grep_id . " = ");
            emit_int_operand($cg, $array_expr->{"end"});
            emit($cg, "; ");
        } elsif ($grep_arr_cleanup == 1) {
            emit($cg, "StradaValue *__grep_sv_" . $grep_id . " = ");
            gen_expression($cg, $array_expr);
            emit($cg, "; strada_cleanup_push(__grep_sv_" . $grep_id . "); StradaArray *__grep_input_" . $grep_id . " = strada_deref_array(__grep_sv_" . $grep_id . "); ");
        } else {
            emit($cg, "StradaArray *__grep_input_" . $grep_id . " = strada_deref_array(");
            gen_expression($cg, $array_expr);
            emit($cg, "); ");
        }
        emit($cg, "StradaValue *__grep_result_" . $grep_id . " = strada_new_array(); strada_cleanup_push(__grep_result_" . $grep_id . "); ");
        if ($grep_is_range == 1) {
            emit($cg, "for (int64_t __grep_i_" . $grep_id . " = __grep_rs_" . $grep_id . "; __grep_i_" . $grep_id . " <= __grep_re_" . $grep_id . "; __grep_i_" . $grep_id . "++) { ");
            emit($cg, "StradaValue *__elem_ = strada_new_int(__grep_i_" . $grep_id . "); ");
        } else {
            emit($cg, "int __grep_len_" . $grep_id . " = strada_array_length(__grep_input_" . $grep_id . "); ");
            emit($cg, "for (int __grep_i_" . $grep_id . " = 0; __grep_i_" . $grep_id . " < __grep_len_" . $grep_id . "; __grep_i_" . $grep_id . "++) { ");
            emit($cg, "StradaValue *__elem_ = strada_array_get(__grep_input_" . $grep_id . ", __grep_i_" . $grep_id . "); ");
        }

        # Set flag to enable $_ magic variable
        $cg->{"in_grep_block"} = 1;

        # Generate block - evaluate to boolean, cleaning up temp if needed
        my scalar $stmts = $block->{"statements"};
        my int $stmt_count = $block->{"statement_count"};
        my int $grep_needs_cleanup = 0;
        if ($stmt_count > 0) {
            my scalar $last_stmt = $stmts->[$stmt_count - 1];
            if ($last_stmt->{"type"} == NODE_EXPR_STMT()) {
                if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $last_stmt->{"expr"}) == 1) {
                    $grep_needs_cleanup = 1;
                }
            }
        }
        if ($grep_needs_cleanup == 1) {
            emit($cg, "if (({ StradaValue *__grep_cond = ");
            my scalar $last_stmt = $stmts->[$stmt_count - 1];
            gen_expression($cg, $last_stmt->{"expr"});
            emit($cg, "; int __grep_bool = strada_to_bool(__grep_cond); strada_decref(__grep_cond); __grep_bool; })) { ");
        } else {
            emit($cg, "if (strada_to_bool(");
            if ($stmt_count > 0) {
                my scalar $last_stmt = $stmts->[$stmt_count - 1];
                if ($last_stmt->{"type"} == NODE_EXPR_STMT()) {
                    gen_expression($cg, $last_stmt->{"expr"});
                }
            }
            emit($cg, ")) { ");
        }

        # Reset flag
        $cg->{"in_grep_block"} = 0;

        emit($cg, "strada_array_push(strada_deref_array(__grep_result_" . $grep_id . "), __elem_); } ");
        emit($cg, "} ");
        emit($cg, "strada_cleanup_pop(); ");
        if ($grep_arr_cleanup == 1) {
            emit($cg, "strada_cleanup_pop(); strada_decref(__grep_sv_" . $grep_id . "); ");
        }
        emit($cg, "__grep_result_" . $grep_id . "; })");
        return;
    }

    # Anonymous function
    if ($type == NODE_ANON_FUNC()) {
        my int $id = $cg->{"anon_func_counter"};
        $cg->{"anon_func_counter"} = $id + 1;
        my str $func_name = "__anon_func_" . $id;

        my scalar $params = $expr->{"params"};
        my int $param_count = $expr->{"param_count"};

        # Save current capture state (for nested closures)
        my int $saved_in_anon = $cg->{"in_anon_func"};
        my str $saved_param_str = $cg->{"anon_param_str"};
        my str $saved_local_str = $cg->{"anon_local_str"};
        my str $saved_capture_str = $cg->{"anon_capture_str"};
        my int $saved_capture_count = $cg->{"anon_capture_count"};
        my int $saved_ret_is_int = $cg->{"ret_is_int"};
        my int $saved_ret_is_num = $cg->{"ret_is_num"};

        # Set up capture context for this closure
        $cg->{"in_anon_func"} = 1;
        $cg->{"anon_local_str"} = "";
        $cg->{"anon_capture_str"} = "";
        $cg->{"anon_capture_count"} = 0;
        # The closure body's returns coerce by ITS return type, not the
        # enclosing function's (see gen_return_value)
        $cg->{"ret_is_int"} = 0;
        if ($expr->{"return_type"} == TYPE_INT()) {
            $cg->{"ret_is_int"} = 1;
        }
        $cg->{"ret_is_num"} = 0;
        if ($expr->{"return_type"} == TYPE_NUM()) {
            $cg->{"ret_is_num"} = 1;
        }

        # Build param string from parameters
        my str $param_str = "";
        my int $i = 0;
        while ($i < $param_count) {
            my scalar $p = $params->[$i];
            if ($param_str eq "") {
                $param_str = $p->{"name"};
            } else {
                $param_str = $param_str . "," . $p->{"name"};
            }
            $i = $i + 1;
        }
        $cg->{"anon_param_str"} = $param_str;

        # Generate forward declaration (triple pointer for capture-by-reference)
        my str $decl = "StradaValue* " . $func_name . "(StradaValue ***__captures";
        $i = 0;
        while ($i < $param_count) {
            my scalar $p = $params->[$i];
            $decl = $decl . ", StradaValue *" . $p->{"name"};
            $i = $i + 1;
        }
        $decl = $decl . ")";
        $cg->{"anon_func_decls"} = $cg->{"anon_func_decls"} . $decl . ";\n";

        my str $def = $decl . " {\n";

        # Save current output (using StringBuilder)
        my str $saved_output = sb_to_string($cg->{"output_sb"});
        my int $saved_indent = $cg->{"indent"};
        my int $saved_in_main = $cg->{"in_main"};

        # Save scope state (closures are separate functions with their own scope)
        my scalar $saved_scope_vars = $cg->{"scope_vars"};
        my scalar $saved_scope_counts = $cg->{"scope_counts"};
        my int $saved_scope_depth = $cg->{"scope_depth"};

        # Save function parameter state (closures have their own parameters)
        my scalar $saved_func_params = $cg->{"func_params"};
        my scalar $saved_func_param_names = $cg->{"func_param_names"};
        my int $saved_func_param_count = $cg->{"func_param_count"};

        # Start fresh for function body (closures are NOT main)
        sb_clear($cg->{"output_sb"});
        $cg->{"indent"} = 1;
        $cg->{"in_main"} = 0;

        # Reset scope for closure (it's a new function)
        my array @new_scope_vars = ();
        my array @new_scope_counts = ();
        $cg->{"scope_vars"} = \@new_scope_vars;
        $cg->{"scope_counts"} = \@new_scope_counts;
        $cg->{"scope_depth"} = 0;

        # Reset function parameter tracking for closure (no param incref in closures)
        $cg->{"func_params"} = {};
        $cg->{"func_param_names"} = [];
        $cg->{"func_param_count"} = 0;

        # Save and check func_has_try for this closure
        my int $saved_func_has_try = $cg->{"func_has_try"};
        my scalar $anon_body = $expr->{"body"};
        if (func_body_has_try($anon_body) == 1) {
            $cg->{"func_has_try"} = 1;
        } else {
            $cg->{"func_has_try"} = 0;
        }

        # Push a scope so `my $x = ...` inside the closure body tracks
        # the local in scope_vars (scope_track_var early-returns when
        # depth == 0). Without this, closure-body locals were never
        # decref'd on return: every closure call leaked one SV per
        # local in its body, and capture bindings like
        # `my $loc = $captured;` (which incref the source) leaked
        # the incref forever.
        scope_push($cg);

        # Generate body (this will populate capture_str as variables are accessed)
        my scalar $body = $expr->{"body"};
        my scalar $stmts = $body->{"statements"};
        my int $stmt_count = $body->{"statement_count"};
        $i = 0;
        while ($i < $stmt_count) {
            gen_statement($cg, $stmts->[$i]);
            $i = $i + 1;
        }
        # Emit decrefs for the closure's locals before the implicit
        # return. scope_pop both removes the scope from scope_vars and
        # emits the trailing decrefs via emit_scope_decref.
        scope_pop($cg);

        # Get body content
        my str $body_content = sb_to_string($cg->{"output_sb"});
        $def = $def . "    (void)__captures;\n";
        $def = $def . $body_content;

        # Always add implicit return at end of closures to prevent undefined behavior
        # If the closure has an explicit return, this is unreachable and optimized away
        $def = $def . "    return strada_undef_static();\n";

        $def = $def . "}\n\n";

        # Capture the capture info before restoring state
        my str $capture_str = $cg->{"anon_capture_str"};
        my int $capture_count = $cg->{"anon_capture_count"};

        # Restore output (using StringBuilder)
        sb_clear($cg->{"output_sb"});
        sb_append($cg->{"output_sb"}, $saved_output);
        $cg->{"indent"} = $saved_indent;
        $cg->{"in_main"} = $saved_in_main;

        # Restore scope state
        $cg->{"scope_vars"} = $saved_scope_vars;
        $cg->{"scope_counts"} = $saved_scope_counts;
        $cg->{"scope_depth"} = $saved_scope_depth;

        # Restore function parameter state
        $cg->{"func_params"} = $saved_func_params;
        $cg->{"func_param_names"} = $saved_func_param_names;
        $cg->{"func_param_count"} = $saved_func_param_count;

        # Restore capture state
        $cg->{"in_anon_func"} = $saved_in_anon;
        $cg->{"anon_param_str"} = $saved_param_str;
        $cg->{"anon_local_str"} = $saved_local_str;
        $cg->{"anon_capture_str"} = $saved_capture_str;
        $cg->{"anon_capture_count"} = $saved_capture_count;
        $cg->{"ret_is_int"} = $saved_ret_is_int;
        $cg->{"ret_is_num"} = $saved_ret_is_num;

        # Restore func_has_try
        $cg->{"func_has_try"} = $saved_func_has_try;

        $cg->{"anon_func_defs"} = $cg->{"anon_func_defs"} . $def;

        # Emit closure creation with captures (using double pointers for capture-by-reference)
        if ($capture_count == 0) {
            emit($cg, "strada_closure_new((void*)&" . $func_name . ", " . $param_count . ", 0, NULL)");
        } else {
            # Build capture array inline with addresses for capture-by-reference
            emit($cg, "strada_closure_new((void*)&" . $func_name . ", " . $param_count . ", " . $capture_count . ", ");
            emit($cg, "(StradaValue**[]){");
            # Parse capture_str to emit address of each captured variable
            my int $cap_idx = 0;
            my int $start = 0;
            my int $len = length($capture_str);
            $i = 0;
            while ($i <= $len) {
                my str $ch = "";
                if ($i < $len) { $ch = substr($capture_str, $i, 1); }
                if ($ch eq "," || $i == $len) {
                    if ($cap_idx > 0) { emit($cg, ", "); }
                    my str $cap_name = substr($capture_str, $start, $i - $start);
                    emit($cg, "&" . $cap_name);
                    $cap_idx = $cap_idx + 1;
                    $start = $i + 1;
                }
                $i = $i + 1;
            }
            emit($cg, "})");
        }
        return;
    }

    # Closure call
    if ($type == NODE_CLOSURE_CALL()) {
        my scalar $args = $expr->{"args"};
        my int $arg_count = $expr->{"arg_count"};

        # Check if callee expression needs cleanup (e.g. hash access returning owned ref)
        my int $callee_cleanup = 0;
        if ($cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $expr->{"closure"}) == 1) {
            $callee_cleanup = 1;
        }

        # Check if any argument needs cleanup
        my int $needs_arg_cleanup = 0;
        if ($cg->{"cleanup_enabled"} == 1 && $arg_count > 0) {
            my int $ca = 0;
            while ($ca < $arg_count) {
                if (needs_temp_cleanup($cg, $args->[$ca]) == 1) {
                    $needs_arg_cleanup = 1;
                }
                $ca = $ca + 1;
            }
        }

        if ($needs_arg_cleanup == 1 || $callee_cleanup == 1) {
            emit($cg, "({ ");
            # Capture callee if it needs cleanup
            if ($callee_cleanup == 1) {
                emit($cg, "StradaValue *__cl_fn = ");
                gen_expression($cg, $expr->{"closure"});
                emit($cg, "; ");
            }
            # Capture each argument that needs cleanup
            my int $ca = 0;
            while ($ca < $arg_count) {
                emit($cg, "StradaValue *__cla" . $ca . " = ");
                gen_expression($cg, $args->[$ca]);
                emit($cg, "; ");
                $ca = $ca + 1;
            }
            # Make the call
            emit($cg, "StradaValue *__clres = strada_closure_call(");
            if ($callee_cleanup == 1) {
                emit($cg, "__cl_fn");
            } else {
                gen_expression($cg, $expr->{"closure"});
            }
            emit($cg, ", " . $arg_count);
            $ca = 0;
            while ($ca < $arg_count) {
                emit($cg, ", __cla" . $ca);
                $ca = $ca + 1;
            }
            emit($cg, "); ");
            # Cleanup callee if needed
            if ($callee_cleanup == 1) {
                emit($cg, "strada_decref(__cl_fn); ");
            }
            # Cleanup arguments that need it
            $ca = 0;
            while ($ca < $arg_count) {
                if (needs_temp_cleanup($cg, $args->[$ca]) == 1) {
                    emit($cg, "strada_decref(__cla" . $ca . "); ");
                }
                $ca = $ca + 1;
            }
            emit($cg, "__clres; })");
        } elsif ($expr->{"has_spread"} == 1) {
            # Spread args: build array and call via strada_closure_call_array
            emit($cg, "({ StradaValue *__cl_fn2 = ");
            gen_expression($cg, $expr->{"closure"});
            emit($cg, "; StradaValue *__cl_arr = strada_new_array(); ");
            my int $si = 0;
            while ($si < $arg_count) {
                my scalar $sarg = $args->[$si];
                if ($sarg->{"type"} == NODE_SPREAD()) {
                    # Spread: push each element from the array
                    emit($cg, "{ StradaArray *__sp_av = strada_deref_array(");
                    gen_expression($cg, $sarg->{"target"});
                    emit($cg, "); if (__sp_av) for (size_t __sp_i = 0; __sp_i < __sp_av->size; __sp_i++) ");
                    emit($cg, "strada_array_push(strada_deref_array(__cl_arr), __sp_av->elements[__sp_av->head + __sp_i]); } ");
                } else {
                    emit($cg, "strada_array_push(strada_deref_array(__cl_arr), ");
                    gen_expression($cg, $sarg);
                    emit($cg, "); ");
                }
                $si = $si + 1;
            }
            emit($cg, "StradaValue *__cl_res2 = strada_closure_call_array(__cl_fn2, __cl_arr); ");
            emit($cg, "strada_decref(__cl_arr); __cl_res2; })");
        } else {
            emit($cg, "strada_closure_call(");
            gen_expression($cg, $expr->{"closure"});
            emit($cg, ", " . $arg_count);
            my int $i = 0;
            while ($i < $arg_count) {
                emit($cg, ", ");
                gen_expression($cg, $args->[$i]);
                $i = $i + 1;
            }
            emit($cg, ")");
        }
        return;
    }

    # Ternary expression: cond ? true_expr : false_expr
    # FIX: When branches return borrowed references (hash/array access), we need
    # to incref the result so it becomes an owned reference. This prevents the
    # "double hash access in ternary" bug where:
    #   defined($h->{"key"}) ? $h->{"key"} : ""
    # would cause memory corruption because the ternary result is a borrowed
    # reference that might be incorrectly decref'd by callers.
    if ($type == NODE_TERNARY()) {
        my int $true_needs = return_needs_incref($cg, $expr->{"true_expr"});
        my int $false_needs = return_needs_incref($cg, $expr->{"false_expr"});

        if (($true_needs == 1 || $false_needs == 1) && $cg->{"cleanup_enabled"} == 1) {
            # At least one branch returns borrowed ref — need to make both owned
            my int $true_owned = needs_temp_cleanup($cg, $expr->{"true_expr"});
            my int $false_owned = needs_temp_cleanup($cg, $expr->{"false_expr"});

            if ($true_owned == 1 && $false_owned == 1) {
                # Both branches already return owned values — no incref needed
                emit($cg, "(");
                emit_condition($cg, $expr->{"condition"});
                emit($cg, " ? ");
                gen_expression($cg, $expr->{"true_expr"});
                emit($cg, " : ");
                gen_expression($cg, $expr->{"false_expr"});
                emit($cg, ")");
            } elsif ($true_owned == 0 && $false_owned == 0) {
                # Both branches return borrowed — incref the result
                emit($cg, "({ StradaValue *__tern_tmp = (");
                emit_condition($cg, $expr->{"condition"});
                emit($cg, " ? ");
                gen_expression($cg, $expr->{"true_expr"});
                emit($cg, " : ");
                gen_expression($cg, $expr->{"false_expr"});
                emit($cg, "); strada_incref(__tern_tmp); __tern_tmp; })");
            } else {
                # Mixed: selectively incref only the borrowed branch
                emit($cg, "({ StradaValue *__tern_tmp; if (");
                emit_condition($cg, $expr->{"condition"});
                emit($cg, ") { __tern_tmp = ");
                gen_expression($cg, $expr->{"true_expr"});
                emit($cg, ";");
                if ($true_owned == 0) {
                    emit($cg, " strada_incref(__tern_tmp);");
                }
                emit($cg, " } else { __tern_tmp = ");
                gen_expression($cg, $expr->{"false_expr"});
                emit($cg, ";");
                if ($false_owned == 0) {
                    emit($cg, " strada_incref(__tern_tmp);");
                }
                emit($cg, " } __tern_tmp; })");
            }
        } else {
            emit($cg, "(");
            emit_condition($cg, $expr->{"condition"});
            emit($cg, " ? ");
            gen_expression($cg, $expr->{"true_expr"});
            emit($cg, " : ");
            gen_expression($cg, $expr->{"false_expr"});
            emit($cg, ")");
        }
        return;
    }

    # Range expression: start..end
    if ($type == NODE_RANGE()) {
        my int $start_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $expr->{"start"}) == 1;
        my int $end_cleanup = $cg->{"cleanup_enabled"} == 1 && needs_temp_cleanup($cg, $expr->{"end"}) == 1;
        if ($start_cleanup == 1 || $end_cleanup == 1) {
            emit($cg, "({ ");
            if ($start_cleanup == 1) {
                emit($cg, "StradaValue *__range_s = ");
                gen_expression($cg, $expr->{"start"});
                emit($cg, "; ");
            }
            if ($end_cleanup == 1) {
                emit($cg, "StradaValue *__range_e = ");
                gen_expression($cg, $expr->{"end"});
                emit($cg, "; ");
            }
            emit($cg, "StradaValue *__range_r = strada_range(");
            if ($start_cleanup == 1) {
                emit($cg, "__range_s");
            } else {
                gen_expression($cg, $expr->{"start"});
            }
            emit($cg, ", ");
            if ($end_cleanup == 1) {
                emit($cg, "__range_e");
            } else {
                gen_expression($cg, $expr->{"end"});
            }
            emit($cg, "); ");
            if ($start_cleanup == 1) {
                emit($cg, "strada_decref(__range_s); ");
            }
            if ($end_cleanup == 1) {
                emit($cg, "strada_decref(__range_e); ");
            }
            emit($cg, "__range_r; })");
        } else {
            emit($cg, "strada_range(");
            gen_expression($cg, $expr->{"start"});
            emit($cg, ", ");
            gen_expression($cg, $expr->{"end"});
            emit($cg, ")");
        }
        return;
    }

    # Await expression: await $future
    if ($type == NODE_AWAIT()) {
        emit($cg, "strada_future_await(");
        gen_expression($cg, $expr->{"expr"});
        emit($cg, ")");
        return;
    }

    # Readline expression (diamond operator): <$fh>
    if ($type == NODE_READLINE()) {
        my str $varname = $expr->{"varname"};
        emit($cg, "strada_read_line(" . escape_c_keyword($varname) . ")");
        return;
    }

    # Spread operator - only valid inside function call arguments
    # If we reach here, the spread is being used incorrectly
    if ($type == NODE_SPREAD()) {
        die("error: spread operator (...) is only valid in function call arguments");
        return;
    }
}

# ============================================================
# Statement Code Generation
# ============================================================

