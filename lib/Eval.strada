        my int $dt_d = $dt->{"day"};
        my int $dt_h = $dt->{"hour"};
        my int $dt_mi = $dt->{"minute"};
        my int $dt_s = $dt->{"second"};
        my str $fmt = $args->[1];
        my str $result = "";
        __C__ {
