# binary-trees (benchmarks-game style) — the classic allocator stress:
# build perfect binary trees of hashrefs, walk them, throw them away.
# Deep pointer-chasing plus allocation/teardown of millions of small
# nodes; bench_gc's flat churn doesn't exercise depth. Comparable to the
# public benchmarks-game tables for other languages (depth 16 here).
#
# Sections:
#   stretch    — one depth-17 tree built+checked+freed
#   long-lived — depth-16 tree kept alive across the run
#   iterate    — depths 4..14 (step 2), many short-lived trees each
#
# Reference numbers: benchmarks/BASELINE.md

package main;

func build(int $depth) scalar {
    if ($depth == 0) {
        return { "l" => undef, "r" => undef };
    }
    return { "l" => build($depth - 1), "r" => build($depth - 1) };
}

func check(scalar $node) int {
    if (!defined($node->{"l"})) {
        return 1;
    }
    return 1 + check($node->{"l"}) + check($node->{"r"});
}

func main() int {
    my int $max_depth = 16;

    my num $t0 = core::hires_time();

    # 1. stretch tree
    my scalar $stretch = build($max_depth + 1);
    my int $stretch_check = check($stretch);
    $stretch = undef;
    my num $t1 = core::hires_time();
    say("stretch: " . $stretch_check . " " . ($t1 - $t0));

    # 2. long-lived tree (held while the iteration churns)
    my scalar $long_lived = build($max_depth);
    my num $t2 = core::hires_time();
    say("long-lived: built " . ($t2 - $t1));

    # 3. iterations: many short-lived trees per depth
    my int $depth = 4;
    while ($depth <= 14) {
        my int $iters = 1 << ($max_depth - $depth + 2);
        my int $sum = 0;
        my int $i = 0;
        while ($i < $iters) {
            my scalar $t = build($depth);
            $sum += check($t);
            $i++;
        }
        say("depth " . $depth . ": " . $iters . " trees, check " . $sum);
        $depth += 2;
    }
    my num $t3 = core::hires_time();
    say("iterate: " . check($long_lived) . " " . ($t3 - $t2));

    say("total: " . ($t3 - $t0));
    return 0;
}
