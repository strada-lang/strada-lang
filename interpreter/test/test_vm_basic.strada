package main;

func fib(int $n) int {
    if ($n < 2) {
        return $n;
    }
    return fib($n - 1) + fib($n - 2);
}

func main() int {
    my int $sum = 0;
    my int $i = 1;
    while ($i <= 100) {
        $sum += $i;
        $i++;
    }
    say("sum: " . $sum);
    say("fib(10): " . fib(10));
    return 0;
}
