# test_udp_ipv6.strada - dual-stack UDP datagram round trip.
#
# sys::udp_socket() / udp_server() create dual-stack IPv6 UDP sockets
# (IPV6_V6ONLY off), so udp_sendto() reaches both IPv6 and IPv4 destinations
# (v4 via v4-mapped addresses) and udp_recvfrom() reports the sender's address
# (IPv4-mapped senders are shown as dotted-quad).

func main() int {
    my int $port = 19898;
    my scalar $server = sys::udp_server($port);
    if (!$server) { say("FAIL: could not bind UDP server"); return 1; }

    my int $pid = sys::fork();
    if ($pid == 0) {
        # Child: send a datagram to the server over IPv6 loopback.
        my scalar $sock = sys::udp_socket();
        sys::udp_sendto($sock, "ping", "::1", $port);
        my scalar $reply = sys::udp_recvfrom($sock, 1024);
        say("client received: " . $reply->{"data"});
        sys::socket_close($sock);
        core::exit(0);
    }

    # Parent: receive the datagram and reply to its sender.
    my scalar $msg = sys::udp_recvfrom($server, 1024);
    say("server received: " . $msg->{"data"} . " from " . $msg->{"ip"});
    sys::udp_sendto($server, "pong:" . $msg->{"data"}, $msg->{"ip"}, $msg->{"port"});
    sys::socket_close($server);
    sys::wait();
    return 0;
}
