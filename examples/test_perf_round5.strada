# Regression tests for the round-5 performance work:
#   - zero-copy keys()/each() (shared key StradaStrings + COW on mutation)
#   - join via strada_join_sv (borrowed STR elements, direct-build result)
#   - decorate-sort-undecorate for mixed-type default sort
#   - reusable pcre2 match data (incl. nested matches via s///e)
#   - condition-level CSE for repeated literal-key hash fetches
#   - growable sprintf buffer (wide formats no longer truncate)

func main() int {
    my int $fails = 0;

    # --- zero-copy keys: mutating a keys() copy must not corrupt the hash ---
    my hash %m = ("alpha" => 1, "beta" => 2, "gamma" => 3);
    my array @ks = keys(%m);
    my str $k = $ks[0];
    $k = $k . "_mutated";          # concat on the shared-SS copy (COW)
    my array @after = sort(keys(%m));
    if (join(",", @after) ne "alpha,beta,gamma") { say("FAIL keys-cow: " . join(",", @after)); $fails = $fails + 1; }
    # each() key shares too — append to it, then re-walk
    my array @pair = each(%m);
    if (size(@pair) == 2) {
        my str $ek = $pair[0];
        $ek = $ek . "X";
        my array @after2 = sort(keys(%m));
        if (join(",", @after2) ne "alpha,beta,gamma") { say("FAIL each-cow"); $fails = $fails + 1; }
    } else {
        say("FAIL each-shape");
        $fails = $fails + 1;
    }

    # --- join: borrowed strings, mixed types, UTF-8 flag, empty ---
    my array @js = ("a", "b", "c");
    if (join("-", @js) ne "a-b-c") { say("FAIL join-str"); $fails = $fails + 1; }
    my array @jm = ("x", 5, 2.5);
    if (join("|", @jm) ne "x|5|2.5") { say("FAIL join-mixed"); $fails = $fails + 1; }
    my array @je = ();
    if (join(",", @je) ne "") { say("FAIL join-empty"); $fails = $fails + 1; }
    # non-ASCII bytes survive the borrow/direct-build path intact
    my array @ju = ("héllo", "wörld");
    my str $joined_u = join(" ", @ju);
    if ($joined_u ne "héllo wörld") { say("FAIL join-nonascii: " . $joined_u); $fails = $fails + 1; }
    # char-oriented (SVf_UTF8) elements propagate the flag to the result
    my str $wide = chr(9731);            # U+2603 snowman, UTF8-flagged
    my array @jw = ($wide, $wide);
    my str $joined_w = join("", @jw);
    if (length($joined_w) != 2) { say("FAIL join-utf8flag len=" . length($joined_w)); $fails = $fails + 1; }
    if (join("==", 1, 2, 3) ne "1==2==3") { say("FAIL join-list"); $fails = $fails + 1; }

    # --- sort: mixed types stringify once; order must match string cmp ---
    my array @nums = (10, 2, 33, 4, 2);
    if (join(",", sort(@nums)) ne "10,2,2,33,4") { say("FAIL sort-mixed"); $fails = $fails + 1; }
    my array @strs = ("pear", "apple", "fig");
    if (join(",", sort(@strs)) ne "apple,fig,pear") { say("FAIL sort-str"); $fails = $fails + 1; }
    my hash %sh = ("b" => 2, "a" => 1);
    if (join(",", sort(%sh)) ne "1,2,a,b") { say("FAIL sort-hash"); $fails = $fails + 1; }

    # --- regex: /g loop + nested match inside s///e (match-data reuse) ---
    my str $text = "a1 b22 c333";
    my int $hits = 0;
    while ($text =~ /(\d+)/g) { $hits = $hits + 1; }
    if ($hits != 3) { say("FAIL rxg hits=" . $hits); $fails = $fails + 1; }
    my str $sub = "n10 n20";
    $sub =~ s/(\d+)/$1 * 3/eg;
    if ($sub ne "n30 n60") { say("FAIL rx-subst-e: " . $sub); $fails = $fails + 1; }

    # --- CSE: repeated literal-key fetches in conditions ---
    my hash %h = ("k" => 50, "other" => 1);
    if ($h{"k"} > 0 && $h{"k"} < 100) { } else { say("FAIL cse-and"); $fails = $fails + 1; }
    if ($h{"k"} > 100 || $h{"k"} == 50) { } else { say("FAIL cse-or"); $fails = $fails + 1; }
    if ($h{"missing"} > 0 && $h{"missing"} < 5) { say("FAIL cse-undef"); $fails = $fails + 1; }
    my int $iters = 0;
    while ($h{"k"} > 0 && $h{"k"} < 100) {
        $h{"k"} = $h{"k"} + 30;
        $iters = $iters + 1;
    }
    if ($iters != 2 || $h{"k"} != 110) { say("FAIL cse-while " . $iters . " " . $h{"k"}); $fails = $fails + 1; }
    # ternary inside a pure condition
    my hash %t = ("a" => 5);
    if (($t{"a"} > 3 ? $t{"a"} : 0) == 5 && $t{"a"} == 5) { } else { say("FAIL cse-ternary"); $fails = $fails + 1; }

    # --- sprintf: wide formats that previously truncated silently ---
    my str $w = core::sprintf("%99999d", 5);
    if (length($w) != 99999) { say("FAIL spf-wide-d len=" . length($w)); $fails = $fails + 1; }
    if (substr($w, 99998, 1) ne "5") { say("FAIL spf-wide-d tail"); $fails = $fails + 1; }
    my str $wb = core::sprintf("%20000b", 5);
    if (length($wb) != 20000) { say("FAIL spf-wide-b len=" . length($wb)); $fails = $fails + 1; }
    my str $ws = core::sprintf("%070000s", "abc");
    if (length($ws) != 70000) { say("FAIL spf-wide-s len=" . length($ws)); $fails = $fails + 1; }
    if (substr($ws, 69997, 3) ne "abc") { say("FAIL spf-wide-s tail"); $fails = $fails + 1; }
    # basics unchanged
    if (core::sprintf("[%05.1f|%x|%s]", 3.14159, 255, "ok") ne "[003.1|ff|ok]") { say("FAIL spf-basic"); $fails = $fails + 1; }
    if (core::sprintf("100%%") ne "100%") { say("FAIL spf-pct"); $fails = $fails + 1; }
    my str $long = "y" x 100000;
    if (length(core::sprintf("<%s>", $long)) != 100002) { say("FAIL spf-long-s"); $fails = $fails + 1; }

    if ($fails == 0) {
        say("All round5 perf tests passed");
    } else {
        say($fails . " round5 perf tests FAILED");
    }
    return 0;
}
