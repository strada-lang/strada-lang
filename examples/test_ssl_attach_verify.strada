use lib "lib";
use ssl;
package main;

my int $pass = 0;
my int $fail = 0;
func ok(int $c, str $m) void {
    if ($c) { say("  ok: " . $m); $pass = $pass + 1; }
    else { say("  FAIL: " . $m); $fail = $fail + 1; }
}

func main() int {
    ssl::init();
    # A real fd to wrap (attach_fd does no handshake, so a listening socket fd works).
    my scalar $srv = core::socket_server(38947);
    if (!defined($srv)) { say("FAIL: could not create test socket"); return 1; }
    my int $fd = core::socket_fd($srv);
    ok($fd >= 0, "got a valid fd to wrap");

    # verify=1 + empty host  -> MUST be refused (no hostname to bind = MITM risk)
    my int $c_refuse = ssl::attach_fd($fd, 1, "");
    ok($c_refuse == 0, "attach_fd(verify=1, host='') is REFUSED");

    # verify=1 + real host    -> accepted (binds the name)
    my int $c_ok = ssl::attach_fd($fd, 1, "example.com");
    ok($c_ok != 0, "attach_fd(verify=1, host='example.com') is accepted");

    # verify=0 + empty host    -> accepted (caller knowingly skips verification)
    my int $c_insec = ssl::attach_fd($fd, 0, "");
    ok($c_insec != 0, "attach_fd(verify=0, host='') is accepted (explicit opt-out)");

    core::socket_close($srv);
    say("");
    say("Results: " . $pass . " passed, " . $fail . " failed");
    if ($fail == 0) { say("PASS: All ssl attach_fd tests passed"); return 0; }
    return 1;
}
