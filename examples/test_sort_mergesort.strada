# Regression: sort { ... } @a uses an O(n log n) stable merge sort (was an
# O(n^2) bubble sort that timed out at scale). Verifies large-array ordering,
# descending, string cmp, and STABILITY (equal keys keep input order).
func main() int {
    # Large numeric sort: must be correctly ordered (and fast — O(n^2) would hang).
    my array @a;
    my int $i = 0;
    while ($i < 20000) { push(@a, (($i * 7919) + 17) % 10007); $i = $i + 1; }
    my scalar $s = sort { $a <=> $b; } @a;
    my int $ok = 1; my int $j = 1;
    while ($j < size($s)) {
        if ($s->[$j - 1] > $s->[$j]) { $ok = 0; }
        $j = $j + 1;
    }
    if ($ok == 0) { say("FAIL: not ordered"); return 1; }
    if (size($s) != 20000) { say("FAIL: size " . size($s)); return 1; }

    # Descending.
    my array @b = (3, 1, 4, 1, 5, 9, 2, 6);
    my scalar $d = sort { $b <=> $a; } @b;
    if ($d->[0] != 9 || $d->[7] != 1) { say("FAIL: desc"); return 1; }

    # String cmp.
    my array @w = ("pear", "apple", "fig", "banana");
    my scalar $ws = sort { $a cmp $b; } @w;
    if ($ws->[0] ne "apple" || $ws->[3] ne "pear") { say("FAIL: cmp"); return 1; }

    # Stability: sort pairs by first field only; equal firsts keep input order.
    # Encode as "<key>:<seq>"; after sorting by key, seqs within a key must ascend.
    my array @p = ("2:0", "1:1", "2:2", "1:3", "2:4", "1:5");
    my scalar $sp = sort { core::ord_byte($a) <=> core::ord_byte($b); } @p;
    # keys: 1,1,1,2,2,2 ; within key '1' seqs should be 1,3,5 ; key '2' -> 0,2,4
    if ($sp->[0] ne "1:1" || $sp->[1] ne "1:3" || $sp->[2] ne "1:5") { say("FAIL: stable-1 " . $sp->[0] . $sp->[1] . $sp->[2]); return 1; }
    if ($sp->[3] ne "2:0" || $sp->[4] ne "2:2" || $sp->[5] ne "2:4") { say("FAIL: stable-2"); return 1; }

    say("all sort tests passed");
    return 0;
}
