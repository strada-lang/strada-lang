func main() int {
    # variable-key compound assign must not crash or leak (regression:
    # gen_hash_compound_assign used strada_hash_set_sv (StradaHash*) with a
    # StradaValue*, and over-decref'd a borrowed key).
    my hash %h;
    my str $k = "x";
    $h{$k} += 1;
    $h{$k} += 4;
    if ($h{$k} != 5) { say("FAIL pluseq"); return 1; }
    my str $j = "y";
    $h{$j} .= "a"; $h{$j} .= "b";
    if ($h{$j} ne "ab") { say("FAIL dotcat"); return 1; }
    # many distinct variable keys (resize) + read-back
    my int $i = 0; my int $sum = 0;
    while ($i < 1000) { my str $key = "n" . $i; $h{$key} += $i; $i = $i + 1; }
    $i = 0;
    while ($i < 1000) { my str $key = "n" . $i; $sum += $h{$key}; $i = $i + 1; }
    if ($sum != 499500) { say("FAIL sum got " . $sum); return 1; }
    # borrowed key must survive the compound assign (UAF check)
    say("ok " . $k . " " . $j);
    return 0;
}
