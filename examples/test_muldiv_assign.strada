# Test *= and /= compound assignment — on scalars, hash elements, array
# elements, deref targets, and our-variables. Regression test: these two
# operators previously did not lex at all ("unexpected '=' in expression"),
# while +=, -=, .= worked.
func main() int {
    my int $pass = 0;
    my int $fail = 0;

    my int $x = 3;
    $x *= 4;
    if ($x == 12) { $pass = $pass + 1; } else { $fail = $fail + 1; say("FAIL 1"); }

    my num $y = 12.0;
    $y /= 3;
    if ($y == 4) { $pass = $pass + 1; } else { $fail = $fail + 1; say("FAIL 2"); }

    my $z = 5;
    $z *= 2;
    $z /= 4;
    if ($z == 2.5) { $pass = $pass + 1; } else { $fail = $fail + 1; say("FAIL 3"); }

    my hash %h;
    $h{"a"} = 8;
    $h{"a"} *= 4;
    if ($h{"a"} == 32) { $pass = $pass + 1; } else { $fail = $fail + 1; say("FAIL 4"); }
    $h{"a"} /= 8;
    if ($h{"a"} == 4) { $pass = $pass + 1; } else { $fail = $fail + 1; say("FAIL 5"); }

    my array @a = (3, 4);
    $a[0] *= 5;
    if ($a[0] == 15) { $pass = $pass + 1; } else { $fail = $fail + 1; say("FAIL 6"); }

    my scalar $r = { "c" => 10 };
    $r->{"c"} *= 3;
    if ($r->{"c"} == 30) { $pass = $pass + 1; } else { $fail = $fail + 1; say("FAIL 7"); }
    $r->{"c"} /= 2;
    if ($r->{"c"} == 15) { $pass = $pass + 1; } else { $fail = $fail + 1; say("FAIL 8"); }

    # Nested autoviv chain combined with *=
    my hash %d;
    $d{"a"}{"b"} = 2;
    $d{"a"}{"b"} *= 7;
    if ($d{"a"}{"b"} == 14) { $pass = $pass + 1; } else { $fail = $fail + 1; say("FAIL 9"); }

    our $g = 6;
    $g *= 2;
    if ($g == 12) { $pass = $pass + 1; } else { $fail = $fail + 1; say("FAIL 10"); }

    # Lexer regression guards: division, defined-or, regex with leading =
    my int $q = 10 / 2;
    if ($q == 5) { $pass = $pass + 1; } else { $fail = $fail + 1; say("FAIL 11"); }
    my $u;
    my $v = $u // "dflt";
    if ($v eq "dflt") { $pass = $pass + 1; } else { $fail = $fail + 1; say("FAIL 12"); }
    my str $s = "a=b";
    my int $m = 0;
    if ($s =~ /=/) { $m = 1; }
    if ($m == 1) { $pass = $pass + 1; } else { $fail = $fail + 1; say("FAIL 13"); }
    my str $s2 = "x=1";
    $s2 =~ s/=/:/;
    if ($s2 eq "x:1") { $pass = $pass + 1; } else { $fail = $fail + 1; say("FAIL 14"); }

    if ($fail == 0) {
        say("All muldiv assign tests passed (" . $pass . " checks)");
    } else {
        say("FAILED: " . $fail . " of " . ($pass + $fail));
    }
    return $fail;
}
