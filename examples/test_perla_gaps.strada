/* Test cases for Strada bugs/gaps found via Perla */

our $pass = 0;
our $fail = 0;

func ok(scalar $test, str $name) void {
    if ($test) {
        $pass += 1;
    } else {
        $fail += 1;
        say("FAIL: " . $name);
    }
}

# === Bug #1: Compound assignment on hash elements ===
func test_hash_compound() void {
    my hash %h = ("a" => 10, "b" => 20);
    $h{"a"} += 5;
    ok($h{"a"} == 15, "hash += int");

    $h{"b"} -= 3;
    ok($h{"b"} == 17, "hash -= int");

    my hash %s = ("x" => "hello");
    $s{"x"} .= " world";
    ok($s{"x"} eq "hello world", "hash .= str");

    # Arrow hash compound assignment
    my scalar $ref = {"count" => 0};
    $ref->{"count"} += 1;
    $ref->{"count"} += 1;
    ok($ref->{"count"} == 2, "arrow hash +=");

    # Nested arrow hash
    my scalar $nested = {"inner" => {"val" => 10}};
    $nested->{"inner"}->{"val"} += 5;
    ok($nested->{"inner"}->{"val"} == 15, "nested arrow hash +=");
}

# === Bug #2: Compound assignment on array elements ===
func test_array_compound() void {
    my array @a = (10, 20, 30);
    $a[0] += 5;
    ok($a[0] == 15, "array[0] += 5");

    $a[1] -= 3;
    ok($a[1] == 17, "array[1] -= 3");

    $a[2] += 10;
    ok($a[2] == 40, "array[2] += 10");
}

# === Bug #3: Post-increment on our variables ===
our $counter = 0;

func test_our_incr() void {
    $counter++;
    $counter++;
    $counter++;
    ok($counter == 3, "our var ++ (3)");

    $counter--;
    ok($counter == 2, "our var -- (2)");

    # Pre-increment
    ++$counter;
    ok($counter == 3, "our var pre-++ (3)");
}

# === Bug #4: shift()/pop() with empty parens ===
func test_shift_empty(str $a, str $b, str $c) void {
    # We test via no-parens function below
}

func test_shift_pop {
    my $first = shift();
    my $last = pop();
    ok($first eq "alpha", "shift() = alpha");
    ok($last eq "gamma", "pop() = gamma");
}

# === Bug #5: extends + no-parens func new ===
package TestBase;

func new {
    my $class = shift(@_);
    my $val = shift(@_);
    return bless({"val" => $val, "base_called" => 1}, $class);
}

func val {
    my $self = shift(@_);
    return $self->{"val"};
}

package TestChild;
extends TestBase;

func new {
    my $class = shift(@_);
    my $val = shift(@_);
    my scalar $self = TestBase::new($class, $val);
    $self->{"child_called"} = 1;
    return $self;
}

package main;

func test_extends_new() void {
    my scalar $obj = TestChild::new("TestChild", "hello");
    ok($obj->val() eq "hello", "extends new: val preserved");
    ok($obj->{"base_called"} == 1, "extends new: base body ran");
    ok($obj->{"child_called"} == 1, "extends new: child body ran");
}

# === Bug #7: Hash from flat array ===
func test_hash_from_array() void {
    my array @pairs = ("x", 10, "y", 20, "z", 30);
    my hash %h = @pairs;
    ok($h{"x"} == 10, "hash from array: x=10");
    ok($h{"y"} == 20, "hash from array: y=20");
    ok($h{"z"} == 30, "hash from array: z=30");
}

# === Bug #6: Hash slurp destructuring ===
func receive_hash_slurp {
    my ($first, %rest) = @_;
    ok($first eq "hello", "hash slurp: first=hello");
    ok($rest{"a"} == 1, "hash slurp: a=1");
    ok($rest{"b"} == 2, "hash slurp: b=2");
}

func test_hash_slurp() void {
    receive_hash_slurp("hello", "a", 1, "b", 2);
}

# === Bug #8: int() as a function ===
func test_int_func() void {
    ok(int(3.7) == 3, "int(3.7) = 3");
    ok(int(-2.9) == -2, "int(-2.9) = -2");
    ok(int(0.5) == 0, "int(0.5) = 0");
    ok(int(100) == 100, "int(100) = 100");
}

func main() int {
    test_hash_compound();
    test_array_compound();
    test_our_incr();
    test_shift_pop("alpha", "beta", "gamma");
    test_extends_new();
    test_hash_from_array();
    test_hash_slurp();
    test_int_func();

    say("\nPassed: " . $pass);
    say("Failed: " . $fail);
    if ($fail == 0) {
        say("All Perla gap tests passed!");
    }
    return $fail;
}
