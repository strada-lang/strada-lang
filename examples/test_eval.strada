use lib "lib";
use Eval;

func main() int {
    my int $pass = 0;
    my int $fail = 0;

    # Test 1: Arithmetic
    my $r1 = Strada::Interpreter::eval("2 + 2");
    if ($r1 == 4) { $pass = $pass + 1; } else { $fail = $fail + 1; say("FAIL 1: " . $r1); }

    # Test 2: String operations
    my $r2 = Strada::Interpreter::eval("uc(\"hello\")");
    if ($r2 eq "HELLO") { $pass = $pass + 1; } else { $fail = $fail + 1; say("FAIL 2: " . $r2); }

    # Test 3: Variable persistence
    Strada::Interpreter::eval("my int \$x = 42;");
    my $r3 = Strada::Interpreter::eval("\$x * 2");
    if ($r3 == 84) { $pass = $pass + 1; } else { $fail = $fail + 1; say("FAIL 3: " . $r3); }

    # Test 4: Function definition and call
    Strada::Interpreter::eval("func twice(int \$n) int { return \$n * 2; }");
    my $r4 = Strada::Interpreter::eval("twice(21)");
    if ($r4 == 42) { $pass = $pass + 1; } else { $fail = $fail + 1; say("FAIL 4: " . $r4); }

    # Test 5: Array operations
    Strada::Interpreter::eval("my array \@nums = (10, 20, 30);");
    my $r5 = Strada::Interpreter::eval("size(\@nums)");
    if ($r5 == 3) { $pass = $pass + 1; } else { $fail = $fail + 1; say("FAIL 5: " . $r5); }

    if ($fail == 0) {
        say("All eval tests passed (" . $pass . " checks)");
    } else {
        say("FAILED: " . $fail . " of " . ($pass + $fail));
    }
    return $fail;
}
