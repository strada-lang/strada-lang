# test_socket_ipv6.strada - IPv6 (and dual-stack) socket round trip.
#
# strada's socket layer resolves addresses with getaddrinfo (AF_UNSPEC), so
# sys::socket_client() connects over IPv4 or IPv6 transparently, and
# sys::socket_server() binds the IPv6 wildcard (::) with IPV6_V6ONLY off — a
# dual-stack listener that accepts both IPv4 and IPv6 clients.

func main() int {
    my int $port = 19696;
    my scalar $server = sys::socket_server($port);
    if (!$server) { say("FAIL: could not bind server"); return 1; }

    my int $pid = sys::fork();
    if ($pid == 0) {
        # Child: connect over IPv6 loopback.
        my scalar $sock = sys::socket_client("::1", $port);
        if (!$sock) { say("FAIL: could not connect over ::1"); core::exit(1); }
        sys::socket_send($sock, "ping");
        my str $reply = sys::socket_recv($sock, 1024);
        say("client received: " . $reply);
        sys::socket_close($sock);
        core::exit(0);
    }

    # Parent: accept the IPv6 connection, echo back.
    my scalar $client = sys::socket_accept($server);
    my str $data = sys::socket_recv($client, 1024);
    say("server received: " . $data);
    sys::socket_send($client, "pong:" . $data);
    sys::socket_close($client);
    sys::socket_close($server);
    sys::wait();
    return 0;
}
