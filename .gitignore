# ── repo-root whitelist ──
# Ad-hoc test binaries (t1, verify_foo, repro, …) constantly land in the
# repo root during development; there were ~400 of them. Ignore everything
# at top level except the known project files and directories — a new
# tracked root entry needs a !/name line here.
/*
!/.gitignore
!/CHANGELOG.md
!/CLAUDE.md
!/CLAUDE_DEEP_DIVE.md
!/ROADMAP.md
!/SECURITY_AUDIT_MEMORY.md
!/FEATURES.md
!/LICENSE
!/Makefile
!/README.md
!/configure
!/strada
!/benchmarks/
!/bootstrap/
!/compiler/
!/docs/
!/examples/
!/interpreter/
!/lib/
!/perl/
!/runtime/
!/t/
!/tools/
!/vendor/

# Compiled benchmark binaries (extensionless siblings of bench_*.strada)
benchmarks/bench_*
!benchmarks/bench_*.*

# ── housekeeping 2026-06: generated / artifact / out-of-tree files ──
# lib/Eval.strada is GENERATED by the Makefile (concatenated from compiler
# sources + lib/Strada/Eval.strada) and removed by `make clean`.
lib/Eval.strada
lib/Eval.so.strada
# Local scratch backup
lib/Nesso-good.strada
# Interpreter ad-hoc test binary
interpreter/test_open_str
# Perl CPAN module build artifacts (perl/Strada)
perl/Strada/MYMETA.json
perl/Strada/MYMETA.yml
perl/Strada/Makefile
perl/Strada/MANIFEST.bak
perl/Strada/*.tar.gz
# Generated C for tools + built tool binaries not already listed
tools/perl2strada.c
tools/strada2perl.c
tools/strada2perl
tools/cpan2strada
tools/strada-jit.c
# Scratch test dir
tools/tt/
# Out-of-tree Perla runtime support (Perla itself is not in this repo yet)
runtime/perla_dbi.c
runtime/perla_stash.c
*.smeta
