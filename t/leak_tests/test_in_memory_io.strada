#!/usr/bin/env strada
# Leak test: in-memory file I/O via \$scalar refs.
#
# `core::open(\$buf, "w")` uses open_memstream and on close writes the
# buffer back into the target scalar. The path takes a slot ref
# (StradaValue**), increfs it, and decrefs on close. Verify no per-op
# leaks across many iterations.

func main() int {
    say("Testing in-memory I/O for memory leaks...");
    my int $iterations = 1000;

    # 1. Write + close + writeback
    say("  write loop...");
    my int $i = 0;
    while ($i < $iterations) {
        my str $buf = "";
        my scalar $fh = core::open(\$buf, "w");
        say($fh, "line " . $i);
        say($fh, "another " . $i);
        core::close($fh);
        if (length($buf) == 0) {
            say("    FAIL: empty writeback at iter " . $i);
            return 1;
        }
        $i = $i + 1;
    }

    # 2. Append mode (pre-write existing content + append + close)
    say("  append loop...");
    $i = 0;
    while ($i < $iterations) {
        my str $buf = "prefix";
        my scalar $fh = core::open(\$buf, "a");
        say($fh, "added");
        core::close($fh);
        if (length($buf) < 6) {
            say("    FAIL: append lost prefix at iter " . $i);
            return 1;
        }
        $i = $i + 1;
    }

    # 3. Read mode (copy + fmemopen + close)
    say("  read loop...");
    $i = 0;
    my str $src = "line one\nline two\nline three\n";
    while ($i < $iterations) {
        my scalar $rh = core::open(\$src, "r");
        my str $l1 = <$rh>;
        my str $l2 = <$rh>;
        my str $l3 = <$rh>;
        core::close($rh);
        if ($l1 eq "" || $l2 eq "" || $l3 eq "") {
            say("    FAIL: missing line at iter " . $i);
            return 1;
        }
        $i = $i + 1;
    }

    # 4. Round-trip (write then read same buffer)
    say("  round-trip loop...");
    $i = 0;
    while ($i < $iterations) {
        my str $buf = "";
        my scalar $wh = core::open(\$buf, "w");
        say($wh, "data " . $i);
        core::close($wh);
        my scalar $rh = core::open(\$buf, "r");
        my str $line = <$rh>;
        core::close($rh);
        if ($line eq "") {
            say("    FAIL: round-trip empty at iter " . $i);
            return 1;
        }
        $i = $i + 1;
    }

    # 5. Don't explicitly close — let the scope drop the filehandle.
    #    The destructor on the StradaValue should still run the writeback
    #    and free the meta/buffer.
    say("  drop-without-close loop...");
    $i = 0;
    while ($i < $iterations) {
        my str $buf = "";
        my scalar $fh = core::open(\$buf, "w");
        say($fh, "dropped " . $i);
        # No core::close — $fh scope ends here
        $i = $i + 1;
    }

    say("All in-memory I/O leak tests passed");
    return 0;
}
