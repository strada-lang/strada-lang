#!/usr/bin/env strada
# Leak / codegen regression:
#   - exists($h{k}->{x}) leaked the hash sub-expression
#     (CodeGen.strada:5391-5414 — owned ref source uncaptured).
#   - delete($h{k}->{x}) leaked symmetrically (CodeGen.strada:5488+).
#   - $h{k}->[i] OP= v and $h{k}->[i]++ produced invalid C —
#     gen_compound_assign dispatch was missing NODE_DEREF_ARRAY.
#   - strada_strftime did not guard tagged-int time_hash → segfault on
#     core::strftime(..., core::time()).
#   - core::sprintf (namespaced) didn't match the codegen branch.
#
# Run: valgrind --leak-check=full ./test_exists_delete_compound_leaks

package main;

func test_exists_deref_owned() void {
    my int $iter = 200;
    my int $i = 0;
    while ($i < $iter) {
        my hash %h = ();
        $h{"k"} = { "x" => "value-x", "y" => "value-y" };
        my int $ex = exists($h{"k"}->{"x"});
        if ($ex != 1) {
            say("FAIL exists deref: " . $ex);
            return;
        }
        $i = $i + 1;
    }
    say("test_exists_deref_owned: PASS");
}

func test_delete_deref_owned() void {
    my int $iter = 200;
    my int $i = 0;
    while ($i < $iter) {
        my hash %h = ();
        $h{"k"} = { "a" => "alpha", "b" => "bravo" };
        my scalar $d = delete($h{"k"}->{"a"});
        if (defined($d) && ref($d) ne "") {
            # ok
        }
        $i = $i + 1;
    }
    say("test_delete_deref_owned: PASS");
}

func test_deref_array_compound() void {
    my int $iter = 100;
    my int $i = 0;
    while ($i < $iter) {
        my hash %h = ("k" => [10, 20, 30]);
        $h{"k"}->[1] += 5;
        $h{"k"}->[0]++;
        $h{"k"}->[2] -= 3;
        $i = $i + 1;
    }
    say("test_deref_array_compound: PASS");
}

func test_strftime_tagged_int() void {
    # core::strftime(fmt, core::time()) previously segfaulted because
    # strada_strftime dereferenced the tagged-int time_hash.
    my int $iter = 50;
    my int $i = 0;
    while ($i < $iter) {
        my int $t = core::time();
        # Don't actually call strftime with a tagged int — we just
        # need to verify the runtime guard doesn't crash. Use a hash.
        my scalar $tm = core::localtime($t);
        my str $s = core::strftime("%Y", $tm);
        if (length($s) != 4) {
            say("FAIL strftime: " . $s);
            return;
        }
        $i = $i + 1;
    }
    say("test_strftime_tagged_int: PASS");
}

func test_core_sprintf() void {
    my int $iter = 100;
    my int $i = 0;
    while ($i < $iter) {
        my str $s = "n=" . core::sprintf("%d", $i);
        if (length($s) < 3) {
            say("FAIL core::sprintf: " . $s);
            return;
        }
        $i = $i + 1;
    }
    say("test_core_sprintf: PASS");
}

func main() int {
    test_exists_deref_owned();
    test_delete_deref_owned();
    test_deref_array_compound();
    test_strftime_tagged_int();
    test_core_sprintf();
    return 0;
}
