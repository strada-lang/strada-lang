# Multithreading leak test.
#
# Regression guard for the stop-the-world cycle collector under threading.
# Each worker thread builds reference cycles that plain refcounting cannot
# reclaim (hashref<->hashref and arrayref<->hashref), so the threaded collector
# must stop the world and collect them. With > the GC candidate threshold
# (10000) of cycles across the workers, a mid-run stop-the-world collection
# fires (not just the exit sweep). Also touches a shared `our` global (the
# locked global registry) and verifies thread handles + closures free cleanly
# on join. Must be valgrind-clean: definitely/indirectly lost == 0.

our int $shared = 0;

func main() int {
    my array @threads = ();
    my int $t = 0;
    while ($t < 4) {
        push(@threads, thread::create(func () {
            my int $i = 0;
            while ($i < 3000) {
                # hashref <-> hashref cycle (dropped each iteration)
                my scalar $a = {};
                my scalar $b = {};
                $a->{"peer"} = $b;
                $b->{"peer"} = $a;
                # arrayref <-> hashref cycle
                my scalar $arr = [];
                my scalar $h = {};
                push(@$arr, $h);
                $h->{"back"} = $arr;
                # shared global mutation: exercises the locked global registry
                $shared = $shared + 1;
                $i = $i + 1;
            }
            return 0;
        }));
        $t = $t + 1;
    }
    $t = 0;
    while ($t < size(@threads)) {
        thread::join($threads[$t]);
        $t = $t + 1;
    }
    say("threads done");
    return 0;
}
