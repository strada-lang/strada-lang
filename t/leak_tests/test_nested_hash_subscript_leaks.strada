#!/usr/bin/env strada
# Leak regression: codegen for nested hash access / slice / compound
# assign inlined the owned-ref source sub-expression directly into the
# borrow operation (strada_hv_fetch_owned_sv, strada_deref_array,
# strada_deref_hash), leaking the source owned ref every read.
#
# Specifically covers:
#   - NODE_HASH_ACCESS expression-key against owned source: $outer{$h_key}{$k}
#   - NODE_HASH_ACCESS concat-key against owned source: $outer{$h_key}{"p-" . $r}
#   - NODE_ARRAY_SLICE against owned source: @{$h{$k}}[0,1,2]
#   - NODE_HASH_SLICE against owned source: @{$h{$k}}{"a","b"}
#   - gen_array_compound_assign against owned source: $h{$k}[i] += val
#
# (NODE_SUBSCRIPT $h{$k}[i] and NODE_DEREF_ARRAY $h{$k}->[i] are known
# to still leak one wrapper SV per call — see CodeGen.strada NOTE; the
# borrow-vs-own semantics on strada_array_get make the obvious fix
# overcount when the array is held elsewhere.)
#
# Run: valgrind --leak-check=full ./test_nested_hash_subscript_leaks

package main;

func test_hash_access_expr_key() void {
    my int $iter = 200;
    my int $i = 0;
    while ($i < $iter) {
        my hash %outer = ();
        $outer{"inner"} = { "a" => 1, "b" => 2, "c" => 3 };
        my str $h_key = "inner";
        my str $k = "b";
        my int $v = $outer{$h_key}{$k};
        if ($v != 2) {
            say("FAIL expr-key: " . $v);
            return;
        }
        $i = $i + 1;
    }
    say("test_hash_access_expr_key: PASS");
}

func test_hash_access_concat_key() void {
    my int $iter = 200;
    my int $i = 0;
    while ($i < $iter) {
        my hash %outer = ();
        $outer{"inner"} = { "p-x" => "px-val", "p-y" => "py-val" };
        my str $h_key = "inner";
        my str $r = "x";
        my str $v = $outer{$h_key}{"p-" . $r};
        if ($v ne "px-val") {
            say("FAIL concat-key: " . $v);
            return;
        }
        $i = $i + 1;
    }
    say("test_hash_access_concat_key: PASS");
}

func test_array_slice_against_owned_source() void {
    my int $iter = 100;
    my int $i = 0;
    while ($i < $iter) {
        my hash %h = ();
        $h{"arr"} = [10, 20, 30, 40, 50];
        my str $k = "arr";
        my array @slice = @{$h{$k}}[0, 2, 4];
        if ($slice[0] != 10 || $slice[1] != 30 || $slice[2] != 50) {
            say("FAIL array slice");
            return;
        }
        $i = $i + 1;
    }
    say("test_array_slice_against_owned_source: PASS");
}

func test_hash_slice_against_owned_source() void {
    my int $iter = 100;
    my int $i = 0;
    while ($i < $iter) {
        my hash %h = ();
        $h{"sub"} = { "a" => "alpha", "b" => "beta", "c" => "gamma" };
        my str $k = "sub";
        my array @slice = @{$h{$k}}{"a", "c"};
        if ($slice[0] ne "alpha" || $slice[1] ne "gamma") {
            say("FAIL hash slice");
            return;
        }
        $i = $i + 1;
    }
    say("test_hash_slice_against_owned_source: PASS");
}

func test_array_compound_against_owned_source() void {
    my int $iter = 100;
    my int $i = 0;
    while ($i < $iter) {
        my hash %h = ();
        $h{"arr"} = [10, 20, 30];
        my str $k = "arr";
        $h{$k}[1] += 5;
        # NOTE: we deliberately don't verify the result by reading
        # $h{"arr"}[1] here — that pattern goes through NODE_SUBSCRIPT
        # which still has a pre-existing leak (see CodeGen.strada NOTE
        # on subscript). The compound-assign fix itself is leak-clean.
        $i = $i + 1;
    }
    say("test_array_compound_against_owned_source: PASS");
}

func main() int {
    test_hash_access_expr_key();
    test_hash_access_concat_key();
    test_array_slice_against_owned_source();
    test_hash_slice_against_owned_source();
    test_array_compound_against_owned_source();
    return 0;
}
